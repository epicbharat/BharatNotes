---
layout: base.njk
title: "UPSC PYQ Quiz Hub — Practice by Subject"
description: "Practice UPSC Prelims Previous Year Questions by subject. Interactive MCQs with score tracking, explanations, and progress — no login needed."
---

<style>
/* ══════════════════════════════════════════
   Quiz Hub styles
   ══════════════════════════════════════════ */

/* ── Unified hero ──────────────────────────── */
.qh-hero {
  background: linear-gradient(125deg,
    #0b3d2e 0%, #163528 30%,
    #2a1a05 62%, #1c1008 100%);
  color: #fff;
  padding: var(--space-10) 0;
  position: relative; overflow: hidden;
}
.qh-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 78% 50%, rgba(212,160,23,0.16) 0%, transparent 55%);
  pointer-events: none;
}
.qh-hero__layout {
  display: grid;
  grid-template-columns: 1fr 1px 300px;
  gap: var(--space-8);
  align-items: center;
  position: relative; z-index: 1;
}
.qh-hero__sep {
  background: rgba(255,255,255,0.1);
  align-self: stretch; min-height: 220px;
}
.qh-hero__eyebrow {
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: #fde68a; margin-bottom: var(--space-2);
}
.qh-hero__title {
  font-family: var(--font-heading);
  font-size: var(--text-3xl); font-weight: 800;
  margin: 0 0 var(--space-2);
}
.qh-hero__sub {
  color: rgba(255,255,255,0.65); font-size: var(--text-sm);
  max-width: 440px; margin-bottom: var(--space-6);
}
.qh-totals {
  display: flex; flex-wrap: wrap; gap: var(--space-6);
  margin-bottom: var(--space-5);
}
.qh-total { text-align: center; }
.qh-total__num {
  display: block; font-size: var(--text-xl); font-weight: 800;
  color: #fde68a; line-height: 1.1;
}
.qh-total__lbl { font-size: var(--text-xs); color: rgba(255,255,255,0.5); }

/* Inline summary */
.qh-summary {
  display: none;
  padding: var(--space-3) var(--space-4);
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px; max-width: 380px;
}
.qh-summary__inner {
  display: flex; flex-wrap: wrap; gap: var(--space-4);
  align-items: center; font-size: var(--text-sm);
}
.qh-summary__item { display: flex; align-items: center; gap: var(--space-2); color: rgba(255,255,255,0.7); }
.qh-summary__dot  { width: 8px; height: 8px; border-radius: 50%; }
.qh-summary__num  { font-weight: 800; color: #fff; }

/* Right: Ujiyari */
.ujq-pill {
  display: inline-block;
  font-size: 0.62rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
  color: #fde68a; background: rgba(253,230,138,0.12);
  border: 1px solid rgba(253,230,138,0.25);
  padding: 3px 12px; border-radius: 999px; margin-bottom: var(--space-3);
}
.ujq-side-desc {
  font-size: var(--text-xs); line-height: 1.65;
  color: rgba(255,255,255,0.58); margin-bottom: var(--space-3);
}
.ujq-side-desc strong { color: #fde68a; }
.ujq-side-desc em { font-style: normal; color: #fff; font-weight: 700; }
.ujq-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: var(--space-4); }
.ujq-tag {
  font-size: 0.6rem; font-weight: 700;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 3px 10px; border-radius: 999px;
}
.ujq-cta-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(253,230,138,0.3);
  border-radius: 14px; padding: var(--space-4) var(--space-5);
  text-align: center;
  backdrop-filter: blur(8px);
  box-shadow: 0 6px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.08);
}
.ujq-cta-logo  { font-size: 2rem; margin-bottom: 2px; }
.ujq-cta-site  { font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: #fde68a; margin-bottom: 2px; }
.ujq-cta-label { font-size: var(--text-xs); color: rgba(255,255,255,0.4); margin-bottom: var(--space-3); }
.ujq-cta-btn {
  display: block;
  background: linear-gradient(135deg, #d4a017, #f5c842);
  color: #1c1008; font-weight: 800; font-size: var(--text-sm);
  padding: 10px var(--space-4); border-radius: 8px;
  text-decoration: none;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 3px 10px rgba(212,160,23,0.4);
  margin-bottom: var(--space-2);
}
.ujq-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 16px rgba(212,160,23,0.55); text-decoration: none; color: #1c1008; }
.ujq-cta-note { font-size: 0.6rem; color: rgba(255,255,255,0.3); margin: 0; }

/* Subject grid */
.qh-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--space-5);
  padding: var(--space-8) 0 var(--space-16);
}

/* Subject card */
.qh-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-top: 4px solid var(--qhc, var(--color-brand));
  border-radius: 14px; padding: var(--space-5);
  text-decoration: none; color: inherit;
  display: flex; flex-direction: column; gap: var(--space-3);
  transition: box-shadow 0.18s, transform 0.15s;
}
.qh-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.1); transform: translateY(-3px); text-decoration: none; }
.qh-card__head { display: flex; align-items: center; gap: var(--space-3); }
.qh-card__icon { font-size: 1.6rem; }
.qh-card__name { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; color: var(--qhc, var(--color-brand)); }
.qh-card__desc { font-size: var(--text-xs); color: var(--color-text-muted); line-height: 1.5; flex: 1; }
.qh-card__meta { display: flex; justify-content: space-between; font-size: var(--text-xs); color: var(--color-text-muted); }
.qh-card__count { font-weight: 700; color: var(--color-text); }
.qh-card__bar { height: 5px; background: var(--color-border); border-radius: 999px; overflow: hidden; display: flex; }
.qh-card__fill { height: 100%; transition: width 0.5s ease; }
.qh-card__fill--correct { background: #22c55e; }
.qh-card__fill--wrong   { background: #ef4444; }
.qh-card__status {
  font-size: 0.65rem; font-weight: 700;
  padding: 2px 10px; border-radius: 999px; align-self: flex-start;
  background: var(--color-border); color: var(--color-text-muted);
}
.qh-card__status--done    { background: rgba(22,163,74,0.12); color: #16a34a; }
.qh-card__status--partial { background: rgba(212,160,23,0.1);  color: #b45309; }
.qh-card__status--weak    { background: rgba(220,38,38,0.1);   color: #dc2626; }
.qh-card__cta {
  display: inline-flex; align-items: center; justify-content: center;
  gap: var(--space-2); padding: 9px var(--space-4);
  background: var(--qhc, var(--color-brand));
  color: #fff; border-radius: var(--radius-md);
  font-size: var(--text-xs); font-weight: 700;
  margin-top: auto; transition: opacity 0.15s;
}
.qh-card:hover .qh-card__cta { opacity: 0.88; }
.qh-card--empty { opacity: 0.6; pointer-events: none; }
.qh-card--empty .qh-card__cta { background: #94a3b8; }

@media (max-width: 860px) {
  .qh-hero__layout { grid-template-columns: 1fr; }
  .qh-hero__sep    { display: none; }
  .qh-hero__title  { font-size: var(--text-2xl); }
  .qh-grid         { grid-template-columns: 1fr; }
}
</style>

<!-- Unified hero: Quiz Hub + Ujiyari promo -->
<div class="qh-hero">
  <div class="container">
    <div class="qh-hero__layout">

      <!-- Left: BharatNotes PYQ Hub -->
      <div class="qh-hero__left">
        <p class="qh-hero__eyebrow">Practice Dashboard</p>
        <h1 class="qh-hero__title">🎯 UPSC PYQ Quiz Hub</h1>
        <p class="qh-hero__sub">Subject-wise Previous Year Questions — interactive MCQs with instant feedback, explanations, and progress tracking.</p>
        <div class="qh-totals">
          <div class="qh-total">
            <span class="qh-total__num" id="qh-total-q">0</span>
            <span class="qh-total__lbl">Questions</span>
          </div>
          <div class="qh-total">
            <span class="qh-total__num">11</span>
            <span class="qh-total__lbl">Subjects</span>
          </div>
          <div class="qh-total">
            <span class="qh-total__num" id="qh-attempted">0</span>
            <span class="qh-total__lbl">Attempted</span>
          </div>
          <div class="qh-total">
            <span class="qh-total__num" id="qh-avg">—</span>
            <span class="qh-total__lbl">Avg Score</span>
          </div>
        </div>
        <!-- Inline progress summary (shown via JS) -->
        <div class="qh-summary" id="qh-summary">
          <div class="qh-summary__inner">
            <div class="qh-summary__item">
              <span class="qh-summary__dot" style="background:#22c55e;"></span>
              <span class="qh-summary__num" id="qhs-correct">0</span>&nbsp;correct
            </div>
            <div class="qh-summary__item">
              <span class="qh-summary__dot" style="background:#ef4444;"></span>
              <span class="qh-summary__num" id="qhs-wrong">0</span>&nbsp;wrong
            </div>
            <div class="qh-summary__item">
              <span class="qh-summary__dot" style="background:rgba(255,255,255,0.3);"></span>
              <span class="qh-summary__num" id="qhs-remain">0</span>&nbsp;remaining
            </div>
          </div>
        </div>
      </div>

      <!-- Vertical divider -->
      <div class="qh-hero__sep"></div>

      <!-- Right: Ujiyari promo -->
      <div class="qh-hero__right">
        <span class="ujq-pill">⚡ Also Practice on Ujiyari</span>
        <p class="ujq-side-desc">PYQs cover the <em>past</em>. <strong>Ujiyari Quiz</strong> covers <em>today</em> — daily MCQs on news, government schemes &amp; international events. Both together = complete Prelims prep.</p>
        <div class="ujq-tags">
          <span class="ujq-tag">📰 Daily News</span>
          <span class="ujq-tag">🏛️ Schemes</span>
          <span class="ujq-tag">🌏 International</span>
          <span class="ujq-tag">📊 Economy</span>
        </div>
        <div class="ujq-cta-card">
          <div class="ujq-cta-logo">🦁</div>
          <div class="ujq-cta-site">ujiyari.com</div>
          <div class="ujq-cta-label">Current Affairs Quiz Hub</div>
          <a href="https://ujiyari.com/quiz/" target="_blank" rel="noopener" class="ujq-cta-btn">Practice Now →</a>
          <p class="ujq-cta-note">Free · No login · Updated daily</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Subject grid -->
<section style="background:#f1f5f9;">
  <div class="container">
    <div class="qh-grid" id="qh-grid">
      {%- for subj in subjects -%}
      {%- if subj.quiz != false -%}
      {%- set subjectPyq = pyq[subj.slug] or [] -%}
      <a href="/quiz/{{ subj.slug }}/"
         class="qh-card{% if subjectPyq.length == 0 %} qh-card--empty{% endif %}"
         style="--qhc:{{ subj.color }};"
         data-subject="{{ subj.slug }}"
         data-total="{{ subjectPyq.length }}">
        <div class="qh-card__head">
          <span class="qh-card__icon">{{ subj.icon }}</span>
          <span class="qh-card__name">{{ subj.name }}</span>
        </div>
        <p class="qh-card__desc">{{ subj.description }}</p>
        <div class="qh-card__meta">
          <span class="qh-card__count">{{ subjectPyq.length }} question{{ 's' if subjectPyq.length != 1 }}</span>
          <span class="qh-card__status" id="status-{{ subj.slug }}">Not started</span>
        </div>
        <div class="qh-card__bar">
          <div class="qh-card__fill qh-card__fill--correct" id="bar-correct-{{ subj.slug }}" style="width:0%"></div>
          <div class="qh-card__fill qh-card__fill--wrong"   id="bar-wrong-{{ subj.slug }}"   style="width:0%"></div>
        </div>
        <span class="qh-card__cta">
          {%- if subjectPyq.length == 0 -%}📋 Coming Soon{%- else -%}🎯 Start Quiz{%- endif -%}
        </span>
      </a>
      {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
(function () {
  /* Hydrate cards with localStorage scores */
  var STORE_KEY = 'bn_quiz_v2';
  function loadStore() {
    try { return JSON.parse(localStorage.getItem(STORE_KEY)) || {}; }
    catch (e) { return {}; }
  }

  /* Subject question counts from page data (set as data- attributes) */
  var store = loadStore();
  var totalQ = 0, totalAttempted = 0, totalCorrect = 0, totalWrong = 0;

  document.querySelectorAll('.qh-card[data-subject]').forEach(function (card) {
    var subject = card.getAttribute('data-subject');
    var total   = parseInt(card.getAttribute('data-total')) || 0;
    totalQ += total;
    if (!total) return;

    var saved   = store[subject] || {};
    var correct = 0, wrong = 0, answered = 0;

    /* We don't have the correct answers here — we only know what was saved.
       To calculate correct/wrong we'd need the full data. Instead we track
       answered count and link to the subject page for detail. */
    answered = Object.keys(saved).length;

    /* Estimate: we store raw answer idx but not correct flag.
       Just show attempted count in hub — correct % shown on subject page. */
    totalAttempted += answered;

    var pAttempted = total ? (answered / total * 100) : 0;

    /* Score bar (attempted width only — correct/wrong split computed on subject page) */
    var fillEl = document.getElementById('bar-correct-' + subject);
    if (fillEl) fillEl.style.width = pAttempted + '%';

    /* Status badge */
    var statusEl = document.getElementById('status-' + subject);
    if (statusEl) {
      if (answered === 0) {
        statusEl.textContent = 'Not started';
      } else if (answered < total) {
        statusEl.textContent = answered + '/' + total + ' done';
        statusEl.className = 'qh-card__status qh-card__status--partial';
        var btn = card.querySelector('.qh-card__cta');
        if (btn) btn.textContent = '↩ Continue';
      } else {
        statusEl.textContent = 'Completed';
        statusEl.className = 'qh-card__status qh-card__status--done';
        var btn = card.querySelector('.qh-card__cta');
        if (btn) btn.textContent = '✅ Review';
      }
    }
  });

  /* Hero stats */
  var totalEl = document.getElementById('qh-total-q');
  if (totalEl) totalEl.textContent = totalQ;
  var attEl = document.getElementById('qh-attempted');
  if (attEl) attEl.textContent = totalAttempted;

  /* Summary bar */
  if (totalAttempted > 0) {
    var summaryEl = document.getElementById('qh-summary');
    if (summaryEl) summaryEl.style.display = '';
    var remEl = document.getElementById('qhs-remain');
    if (remEl) remEl.textContent = totalQ - totalAttempted;
    var attSum = document.getElementById('qhs-correct');
    if (attSum) attSum.textContent = totalAttempted;
  }
})();
</script>
