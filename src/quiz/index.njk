---
layout: base.njk
title: "Practice PYQs — Official UPSC Prelims Questions by Subject"
description: "Practice official UPSC CSE Prelims Previous Year Questions subject-wise. Actual exam MCQs with verified answers, detailed explanations, score tracking, and progress — no login needed."
---

<style>
/* ══════════════════════════════════════════
   Quiz Hub styles
   ══════════════════════════════════════════ */

/* ── Stats row in page-header ───────────────── */
.qh-hero-stats {
  display: flex; flex-wrap: wrap; gap: var(--space-5);
  margin-top: var(--space-5);
}
.qh-stat {
  display: flex; flex-direction: column; gap: 2px;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px; padding: var(--space-3) var(--space-4);
  min-width: 90px;
}
.qh-stat__num { font-size: var(--text-xl); font-weight: 900; color: #fde68a; line-height: 1; }
.qh-stat__lbl { font-size: var(--text-xs); color: rgba(255,255,255,0.55); font-weight: 600; margin-top: 3px; }

/* Progress summary row (JS-shown) */
.qh-summary {
  display: none; margin-top: var(--space-4);
}
.qh-summary__inner {
  display: flex; flex-wrap: wrap; gap: var(--space-4);
  align-items: center;
}
.qh-summary__item {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 999px; padding: 4px 12px;
  font-size: var(--text-xs); color: rgba(255,255,255,0.8);
}
.qh-summary__dot  { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.qh-summary__num  { font-weight: 800; color: #fff; }

/* Hub layout: cards + sidebar */
.qh-layout {
  display: grid;
  grid-template-columns: 1fr 288px;
  gap: var(--space-6);
  padding: var(--space-8) 0 var(--space-16);
  align-items: start;
}

/* Subject grid */
.qh-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
}

/* Ujiyari sidebar — sticky TOC style */
.qh-sidebar {
  position: sticky;
  top: 80px;
  max-height: calc(100vh - 96px);
  overflow-y: auto;
  scrollbar-width: none;
}
.qh-sidebar::-webkit-scrollbar { display: none; }
.qh-ujiyari-card {
  background: linear-gradient(160deg, #0d3d2c 0%, #0a2218 55%, #1a0e04 100%);
  border-radius: 18px;
  color: #fff; overflow: hidden; position: relative;
  border: 1px solid rgba(212,160,23,0.2);
  box-shadow: 0 8px 32px rgba(0,0,0,0.35);
}
/* gold glow top-right */
.qh-ujiyari-card::before {
  content: '';
  position: absolute; top: -60px; right: -60px;
  width: 220px; height: 220px; border-radius: 50%;
  background: radial-gradient(circle, rgba(212,160,23,0.2) 0%, transparent 70%);
  pointer-events: none;
}
/* Logo hero strip */
.qhuj-logo-strip {
  padding: var(--space-6) var(--space-5) var(--space-4);
  display: flex; align-items: center; justify-content: center;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  position: relative;
}
/* Body */
.qhuj-body { padding: var(--space-5); position: relative; }
.qhuj-name {
  font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 800;
  color: #fde68a; margin-bottom: var(--space-2); line-height: 1.1;
}
.qhuj-tagline {
  font-size: var(--text-xs); color: rgba(255,255,255,0.55);
  line-height: 1.65; margin-bottom: var(--space-4);
}
.qhuj-tagline strong { color: rgba(255,255,255,0.9); }
/* Divider */
.qhuj-div {
  border: none; border-top: 1px solid rgba(255,255,255,0.08);
  margin: 0 0 var(--space-4);
}
.qhuj-features {
  display: flex; flex-direction: column; gap: 10px;
  margin-bottom: var(--space-5);
}
.qhuj-feat {
  display: flex; align-items: center; gap: 10px;
  font-size: var(--text-xs); color: rgba(255,255,255,0.72); line-height: 1.4;
}
.qhuj-feat-icon {
  width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
  background: rgba(212,160,23,0.15); border: 1px solid rgba(212,160,23,0.3);
  display: flex; align-items: center; justify-content: center;
  color: #d4a017; font-size: 11px; font-weight: 800;
}
.qhuj-cta {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg, #c8940f, #f0c040);
  color: #1a0a00; font-weight: 800; font-size: var(--text-sm);
  padding: 13px var(--space-4); border-radius: 10px;
  text-decoration: none; width: 100%;
  transition: transform 0.14s, box-shadow 0.14s;
  box-shadow: 0 4px 18px rgba(212,160,23,0.45);
  letter-spacing: 0.01em;
}
.qhuj-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(212,160,23,0.6); text-decoration: none; color: #1a0a00; }
.qhuj-note {
  font-size: 0.62rem; color: rgba(255,255,255,0.28);
  text-align: center; margin-top: var(--space-3);
}
.qhuj-note a { color: rgba(212,160,23,0.55); text-decoration: none; }
.qhuj-note a:hover { color: #d4a017; }

/* Streak stat glow */
.qh-stat__num--streak { color: #fde68a; }

/* GS filter bar */
.qh-filterbar {
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
  padding: var(--space-3) 0;
  position: sticky;
  top: 60px;
  z-index: 50;
}
.qh-filterpills {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}
.qh-fpill {
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  font-family: var(--font-body);
  padding: 6px 16px;
  border-radius: var(--radius-full);
  border: 1.5px solid var(--color-border);
  background: transparent;
  color: var(--color-text-muted);
  cursor: pointer;
  transition: all 0.14s;
  white-space: nowrap;
}
.qh-fpill:hover { border-color: var(--color-accent); color: var(--color-accent); }
.qh-fpill.active {
  background: var(--color-brand);
  color: #fff;
  border-color: var(--color-brand);
}

@media (max-width: 1024px) {
  .qh-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 860px) {
  .qh-layout  { grid-template-columns: 1fr; }
  .qh-sidebar { position: static; max-height: none; }
  .qh-grid    { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .qh-filterpills { gap: var(--space-1); }
  .qh-fpill { font-size: 0.65rem; padding: 5px 12px; }
}

/* Subject card */
.qh-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-top: 4px solid var(--qhc, var(--color-brand));
  border-radius: 14px; padding: var(--space-5);
  text-decoration: none; color: inherit;
  display: flex; flex-direction: column; gap: var(--space-3);
  transition: box-shadow 0.18s, transform 0.15s;
}
.qh-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.1); transform: translateY(-3px); text-decoration: none; }
.qh-card__head { display: flex; align-items: center; gap: var(--space-3); }
.qh-card__icon { font-size: 1.6rem; }
.qh-card__name { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; color: var(--qhc, var(--color-brand)); }
.qh-card__desc { font-size: var(--text-xs); color: var(--color-text-muted); line-height: 1.5; flex: 1; }
.qh-card__meta { display: flex; justify-content: space-between; font-size: var(--text-xs); color: var(--color-text-muted); }
.qh-card__count { font-weight: 700; color: var(--color-text); }
.qh-card__bar { height: 5px; background: var(--color-border); border-radius: 999px; overflow: hidden; display: flex; }
.qh-card__fill { height: 100%; transition: width 0.5s ease; }
.qh-card__fill--correct { background: #22c55e; }
.qh-card__fill--wrong   { background: #ef4444; }
.qh-card__status {
  font-size: 0.65rem; font-weight: 700;
  padding: 2px 10px; border-radius: 999px; align-self: flex-start;
  background: var(--color-border); color: var(--color-text-muted);
}
.qh-card__status--done    { background: rgba(22,163,74,0.12); color: #16a34a; }
.qh-card__status--partial { background: rgba(212,160,23,0.1);  color: #b45309; }
.qh-card__status--weak    { background: rgba(220,38,38,0.1);   color: #dc2626; }
.qh-card__cta {
  display: inline-flex; align-items: center; justify-content: center;
  gap: var(--space-2); padding: 9px var(--space-4);
  background: var(--qhc, var(--color-brand));
  color: #fff; border-radius: var(--radius-md);
  font-size: var(--text-xs); font-weight: 700;
  margin-top: auto; transition: opacity 0.15s;
}
.qh-card:hover .qh-card__cta { opacity: 0.88; }
.qh-card--empty { opacity: 0.6; pointer-events: none; }
.qh-card--empty .qh-card__cta { background: #94a3b8; }
</style>

<!-- Page hero — same as other BharatNotes section pages -->
<header class="page-header">
  <div class="container">
    <div class="page-header__eyebrow">🎯 Official UPSC CSE Prelims Questions</div>
    <h1 class="page-header__title">Practice PYQs</h1>
    <p class="page-header__subtitle">Practise actual UPSC Prelims Previous Year Questions — verified, subject-wise, with answer explanations and score tracking. No login needed.</p>

    <!-- Stats row (hydrated by JS) -->
    <div class="qh-hero-stats">
      <div class="qh-stat">
        <span class="qh-stat__num" id="qh-total-q">0</span>
        <span class="qh-stat__lbl">Questions</span>
      </div>
      <div class="qh-stat qh-stat--streak" id="qh-streak-stat" style="display:none;">
        <span class="qh-stat__num qh-stat__num--streak" id="qh-streak">0</span>
        <span class="qh-stat__lbl">🔥 Day Streak</span>
      </div>
      <div class="qh-stat">
        <span class="qh-stat__num" id="qh-attempted">0</span>
        <span class="qh-stat__lbl">Attempted</span>
      </div>
      <div class="qh-stat">
        <span class="qh-stat__num" id="qh-accuracy">—</span>
        <span class="qh-stat__lbl">Accuracy</span>
      </div>
    </div>

    <!-- Progress summary (shown by JS when any attempted) -->
    <div class="qh-summary" id="qh-summary">
      <div class="qh-summary__inner">
        <div class="qh-summary__item"><span class="qh-summary__dot" style="background:#22c55e;"></span><span class="qh-summary__num" id="qhs-correct">0</span>&nbsp;correct</div>
        <div class="qh-summary__item"><span class="qh-summary__dot" style="background:#ef4444;"></span><span class="qh-summary__num" id="qhs-wrong">0</span>&nbsp;wrong</div>
        <div class="qh-summary__item"><span class="qh-summary__dot" style="background:rgba(255,255,255,0.4);"></span><span class="qh-summary__num" id="qhs-remain">0</span>&nbsp;remaining</div>
      </div>
    </div>
  </div>
</header>

<!-- GS Paper filter bar -->
<div class="qh-filterbar" id="qh-filterbar">
  <div class="container">
    <div class="qh-filterpills">
      <button class="qh-fpill active" data-gs="all">All Subjects</button>
      <button class="qh-fpill" data-gs="gs1">GS1 — History, Geo, Society</button>
      <button class="qh-fpill" data-gs="gs2">GS2 — Polity, Governance, IR</button>
      <button class="qh-fpill" data-gs="gs3">GS3 — Economy, Science, Env</button>
    </div>
  </div>
</div>

<!-- Subject grid + Ujiyari sidebar -->
<section style="background:#f1f5f9;">
  <div class="container">
    <div class="qh-layout">

      <!-- Subject cards (3-column grid) -->
      <div class="qh-grid" id="qh-grid">
        {%- for subj in subjects -%}
        {%- if subj.quiz != false -%}
        {%- set subjectPyq = pyq[subj.slug] or [] -%}
        <a href="/quiz/{{ subj.slug }}/"
           class="qh-card{% if subjectPyq.length == 0 %} qh-card--empty{% endif %}"
           style="--qhc:{{ subj.color }};"
           data-subject="{{ subj.slug }}"
           data-gs="{{ subj.gs_papers | join(',') }}"
           data-total="{{ subjectPyq.length }}">
          <div class="qh-card__head">
            <span class="qh-card__icon">{{ subj.icon }}</span>
            <span class="qh-card__name">{{ subj.name }}</span>
          </div>
          <p class="qh-card__desc">{{ subj.description }}</p>
          <div class="qh-card__meta">
            <span class="qh-card__count">{{ subjectPyq.length }} question{{ 's' if subjectPyq.length != 1 }}</span>
            <span class="qh-card__status" id="status-{{ subj.slug }}">Not started</span>
          </div>
          <div class="qh-card__bar">
            <div class="qh-card__fill qh-card__fill--correct" id="bar-correct-{{ subj.slug }}" style="width:0%"></div>
            <div class="qh-card__fill qh-card__fill--wrong"   id="bar-wrong-{{ subj.slug }}"   style="width:0%"></div>
          </div>
          <span class="qh-card__cta">
            {%- if subjectPyq.length == 0 -%}📋 Coming Soon{%- else -%}🎯 Start Quiz{%- endif -%}
          </span>
        </a>
        {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Ujiyari sidebar -->
      <aside class="qh-sidebar">
        <div class="qh-ujiyari-card">
          <!-- Logo hero -->
          <div class="qhuj-logo-strip">
            <img src="/img/ujiyari-logo.png" alt="Ujiyari" style="width:120px;height:120px;object-fit:contain;border-radius:20px;filter:drop-shadow(0 4px 16px rgba(212,160,23,0.3));">
          </div>

          <!-- Body -->
          <div class="qhuj-body">
            <div class="qhuj-name">Ujiyari.com</div>
            <p class="qhuj-tagline">Complete your Prelims prep with <strong>Daily Current Affairs Quizzes</strong> — curated for UPSC aspirants.</p>

            <hr class="qhuj-div">

            <div class="qhuj-features">
              <div class="qhuj-feat">
                <span class="qhuj-feat-icon">✦</span>
                Daily MCQs from current affairs
              </div>
              <div class="qhuj-feat">
                <span class="qhuj-feat-icon">≡</span>
                Topic-wise quiz archives
              </div>
              <div class="qhuj-feat">
                <span class="qhuj-feat-icon">✓</span>
                Instant answer explanations
              </div>
              <div class="qhuj-feat">
                <span class="qhuj-feat-icon">◎</span>
                Free — no login needed
              </div>
            </div>

            <a href="https://ujiyari.com/quiz/" target="_blank" rel="noopener" class="qhuj-cta">
              Practice Now
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <p class="qhuj-note">
              PYQs here &nbsp;·&nbsp; <a href="https://ujiyari.com/daily/" target="_blank" rel="noopener">Current Affairs on Ujiyari</a>
            </p>
          </div>
        </div>
      </aside>

    </div>
  </div>
</section>

<script>
(function () {
  /* ── localStorage ── */
  var STORE_KEY = 'bn_quiz_v2';
  var STREAK_KEY = 'bn_streak_v1';

  function loadStore() {
    try { return JSON.parse(localStorage.getItem(STORE_KEY)) || {}; }
    catch (e) { return {}; }
  }

  /* ── Streak tracking ── */
  function trackStreak() {
    try {
      var today = new Date().toDateString();
      var yesterday = new Date(Date.now() - 86400000).toDateString();
      var data = JSON.parse(localStorage.getItem(STREAK_KEY)) || { streak: 0, lastDate: '' };
      if (data.lastDate === today) return data.streak;
      data.streak = (data.lastDate === yesterday) ? (data.streak || 0) + 1 : 1;
      data.lastDate = today;
      localStorage.setItem(STREAK_KEY, JSON.stringify(data));
      return data.streak;
    } catch(e) { return 0; }
  }
  var streak = trackStreak();
  if (streak >= 2) {
    var streakStat = document.getElementById('qh-streak-stat');
    var streakNum  = document.getElementById('qh-streak');
    if (streakStat) streakStat.style.display = '';
    if (streakNum)  streakNum.textContent = streak;
  }

  /* ── Hydrate cards ── */
  var store = loadStore();
  var totalQ = 0, totalAttempted = 0, totalCorrect = 0, totalWrong = 0;

  document.querySelectorAll('.qh-card[data-subject]').forEach(function (card) {
    var subject = card.getAttribute('data-subject');
    var total   = parseInt(card.getAttribute('data-total')) || 0;
    totalQ += total;
    if (!total) return;

    var saved    = store[subject] || {};
    var answered = 0, correct = 0, wrong = 0;

    Object.keys(saved).forEach(function(id) {
      var a = saved[id];
      if (a && typeof a === 'object' && 'ok' in a) {
        answered++;
        if (a.ok) correct++; else wrong++;
      } else {
        answered++; // legacy format: just an index stored
      }
    });

    totalAttempted += answered;
    totalCorrect   += correct;
    totalWrong     += wrong;

    var pC = total ? (correct  / total * 100) : 0;
    var pW = total ? (wrong    / total * 100) : 0;

    var fillC = document.getElementById('bar-correct-' + subject);
    var fillW = document.getElementById('bar-wrong-'   + subject);
    if (fillC) fillC.style.width = pC + '%';
    if (fillW) fillW.style.width = pW + '%';

    var statusEl = document.getElementById('status-' + subject);
    var btn      = card.querySelector('.qh-card__cta');
    if (statusEl) {
      if (answered === 0) {
        statusEl.textContent = 'Not started';
      } else if (answered < total) {
        statusEl.textContent = answered + '/' + total + ' done';
        statusEl.className = 'qh-card__status qh-card__status--partial';
        if (btn) btn.textContent = '↩ Continue';
      } else {
        statusEl.textContent = 'Completed';
        statusEl.className = 'qh-card__status qh-card__status--done';
        if (btn) btn.textContent = '✅ Review';
      }
    }
  });

  /* ── Hero stats ── */
  var el;
  el = document.getElementById('qh-total-q');   if (el) el.textContent = totalQ;
  el = document.getElementById('qh-attempted'); if (el) el.textContent = totalAttempted;
  el = document.getElementById('qh-accuracy');
  if (el) {
    var answeredWithResult = totalCorrect + totalWrong;
    el.textContent = answeredWithResult > 0
      ? Math.round(totalCorrect / answeredWithResult * 100) + '%'
      : '—';
  }

  /* ── Progress summary row ── */
  if (totalAttempted > 0) {
    var summaryEl = document.getElementById('qh-summary');
    if (summaryEl) summaryEl.style.display = '';
    el = document.getElementById('qhs-correct'); if (el) el.textContent = totalCorrect;
    el = document.getElementById('qhs-wrong');   if (el) el.textContent = totalWrong;
    el = document.getElementById('qhs-remain');  if (el) el.textContent = totalQ - totalAttempted;
  }

  /* ── GS Paper filter ── */
  document.querySelectorAll('.qh-fpill').forEach(function (pill) {
    pill.addEventListener('click', function () {
      document.querySelectorAll('.qh-fpill').forEach(function (p) { p.classList.remove('active'); });
      pill.classList.add('active');
      var filter = pill.getAttribute('data-gs');
      document.querySelectorAll('.qh-card[data-gs]').forEach(function (card) {
        var gs = card.getAttribute('data-gs') || '';
        card.style.display = (filter === 'all' || gs.indexOf(filter) !== -1) ? '' : 'none';
      });
    });
  });
})();
</script>
