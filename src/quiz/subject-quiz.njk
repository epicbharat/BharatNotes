---
pagination:
  data: subjects
  size: 1
  alias: subj
permalink: /quiz/{{ subj.slug }}/
layout: base.njk
---
{%- set subjectPyq = pyq[subj.slug] or [] -%}

<style>
/* ══════════════════════════════════════════════════════
   Quiz Subject Page — self-contained styles
   ══════════════════════════════════════════════════════ */

/* Page */
.qs-page { background: #f1f5f9; }

/* Hero */
.qs-hero {
  background: linear-gradient(135deg, var(--qs-color, var(--color-brand-dark)) 0%, color-mix(in srgb, var(--qs-color, var(--color-brand-dark)) 80%, #000) 100%);
  color: #fff;
  padding: var(--space-8) 0 var(--space-6);
}
.qs-hero__back {
  display: inline-flex; align-items: center; gap: 6px;
  color: rgba(255,255,255,0.65); font-size: var(--text-xs);
  text-decoration: none; margin-bottom: var(--space-3);
  font-weight: 600; letter-spacing: 0.02em;
}
.qs-hero__back:hover { color: #fff; }
.qs-hero__subject {
  display: flex; align-items: center; gap: var(--space-3);
  margin-bottom: var(--space-2);
}
.qs-hero__icon { font-size: 2rem; }
.qs-hero__title {
  font-family: var(--font-heading);
  font-size: var(--text-2xl); font-weight: 800; margin: 0;
}
.qs-hero__sub {
  color: rgba(255,255,255,0.65); font-size: var(--text-sm);
  margin: var(--space-1) 0 var(--space-5);
}
.qs-hero__stats {
  display: flex; flex-wrap: wrap; gap: var(--space-6);
}
.qs-hero__stat { text-align: center; min-width: 48px; }
.qs-hero__stat-num {
  display: block; font-size: var(--text-xl); font-weight: 800;
  color: #fde68a; line-height: 1.1;
}
.qs-hero__stat-lbl {
  font-size: 0.65rem; color: rgba(255,255,255,0.5);
  text-transform: uppercase; letter-spacing: 0.07em;
}

/* Progress bar strip */
.qs-prog {
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
  padding: var(--space-3) 0;
  position: sticky; top: 0; z-index: 10;
}
.qs-prog__bar {
  height: 6px; background: #e2e8f0;
  border-radius: 999px; overflow: hidden;
  display: flex; margin-bottom: var(--space-2);
}
.qs-prog__fill {
  height: 100%;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.qs-prog__fill--correct { background: #22c55e; }
.qs-prog__fill--wrong   { background: #ef4444; }
.qs-prog__labels {
  display: flex; gap: var(--space-4);
  font-size: var(--text-xs); color: var(--color-text-muted);
  flex-wrap: wrap;
}
.qs-prog__lbl { display: flex; align-items: center; gap: 4px; }
.qs-prog__dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.qs-prog__dot--correct { background: #22c55e; }
.qs-prog__dot--wrong   { background: #ef4444; }
.qs-prog__dot--remain  { background: #e2e8f0; }
.qs-prog__lbl b { color: var(--color-text); }

/* Filter bar */
.qs-filters {
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
  padding: var(--space-3) 0;
}
.qs-filters__inner {
  display: flex; flex-wrap: wrap; gap: var(--space-2); align-items: center;
}
.qs-filter-select {
  padding: 6px 12px; border-radius: 999px;
  border: 1.5px solid var(--color-border);
  background: var(--color-bg); font-size: var(--text-xs);
  font-family: var(--font-body); color: var(--color-text);
  cursor: pointer; outline: none;
  transition: border-color 0.15s;
}
.qs-filter-select:focus { border-color: var(--qs-color, var(--color-brand)); }
.qs-filter-btn {
  padding: 6px 16px; border-radius: 999px;
  border: 1.5px solid var(--color-border);
  background: transparent; font-size: var(--text-xs);
  font-weight: 600; color: var(--color-text-muted);
  cursor: pointer; font-family: var(--font-body);
  transition: all 0.15s;
}
.qs-filter-btn:hover {
  border-color: var(--qs-color, var(--color-brand));
  color: var(--qs-color, var(--color-brand));
}
.qs-filter-btn.active {
  background: var(--qs-color, var(--color-brand));
  border-color: var(--qs-color, var(--color-brand));
  color: #fff;
}
.qs-sep { width: 1px; height: 18px; background: var(--color-border); }
.qs-reset {
  margin-left: auto; font-size: var(--text-xs);
  color: var(--color-text-muted); background: none;
  border: none; cursor: pointer;
  text-decoration: underline; font-family: var(--font-body);
}
.qs-reset:hover { color: #ef4444; }

/* Main content area */
.qs-main { padding: var(--space-6) 0 var(--space-14); }
.qs-feed-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: var(--space-5);
}
.qs-count {
  font-size: var(--text-sm); font-weight: 600;
  color: var(--color-text-muted);
}
.qs-feed {
  display: flex; flex-direction: column;
  gap: var(--space-5); max-width: 760px;
}

/* ════════════════════════════
   Question Card (.qc)
   ════════════════════════════ */
.qc {
  background: #fff;
  border-radius: 14px;
  border: 1px solid #e2e8f0;
  border-left: 4px solid var(--qs-color, var(--color-brand));
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  overflow: hidden;
  transition: box-shadow 0.2s;
}
.qc:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); }
.qc.qc--answered { border-left-color: var(--qs-color, var(--color-brand)); }
.qc.qc--correct  { border-left-color: #22c55e; }
.qc.qc--wrong    { border-left-color: #ef4444; }

/* Meta row */
.qc-meta {
  display: flex; align-items: center; gap: var(--space-2);
  padding: var(--space-4) var(--space-5) 0;
  flex-wrap: wrap;
}
.qc-num {
  width: 30px; height: 30px;
  background: var(--qs-color, var(--color-brand));
  color: #fff; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--text-xs); font-weight: 800; flex-shrink: 0;
}
.qc-year {
  font-size: var(--text-xs); font-weight: 700; color: #475569;
  background: #f1f5f9; padding: 3px 10px; border-radius: 999px;
}
.qc-badge {
  font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 3px 9px; border-radius: 999px;
}
.qc-badge--ar   { background: rgba(124,58,237,0.1); color: #7c3aed; }
.qc-badge--stmt { background: rgba(15,76,58,0.08);  color: var(--color-brand); }
.qc-badge--dir  { background: rgba(212,160,23,0.1); color: #92400e; }
.qc-topic {
  font-size: var(--text-xs); color: #94a3b8;
  margin-left: auto; white-space: nowrap;
}

/* Body */
.qc-body { padding: var(--space-4) var(--space-5) 0; }
.qc-stem {
  font-size: var(--text-sm); line-height: 1.65;
  color: #1e293b; margin: 0 0 var(--space-3);
  font-weight: 500;
}
.qc-stem:last-child { margin-bottom: 0; }

/* Statement block */
.qc-stmts {
  list-style: none;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-left: 3px solid #94a3b8;
  border-radius: 8px;
  padding: var(--space-3) var(--space-4);
  margin: 0 0 var(--space-3);
  counter-reset: stmt-counter;
}
.qc-stmts li {
  counter-increment: stmt-counter;
  display: flex; gap: var(--space-3);
  font-size: var(--text-sm); line-height: 1.65;
  color: #334155; padding: var(--space-1) 0;
}
.qc-stmts li + li { border-top: 1px solid #e2e8f0; margin-top: var(--space-1); padding-top: var(--space-2); }
.qc-stmts li::before {
  content: counter(stmt-counter) ".";
  font-weight: 700; color: #64748b;
  flex-shrink: 0; min-width: 18px;
}
.qc-tail {
  font-size: var(--text-sm); color: #475569;
  font-style: italic; margin: 0 0 var(--space-1);
}

/* Assertion–Reason block */
.qc-ar {
  border: 1px solid #e2e8f0; border-radius: 10px;
  overflow: hidden; margin-bottom: 0;
}
.qc-ar__row {
  display: flex; gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
}
.qc-ar__row:first-child {
  background: rgba(124,58,237,0.03);
  border-bottom: 1px solid #e2e8f0;
}
.qc-ar__row:last-child { background: rgba(124,58,237,0.015); }
.qc-ar__lbl {
  font-size: var(--text-xs); font-weight: 800; color: #7c3aed;
  white-space: nowrap; min-width: 110px; padding-top: 2px;
}
.qc-ar__txt {
  font-size: var(--text-sm); color: #1e293b; line-height: 1.65;
}

/* Options */
.qc-opts {
  padding: var(--space-4) var(--space-5);
  display: flex; flex-direction: column; gap: 8px;
}
.qc-opt {
  display: flex; align-items: flex-start; gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  border: 1.5px solid #e2e8f0;
  border-radius: 9px;
  background: #fff;
  cursor: pointer; text-align: left; width: 100%;
  font-family: var(--font-body);
  transition: border-color 0.13s, background 0.13s, transform 0.1s;
  outline: none;
}
.qc-opt:hover:not(:disabled) {
  border-color: var(--qs-color, var(--color-brand));
  background: color-mix(in srgb, var(--qs-color, var(--color-brand)) 5%, #fff);
  transform: translateX(2px);
}
.qc-opt:focus-visible { outline: 2px solid var(--qs-color, var(--color-brand)); outline-offset: 2px; }
.qc-opt--selected:not(.qc-opt--correct):not(.qc-opt--wrong) {
  border-color: var(--qs-color, var(--color-brand));
  background: color-mix(in srgb, var(--qs-color, var(--color-brand)) 8%, #fff);
}
.qc-opt--correct { border-color: #22c55e !important; background: #f0fdf4 !important; transform: none !important; }
.qc-opt--wrong   { border-color: #ef4444 !important; background: #fef2f2 !important; transform: none !important; }
.qc-opt:disabled { cursor: default; }

.qc-opt__lbl {
  width: 28px; height: 28px; border-radius: 50%;
  border: 1.5px solid #cbd5e1;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem; font-weight: 800; color: #64748b;
  flex-shrink: 0; font-family: monospace; text-transform: uppercase;
  transition: all 0.13s;
}
.qc-opt--selected .qc-opt__lbl,
.qc-opt:hover:not(:disabled) .qc-opt__lbl {
  background: var(--qs-color, var(--color-brand));
  border-color: var(--qs-color, var(--color-brand));
  color: #fff;
}
.qc-opt--correct .qc-opt__lbl { background: #22c55e !important; border-color: #22c55e !important; color: #fff !important; }
.qc-opt--wrong   .qc-opt__lbl { background: #ef4444 !important; border-color: #ef4444 !important; color: #fff !important; }
.qc-opt__txt {
  font-size: var(--text-sm); color: #1e293b;
  line-height: 1.5; padding-top: 4px; flex: 1;
}
.qc-opt--correct .qc-opt__txt { color: #15803d !important; font-weight: 600; }
.qc-opt--wrong   .qc-opt__txt { color: #dc2626 !important; }

/* Verdict */
.qc-verdict {
  margin: 0 var(--space-5) var(--space-3);
  padding: var(--space-3) var(--space-4);
  border-radius: 8px;
  display: flex; align-items: flex-start;
  gap: var(--space-2); font-size: var(--text-sm); font-weight: 600;
}
.qc-verdict--correct { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
.qc-verdict--wrong   { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
.qc-verdict__icon { font-size: 1.1rem; line-height: 1; flex-shrink: 0; }

/* Explanation */
.qc-expl {
  margin: 0 var(--space-5) var(--space-3);
  border-radius: 8px;
  border: 1px solid #fde68a;
  background: #fffbeb;
  overflow: hidden;
}
.qc-expl__toggle {
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-xs); font-weight: 700; color: #92400e;
  cursor: pointer; list-style: none;
  display: flex; align-items: center; justify-content: space-between;
  user-select: none;
}
.qc-expl__toggle::-webkit-details-marker { display: none; }
.qc-expl__toggle::after {
  content: '▾'; font-size: 0.75rem; transition: transform 0.2s;
}
details[open] .qc-expl__toggle::after { transform: rotate(-180deg); }
.qc-expl__body {
  padding: var(--space-3) var(--space-4) var(--space-4);
  font-size: var(--text-sm); color: #78350f;
  line-height: 1.7; border-top: 1px solid #fde68a;
}

/* Footer */
.qc-footer {
  padding: var(--space-3) var(--space-5) var(--space-4);
  border-top: 1px solid #f1f5f9;
  display: flex; gap: var(--space-3); align-items: center;
}
.qc-check {
  flex: 1; padding: 11px var(--space-4);
  background: var(--qs-color, var(--color-brand));
  color: #fff; border: none; border-radius: 9px;
  font-size: var(--text-sm); font-weight: 700;
  cursor: pointer; font-family: var(--font-body);
  transition: opacity 0.15s, transform 0.1s;
  letter-spacing: 0.02em;
}
.qc-check:disabled { opacity: 0.35; cursor: not-allowed; transform: none !important; }
.qc-check:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
.qc-check:active:not(:disabled) { transform: translateY(0); }
.qc-retry {
  padding: 9px 20px;
  background: transparent; color: #64748b;
  border: 1.5px solid #e2e8f0; border-radius: 9px;
  font-size: var(--text-sm); cursor: pointer;
  font-family: var(--font-body); transition: all 0.15s;
}
.qc-retry:hover {
  border-color: var(--qs-color, var(--color-brand));
  color: var(--qs-color, var(--color-brand));
}
.qc-kbd-hint {
  font-size: 0.6rem; color: #94a3b8; margin-left: auto;
  display: none;
}
@media (hover: hover) { .qc-kbd-hint { display: block; } }

/* Empty / no-questions state */
.qs-empty {
  text-align: center; padding: var(--space-12) var(--space-6);
  background: #fff; border-radius: 14px;
  border: 1px dashed #e2e8f0; max-width: 760px;
  color: var(--color-text-muted);
}
.qs-empty__icon { font-size: 3rem; margin-bottom: var(--space-3); display: block; }
.qs-empty h3 { color: var(--color-text); margin-bottom: var(--space-2); }
.qs-empty p { font-size: var(--text-sm); margin-bottom: var(--space-5); }
.qs-empty-btn {
  display: inline-block; padding: 10px 24px;
  background: var(--qs-color, var(--color-brand));
  color: #fff; border-radius: var(--radius-md);
  text-decoration: none; font-weight: 700; font-size: var(--text-sm);
  border: none; cursor: pointer; font-family: var(--font-body);
}

/* Mobile */
@media (max-width: 640px) {
  .qs-hero__title { font-size: var(--text-xl); }
  .qc-meta  { padding: var(--space-3) var(--space-4) 0; }
  .qc-body  { padding: var(--space-3) var(--space-4) 0; }
  .qc-opts  { padding: var(--space-3) var(--space-4); }
  .qc-footer{ padding: var(--space-3) var(--space-4); }
  .qc-verdict,.qc-expl { margin-left: var(--space-4); margin-right: var(--space-4); }
  .qc-ar__lbl { min-width: 80px; font-size: 0.6rem; }
}
</style>

<!-- Hero -->
<div class="qs-hero" style="--qs-color:{{ subj.color }};">
  <div class="container">
    <a href="/quiz/" class="qs-hero__back">← Quiz Hub</a>
    <div class="qs-hero__subject">
      <span class="qs-hero__icon">{{ subj.icon }}</span>
      <h1 class="qs-hero__title">{{ subj.name }} — PYQ Practice</h1>
    </div>
    <p class="qs-hero__sub">UPSC Prelims Previous Year Questions · Track scores · Practice all MCQ types</p>
    <div class="qs-hero__stats">
      <div class="qs-hero__stat">
        <span class="qs-hero__stat-num" id="qs-total">{{ subjectPyq | length }}</span>
        <span class="qs-hero__stat-lbl">Questions</span>
      </div>
      <div class="qs-hero__stat">
        <span class="qs-hero__stat-num" id="qs-correct-count">0</span>
        <span class="qs-hero__stat-lbl">Correct</span>
      </div>
      <div class="qs-hero__stat">
        <span class="qs-hero__stat-num" id="qs-wrong-count">0</span>
        <span class="qs-hero__stat-lbl">Incorrect</span>
      </div>
      <div class="qs-hero__stat">
        <span class="qs-hero__stat-num" id="qs-remain-count">{{ subjectPyq | length }}</span>
        <span class="qs-hero__stat-lbl">Remaining</span>
      </div>
    </div>
  </div>
</div>

<!-- Progress bar (sticky) -->
<div class="qs-prog">
  <div class="container">
    <div class="qs-prog__bar">
      <div class="qs-prog__fill qs-prog__fill--correct" id="qs-prog-correct" style="width:0%"></div>
      <div class="qs-prog__fill qs-prog__fill--wrong"   id="qs-prog-wrong"   style="width:0%"></div>
    </div>
    <div class="qs-prog__labels">
      <span class="qs-prog__lbl"><span class="qs-prog__dot qs-prog__dot--correct"></span><b id="qs-p-correct">0</b> correct</span>
      <span class="qs-prog__lbl"><span class="qs-prog__dot qs-prog__dot--wrong"></span><b id="qs-p-wrong">0</b> incorrect</span>
      <span class="qs-prog__lbl"><span class="qs-prog__dot qs-prog__dot--remain"></span><b id="qs-p-remain">{{ subjectPyq | length }}</b> remaining</span>
    </div>
  </div>
</div>

<!-- Filter bar -->
<div class="qs-filters" style="--qs-color:{{ subj.color }};">
  <div class="container">
    <div class="qs-filters__inner">
      <select class="qs-filter-select" id="qs-filter-topic" aria-label="Filter by topic">
        <option value="all">All Topics</option>
      </select>
      <select class="qs-filter-select" id="qs-filter-year" aria-label="Filter by year">
        <option value="all">All Years</option>
      </select>
      <span class="qs-sep"></span>
      <button class="qs-filter-btn active" data-f="all">All</button>
      <button class="qs-filter-btn" data-f="unanswered">Unanswered</button>
      <button class="qs-filter-btn" data-f="correct">Correct</button>
      <button class="qs-filter-btn" data-f="wrong">Incorrect</button>
      <button class="qs-reset" id="qs-reset">Reset All</button>
    </div>
  </div>
</div>

<!-- Questions -->
<div class="qs-page">
  <div class="qs-main">
    <div class="container">
      <div class="qs-feed-header">
        <span class="qs-count" id="qs-count"></span>
      </div>
      <div class="qs-feed" id="qs-feed" style="--qs-color:{{ subj.color }};"></div>
    </div>
  </div>
</div>

<script>
(function () {
  /* ── Data ── */
  var DATA    = {{ subjectPyq | dump | safe }};
  var SUBJECT = '{{ subj.slug }}';
  var STORE_KEY = 'bn_quiz_v2';

  /* ── Assertion–Reason fixed options ── */
  var AR_OPTS = [
    'Both A and R are true and R is the correct explanation of A',
    'Both A and R are true but R is NOT the correct explanation of A',
    'A is true but R is false',
    'A is false but R is true'
  ];
  var LETTERS = ['a', 'b', 'c', 'd'];

  /* ── localStorage helpers ── */
  function loadStore() {
    try { return JSON.parse(localStorage.getItem(STORE_KEY)) || {}; }
    catch (e) { return {}; }
  }
  function saveAnswer(id, ansIdx) {
    var store = loadStore();
    if (!store[SUBJECT]) store[SUBJECT] = {};
    store[SUBJECT][id] = ansIdx;
    localStorage.setItem(STORE_KEY, JSON.stringify(store));
  }
  function removeAnswer(id) {
    var store = loadStore();
    if (store[SUBJECT]) {
      delete store[SUBJECT][id];
      localStorage.setItem(STORE_KEY, JSON.stringify(store));
    }
  }
  function clearSubject() {
    var store = loadStore();
    delete store[SUBJECT];
    localStorage.setItem(STORE_KEY, JSON.stringify(store));
  }

  /* ── HTML escape ── */
  function esc(s) {
    if (!s) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  /* ── Build option buttons HTML ── */
  function buildOpts(opts, savedAns, correct) {
    var answered = savedAns !== undefined;
    var html = '<div class="qc-opts" role="radiogroup" aria-label="Answer options">';
    opts.forEach(function (opt, i) {
      var cls = 'qc-opt';
      if (answered) {
        if (i === correct) cls += ' qc-opt--correct';
        else if (i === savedAns) cls += ' qc-opt--wrong';
        if (i === savedAns) cls += ' qc-opt--selected';
      }
      var disabledAttr = answered ? ' disabled' : '';
      html += '<button class="' + cls + '" data-idx="' + i + '"' + disabledAttr + ' type="button">';
      html += '<span class="qc-opt__lbl">' + LETTERS[i] + '</span>';
      html += '<span class="qc-opt__txt">' + esc(opt) + '</span>';
      html += '</button>';
    });
    html += '</div>';
    return html;
  }

  /* ── Build verdict HTML ── */
  function buildVerdict(isCorrect, correct, opts) {
    var cls = isCorrect ? 'qc-verdict--correct' : 'qc-verdict--wrong';
    var icon = isCorrect ? '✓' : '✗';
    var msg = isCorrect
      ? 'Correct!'
      : 'Incorrect — correct answer: (' + LETTERS[correct] + ') ' + esc(opts[correct]);
    return '<div class="qc-verdict ' + cls + '"><span class="qc-verdict__icon">' + icon + '</span><span>' + msg + '</span></div>';
  }

  /* ── Build explanation HTML ── */
  function buildExpl(explanation, open) {
    if (!explanation) return '';
    return '<details class="qc-expl"' + (open ? ' open' : '') + '>' +
      '<summary class="qc-expl__toggle">💡 Explanation</summary>' +
      '<div class="qc-expl__body">' + esc(explanation) + '</div>' +
      '</details>';
  }

  /* ── Render one question card ── */
  function renderCard(q, seqNum, savedAns) {
    var answered  = savedAns !== undefined;
    var isCorrect = answered && savedAns === q.correct;
    var opts = q.qtype === 'assertion' ? AR_OPTS : (q.options || []);

    var cardCls = 'qc';
    if (answered) cardCls += isCorrect ? ' qc--correct qc--answered' : ' qc--wrong qc--answered';

    var html = '<div class="' + cardCls + '" data-id="' + esc(q.id) + '" data-correct="' + q.correct + '">';

    /* meta row */
    var qtypeBadge = '';
    if (q.qtype === 'assertion') qtypeBadge = '<span class="qc-badge qc-badge--ar">Assertion–Reason</span>';
    else if (q.qtype === 'statement') qtypeBadge = '<span class="qc-badge qc-badge--stmt">Statement Based</span>';
    else if (q.qtype === 'direct') qtypeBadge = '<span class="qc-badge qc-badge--dir">Direct MCQ</span>';

    html += '<div class="qc-meta">';
    html += '<span class="qc-num">' + seqNum + '</span>';
    if (q.year) html += '<span class="qc-year">CSE&nbsp;' + q.year + '</span>';
    html += qtypeBadge;
    if (q.topic) html += '<span class="qc-topic">' + esc(q.topic) + (q.subtopic ? ' · ' + esc(q.subtopic) : '') + '</span>';
    html += '</div>';

    /* body */
    html += '<div class="qc-body">';
    if (q.qtype === 'assertion') {
      html += '<div class="qc-ar">';
      html += '<div class="qc-ar__row"><span class="qc-ar__lbl">Assertion (A):</span><span class="qc-ar__txt">' + esc(q.assertion) + '</span></div>';
      html += '<div class="qc-ar__row"><span class="qc-ar__lbl">Reason&nbsp;&nbsp;&nbsp;(R):</span><span class="qc-ar__txt">' + esc(q.reason) + '</span></div>';
      html += '</div>';
    } else {
      html += '<p class="qc-stem">' + esc(q.stem) + '</p>';
      if (q.statements && q.statements.length) {
        html += '<ol class="qc-stmts">';
        q.statements.forEach(function (s) { html += '<li>' + esc(s) + '</li>'; });
        html += '</ol>';
        if (q.tail) html += '<p class="qc-tail">' + esc(q.tail || 'Which of the statements given above is/are correct?') + '</p>';
      }
    }
    html += '</div>';

    /* options */
    html += buildOpts(opts, savedAns, q.correct);

    /* verdict + explanation (if already answered) */
    if (answered) {
      html += buildVerdict(isCorrect, q.correct, opts);
      html += buildExpl(q.explanation, true);
    }

    /* footer */
    html += '<div class="qc-footer">';
    if (!answered) {
      html += '<button class="qc-check" data-id="' + esc(q.id) + '" type="button" disabled>Check Answer</button>';
      html += '<span class="qc-kbd-hint">1–4 to select · Enter to check</span>';
    } else {
      html += '<button class="qc-retry" data-id="' + esc(q.id) + '" type="button">↺ Try Again</button>';
    }
    html += '</div>';

    html += '</div>'; /* .qc */
    return html;
  }

  /* ── Wire events to rendered cards ── */
  function wireCards(feed) {
    /* Option selection */
    feed.querySelectorAll('.qc:not(.qc--answered) .qc-opt').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var card = btn.closest('.qc');
        card.querySelectorAll('.qc-opt').forEach(function (b) { b.classList.remove('qc-opt--selected'); });
        btn.classList.add('qc-opt--selected');
        var checkBtn = card.querySelector('.qc-check');
        if (checkBtn) checkBtn.disabled = false;
      });
    });

    /* Keyboard shortcut (1–4 and Enter) on unanswered cards */
    feed.querySelectorAll('.qc:not(.qc--answered)').forEach(function (card) {
      card.addEventListener('keydown', function (e) {
        var k = e.key;
        var idx = { '1': 0, '2': 1, '3': 2, '4': 3 }[k];
        if (idx !== undefined) {
          var opts = card.querySelectorAll('.qc-opt');
          if (opts[idx]) opts[idx].click();
        }
        if (k === 'Enter') {
          var checkBtn = card.querySelector('.qc-check:not(:disabled)');
          if (checkBtn) checkBtn.click();
        }
      });
      card.setAttribute('tabindex', '0');
    });

    /* Check answer */
    feed.querySelectorAll('.qc-check').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var card  = btn.closest('.qc');
        var id    = btn.getAttribute('data-id');
        var sel   = card.querySelector('.qc-opt--selected');
        if (!sel) return;
        var ansIdx  = parseInt(sel.getAttribute('data-idx'));
        var correct = parseInt(card.getAttribute('data-correct'));
        var q = DATA.find(function (d) { return d.id === id; });
        var opts = q && q.qtype === 'assertion' ? AR_OPTS : (q ? q.options || [] : []);
        var isCorrect = ansIdx === correct;

        /* Save */
        saveAnswer(id, ansIdx);

        /* Style options */
        card.querySelectorAll('.qc-opt').forEach(function (opt, i) {
          opt.disabled = true;
          if (i === correct) opt.classList.add('qc-opt--correct');
          else if (i === ansIdx) opt.classList.add('qc-opt--wrong');
        });

        /* Insert verdict */
        var optsEl = card.querySelector('.qc-opts');
        var verdictEl = document.createElement('div');
        verdictEl.innerHTML = buildVerdict(isCorrect, correct, opts);
        optsEl.parentNode.insertBefore(verdictEl.firstChild, optsEl.nextSibling);

        /* Insert explanation */
        if (q && q.explanation) {
          var explEl = document.createElement('div');
          explEl.innerHTML = buildExpl(q.explanation, true);
          var verdict = card.querySelector('.qc-verdict');
          verdict.parentNode.insertBefore(explEl.firstChild, verdict.nextSibling);
        }

        /* Replace footer */
        var footer = card.querySelector('.qc-footer');
        footer.innerHTML = '<button class="qc-retry" data-id="' + esc(id) + '" type="button">↺ Try Again</button>';
        footer.querySelector('.qc-retry').addEventListener('click', function () {
          removeAnswer(id);
          renderAll();
        });

        /* Update card class */
        card.classList.add('qc--answered');
        card.classList.add(isCorrect ? 'qc--correct' : 'qc--wrong');

        updateProgress();
      });
    });

    /* Try Again */
    feed.querySelectorAll('.qc-retry').forEach(function (btn) {
      btn.addEventListener('click', function () {
        removeAnswer(btn.getAttribute('data-id'));
        renderAll();
      });
    });
  }

  /* ── Populate filter dropdowns ── */
  function populateFilters() {
    var topics = {}, years = {};
    DATA.forEach(function (q) {
      if (q.topic) topics[q.topic] = true;
      if (q.year) years[q.year] = true;
    });

    var topicSel = document.getElementById('qs-filter-topic');
    Object.keys(topics).sort().forEach(function (t) {
      var o = document.createElement('option');
      o.value = t; o.textContent = t;
      topicSel.appendChild(o);
    });

    var yearSel = document.getElementById('qs-filter-year');
    Object.keys(years).sort(function (a, b) { return b - a; }).forEach(function (y) {
      var o = document.createElement('option');
      o.value = y; o.textContent = y;
      yearSel.appendChild(o);
    });

    topicSel.addEventListener('change', renderAll);
    yearSel.addEventListener('change', renderAll);
  }

  /* ── Update progress bar & hero stats ── */
  function updateProgress() {
    var store  = loadStore();
    var saved  = store[SUBJECT] || {};
    var total  = DATA.length;
    var answered = 0, correct = 0;
    DATA.forEach(function (q) {
      var a = saved[q.id];
      if (a !== undefined) { answered++; if (a === q.correct) correct++; }
    });
    var wrong   = answered - correct;
    var remain  = total - answered;
    var pCorrect = total ? (correct / total * 100) : 0;
    var pWrong   = total ? (wrong   / total * 100) : 0;

    document.getElementById('qs-prog-correct').style.width = pCorrect + '%';
    document.getElementById('qs-prog-wrong').style.width   = pWrong   + '%';

    var set = function (id, v) { var el = document.getElementById(id); if (el) el.textContent = v; };
    set('qs-correct-count', correct);
    set('qs-wrong-count',   wrong);
    set('qs-remain-count',  remain);
    set('qs-p-correct', correct);
    set('qs-p-wrong',   wrong);
    set('qs-p-remain',  remain);
  }

  /* ── Main render ── */
  function renderAll() {
    var store = loadStore();
    var saved = store[SUBJECT] || {};
    var feed  = document.getElementById('qs-feed');
    if (!feed) return;

    /* Collect filter values */
    var topicFilter  = document.getElementById('qs-filter-topic').value;
    var yearFilter   = document.getElementById('qs-filter-year').value;
    var activeBtn    = document.querySelector('.qs-filter-btn.active');
    var statusFilter = activeBtn ? activeBtn.getAttribute('data-f') : 'all';

    /* Filter */
    var filtered = DATA.filter(function (q) {
      if (topicFilter !== 'all' && q.topic !== topicFilter) return false;
      if (yearFilter  !== 'all' && String(q.year) !== yearFilter) return false;
      var a = saved[q.id];
      var ans = a !== undefined;
      if (statusFilter === 'unanswered' && ans) return false;
      if (statusFilter === 'correct' && (!ans || a !== q.correct)) return false;
      if (statusFilter === 'wrong'   && (!ans || a === q.correct)) return false;
      return true;
    });

    /* Render */
    if (!DATA.length) {
      feed.innerHTML = '<div class="qs-empty">' +
        '<span class="qs-empty__icon">📝</span>' +
        '<h3>Questions Coming Soon</h3>' +
        '<p>We are preparing verified UPSC PYQs for this subject. Check back shortly.</p>' +
        '<a href="/quiz/" class="qs-empty-btn">← Back to Quiz Hub</a>' +
        '</div>';
      document.getElementById('qs-count').textContent = '';
      return;
    }

    if (!filtered.length) {
      feed.innerHTML = '<div class="qs-empty">' +
        '<span class="qs-empty__icon">🔍</span>' +
        '<h3>No Questions Match</h3>' +
        '<p>Try changing the filters above.</p>' +
        '<button class="qs-empty-btn" id="qs-clear-f">Clear Filters</button>' +
        '</div>';
      document.getElementById('qs-count').textContent = '0 questions';
      var cb = document.getElementById('qs-clear-f');
      if (cb) cb.addEventListener('click', clearFilters);
      return;
    }

    var html = '';
    filtered.forEach(function (q, i) {
      html += renderCard(q, i + 1, saved[q.id]);
    });
    feed.innerHTML = html;
    wireCards(feed);
    updateProgress();

    var n = filtered.length;
    document.getElementById('qs-count').textContent = n + ' question' + (n !== 1 ? 's' : '');
  }

  /* ── Clear filters ── */
  function clearFilters() {
    document.getElementById('qs-filter-topic').value = 'all';
    document.getElementById('qs-filter-year').value  = 'all';
    document.querySelectorAll('.qs-filter-btn').forEach(function (b) { b.classList.remove('active'); });
    var allBtn = document.querySelector('.qs-filter-btn[data-f="all"]');
    if (allBtn) allBtn.classList.add('active');
    renderAll();
  }

  /* ── Wire status filter buttons ── */
  document.querySelectorAll('.qs-filter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.qs-filter-btn').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      renderAll();
    });
  });

  /* ── Reset All ── */
  var resetBtn = document.getElementById('qs-reset');
  if (resetBtn) {
    resetBtn.addEventListener('click', function () {
      if (!window.confirm('Reset all scores for this subject? This cannot be undone.')) return;
      clearSubject();
      renderAll();
    });
  }

  /* ── Boot ── */
  populateFilters();
  renderAll();

})();
</script>
