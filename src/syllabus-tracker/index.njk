    <h2 class="section-heading">Mains — UPSC Syllabus Topics</h2>
    <p style="color:var(--color-text-muted); font-size:var(--text-sm); margin-bottom:var(--space-6);">Official UPSC Mains GS syllabus broken down by paper. Check off topics as you cover them.</p>

    {# ── Per-paper sections ── #}
    {% set paperColors = { gs1: '#9f1239', gs2: '#7c3aed', gs3: '#0369a1', gs4: '#047857' } %}

    {% for key, paper in syllabus %}
    <div class="syl-card" style="--syl-color:{{ paperColors[paper.slug] }}; margin-bottom:var(--space-6);">
      <div class="syl-card__head">
        <span class="syl-card__icon">{{ paper.icon }}</span>
        <div>
          <h2 class="syl-card__title" style="font-size:1.15rem;">{{ paper.title }}</h2>
          <span class="syl-card__count">{{ paper.subtitle }}</span>
        </div>
        <span id="progress-{{ paper.slug }}" style="font-size:0.85rem; font-weight:700; color:{{ paperColors[paper.slug] }};">0%</span>
      </div>

      {# Progress bar #}
      <div style="padding:0 var(--space-4); padding-top:var(--space-3);">
        <div style="background:var(--color-border); border-radius:99px; height:7px; overflow:hidden;">
          <div id="bar-{{ paper.slug }}" style="background:{{ paperColors[paper.slug] }}; height:100%; width:0%; border-radius:99px; transition:width 0.3s;"></div>
        </div>
      </div>

      {# Sections with checkboxes #}
      <div style="padding:var(--space-4);">
        {% for section in paper.sections %}
        <div style="margin-bottom:var(--space-4);">
          <h4 style="font-size:0.78rem; color:{{ paperColors[paper.slug] }}; text-transform:uppercase; letter-spacing:0.05em; font-weight:700; margin-bottom:var(--space-2);">{{ section.title }}</h4>
          {% for topic in section.topics %}
          <label class="syllabus-label">
            <input type="checkbox" class="syllabus-check" data-paper="{{ paper.slug }}" data-topic="{{ topic | slugify }}">
            <span class="syllabus-label__text">{{ topic }}</span>
          </label>
          {% endfor %}
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}

    {# ── Reset ── #}
    <div style="text-align:center; margin-top:var(--space-4); padding-top:var(--space-6); border-top:1px solid var(--color-border);">
      <button id="reset-syllabus" style="background:none; border:1.5px solid var(--color-error, #dc2626); color:var(--color-error, #dc2626); padding:0.5em 1.5em; border-radius:8px; font-size:var(--text-sm); font-weight:600; cursor:pointer;">Reset All Checkmarks</button>
    </div>

  </div>
</section>

<script>
(function() {
  /* ── Storage keys ── */
  var PRELIMS_KEY = 'bharatnotes_prelims_tracker';
  var MAINS_KEY = 'bharatnotes_syllabus';

  var prelimsSaved = {};
  var mainsSaved = {};
  try { prelimsSaved = JSON.parse(localStorage.getItem(PRELIMS_KEY) || '{}'); } catch(e) {}
  try { mainsSaved = JSON.parse(localStorage.getItem(MAINS_KEY) || '{}'); } catch(e) {}

  /* ── Helper: bind checkboxes ── */
  function bindChecks(selector, storageObj, storageKey, keyFn) {
    var cbs = document.querySelectorAll(selector);
    cbs.forEach(function(cb) {
      var key = keyFn(cb);
      if (storageObj[key]) {
        cb.checked = true;
        cb.closest('.syllabus-label').classList.add('syllabus-label--done');
      }
      cb.addEventListener('change', function() {
        var k = keyFn(cb);
        var label = cb.closest('.syllabus-label');
        if (cb.checked) {
          storageObj[k] = true;
          label.classList.add('syllabus-label--done');
        } else {
          delete storageObj[k];
          label.classList.remove('syllabus-label--done');
        }
        localStorage.setItem(storageKey, JSON.stringify(storageObj));
        updateAll();
      });
    });
    return cbs;
  }

  var prelimsCbs = bindChecks('.prelims-check', prelimsSaved, PRELIMS_KEY, function(cb) {
    return cb.dataset.subject + '/' + cb.dataset.slug;
  });
  var mainsCbs = bindChecks('.syllabus-check', mainsSaved, MAINS_KEY, function(cb) {
    return cb.dataset.paper + '/' + cb.dataset.topic;
  });

  /* ── Prelims per-subject counts ── */
  var subjectTotals = {};
  prelimsCbs.forEach(function(cb) {
    var s = cb.dataset.subject;
    if (!subjectTotals[s]) subjectTotals[s] = { total: 0, checked: 0 };
    subjectTotals[s].total++;
  });

  function updateAll() {
    /* Prelims */
    var pDone = 0, pTotal = 0;
    /* Reset subject counts */
    Object.keys(subjectTotals).forEach(function(s) { subjectTotals[s].checked = 0; });

    prelimsCbs.forEach(function(cb) {
      pTotal++;
      if (cb.checked) {
        pDone++;
        subjectTotals[cb.dataset.subject].checked++;
      }
    });

    var pPct = pTotal ? Math.round((pDone / pTotal) * 100) : 0;
    document.getElementById('prelims-done').textContent = pDone;
    document.getElementById('prelims-total').textContent = pTotal;
    document.getElementById('prelims-pct').textContent = pPct + '%';
    document.getElementById('bar-prelims').style.width = pPct + '%';

    /* Per-subject counters */
    Object.keys(subjectTotals).forEach(function(s) {
      var el = document.getElementById('prelims-count-' + s);
      if (el) el.textContent = subjectTotals[s].checked + ' / ' + subjectTotals[s].total;
    });

    /* Mains */
    var mPapers = {};
    var mDone = 0, mTotal = 0;
    mainsCbs.forEach(function(cb) {
      var p = cb.dataset.paper;
      if (!mPapers[p]) mPapers[p] = { checked: 0, total: 0 };
      mPapers[p].total++;
      mTotal++;
      if (cb.checked) { mPapers[p].checked++; mDone++; }
    });

    Object.keys(mPapers).forEach(function(slug) {
      var data = mPapers[slug];
      var pct = Math.round((data.checked / data.total) * 100);
      var progEl = document.getElementById('progress-' + slug);
      var barEl = document.getElementById('bar-' + slug);
      if (progEl) progEl.textContent = pct + '%';
      if (barEl) barEl.style.width = pct + '%';
    });

    /* Overall = prelims + mains combined */
    var allDone = pDone + mDone;
    var allTotal = pTotal + mTotal;
    var allPct = allTotal ? Math.round((allDone / allTotal) * 100) : 0;
    document.getElementById('stat-pct').textContent = allPct + '%';
    document.getElementById('stat-done').textContent = allDone;
    document.getElementById('stat-remaining').textContent = allTotal - allDone;
    document.getElementById('bar-overall').style.width = allPct + '%';
  }

  updateAll();

  /* ── Reset ── */
  document.getElementById('reset-syllabus').addEventListener('click', function() {
    if (confirm('This will uncheck everything — Prelims topics and Mains syllabus. Are you sure?')) {
      localStorage.removeItem(PRELIMS_KEY);
      localStorage.removeItem(MAINS_KEY);
      prelimsSaved = {};
      mainsSaved = {};
      prelimsCbs.forEach(function(cb) {
        cb.checked = false;
        cb.closest('.syllabus-label').classList.remove('syllabus-label--done');
      });
      mainsCbs.forEach(function(cb) {
        cb.checked = false;
        cb.closest('.syllabus-label').classList.remove('syllabus-label--done');
      });
      updateAll();
    }
  });
})();
</script>
