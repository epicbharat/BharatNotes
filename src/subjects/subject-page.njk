---
pagination:
  data: subjects
  size: 1
  alias: subj
permalink: "/subjects/{{ subj.slug }}/"
layout: base.njk
eleventyComputed:
  title: "{{ subj.name }}"
  description: "{{ subj.description }} — UPSC notes from foundation to Mains level with MCQs and PYQ analysis."
---

<section class="page-header">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      <a href="/subjects/">Subjects</a><span class="breadcrumb__sep">/</span>
      {{ subj.name }}
    </nav>
    <div style="display:flex; align-items:center; gap:var(--space-3); margin-bottom:var(--space-3);">
      <span style="font-size:2.5rem;">{{ subj.icon }}</span>
      <div>
        <p class="page-header__eyebrow">
          {% for paper in subj.gs_papers %}
          <span class="gs-badge gs-badge--{{ paper }}" style="font-size:0.65rem;">{{ paper | upper }}</span>
          {% endfor %}
        </p>
        <h1 class="page-header__title">{{ subj.name }}</h1>
      </div>
    </div>
    <p class="page-header__subtitle">{{ subj.description }}</p>
  </div>
</section>

<section style="padding:var(--space-8) 0;">
  <div class="container">

    <!-- Syllabus sections -->
    {% for sectionName in subj.syllabus_sections %}
    <div class="subject-section">
      <h2 class="subject-section__heading" style="border-bottom-color:{{ subj.color }};">{{ sectionName }}</h2>

      {# Find topics matching this subject AND this syllabus section, sorted by chapter #}
      {% set topicList = [] %}
      {% for topic in collections.allTopics %}
        {% if topic.data.subject == subj.slug and topic.data.syllabus_topic == sectionName %}
          {% set topicList = (topicList.push(topic), topicList) %}
        {% endif %}
      {% endfor %}

      {% if topicList.length > 0 %}

        {# Separate: topics with sub-chapters vs flat topics #}
        {% set indexTopics = [] %}
        {% set flatTopics = [] %}
        {% for topic in topicList | sort(false, false, "data.chapter") %}
          {% set subChapters = [] %}
          {% for item in collections.all %}
            {% if item.data.parent_topic_url == topic.url %}
              {% set subChapters = (subChapters.push(item), subChapters) %}
            {% endif %}
          {% endfor %}
          {% if subChapters.length > 0 %}
            {% set indexTopics = (indexTopics.push({topic: topic, chapters: subChapters}), indexTopics) %}
          {% else %}
            {% set flatTopics = (flatTopics.push(topic), flatTopics) %}
          {% endif %}
        {% endfor %}

        {# Render section blocks (topics with chapters) #}
        {% for entry in indexTopics %}
        <div class="section-block{% if entry.topic.data.syllabus_direct %} section-block--syllabus-direct{% endif %}">
          <a href="{{ entry.topic.url }}" class="section-block__header">
            {% if entry.topic.data.chapter %}
            <span class="section-block__number" style="background:{{ subj.color }};">{{ entry.topic.data.chapter | string | padStart(2, "0") }}</span>
            {% endif %}
            <div class="section-block__info">
              <h3 class="section-block__title">{{ entry.topic.data.title }}</h3>
              <p class="section-block__count">{{ entry.chapters.length }} chapter{{ "s" if entry.chapters.length > 1 }}{% if entry.topic.data.syllabus_direct %} &nbsp;<span class="syllabus-direct-badge">UPSC Syllabus</span>{% endif %}</p>
            </div>
            <span class="section-block__arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 6 15 12 9 18"/></svg>
            </span>
          </a>
          <ul class="chapter-list">
            {% for ch in entry.chapters | sort(false, false, "data.sub_chapter") %}
            <li class="chapter-list__item">
              <a href="{{ ch.url }}" class="chapter-list__link">
                <span class="chapter-list__num" style="color:{{ subj.color }};">{{ ch.data.sub_chapter | string | padStart(2, "0") }}</span>
                <span class="chapter-list__title">{{ ch.data.title }}</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}

        {# Render flat topic cards (no sub-chapters) #}
        {% if flatTopics.length > 0 %}
        <div class="topic-grid">
          {% for topic in flatTopics %}
          <a href="{{ topic.url }}" class="card" style="text-decoration:none;">
            {% if topic.data.chapter %}
            <span style="font-size:var(--text-xs); font-weight:var(--font-bold); color:{{ subj.color }}; letter-spacing:var(--tracking-wider); text-transform:uppercase; margin-bottom:var(--space-1); display:block;">Chapter {{ topic.data.chapter | string | padStart(2, "0") }}</span>
            {% endif %}
            <h3 class="card__title" style="font-size:var(--text-base);">{{ topic.data.title }}</h3>
            {% if topic.data.description %}
            <p class="card__desc">{{ topic.data.description | truncate(100) }}</p>
            {% endif %}
            <div style="margin-top:var(--space-2); display:flex; gap:var(--space-2);">
              {% if topic.data.foundation %}<span style="font-size:0.6rem; background:#d1fae5; color:#065f46; padding:1px 6px; border-radius:var(--radius-full);">Foundation</span>{% endif %}
              {% if topic.data.prelims %}<span style="font-size:0.6rem; background:#fef3c7; color:#92400e; padding:1px 6px; border-radius:var(--radius-full);">Prelims</span>{% endif %}
              {% if topic.data.mains %}<span style="font-size:0.6rem; background:#dbeafe; color:#1e40af; padding:1px 6px; border-radius:var(--radius-full);">Mains</span>{% endif %}
            </div>
          </a>
          {% endfor %}
        </div>
        {% endif %}

      {% else %}
      <div class="card" style="background:var(--color-bg); border:2px dashed var(--color-border);">
        <p style="color:var(--color-text-muted); font-size:var(--text-sm); text-align:center; padding:var(--space-4);">Topics for {{ sectionName }} are being prepared. Check back soon!</p>
      </div>
      {% endif %}
    </div>
    {% endfor %}

    <!-- Current Affairs Link -->
    <div class="card" style="border-left:4px solid var(--color-accent); margin-top:var(--space-6);">
      <h3 class="card__title">Current Affairs for {{ subj.name }}</h3>
      <p class="card__desc" style="margin-bottom:var(--space-3);">Stay updated with daily news, editorials, and analysis on Ujiyari.com — auto-linked to this subject.</p>
      <a href="https://ujiyari.com/subjects/{{ subj.slug }}/" class="btn btn--accent btn--sm" target="_blank">View on Ujiyari →</a>
    </div>

  </div>
</section>
