@media(max-width:768px){.sk-books{grid-template-columns:1fr}.sk-hero-stats{gap:var(--space-4)}.sk-supp,.sk-supp--priority{grid-template-columns:1fr 1fr}.sk-nav{gap:var(--space-1)}.sk-nav-btn{padding:5px 10px;font-size:0.6rem}}
