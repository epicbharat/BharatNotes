      var prefixes=book.dataset.ck.split('|');
      var matched=0,total=0;
      keys.forEach(function(k){for(var i=0;i<prefixes.length;i++){if(k.indexOf(prefixes[i])===0){matched++;break;}}});
      prefixes.forEach(function(p){Object.keys(tc).forEach(function(k){if(k.indexOf(p)===0||p.indexOf(k)===0)total+=tc[k];});});
      if(total===0)total=1;
      var bp=Math.min(100,Math.round(matched/total*100));
      var fill=book.querySelector('.sk-book__bar-fill');
      var pctEl=book.querySelector('.sk-book__pct');
      var color=getComputedStyle(book).getPropertyValue('--sk-color').trim();
      if(fill){fill.style.width=bp+'%';fill.style.background=color||'var(--color-brand)';}
      if(pctEl&&book.dataset.ck!=='prelims-gs/Current Events')pctEl.textContent=bp+'%';
    });
  }catch(e){}
})();
</script>
