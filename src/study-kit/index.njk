<script>
// Read checklist progress and show overall %
(function() {
  try {
    var state = JSON.parse(localStorage.getItem('bharatnotes_upsc_checklist') || '{}');
    var done = Object.keys(state).length;
    // Approximate total from checklist (559 topics)
    var total = 559;
    var pct = total ? Math.round(done / total * 100) : 0;
    document.getElementById('sk-pct').textContent = pct + '%';
    document.getElementById('sk-bar').style.width = pct + '%';
    if (done > 0) {
      document.getElementById('sk-bar-text').textContent = done + ' of ' + total + ' syllabus topics covered';
    }
  } catch(e) {}
})();
</script>
