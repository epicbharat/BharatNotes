.sk-section-label{font-family:var(--font-heading);font-size:var(--text-xl);color:var(--color-text);margin:var(--space-10) 0 var(--space-5);padding-bottom:var(--space-3);border-bottom:2px solid var(--color-border);scroll-margin-top:60px}

.sk-cta{background:linear-gradient(135deg,#1e3a5f 0%,#0f4c3a 100%);border-radius:var(--radius-lg);padding:var(--space-8);text-align:center;color:#fff;margin-top:var(--space-8)}
.sk-cta h3{font-family:var(--font-heading);font-size:var(--text-lg);margin:0 0 var(--space-2)}
.sk-cta p{font-size:var(--text-sm);opacity:0.8;margin:0 0 var(--space-4);max-width:500px;margin-left:auto;margin-right:auto}
