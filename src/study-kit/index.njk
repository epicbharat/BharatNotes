.sk-book__tag--prelims{color:#b45309;border-color:#fde68a;background:#fffbeb}
.sk-book__tag--gs1{color:#9f1239;border-color:#fecdd3;background:#fff1f2}
.sk-book__tag--gs2{color:#7c3aed;border-color:#ddd6fe;background:#f5f3ff}
.sk-book__tag--gs3{color:#0369a1;border-color:#bae6fd;background:#f0f9ff}
.sk-book__tag--gs4{color:#854d0e;border-color:#fde68a;background:#fefce8}
.sk-book__meta{font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-2)}
