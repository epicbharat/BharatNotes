<!-- ═══════════════════════════════════════════════════
     SUBJECTS — editorial left intro + subject grid
════════════════════════════════════════════════════ -->
<section class="subjects-section">
  <div class="container">
    <div class="subjects-layout">

      <div class="subjects-intro">
        <h2 class="subjects-intro__heading">12 Subjects.<br>One Platform.</h2>
        <p class="subjects-intro__text">Every UPSC GS paper covered in full depth — Foundation, Prelims, and Mains levels for each subject.</p>
        <a href="/subjects/" class="subjects-intro__link">View all subjects &rarr;</a>
      </div>

      <div class="subjects-grid">
        {% for subj in subjects %}
        <a href="/subjects/{{ subj.slug }}/" class="subject-chip" style="--chip-color: {{ subj.color }};">
          <span class="subject-chip__icon">{{ subj.icon }}</span>
          <span class="subject-chip__name">{{ subj.name }}</span>
          <span class="subject-chip__papers">
            {% for paper in subj.gs_papers %}{{ paper | upper }}{% if not loop.last %}&thinsp;&middot;&thinsp;{% endif %}{% endfor %}
          </span>
        </a>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

