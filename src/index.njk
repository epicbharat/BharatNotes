    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:var(--space-5);">

      <a href="/start-here/#beginner" class="card" style="text-decoration:none; border-top:3px solid #7c3aed;">
        <div style="font-size:1.6rem; margin-bottom:var(--space-3);">🌱</div>
        <h3 class="card__title" style="color:#7c3aed;">Just Starting</h3>
        <p class="card__desc">New to UPSC? Understand the exam, build your foundation, begin subject-wise study.</p>
        <span style="font-size:var(--text-xs); color:var(--color-accent); margin-top:var(--space-3); display:block; font-weight:var(--font-semibold);">12-month plan &rarr;</span>
      </a>

      <a href="/prelims/" class="card" style="text-decoration:none; border-top:3px solid var(--color-accent);">
        <div style="font-size:1.6rem; margin-bottom:var(--space-3);">🎯</div>
        <h3 class="card__title" style="color:var(--color-accent);">Prelims Prep</h3>
        <p class="card__desc">Know the basics? Subject-wise quizzes, mock tests, PYQ practice, and fact revision.</p>
        <span style="font-size:var(--text-xs); color:var(--color-accent); margin-top:var(--space-3); display:block; font-weight:var(--font-semibold);">Start practicing &rarr;</span>
      </a>

      <a href="/mains/" class="card" style="text-decoration:none; border-top:3px solid var(--color-brand);">
        <div style="font-size:1.6rem; margin-bottom:var(--space-3);">✍️</div>
        <h3 class="card__title" style="color:var(--color-brand);">Mains & Essay</h3>
        <p class="card__desc">Deep analytical notes, answer frameworks, GS paper-wise study, essay practice.</p>
        <span style="font-size:var(--text-xs); color:var(--color-accent); margin-top:var(--space-3); display:block; font-weight:var(--font-semibold);">Deepen your prep &rarr;</span>
      </a>

      <a href="/interview/" class="card" style="text-decoration:none; border-top:3px solid #0e7490;">
        <div style="font-size:1.6rem; margin-bottom:var(--space-3);">🎤</div>
        <h3 class="card__title" style="color:#0e7490;">Interview Ready</h3>
        <p class="card__desc">Build opinions, prepare DAF-based questions, stay sharp on current affairs.</p>
        <span style="font-size:var(--text-xs); color:var(--color-accent); margin-top:var(--space-3); display:block; font-weight:var(--font-semibold);">Prepare for panel &rarr;</span>
      </a>
    </div>
  </div>
</section>

<!-- Subjects Grid -->
<section style="padding:var(--space-16) 0; background:var(--color-bg-alt);">
  <div class="container">
    <h2 class="section-title" style="text-align:center; margin-bottom:var(--space-2);">Browse by Subject</h2>
    <p class="section-subtitle" style="text-align:center; margin-bottom:var(--space-8);">Each subject has Foundation, Prelims & Mains depth levels. Study at your pace.</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:var(--space-5);">
      {% for subj in subjects %}
      <a href="/subjects/{{ subj.slug }}/" class="card" style="text-decoration:none; border-left:3px solid {{ subj.color }};">
        <div style="display:flex; align-items:center; gap:var(--space-3); margin-bottom:var(--space-3);">
          <span style="font-size:1.4rem;">{{ subj.icon }}</span>
          <h3 style="font-family:var(--font-heading); font-size:var(--text-lg); color:{{ subj.color }};">{{ subj.name }}</h3>
        </div>
        <p class="card__desc">{{ subj.description }}</p>
        <div style="margin-top:var(--space-3);">
          {% for paper in subj.gs_papers %}
          <span class="gs-badge gs-badge--{{ paper }}">{{ paper | upper }}</span>
          {% endfor %}
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

