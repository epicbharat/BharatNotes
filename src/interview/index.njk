        { q: "Is One Nation One Election feasible and desirable?", subject: "polity" },
        { q: "Should India aim for a permanent UNSC seat or reform the UN?", subject: "international-relations" },
        { q: "Is the Indian judiciary overstepping its role?", subject: "polity" },
