.si-link { display: flex; align-items: flex-start; gap: var(--space-2); padding: var(--space-3) var(--space-3); border-radius: var(--radius-md); border: 1px solid transparent; text-decoration: none; color: var(--color-text); font-size: var(--text-sm); line-height: 1.4; transition: all 0.12s; }
.si-link:hover { border-color: var(--color-brand); background: var(--color-brand-pale, #f0fdf4); color: var(--color-brand); }
.si-link__num { font-size: var(--text-xs); font-weight: 700; color: var(--color-text-muted); min-width: 20px; flex-shrink: 0; padding-top: 1px; }

/* Other sections */
