---
layout: base.njk
title: "Mains Answer Practice"
description: "Practice UPSC Mains GS answer writing — topic-wise prompts with word limits, marks allocation, and approach hints."
---

<section class="page-header">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      Mains Practice
    </nav>
    <p class="page-header__eyebrow">Write Better Answers</p>
    <h1 class="page-header__title">Mains Answer Practice</h1>
    <p class="page-header__subtitle">Daily practice prompts for GS answer writing. Pick a paper, pick a topic, write your answer in 150/250 words.</p>
  </div>
</section>

<section style="padding:var(--space-8) 0;">
  <div class="container">

    <!-- Filter tabs -->
    <div style="display:flex; gap:var(--space-2); margin-bottom:var(--space-6); flex-wrap:wrap;">
      <button class="btn btn--accent btn--sm paper-filter active" data-paper="all">All Papers</button>
      <button class="btn btn--ghost btn--sm paper-filter" data-paper="gs1">GS1</button>
      <button class="btn btn--ghost btn--sm paper-filter" data-paper="gs2">GS2</button>
      <button class="btn btn--ghost btn--sm paper-filter" data-paper="gs3">GS3</button>
      <button class="btn btn--ghost btn--sm paper-filter" data-paper="gs4">GS4</button>
    </div>

    <div id="prompts-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(340px, 1fr)); gap:var(--space-5);">

      {% for key, paper in syllabus %}
      {% for section in paper.sections %}
      {% for topic in section.topics %}
      <div class="card prompt-card" data-paper="{{ paper.slug }}">
        <div style="display:flex; align-items:center; gap:var(--space-2); margin-bottom:var(--space-3);">
          <span class="gs-badge gs-badge--{{ paper.slug }}">{{ paper.slug | upper }}</span>
          <span style="font-size:var(--text-xs); color:var(--color-text-muted);">{{ section.title }}</span>
        </div>
        <h3 class="card__title" style="font-size:var(--text-base);">{{ topic }}</h3>
        <div style="margin-top:var(--space-3); display:flex; gap:var(--space-2);">
          <span style="font-size:var(--text-xs); background:var(--color-bg); padding:2px 8px; border-radius:var(--radius-full); color:var(--color-text-muted);">250 words</span>
          <span style="font-size:var(--text-xs); background:var(--color-bg); padding:2px 8px; border-radius:var(--radius-full); color:var(--color-text-muted);">15 marks</span>
        </div>
        <div style="margin-top:var(--space-3);">
          <a href="/{{ paper.slug }}/{{ topic | slugify }}/" style="font-size:var(--text-sm); color:var(--color-brand-light);">Read notes &rarr;</a>
        </div>
      </div>
      {% endfor %}
      {% endfor %}
      {% endfor %}

    </div>
  </div>
</section>

<script>
document.querySelectorAll('.paper-filter').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.paper-filter').forEach(b => {
      b.classList.remove('active');
      b.className = b.className.replace('btn--accent', 'btn--ghost');
    });
    btn.classList.add('active');
    btn.className = btn.className.replace('btn--ghost', 'btn--accent');

    const paper = btn.dataset.paper;
    document.querySelectorAll('.prompt-card').forEach(card => {
      card.style.display = (paper === 'all' || card.dataset.paper === paper) ? '' : 'none';
    });
  });
});
</script>
