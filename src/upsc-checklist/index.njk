  // ── localStorage ──
  var KEY = 'bharatnotes_upsc_checklist';
  function getState() {
    try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch(e) { return {}; }
  }
  function saveState(st) { localStorage.setItem(KEY, JSON.stringify(st)); }

  var state = getState();

  // ── Build total topic count ──
  var totalTopics = 0;
  SYLLABUS.forEach(function(paper) {
    paper.sections.forEach(function(sec) { totalTopics += sec.topics.length; });
  });

  // ── Populate filter dropdown ──
  var filterEl = document.getElementById('ck-filter');
  SYLLABUS.forEach(function(paper) {
    var opt = document.createElement('option');
    opt.value = paper.id;
    opt.textContent = paper.title.split('—')[0].trim();
    filterEl.appendChild(opt);
  });

  // ── Render checklist ──
  var listEl = document.getElementById('ck-list');

  function renderAll() {
    var search = (document.getElementById('ck-search').value || '').toLowerCase();
    var filterPaper = filterEl.value;
    var filterStatus = document.getElementById('ck-status').value;
    var html = '';

    SYLLABUS.forEach(function(paper) {
      if (filterPaper !== 'all' && paper.id !== filterPaper) return;

      var paperTopics = 0, paperDone = 0;
      paper.sections.forEach(function(sec) {
        sec.topics.forEach(function(t) {
          paperTopics++;
          if (state[paper.id + '/' + sec.name + '/' + t]) paperDone++;
        });
      });
      var paperPct = paperTopics ? Math.round((paperDone / paperTopics) * 100) : 0;

      html += '<div class="syl-card" style="--syl-color:' + paper.color + '; margin-bottom:var(--space-5);">';
      html += '<div class="syl-card__head">';
      html += '<div style="flex:1;"><h3 class="syl-card__title" style="font-size:var(--text-sm);">' + paper.title + '</h3>';
      html += '<span class="syl-card__count">' + paperDone + ' / ' + paperTopics + ' done (' + paperPct + '%)</span></div></div>';
      html += '<div style="padding:0 var(--space-4) var(--space-2);"><div style="background:var(--color-border);border-radius:99px;height:6px;overflow:hidden;">';
      html += '<div style="background:' + paper.color + ';height:100%;width:' + paperPct + '%;border-radius:99px;transition:width 0.3s;"></div></div></div>';

      paper.sections.forEach(function(sec) {
        var secHasVisible = false;
        var secHtml = '';

        sec.topics.forEach(function(topic, ti) {
          var tid = paper.id + '/' + sec.name + '/' + topic;
          var done = !!state[tid];

          if (filterStatus === 'done' && !done) return;
          if (filterStatus === 'pending' && done) return;
          if (search && topic.toLowerCase().indexOf(search) === -1 && sec.name.toLowerCase().indexOf(search) === -1) return;

          secHasVisible = true;
          secHtml += '<label class="syllabus-label' + (done ? ' syllabus-label--done' : '') + '">';
          secHtml += '<input type="checkbox" data-tid="' + tid.replace(/"/g, '&quot;') + '"' + (done ? ' checked' : '') + '>';
          secHtml += '<span class="syllabus-label__text">' + topic + '</span></label>';
        });

        if (secHasVisible) {
          html += '<div style="padding:var(--space-2) var(--space-4) var(--space-3);">';
          html += '<p style="font-size:var(--text-xs); font-weight:700; color:' + paper.color + '; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:var(--space-2);">' + sec.name + '</p>';
          html += secHtml + '</div>';
        }
      });

      html += '</div>';
    });

    listEl.innerHTML = html || '<p style="text-align:center; color:var(--color-text-muted); padding:var(--space-8);">No topics match your filters.</p>';
    updateStats();
  }

  function updateStats() {
    var done = 0;
    SYLLABUS.forEach(function(paper) {
      paper.sections.forEach(function(sec) {
        sec.topics.forEach(function(t) {
          if (state[paper.id + '/' + sec.name + '/' + t]) done++;
        });
      });
    });
    var pct = totalTopics ? Math.round((done / totalTopics) * 100) : 0;
    document.getElementById('ck-pct').textContent = pct + '%';
    document.getElementById('ck-done').textContent = done;
    document.getElementById('ck-total').textContent = totalTopics;
    document.getElementById('ck-left').textContent = totalTopics - done;
    document.getElementById('ck-bar').style.width = pct + '%';
  }

  // ── Event: checkbox toggle ──
  listEl.addEventListener('change', function(e) {
    if (e.target.type !== 'checkbox') return;
    var tid = e.target.dataset.tid;
    if (e.target.checked) {
      state[tid] = 1;
    } else {
      delete state[tid];
    }
    saveState(state);
    var label = e.target.closest('.syllabus-label');
    if (label) label.classList.toggle('syllabus-label--done', e.target.checked);
    renderAll();
  });

  // ── Event: search and filters ──
  document.getElementById('ck-search').addEventListener('input', renderAll);
  filterEl.addEventListener('change', renderAll);
  document.getElementById('ck-status').addEventListener('change', renderAll);

  // ── Event: reset ──
  document.getElementById('ck-reset').addEventListener('click', function() {
    if (confirm('Reset ALL checklist progress? This cannot be undone.')) {
      state = {};
      saveState(state);
      renderAll();
    }
  });

  // ── Initial render ──
  renderAll();
})();
</script>
