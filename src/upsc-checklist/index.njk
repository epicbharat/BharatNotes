  var KEY = 'bharatnotes_upsc_checklist';
  function getState() { try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch(e) { return {}; } }
  function saveState(s) { localStorage.setItem(KEY, JSON.stringify(s)); }
  var state = getState();

  var totalTopics = 0;
  SYLLABUS.forEach(function(p) { p.sections.forEach(function(s) { totalTopics += s.topics.length; }); });

  var CIRC = 2 * Math.PI * 42; // 263.89

  // ── Paper mini cards ──
  var gridEl = document.getElementById('ck-paper-grid');
  function renderPaperCards() {
    var html = '';
    SYLLABUS.forEach(function(paper) {
      var t = 0, d = 0;
      paper.sections.forEach(function(s) { s.topics.forEach(function(tp) { t++; if (state[paper.id+'/'+s.name+'/'+tp]) d++; }); });
      var pct = t ? Math.round(d/t*100) : 0;
      html += '<div class="ck-paper-card" style="--ck-color:'+paper.color+';" data-paper="'+paper.id+'">';
      html += '<p class="ck-paper-card__title">'+paper.short+'</p>';
      html += '<div class="ck-paper-card__bar"><div class="ck-paper-card__fill" style="width:'+pct+'%;background:'+paper.color+';"></div></div>';
      html += '<div class="ck-paper-card__meta"><span>'+d+'/'+t+'</span><span style="font-weight:700;color:'+paper.color+';">'+pct+'%</span></div>';
      html += '</div>';
    });
    gridEl.innerHTML = html;
  }

  // ── Progress ring ──
  function updateRing() {
    var d = 0;
    SYLLABUS.forEach(function(p) { p.sections.forEach(function(s) { s.topics.forEach(function(t) { if (state[p.id+'/'+s.name+'/'+t]) d++; }); }); });
    var pct = totalTopics ? Math.round(d/totalTopics*100) : 0;
    var offset = CIRC - (pct/100)*CIRC;
    document.getElementById('ck-ring').setAttribute('stroke-dashoffset', offset);
    document.getElementById('ck-ring-pct').textContent = pct+'%';
    document.getElementById('ck-ring-sub').textContent = d+' / '+totalTopics;
    document.getElementById('ck-hero-label').textContent = d+' of '+totalTopics+' topics completed';
    var left = totalTopics - d;
    document.getElementById('ck-hero-sub').textContent = left > 0 ? left+' remaining — keep going!' : 'All topics covered! Revision time.';
  }

  // ── Stage tabs ──
  var activeStage = 'all';
  document.getElementById('ck-stage-tabs').addEventListener('click', function(e) {
    var tab = e.target.closest('.ck-stage-tab');
    if (!tab) return;
    activeStage = tab.dataset.stage;
    document.querySelectorAll('.ck-stage-tab').forEach(function(t) { t.classList.toggle('active', t === tab); });
    renderChecklist();
  });

  // ── Paper card click → filter ──
  gridEl.addEventListener('click', function(e) {
    var card = e.target.closest('.ck-paper-card');
    if (!card) return;
    var pid = card.dataset.paper;
    var paper = SYLLABUS.find(function(p) { return p.id === pid; });
    if (paper) {
      activeStage = paper.stage;
      document.querySelectorAll('.ck-stage-tab').forEach(function(t) { t.classList.toggle('active', t.dataset.stage === activeStage); });
      renderChecklist();
      // Scroll to that paper section
      var el = document.querySelector('[data-section-paper="'+pid+'"]');
      if (el) el.scrollIntoView({ behavior:'smooth', block:'start' });
    }
  });

  // ── Render checklist ──
  var listEl = document.getElementById('ck-list');
  function renderChecklist() {
    var search = (document.getElementById('ck-search').value||'').toLowerCase();
    var statusF = document.getElementById('ck-status').value;
    var html = '';

    SYLLABUS.forEach(function(paper) {
      if (activeStage !== 'all' && paper.stage !== activeStage) return;

      var pt = 0, pd = 0;
      paper.sections.forEach(function(s) { s.topics.forEach(function(t) { pt++; if (state[paper.id+'/'+s.name+'/'+t]) pd++; }); });
      var ppct = pt ? Math.round(pd/pt*100) : 0;

      var sectionsHtml = '';
      var hasAny = false;

      paper.sections.forEach(function(sec, si) {
        var topicsHtml = '';
        var st = 0, sd = 0;

        sec.topics.forEach(function(topic) {
          var tid = paper.id+'/'+sec.name+'/'+topic;
          var done = !!state[tid];
          st++; if (done) sd++;

          if (statusF === 'done' && !done) return;
          if (statusF === 'pending' && done) return;
          if (search && topic.toLowerCase().indexOf(search) === -1 && sec.name.toLowerCase().indexOf(search) === -1) return;

          topicsHtml += '<label class="ck-topic'+(done?' ck-topic--done':'')+'" style="--ck-color:'+paper.color+';">';
          topicsHtml += '<input type="checkbox" data-tid="'+tid.replace(/"/g,'&quot;')+'"'+(done?' checked':'')+'>';
          topicsHtml += '<span>'+topic+'</span></label>';
        });

        if (!topicsHtml) return;
        hasAny = true;
        var spct = st ? Math.round(sd/st*100) : 0;

        sectionsHtml += '<div class="ck-section" data-section-id="'+paper.id+'-'+si+'">';
        sectionsHtml += '<div class="ck-section__head" data-toggle="'+paper.id+'-'+si+'">';
        sectionsHtml += '<div class="ck-section__color" style="background:'+paper.color+';"></div>';
        sectionsHtml += '<div class="ck-section__info"><p class="ck-section__title">'+sec.name+'</p>';
        sectionsHtml += '<span class="ck-section__count">'+sd+' / '+st+'</span></div>';
        sectionsHtml += '<span class="ck-section__pct" style="color:'+paper.color+';">'+spct+'%</span>';
        sectionsHtml += '<span class="ck-section__arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span>';
        sectionsHtml += '</div>';
        sectionsHtml += '<div class="ck-section__body">'+topicsHtml+'</div></div>';
      });

      if (!hasAny) return;

      html += '<div style="margin-bottom:var(--space-6);" data-section-paper="'+paper.id+'">';
      html += '<div style="display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-3);">';
      html += '<div style="width:6px;height:6px;border-radius:50%;background:'+paper.color+';flex-shrink:0;"></div>';
      html += '<h3 style="font-size:var(--text-sm);font-weight:700;color:'+paper.color+';margin:0;flex:1;">'+paper.title+'</h3>';
      html += '<span style="font-size:var(--text-xs);font-weight:700;color:'+paper.color+';">'+ppct+'%</span></div>';
      html += sectionsHtml + '</div>';
    });

    listEl.innerHTML = html || '<p style="text-align:center;color:var(--color-text-muted);padding:var(--space-8);">No topics match your filters.</p>';
  }

  function updateAll() { updateRing(); renderPaperCards(); renderChecklist(); }

  // ── Accordion toggle ──
  listEl.addEventListener('click', function(e) {
    var head = e.target.closest('.ck-section__head');
    if (!head) return;
    var body = head.nextElementSibling;
    var arrow = head.querySelector('.ck-section__arrow');
    body.classList.toggle('open');
    if (arrow) arrow.classList.toggle('open');
  });

  // ── Checkbox toggle ──
  listEl.addEventListener('change', function(e) {
    if (e.target.type !== 'checkbox') return;
    var tid = e.target.dataset.tid;
    if (e.target.checked) state[tid] = 1; else delete state[tid];
    saveState(state);
    var label = e.target.closest('.ck-topic');
    if (label) label.classList.toggle('ck-topic--done', e.target.checked);
    updateRing(); renderPaperCards();
    // Update section counts without full re-render
    var section = e.target.closest('.ck-section');
    if (section) {
      var checks = section.querySelectorAll('input[type="checkbox"]');
      var total = checks.length, done = 0;
      checks.forEach(function(c) { if (c.checked) done++; });
      var pct = total ? Math.round(done/total*100) : 0;
      var countEl = section.querySelector('.ck-section__count');
      var pctEl = section.querySelector('.ck-section__pct');
      if (countEl) countEl.textContent = done+' / '+total;
      if (pctEl) pctEl.textContent = pct+'%';
    }
  });

  // ── Search & status filter ──
  var searchTimer;
  document.getElementById('ck-search').addEventListener('input', function() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(renderChecklist, 200);
  });
  document.getElementById('ck-status').addEventListener('change', renderChecklist);

  // ── Bulk actions ──
  document.getElementById('ck-mark-visible').addEventListener('click', function() {
    var boxes = listEl.querySelectorAll('input[type="checkbox"]:not(:checked)');
    boxes.forEach(function(cb) { cb.checked = true; state[cb.dataset.tid] = 1; });
    saveState(state); updateAll();
  });
  document.getElementById('ck-clear-visible').addEventListener('click', function() {
    var boxes = listEl.querySelectorAll('input[type="checkbox"]:checked');
    boxes.forEach(function(cb) { cb.checked = false; delete state[cb.dataset.tid]; });
    saveState(state); updateAll();
  });

  // ── Export ──
  document.getElementById('ck-export').addEventListener('click', function() {
    var blob = new Blob([JSON.stringify(state, null, 2)], { type:'application/json' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'bharatnotes-upsc-checklist.json';
    a.click(); URL.revokeObjectURL(a.href);
  });

  // ── Import ──
  document.getElementById('ck-import-btn').addEventListener('click', function() {
    document.getElementById('ck-import-file').click();
  });
  document.getElementById('ck-import-file').addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(ev) {
      try {
        var imported = JSON.parse(ev.target.result);
        Object.keys(imported).forEach(function(k) { state[k] = imported[k]; });
        saveState(state); updateAll();
        alert('Progress imported successfully!');
      } catch(err) { alert('Invalid file format.'); }
    };
    reader.readAsText(file);
    e.target.value = '';
  });

  // ── Reset ──
  document.getElementById('ck-reset').addEventListener('click', function() {
    if (confirm('Reset ALL checklist progress? This cannot be undone.')) {
      state = {}; saveState(state); updateAll();
    }
  });

  // ── Initial render ──
  updateAll();
  // Auto-expand first section of first visible paper
  var firstBody = listEl.querySelector('.ck-section__body');
  var firstArrow = listEl.querySelector('.ck-section__arrow');
  if (firstBody) { firstBody.classList.add('open'); if (firstArrow) firstArrow.classList.add('open'); }
})();
</script>
