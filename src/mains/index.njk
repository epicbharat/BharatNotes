<script>
document.querySelectorAll('.mn-subj__head').forEach(function(h){
  h.addEventListener('click',function(){
    var id=h.dataset.t;var body=document.getElementById(id);var arrow=h.querySelector('.mn-subj__arrow');
    if(body)body.classList.toggle('open');if(arrow)arrow.classList.toggle('open');
  });
});
// Auto-expand first in each paper
document.querySelectorAll('.mn-paper').forEach(function(p){
  var first=p.querySelector('.mn-subj__body');var arrow=p.querySelector('.mn-subj__arrow');
  if(first){first.classList.add('open');if(arrow)arrow.classList.add('open');}
});
</script>
