---
layout: base.njk
title: "Contact | BharatNotes"
description: "Get in touch with the BharatNotes team — feedback, suggestions, content corrections or collaborations."
---

<style>
.contact-hero {
  background: linear-gradient(135deg, #0a1a0f 0%, #0f2d1a 60%, #0f4c3a 100%);
  padding: var(--space-12) 0 var(--space-10);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.contact-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 60%, rgba(212,160,23,.08) 0%, transparent 65%);
  pointer-events: none;
}
.contact-hero__inner { position: relative; z-index: 1; }
.contact-hero__kicker {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--color-accent-light);
  border: 1px solid rgba(212,160,23,.3);
  background: rgba(212,160,23,.1);
  border-radius: 100px;
  padding: 4px 12px;
  margin-bottom: var(--space-4);
}
.contact-hero h1 {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  color: #fff;
  margin: 0 0 var(--space-3);
  line-height: 1.2;
}
.contact-hero h1 em { color: var(--color-accent-light); font-style: italic; }
.contact-hero p {
  color: rgba(255,255,255,.6);
  font-size: var(--text-sm);
  max-width: 500px;
  margin: 0 auto;
}

/* ── Body ─────────────────────────────────────────────────── */
.contact-body {
  background: var(--color-bg);
  padding: var(--space-10) 0 var(--space-16);
}
.contact-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: var(--space-8);
  max-width: 900px;
  margin: 0 auto;
}

/* ── Form card ────────────────────────────────────────────── */
.contact-form-card {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 20px;
  padding: var(--space-6) var(--space-7);
  box-shadow: 0 2px 16px rgba(0,0,0,.05);
}
.contact-form-card h2 {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  margin: 0 0 var(--space-5);
  color: var(--color-text);
}
.cf-row { margin-bottom: var(--space-4); }
.cf-label {
  display: block;
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--color-text-muted);
  margin-bottom: 6px;
}
.cf-input, .cf-select, .cf-textarea {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid #e5e7eb;
  border-radius: 10px;
  font-size: var(--text-sm);
  font-family: var(--font-body);
  color: var(--color-text);
  background: #fafafa;
  box-sizing: border-box;
  transition: border-color .15s, background .15s;
}
.cf-input:focus, .cf-select:focus, .cf-textarea:focus {
  outline: none;
  border-color: var(--color-primary);
  background: #fff;
}
.cf-textarea { min-height: 140px; resize: vertical; line-height: 1.6; }
.cf-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
.cf-submit {
  width: 100%;
  padding: 13px;
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-size: var(--text-sm);
  font-weight: 700;
  cursor: pointer;
  transition: background .15s;
  margin-top: var(--space-2);
}
.cf-submit:hover { background: #0a3d2c; }
.cf-submit:disabled { background: #9ca3af; cursor: not-allowed; }
.cf-success {
  display: none;
  text-align: center;
  padding: var(--space-8);
}
.cf-success__icon {
  width: 56px; height: 56px;
  background: #dcfce7;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto var(--space-4);
  font-size: 1.5rem;
}
.cf-success h3 { font-family: var(--font-heading); font-size: 1.3rem; margin: 0 0 var(--space-2); }
.cf-success p { font-size: var(--text-sm); color: var(--color-text-muted); }
.cf-error {
  display: none;
  margin-top: var(--space-3);
  padding: 10px 14px;
  background: #fef2f2;
  border-radius: 10px;
  font-size: var(--text-sm);
  color: #dc2626;
}

/* ── Info sidebar ─────────────────────────────────────────── */
.contact-info { display: flex; flex-direction: column; gap: var(--space-4); }
.contact-info-card {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  padding: var(--space-5);
}
.contact-info-card h3 {
  font-size: var(--text-sm);
  font-weight: 700;
  margin: 0 0 var(--space-3);
  color: var(--color-text);
}
.contact-info-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-bottom: var(--space-2);
  line-height: 1.5;
}
.contact-info-item svg { flex-shrink: 0; margin-top: 1px; color: var(--color-primary); }
.contact-tg-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: var(--space-2);
  padding: 7px 14px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: 10px;
  font-size: var(--text-xs);
  font-weight: 700;
  color: #1d4ed8;
  text-decoration: none;
}
.contact-tg-badge:hover { background: #dbeafe; }

@media (max-width: 768px) {
  .contact-layout { grid-template-columns: 1fr; }
  .cf-row-2 { grid-template-columns: 1fr; }
  .contact-form-card { padding: var(--space-5); }
}
</style>

<section class="contact-hero">
  <div class="container">
    <div class="contact-hero__inner">
      <span class="contact-hero__kicker">✉️ Get in Touch</span>
      <h1>Contact <em>BharatNotes</em></h1>
      <p>Feedback, corrections, suggestions or collaborations — we read every message.</p>
    </div>
  </div>
</section>

<section class="contact-body">
  <div class="container">
    <div class="contact-layout">

      <!-- Form -->
      <div class="contact-form-card">
        <h2>Send a Message</h2>
        <form id="contact-form" novalidate>
          <div class="cf-row-2">
            <div class="cf-row">
              <label class="cf-label" for="cf-name">Your Name *</label>
              <input class="cf-input" id="cf-name" type="text" placeholder="Bharat Choudhary" required autocomplete="name">
            </div>
            <div class="cf-row">
              <label class="cf-label" for="cf-email">Email Address *</label>
              <input class="cf-input" id="cf-email" type="email" placeholder="you@example.com" required autocomplete="email">
            </div>
          </div>
          <div class="cf-row">
            <label class="cf-label" for="cf-subject">Subject</label>
            <select class="cf-select" id="cf-subject">
              <option value="General Enquiry">General Enquiry</option>
              <option value="Content Correction">Content Correction / Error Report</option>
              <option value="Suggestion">Feature / Content Suggestion</option>
              <option value="Collaboration">Collaboration / Partnership</option>
              <option value="Technical Issue">Technical Issue</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="cf-row">
            <label class="cf-label" for="cf-message">Message *</label>
            <textarea class="cf-textarea" id="cf-message" placeholder="Write your message here…" required></textarea>
          </div>
          <button class="cf-submit" type="submit" id="cf-submit-btn">Send Message →</button>
          <div class="cf-error" id="cf-error"></div>
        </form>
        <div class="cf-success" id="cf-success">
          <div class="cf-success__icon">✓</div>
          <h3>Message Sent!</h3>
          <p>We've received your message and will get back to you soon. Thank you for reaching out.</p>
        </div>
      </div>

      <!-- Info sidebar -->
      <div class="contact-info">
        <div class="contact-info-card">
          <h3>When to reach out</h3>
          <div class="contact-info-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Found a factual error or outdated data in our notes</span>
          </div>
          <div class="contact-info-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>Suggestions for new topics, subjects or features</span>
          </div>
          <div class="contact-info-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Collaboration, content partnership or educational use</span>
          </div>
          <div class="contact-info-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span>Technical bugs or issues with the website</span>
          </div>
        </div>

        <div class="contact-info-card">
          <h3>Response time</h3>
          <p style="font-size:var(--text-xs);color:var(--color-text-muted);line-height:1.6;margin:0 0 var(--space-3);">We typically respond within <strong>24–48 hours</strong>. For urgent corrections, responses are usually faster.</p>
          <p style="font-size:var(--text-xs);color:var(--color-text-muted);line-height:1.6;margin:0;">BharatNotes is a solo project — we appreciate your patience.</p>
        </div>

        <div class="contact-info-card">
          <h3>Telegram channel</h3>
          <p style="font-size:var(--text-xs);color:var(--color-text-muted);line-height:1.6;margin:0 0 var(--space-3);">Follow updates, new content alerts and current affairs integration on Telegram.</p>
          <a class="contact-tg-badge" href="https://t.me/bharatnotes_contact_bot" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.17 13.667l-2.95-.924c-.64-.203-.657-.64.136-.954l11.57-4.461c.537-.194 1.006.131.968.893z"/></svg>
            @bharatnotes_contact_bot
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function(){
  var RELAY_URL = 'https://contact-relay.epicbharat.workers.dev';

  document.getElementById('contact-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var btn   = document.getElementById('cf-submit-btn');
    var errEl = document.getElementById('cf-error');
    var name    = document.getElementById('cf-name').value.trim();
    var email   = document.getElementById('cf-email').value.trim();
    var subject = document.getElementById('cf-subject').value;
    var message = document.getElementById('cf-message').value.trim();

    errEl.style.display = 'none';
    if (!name || !email || !message) {
      errEl.textContent = 'Please fill in all required fields.';
      errEl.style.display = 'block';
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errEl.textContent = 'Please enter a valid email address.';
      errEl.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';

    fetch(RELAY_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, subject, message })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (data.error) throw new Error(data.error);
      document.getElementById('contact-form').style.display = 'none';
      document.getElementById('cf-success').style.display = 'block';
    })
    .catch(function(err){
      errEl.textContent = 'Failed to send: ' + err.message + '. Please try again.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send Message →';
    });
  });
})();
</script>
