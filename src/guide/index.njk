<script>
/* Highlight active TOC item on scroll */
(function(){
  var sections = document.querySelectorAll('.guide-section');
  var links    = document.querySelectorAll('.guide-toc__list a');
  if (!sections.length || !links.length) return;

  function setActive() {
    var scrollY = window.scrollY + 100;
    var active  = null;
    sections.forEach(function(s) {
      if (s.offsetTop <= scrollY) active = s.id;
    });
    links.forEach(function(a) {
      a.classList.toggle('active', a.getAttribute('href') === '#' + active);
    });
  }
  window.addEventListener('scroll', setActive, { passive: true });
  setActive();
})();

function guideShare() {
  var url  = 'https://bharatnotes.com/guide/';
  var text = 'How to use BharatNotes & Ujiyari for UPSC — the complete guide. Static notes + daily current affairs = everything UPSC demands.';
