        {q:"You have to dream before your dreams can come true.", a:"A.P.J. Abdul Kalam"},
        {q:"Great minds discuss ideas; average minds discuss events; small minds discuss people.", a:"Eleanor Roosevelt"},
        {q:"Injustice anywhere is a threat to justice everywhere.", a:"Martin Luther King Jr."}
      ];
      var today = new Date();
      var dayIndex = (today.getFullYear() * 366 + today.getMonth() * 31 + today.getDate()) % quotes.length;
      var q = quotes[dayIndex];
      document.getElementById('footer-quote').textContent = '"' + q.q + '"';
      document.getElementById('footer-quote-author').textContent = '— ' + q.a;
    })();
    </script>
  </div>
</footer>

