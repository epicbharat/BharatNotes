<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="language" content="en">
  <meta name="author" content="Bharat Choudhary">
  <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">

  {%- set pageTitle %}{% if title %}{{ title }} — UPSC Notes | BharatNotes{% else %}BharatNotes — Free UPSC & IAS Notes | Prelims to Interview{% endif %}{% endset -%}
  {%- set pageDesc -%}
    {%- if description -%}{{ description }}
    {%- elif syllabus_topic -%}{{ title }} — Free UPSC {{ syllabus_topic }} notes with PYQs, key concepts & exam strategy for IAS Prelims and Mains.
    {%- else -%}{{ site.description }}
    {%- endif -%}
  {%- endset -%}
  {%- set pageUrl = site.url + (page.url or '/') -%}

  <title>{{ pageTitle | safe }}</title>
  <meta name="description" content="{{ pageDesc | safe }}">
  <link rel="canonical" href="{{ pageUrl }}">
  {% if robotsMeta %}<meta name="robots" content="{{ robotsMeta }}">{% endif %}
  <link rel="alternate" hreflang="en-in" href="{{ pageUrl }}">
  <link rel="alternate" type="application/rss+xml" title="BharatNotes RSS" href="{{ site.url }}/feed.xml">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ pageTitle | safe }}">
  <meta property="og:description" content="{{ pageDesc | safe }}">
  <meta property="og:type" content="{% if layout == 'topic.njk' %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:site_name" content="BharatNotes — Free UPSC Notes">
  <meta property="og:locale" content="en_IN">
  <meta property="og:image" content="{{ site.url }}/images/logos/bharatnotes-og.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="BharatNotes — Free UPSC Civil Services Notes">
  {% if layout == 'topic.njk' %}
  <meta property="article:published_time" content="{{ date | isoDate }}">
  <meta property="article:author" content="https://www.linkedin.com/in/epicbharat/">
  <meta property="article:section" content="{{ syllabus_topic or subject }}">
  {% if tags %}{% for tag in tags %}<meta property="article:tag" content="{{ tag }}">
  {% endfor %}{% endif %}
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle | safe }}">
  <meta name="twitter:description" content="{{ pageDesc | safe }}">
  <meta name="twitter:image" content="{{ site.url }}/images/logos/bharatnotes-og.jpg">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "{% if layout == 'topic.njk' %}Article{% else %}WebSite{% endif %}",
    "name": "{{ title or site.shortName }}",
    "url": "{{ pageUrl }}",
    {% if layout == 'topic.njk' %}"headline": "{{ title }}",
    "datePublished": "{{ date | isoDate }}",
    "author": {"@type": "Person", "name": "Bharat Choudhary", "url": "https://www.linkedin.com/in/epicbharat/"},
    "publisher": {"@type": "Organization", "name": "{{ site.shortName }}", "url": "{{ site.url }}", "logo": {"@type": "ImageObject", "url": "{{ site.url }}/images/logos/bharatnotes-logo.png"}},
    {% endif %}"description": "{{ pageDesc | safe }}"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ site.shortName }}",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/images/logos/bharatnotes-logo.png",
    "founder": {"@type": "Person", "name": "Bharat Choudhary", "url": "https://www.linkedin.com/in/epicbharat/"},
    "description": "{{ site.description }}",
    "sameAs": ["https://ujiyari.com", "https://www.linkedin.com/in/epicbharat/"]
  }
  </script>
  {% if layout == 'topic.njk' %}
  {%- set _subjectName = subject -%}
  {%- for s in subjects -%}{%- if s.slug == subject -%}{%- set _subjectName = s.name -%}{%- endif -%}{%- endfor -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/"},
      {"@type": "ListItem", "position": 2, "name": "Subjects", "item": "{{ site.url }}/subjects/"},
      {"@type": "ListItem", "position": 3, "name": "{{ _subjectName }}", "item": "{{ site.url }}/subjects/{{ subject }}/"},
      {"@type": "ListItem", "position": 4, "name": "{{ title }}"}
    ]
  }
  </script>
  {% endif %}

  <!-- Favicon & PWA -->
  <link rel="icon" type="image/png" href="/images/logos/bharatnotes-logo.png">
  <link rel="apple-touch-icon" href="/images/logos/bharatnotes-logo.png">
  <meta name="theme-color" content="#1e293b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.json">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/main.css?v={{ site.buildTime }}">
</head>
<body>

<!-- Skip to main content (accessibility) -->
<a href="#main-content" class="skip-link">Skip to main content</a>

<!-- Header -->
<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <span role="img" aria-label="Books">📚</span>
        BharatNotes
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation menu" aria-expanded="false">&#9776;</button>
      <nav class="primary-nav" aria-label="Main navigation">
        <a href="/start-here/" class="primary-nav__link" {% if '/start-here/' in page.url %}aria-current="page"{% endif %}>Start Here</a>
        <a href="/subjects/" class="primary-nav__link" {% if '/subjects/' in page.url %}aria-current="page"{% endif %}>Subjects</a>
        <a href="/prelims/" class="primary-nav__link" {% if '/prelims/' in page.url %}aria-current="page"{% endif %}>Prelims</a>
        <a href="/mains/" class="primary-nav__link" {% if '/mains/' in page.url %}aria-current="page"{% endif %}>Mains</a>
        <a href="/pyq/" class="primary-nav__link" {% if '/pyq/' in page.url %}aria-current="page"{% endif %}>PYQ</a>
        <a href="/tracker/" class="primary-nav__link" {% if '/tracker/' in page.url %}aria-current="page"{% endif %}>Tracker</a>
        <div class="primary-nav__dropdown">
          <button class="primary-nav__link primary-nav__dropdown-toggle" aria-expanded="false" aria-haspopup="true">Resources <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align:-1px;margin-left:2px;"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="primary-nav__dropdown-menu" role="menu">
            <a href="/resources/" class="primary-nav__dropdown-item" role="menuitem">All Resources</a>
            <a href="/resources/vocab-builder/" class="primary-nav__dropdown-item" role="menuitem">📚 Vocab Builder</a>
            <a href="/resources/key-terms/" class="primary-nav__dropdown-item" role="menuitem">📖 Key Terms & Concepts</a>
            <a href="/upsc-checklist/" class="primary-nav__dropdown-item" role="menuitem">📋 UPSC Syllabus Checklist</a>
            <a href="/study-kit/" class="primary-nav__dropdown-item" role="menuitem">📦 UPSC Study Kit</a>
          </div>
        </div>
        <a href="https://ujiyari.com" class="primary-nav__link" target="_blank" rel="noopener" style="color:var(--color-accent-light);">Ujiyari ↗</a>
      </nav>
    </div>
  </div>
</header>

<main id="main-content">
  {{ content | safe }}
</main>

<!-- Footer -->
<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <div>
        <div style="font-family:var(--font-serif); font-size:var(--text-xl); font-weight:var(--font-bold); color:var(--color-white); margin-bottom:var(--space-3);">📚 {{ site.shortName }}</div>
        <p style="font-size:var(--text-sm);">{{ site.tagline }}</p>
        <p style="font-size:var(--text-xs); margin-top:var(--space-3);">A companion to <a href="https://ujiyari.com" style="color:var(--color-accent-light);">Ujiyari.com</a> — daily current affairs.</p>
      </div>
      <div class="footer-col">
        <h4>Study</h4>
        <a href="/subjects/" class="footer-link">Browse Subjects</a>
        <a href="/prelims/" class="footer-link">Prelims Practice</a>
        <a href="/mains/" class="footer-link">Mains Preparation</a>
        <a href="/interview/" class="footer-link">Interview Prep</a>
        <a href="/pyq/" class="footer-link">PYQ Analysis</a>
      </div>
      <div class="footer-col">
        <h4>Tools</h4>
        <a href="/start-here/" class="footer-link">Start Here</a>
        <a href="/study-plan/" class="footer-link">Study Plans</a>
        <a href="/tracker/" class="footer-link">Progress Tracker</a>
        <a href="/resources/" class="footer-link">Books & Resources</a>
        <a href="https://ujiyari.com/daily/" class="footer-link">Daily Current Affairs</a>
      </div>
      <div class="footer-col">
        <h4>About</h4>
        <a href="/about/" class="footer-link">About BharatNotes</a>
        <a href="/privacy/" class="footer-link">Privacy Policy</a>
        <a href="/disclaimer/" class="footer-link">Disclaimer</a>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:var(--space-4);padding:var(--space-5) 0;margin-top:var(--space-5);border-top:1px solid rgba(255,255,255,0.1);">
      <img src="https://media.licdn.com/dms/image/v2/D4D03AQH2KV4IqVcEtg/profile-displayphoto-shrink_200_200/profile-displayphoto-shrink_200_200/0/1719853762498?e=2147483647&v=beta&t=5rFYV-sO0cYIGMg8nqFSfG6WuC0S9Bka7cR2rLYHqK8" alt="Bharat Choudhary" style="width:48px;height:48px;border-radius:50%;border:2px solid rgba(255,255,255,0.2);flex-shrink:0;" loading="lazy">
      <div style="flex:1;">
        <p style="font-size:var(--text-sm);font-weight:600;color:#fff;margin:0;">Built by Bharat Choudhary</p>
        <p style="font-size:var(--text-xs);color:rgba(255,255,255,0.5);margin:2px 0 0;">
          <a href="https://www.linkedin.com/in/epicbharat/" target="_blank" rel="noopener" style="color:var(--color-accent-light);text-decoration:none;">LinkedIn &rarr;</a>
        </p>
      </div>
    </div>
    <div class="footer-copy">
      <p>&copy; {{ site.year }} BharatNotes by Bharat Choudhary. All rights reserved.</p>
    </div>
  </div>
</footer>

<!-- Go to Top -->
<button id="go-top" class="go-top" aria-label="Back to top" hidden>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
</button>

<script src="/js/nav.js" defer></script>
<script src="/js/bookmarks.js" defer></script>
<script src="/js/pdf.js" defer></script>
<script>
// Go to Top button
(function(){
  var btn = document.getElementById('go-top');
  if (!btn) return;
  var shown = false;
  window.addEventListener('scroll', function() {
    var shouldShow = window.scrollY > 400;
    if (shouldShow !== shown) {
      shown = shouldShow;
      btn.hidden = !shown;
      btn.classList.toggle('go-top--visible', shown);
    }
  }, { passive: true });
  btn.addEventListener('click', function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
</script>

<!-- Cookie Consent Banner -->
<div id="cookie-banner" class="cookie-banner" hidden>
  <div class="cookie-banner__inner">
    <p class="cookie-banner__text">We use cookies for ads (Google AdSense) to keep BharatNotes free. No personal data is collected by us. <a href="/privacy/">Learn more</a></p>
    <div class="cookie-banner__actions">
      <button id="cookie-accept" class="btn btn--accent btn--sm">Accept</button>
      <button id="cookie-reject" class="btn btn--ghost btn--sm">Reject</button>
    </div>
  </div>
</div>
<script>
// Cookie consent — geo-aware: banner only for GDPR/LGPD regions (EU, UK, Brazil, etc.)
// Indian users (~95% of traffic) get AdSense immediately with zero friction.
(function(){
  var KEY = 'bharatnotes_cookie_consent';
  var banner = document.getElementById('cookie-banner');
  var consent = localStorage.getItem(KEY);

  // GDPR/LGPD timezones — covers EU, UK, EEA, Switzerland, Brazil
  var CONSENT_ZONES = [
    'Europe/', 'Atlantic/Reykjavik', 'Atlantic/Canary', 'Atlantic/Madeira',
    'Atlantic/Azores', 'Atlantic/Faroe', 'America/Sao_Paulo', 'America/Bahia',
    'America/Fortaleza', 'America/Recife', 'America/Belem', 'America/Manaus',
    'America/Cuiaba', 'America/Porto_Velho', 'America/Boa_Vista',
    'America/Campo_Grande', 'America/Araguaina', 'America/Maceio',
    'America/Noronha', 'America/Rio_Branco'
  ];

  function isConsentRegion() {
    try {
      var tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
      for (var i = 0; i < CONSENT_ZONES.length; i++) {
        if (tz.indexOf(CONSENT_ZONES[i]) === 0 || tz === CONSENT_ZONES[i]) return true;
      }
    } catch(e) {}
    return false;
  }

  function initAdUnits() {
    var ads = document.querySelectorAll('ins.adsbygoogle');
    for (var i = 0; i < ads.length; i++) {
      if (!ads[i].dataset.adsbygoogleStatus) {
        try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
      }
    }
  }

  function loadAdSense() {
    if (document.getElementById('adsense-script')) return;
    var s = document.createElement('script');
    s.id = 'adsense-script';
    s.async = true;
    s.crossOrigin = 'anonymous';
    s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9707179008545368';
    s.onload = function() { initAdUnits(); };
    document.head.appendChild(s);
  }

  function hideBanner() {
    banner.classList.remove('cookie-banner--visible');
    setTimeout(function() { banner.hidden = true; }, 350);
  }

  function showBanner() {
    banner.hidden = false;
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        banner.classList.add('cookie-banner--visible');
      });
    });
  }

  var needsConsent = isConsentRegion();

  if (!needsConsent) {
    // India, US, and most of the world — load AdSense immediately, no banner
    loadAdSense();
  } else if (consent === 'accepted') {
    loadAdSense();
  } else if (consent === 'rejected') {
    // GDPR user rejected — don't load ads, don't show banner again
  } else {
    // GDPR region, no prior choice — show banner, wait for consent
    showBanner();
  }

  document.getElementById('cookie-accept').addEventListener('click', function() {
    localStorage.setItem(KEY, 'accepted');
    hideBanner();
    loadAdSense();
  });

  document.getElementById('cookie-reject').addEventListener('click', function() {
    localStorage.setItem(KEY, 'rejected');
    hideBanner();
  });
})();
</script>

<!-- Copy attribution -->
<script>
document.addEventListener('copy', function(e) {
  var sel = window.getSelection();
  if (!sel || sel.toString().length < 40) return;
  var text = sel.toString();
  var source = '\n\n— Source: BharatNotes.com (' + window.location.href + ')';
  if (e.clipboardData) {
    e.clipboardData.setData('text/plain', text + source);
    e.clipboardData.setData('text/html', sel.getRangeAt(0).cloneContents().textContent + '<br><br><small>— Source: <a href="' + window.location.href + '">BharatNotes.com</a></small>');
    e.preventDefault();
  }
});
</script>
</body>
</html>
