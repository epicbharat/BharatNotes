---
layout: base.njk
---


{# Collect all NCERT chapters for this book (if book_slug set) or all books for a class #}
{%- set isBookPage = book_slug and ncert_class -%}
{%- set isClassPage = ncert_class and not book_slug -%}

{%- if isBookPage -%}
  {%- set bookChapters = [] -%}
  {%- for item in collections.all -%}
    {%- if item.data.book_slug == book_slug and item.data.ncert_class == ncert_class and item.data.chapter -%}
      {%- set bookChapters = (bookChapters.push(item), bookChapters) -%}
    {%- endif -%}
  {%- endfor -%}
  {%- set bookChapters = bookChapters | sort(false, false, "data.chapter") -%}
{%- endif -%}

{# Book page #}
{%- if isBookPage -%}

<header class="ncert-header">
  <div class="container">
    <nav class="breadcrumb" style="margin-bottom:var(--space-4);">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      <a href="/ncert/">NCERT</a><span class="breadcrumb__sep">/</span>
      <a href="/ncert/class-{{ ncert_class }}/">Class {{ ncert_class }}</a><span class="breadcrumb__sep">/</span>
      {{ title }}
    </nav>
    <div class="ncert-class-badge">
      📚 Class {{ ncert_class }} · {{ subject_area }}
    </div>
    <h1>{{ title }}</h1>
    {% if description %}<p class="ncert-header__subtitle">{{ description }}</p>{% endif %}
    <div class="ncert-book-tag">
      <span>📖</span> {{ bookChapters.length }} Chapters
    </div>
  </div>
</header>

<section style="padding:var(--space-3) 0 var(--space-8);">
  <div class="container">
    <div class="layout-with-sidebar">
      <div>
        {% if content | trim %}
        <article class="article-body" style="margin-bottom:var(--space-8);">{{ content | safe }}</article>
        {% endif %}

        <div class="card">
          <h2 style="font-family:var(--font-heading);font-size:var(--text-xl);color:var(--ncert-blue-dark);margin-bottom:var(--space-6);">Chapters</h2>
          {% if bookChapters.length %}
          <ul class="ncert-chapter-list">
            {% for ch in bookChapters %}
            <li class="ncert-chapter-list__item">
              <a href="{{ ch.url }}" class="ncert-chapter-list__link">
                <span class="ncert-chapter-list__num">{{ ch.data.chapter | string | padStart(2,"0") }}</span>
                <span class="ncert-chapter-list__title">{{ ch.data.title }}</span>
                <span class="ncert-chapter-list__arrow">→</span>
              </a>
            </li>
            {% endfor %}
          </ul>
          {% else %}
          <p style="color:var(--color-text-muted);font-size:var(--text-sm);">Chapters coming soon.</p>
          {% endif %}
        </div>
      </div>

      <aside class="topic-sidebar">

        <!-- Author Profile -->
        <div class="ncert-author-card">
          <div class="ncert-author-card__header">
            <img class="ncert-author-card__photo" src="/img/bharat-choudhary.png" alt="Bharat Choudhary" loading="lazy">
            <div>
              <div class="ncert-author-card__name">Bharat Choudhary</div>
              <div class="ncert-author-card__role">UPSC Educator &amp; Content Creator</div>
            </div>
          </div>
          <div class="ncert-author-card__sites">
            <a href="https://bharatnotes.com" class="ncert-author-card__site" target="_blank" rel="noopener">
              <div class="ncert-author-card__site-badge ncert-author-card__site-badge--bn">B</div>
              <span class="ncert-author-card__site-name">BharatNotes</span>
              <span class="ncert-author-card__site-desc">GS Notes</span>
            </a>
            <a href="https://ujiyari.com" class="ncert-author-card__site" target="_blank" rel="noopener">
              <div class="ncert-author-card__site-badge ncert-author-card__site-badge--uj">U</div>
              <span class="ncert-author-card__site-name">Ujiyari</span>
              <span class="ncert-author-card__site-desc">Current Affairs</span>
            </a>
          </div>
        </div>

        <!-- Book Info -->
        <div class="ncert-book-info-card">
          <div class="ncert-book-info-card__label">📚 Book Info</div>
          <div class="ncert-book-info-card__item"><strong>Class</strong><span>Class {{ ncert_class }}</span></div>
          <div class="ncert-book-info-card__item"><strong>Subject</strong><span>{{ subject_area }}</span></div>
          {% if gs_papers %}
          <div class="ncert-book-info-card__item">
            <strong>GS Paper</strong>
            <span>{% for paper in gs_papers %}{{ paper | upper }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
          </div>
          {% endif %}
          <div class="ncert-book-info-card__item"><strong>Chapters</strong><span>{{ bookChapters.length }}</span></div>
        </div>

        <!-- Practice & Prepare -->
        <div class="card" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--color-brand);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:var(--space-3);">Practice &amp; Prepare</h4>
          {% if gs_subject_url %}
          <a href="{{ gs_subject_url }}" class="btn btn--accent btn--sm" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">🎯 GS Notes on This Subject</a>
          {% endif %}
          <a href="/ncert/class-{{ ncert_class }}/" class="btn btn--ghost btn--sm" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">← All Class {{ ncert_class }} Books</a>
          <a href="/ncert/" class="btn btn--ghost btn--sm" style="width:100%;justify-content:center;">📚 All NCERT Books</a>
        </div>

        <!-- Current Affairs -->
        <div class="card">
          <h4 style="color:var(--ncert-blue);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:var(--space-3);">📰 Current Affairs</h4>
          <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-3);">Link this book to live news</p>
          {% if subject_area %}
          <a href="https://ujiyari.com/search/?q={{ subject_area | urlencode }}" class="btn btn--accent btn--sm" target="_blank" rel="noopener" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">{{ subject_area }} News →</a>
          {% endif %}
          <a href="https://ujiyari.com/editorials/" class="btn btn--ghost btn--sm" target="_blank" rel="noopener" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">Editorial Analysis →</a>
          <a href="https://ujiyari.com/daily/" class="btn btn--ghost btn--sm" target="_blank" rel="noopener" style="width:100%;justify-content:center;">Daily Updates →</a>
        </div>

      </aside>
    </div>
  </div>
</section>

{# Class page — list of books #}
{%- elif isClassPage -%}

{%- set classBooks = [] -%}
{%- for item in collections.all -%}
  {%- if item.data.ncert_class == ncert_class and item.data.layout == "ncert-index.njk" and item.data.book_slug -%}
    {%- set classBooks = (classBooks.push(item), classBooks) -%}
  {%- endif -%}
{%- endfor -%}

<header class="ncert-header">
  <div class="container">
    <nav class="breadcrumb" style="margin-bottom:var(--space-4);">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      <a href="/ncert/">NCERT</a><span class="breadcrumb__sep">/</span>
      Class {{ ncert_class }}
    </nav>
    <div class="ncert-class-badge">NCERT · Class {{ ncert_class }}</div>
    <h1>{{ title }}</h1>
    {% if description %}<p class="ncert-header__subtitle">{{ description }}</p>{% endif %}
  </div>
</header>

<section style="padding:var(--space-10) 0;">
  <div class="container">
    {% if content | trim %}
    <article class="article-body" style="margin-bottom:var(--space-8);">{{ content | safe }}</article>
    {% endif %}

    {% if classBooks.length %}
    <div class="ncert-book-grid">
      {% for book in classBooks %}
      <a href="{{ book.url }}" class="ncert-book-card">
        <div class="ncert-book-card__subject">{{ book.data.subject_area }}</div>
        <div class="ncert-book-card__title">{{ book.data.title }}</div>
        {% if book.data.description %}
        <div style="font-size:var(--text-xs);color:var(--color-text-muted);line-height:var(--leading-relaxed);">{{ book.data.description | truncate(100) }}</div>
        {% endif %}
        <div class="ncert-book-card__chapters">Browse chapters →</div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p style="color:var(--color-text-muted);">Books coming soon.</p>
    {% endif %}
  </div>
</section>

{# Hub page — show all classes #}
{%- else -%}

{%- set allClasses = [6, 7, 8, 9, 10, 11, 12] -%}

<header class="ncert-hub-header">
  <div class="container">
    <div class="ncert-phase-badge">Class VI · VII · VIII · IX · X · XI · XII</div>
    <h1>{{ title }}</h1>
    <p>{{ description }}</p>
  </div>
</header>

<section style="padding:var(--space-10) 0;">
  <div class="container">
    {% if content | trim %}
    <article class="article-body" style="margin-bottom:var(--space-8);">{{ content | safe }}</article>
    {% endif %}

    {# Dynamic class cards #}
    <div class="ncert-book-grid" style="grid-template-columns:repeat(auto-fill,minmax(240px,1fr));margin-top:var(--space-6);">
      {%- for cls in allClasses -%}
      {%- set classBooks = [] -%}
      {%- for item in collections.all -%}
        {%- if item.data.ncert_class == cls and item.data.layout == "ncert-index.njk" and item.data.book_slug -%}
          {%- set classBooks = (classBooks.push(item), classBooks) -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if classBooks.length -%}
      <a href="/ncert/class-{{ cls }}/" class="ncert-book-card" style="text-decoration:none;">
        <div class="ncert-book-card__subject" style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;color:var(--ncert-blue);">NCERT</div>
        <div class="ncert-book-card__title" style="font-size:var(--text-xl);font-weight:700;margin:var(--space-2) 0;">Class {{ cls }}</div>
        <div style="font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-3);">{{ classBooks.length }} book{% if classBooks.length != 1 %}s{% endif %}</div>
        <div class="ncert-book-card__chapters">Browse books →</div>
      </a>
      {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- endif -%}
