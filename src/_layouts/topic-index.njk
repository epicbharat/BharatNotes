---
layout: base.njk
---

{%- set subjectData = null -%}
{%- for s in subjects -%}
  {%- if s.slug == subject -%}{%- set subjectData = s -%}{%- endif -%}
{%- endfor -%}

{# Collect chapters that point to this topic index #}
{%- set chapters = [] -%}
{%- for item in collections.all -%}
  {%- if item.data.parent_topic_url == page.url -%}
    {%- set chapters = (chapters.push(item), chapters) -%}
  {%- endif -%}
{%- endfor -%}

<section class="page-header">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      <a href="/subjects/">Subjects</a><span class="breadcrumb__sep">/</span>
      {% if subjectData %}<a href="/subjects/{{ subject }}/">{{ subjectData.name }}</a><span class="breadcrumb__sep">/</span>{% endif %}
      {{ title }}
    </nav>
    <div class="page-header__tags">
      {% if subjectData %}<span style="font-size:1.5rem;">{{ subjectData.icon }}</span>{% endif %}
      {% for paper in gs_papers %}
      <span class="gs-badge gs-badge--{{ paper }}">{{ paper | upper }}</span>
      {% endfor %}
    </div>
    {% if chapter %}<span style="font-size:var(--text-xs); font-weight:700; color:var(--color-accent); letter-spacing:0.06em; text-transform:uppercase;">Chapter {{ chapter | string | padStart(2, "0") }}</span>{% endif %}
    <h1 class="page-header__title">{{ title }}</h1>
    {% if description %}<p class="page-header__subtitle">{{ description }}</p>{% endif %}
  </div>
</section>

<section style="padding:var(--space-8) 0;">
  <div class="container">
    <div class="layout-with-sidebar">
      <div>
        <!-- Overview content from the index.md body -->
        {% if content | trim %}
        <article class="article-body" style="margin-bottom:var(--space-8);">
          {{ content | safe }}
        </article>
        {% endif %}

        <!-- Chapter listing -->
        <div style="margin-bottom:var(--space-8);">
          <h2 style="font-family:var(--font-serif); font-size:var(--text-xl); color:var(--color-brand-dark); margin-bottom:var(--space-5);">Chapters in {{ title }}</h2>
          <div style="display:grid; gap:var(--space-4);">
            {% for ch in chapters | sort(false, false, "data.sub_chapter") %}
            <a href="{{ ch.url }}" class="card chapter-card" style="text-decoration:none; display:block; padding:var(--space-4) var(--space-5); border-left:4px solid {{ subjectData.color if subjectData else 'var(--color-brand)' }}; transition:transform 0.15s ease, box-shadow 0.15s ease;">
              <div style="display:flex; align-items:baseline; gap:var(--space-3); margin-bottom:var(--space-1);">
                <span style="font-size:var(--text-xs); font-weight:700; color:{{ subjectData.color if subjectData else 'var(--color-accent)' }}; letter-spacing:0.06em; text-transform:uppercase; white-space:nowrap;">Ch {{ ch.data.sub_chapter | string | padStart(2, "0") }}</span>
                <h3 class="card__title" style="font-size:var(--text-base); margin:0;">{{ ch.data.title }}</h3>
              </div>
              {% if ch.data.description %}
              <p class="card__desc" style="margin:var(--space-1) 0 0 0; font-size:var(--text-sm);">{{ ch.data.description | truncate(120) }}</p>
              {% endif %}
              <div style="margin-top:var(--space-2); display:flex; gap:var(--space-2);">
                {% if ch.data.foundation %}<span style="font-size:0.6rem; background:#d1fae5; color:#065f46; padding:1px 6px; border-radius:var(--radius-full);">Foundation</span>{% endif %}
                {% if ch.data.prelims %}<span style="font-size:0.6rem; background:#fef3c7; color:#92400e; padding:1px 6px; border-radius:var(--radius-full);">Prelims</span>{% endif %}
                {% if ch.data.mains %}<span style="font-size:0.6rem; background:#dbeafe; color:#1e40af; padding:1px 6px; border-radius:var(--radius-full);">Mains</span>{% endif %}
              </div>
            </a>
            {% endfor %}
          </div>

          {% if chapters.length == 0 %}
          <div class="card" style="background:var(--color-bg); border:2px dashed var(--color-border);">
            <p style="color:var(--color-text-muted); font-size:var(--text-sm); text-align:center; padding:var(--space-4);">Chapters are being prepared. Check back soon!</p>
          </div>
          {% endif %}
        </div>

        <!-- In-article ad unit -->
        <div style="margin:var(--space-6) 0; text-align:center;">
          <ins class="adsbygoogle"
               style="display:block; text-align:center;"
               data-ad-layout="in-article"
               data-ad-format="fluid"
               data-ad-client="ca-pub-9707179008545368"
               data-ad-slot="4545617453"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="topic-sidebar">
        <!-- Topic Info -->
        <div class="card" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--color-brand); font-size:var(--text-xs); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:var(--space-3);">Topic Info</h4>
          {% if syllabus_topic %}
          <div style="font-size:var(--text-xs); color:var(--color-text-muted); margin-bottom:var(--space-2);">
            <strong>Syllabus:</strong> {{ syllabus_topic }}
          </div>
          {% endif %}
          {% if gs_papers %}
          <div style="font-size:var(--text-xs); color:var(--color-text-muted); margin-bottom:var(--space-2);">
            <strong>GS Paper:</strong>
            {% for paper in gs_papers %}{{ paper | upper }}{% if not loop.last %}, {% endif %}{% endfor %}
          </div>
          {% endif %}
          <div style="font-size:var(--text-xs); color:var(--color-text-muted); margin-bottom:var(--space-2);">
            <strong>Chapters:</strong> {{ chapters.length }}
          </div>
          <div style="font-size:var(--text-xs); color:var(--color-text-muted);">
            <strong>Depth:</strong>
            {% if foundation %}Foundation {% endif %}{% if prelims %}Prelims {% endif %}{% if mains %}Mains{% endif %}
          </div>
        </div>

        <!-- More in this subject -->
        {% if subjectData %}
        <div class="card" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--color-brand); font-size:var(--text-xs); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:var(--space-3);">More in {{ subjectData.name }}</h4>
          {% set siblings = collections.allTopics | selectattr("data.subject", "equalto", subject) | sort(false, false, "data.chapter") %}
          {% for sibling in siblings | limit(8) %}
          {% if sibling.url != page.url %}
          <a href="{{ sibling.url }}" style="display:block; font-size:var(--text-xs); padding:var(--space-1) 0; color:var(--color-text-muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ sibling.data.title }}</a>
          {% endif %}
          {% endfor %}
          <a href="/subjects/{{ subject }}/" style="display:block; font-size:var(--text-xs); padding:var(--space-2) 0; color:var(--color-brand-light); font-weight:var(--font-semibold);">View all →</a>
        </div>
        {% endif %}

        <!-- Current Affairs from Ujiyari -->
        <div class="card">
          <h4 style="color:var(--color-brand); font-size:var(--text-xs); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:var(--space-3);">Current Affairs</h4>
          <p style="font-size:var(--text-xs); color:var(--color-text-muted); margin-bottom:var(--space-3);">Link static concepts with live news from Ujiyari.com</p>
          <a href="https://ujiyari.com/subjects/{{ subject }}/" class="btn btn--accent btn--sm" target="_blank" style="width:100%; justify-content:center; margin-bottom:var(--space-2);">{{ subjectData.name if subjectData else 'Subject' }} News →</a>
          <a href="https://ujiyari.com/daily/" class="btn btn--ghost btn--sm" target="_blank" style="width:100%; justify-content:center;">Daily Updates →</a>
        </div>
      </aside>
    </div>
  </div>
</section>
