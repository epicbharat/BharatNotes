---
layout: base.njk
---

{%- set classLabel = "Class " + ncert_class -%}
{%- set chapterPad = chapter | string | padStart(2, "0") -%}

{# Collect sibling chapters in same book #}
{%- set bookChapters = [] -%}
{%- for item in collections.all -%}
  {%- if item.data.book_slug == book_slug and item.data.ncert_class == ncert_class and item.data.chapter -%}
    {%- set bookChapters = (bookChapters.push(item), bookChapters) -%}
  {%- endif -%}
{%- endfor -%}
{%- set bookChapters = bookChapters | sort(false, false, "data.chapter") -%}

{%- set prevCh = null -%}{%- set nextCh = null -%}{%- set foundSelf = false -%}
{%- for ch in bookChapters -%}
  {%- if ch.url == page.url -%}{%- set foundSelf = true -%}
  {%- elif not foundSelf -%}{%- set prevCh = ch -%}
  {%- elif foundSelf and not nextCh -%}{%- set nextCh = ch -%}
  {%- endif -%}
{%- endfor -%}

{# Build book index URL #}
{%- set bookIndexUrl = "/ncert/class-" + ncert_class + "/" + book_slug + "/" -%}

<!-- Page Header -->
<header class="ncert-header">
  <div class="container">
    <nav class="breadcrumb" style="margin-bottom:var(--space-5);">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      <a href="/ncert/">NCERT</a><span class="breadcrumb__sep">/</span>
      <a href="/ncert/class-{{ ncert_class }}/">{{ classLabel }}</a><span class="breadcrumb__sep">/</span>
      <a href="{{ bookIndexUrl }}">{{ book }}</a><span class="breadcrumb__sep">/</span>
      Ch {{ chapterPad }}
    </nav>

    <div class="ncert-header__meta">
      <div class="ncert-class-badge">📚 {{ classLabel }} · {{ subject_area }}</div>
      {% if gs_papers %}
      {% for paper in gs_papers %}
      <span class="ncert-gs-badge ncert-gs-badge--{{ paper }}">{{ paper | upper }}</span>
      {% endfor %}
      {% endif %}
    </div>

    <h1>{{ title }}</h1>
    {% if description %}<p class="ncert-header__subtitle">{{ description }}</p>{% endif %}
    <div class="page-header__actions">
      <button id="btn-download-pdf-hero" class="page-header__action-btn" onclick="document.getElementById('btn-download-pdf') && document.getElementById('btn-download-pdf').click()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Save PDF
      </button>
    </div>
  </div>
</header>

<!-- Main Content -->
<section style="padding:var(--space-3) 0 var(--space-8);">
  <div class="container">
    <div class="layout-with-sidebar">
      <!-- Article -->
      <div>
        <!-- Mobile TOC -->
        <div class="toc-mobile" id="toc-mobile" hidden>
          <button class="toc-mobile__toggle" id="toc-mobile-toggle" aria-expanded="false">
            <span>In This Chapter</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <ul class="toc-list toc-mobile__list" id="toc-mobile-list" hidden></ul>
        </div>

        <article class="article-body ncert-article" data-pagefind-body>
          {{ content | safe }}
        </article>

        <!-- Chapter Navigation -->
        <nav class="chapter-nav">
          {% if prevCh %}
          <a href="{{ prevCh.url }}" class="chapter-nav__link">
            <span class="chapter-nav__arrow">←</span>
            <div>
              <span class="chapter-nav__label">Previous Chapter</span>
              <span class="chapter-nav__title">{{ prevCh.data.title | truncate(60, true) }}</span>
            </div>
          </a>
          {% else %}
          <a href="{{ bookIndexUrl }}" class="chapter-nav__link">
            <span class="chapter-nav__arrow">←</span>
            <div>
              <span class="chapter-nav__label">Back to</span>
              <span class="chapter-nav__title">{{ book }}</span>
            </div>
          </a>
          {% endif %}
          {% if nextCh %}
          <a href="{{ nextCh.url }}" class="chapter-nav__link chapter-nav__link--next">
            <div>
              <span class="chapter-nav__label">Next Chapter</span>
              <span class="chapter-nav__title">{{ nextCh.data.title | truncate(60, true) }}</span>
            </div>
            <span class="chapter-nav__arrow">→</span>
          </a>
          {% else %}
          <a href="{{ bookIndexUrl }}" class="chapter-nav__link chapter-nav__link--next">
            <div>
              <span class="chapter-nav__label">Back to</span>
              <span class="chapter-nav__title">{{ book }}</span>
            </div>
            <span class="chapter-nav__arrow">→</span>
          </a>
          {% endif %}
        </nav>
      </div>

      <!-- Sidebar -->
      <aside class="topic-sidebar">

        <!-- Author Profile -->
        <div class="ncert-author-card">
          <div class="ncert-author-card__header">
            <img class="ncert-author-card__photo" src="/img/bharat-choudhary.png" alt="Bharat Choudhary" loading="lazy">
            <div>
              <div class="ncert-author-card__name">Bharat Choudhary</div>
              <div class="ncert-author-card__role">UPSC Educator &amp; Content Creator</div>
            </div>
          </div>
          <div class="ncert-author-card__sites">
            <a href="https://bharatnotes.com" class="ncert-author-card__site" target="_blank" rel="noopener">
              <div class="ncert-author-card__site-badge ncert-author-card__site-badge--bn">B</div>
              <span class="ncert-author-card__site-name">BharatNotes</span>
              <span class="ncert-author-card__site-desc">GS Notes</span>
            </a>
            <a href="https://ujiyari.com" class="ncert-author-card__site" target="_blank" rel="noopener">
              <div class="ncert-author-card__site-badge ncert-author-card__site-badge--uj">U</div>
              <span class="ncert-author-card__site-name">Ujiyari</span>
              <span class="ncert-author-card__site-desc">Current Affairs</span>
            </a>
          </div>
        </div>

        <!-- Save as PDF -->
        <div class="card" style="margin-bottom:var(--space-5);">
          <button id="btn-download-pdf" class="btn btn--primary" style="width:100%;justify-content:center;gap:8px;min-height:48px;font-size:var(--text-sm);border-radius:10px;touch-action:manipulation;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download PDF
          </button>
          <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-2);text-align:center;">Clean, ad-free PDF · longer pages may take a few seconds</p>
        </div>

        <!-- Chapter Info -->
        <div class="ncert-book-info-card">
          <div class="ncert-book-info-card__label">📚 Chapter Info</div>
          <div class="ncert-book-info-card__item">
            <strong>Class</strong><span>{{ classLabel }}</span>
          </div>
          <div class="ncert-book-info-card__item">
            <strong>Book</strong><span title="{{ book }}">{{ book }}</span>
          </div>
          <div class="ncert-book-info-card__item">
            <strong>Subject</strong><span>{{ subject_area }}</span>
          </div>
          <div class="ncert-book-info-card__item">
            <strong>Chapter</strong><span>{{ chapterPad }}</span>
          </div>
          {% if gs_papers %}
          <div class="ncert-book-info-card__item">
            <strong>GS Paper</strong><span>{% for paper in gs_papers %}{{ paper | upper }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
          </div>
          {% endif %}
        </div>

        <!-- TOC Sidebar -->
        <nav class="toc-card card ncert-toc" id="toc-sidebar" aria-label="Table of contents" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--ncert-blue);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:var(--space-3);">In This Chapter</h4>
          <ul class="toc-list" id="toc-list"></ul>
        </nav>

        <!-- Study Tools -->
        <div class="card" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--ncert-blue);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:var(--space-3);">Practice & Prepare</h4>
          {% if gs_subject_url %}
          <a href="{{ gs_subject_url }}" class="btn btn--accent btn--sm" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">🎯 GS Notes on This Topic</a>
          {% endif %}
          <a href="/prelims/" class="btn btn--ghost btn--sm" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">📋 Prelims Practice</a>
          <a href="/mains/" class="btn btn--ghost btn--sm" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">✍️ Mains Practice</a>
          <a href="/pyq/" class="btn btn--ghost btn--sm" style="width:100%;justify-content:center;">📝 PYQ Analysis</a>
        </div>

        <!-- Chapters in this Book -->
        {% if bookChapters.length > 1 %}
        <div class="card" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--ncert-blue);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:var(--space-3);">{{ book }}</h4>
          {% for ch in bookChapters %}
          {% if ch.url == page.url %}
          <span style="display:block;font-size:var(--text-xs);padding:var(--space-1) 0;color:var(--ncert-blue);font-weight:var(--font-semibold);">→ Ch {{ ch.data.chapter | string | padStart(2,"0") }}. {{ ch.data.title | truncate(45, true) }}</span>
          {% else %}
          <a href="{{ ch.url }}" style="display:block;font-size:var(--text-xs);padding:var(--space-1) 0;color:var(--color-text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Ch {{ ch.data.chapter | string | padStart(2,"0") }}. {{ ch.data.title | truncate(45, true) }}</a>
          {% endif %}
          {% endfor %}
          <a href="{{ bookIndexUrl }}" style="display:block;font-size:var(--text-xs);padding:var(--space-2) 0;color:var(--ncert-blue);font-weight:var(--font-semibold);">← Back to book index</a>
        </div>
        {% endif %}

        <!-- Current Affairs -->
        <div class="card">
          <h4 style="color:var(--ncert-blue);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:var(--space-3);">📰 Current Affairs</h4>
          <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-3);">Link this chapter to live news</p>
          {% if subject_area %}
          <a href="https://ujiyari.com/search/?q={{ subject_area | urlencode }}" class="btn btn--accent btn--sm" target="_blank" rel="noopener" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">{{ subject_area }} News →</a>
          {% endif %}
          <a href="https://ujiyari.com/editorials/" class="btn btn--ghost btn--sm" target="_blank" rel="noopener" style="width:100%;justify-content:center;margin-bottom:var(--space-2);">Editorial Analysis →</a>
          <a href="https://ujiyari.com/daily/" class="btn btn--ghost btn--sm" target="_blank" rel="noopener" style="width:100%;justify-content:center;">Daily Updates →</a>
        </div>

      </aside>
    </div>
  </div>
</section>

<script>
(function() {
  var article = document.querySelector('.ncert-article');
  if (!article) return;

  /* ── Wrap tables ── */
  var tables = article.querySelectorAll('table');
  for (var t = 0; t < tables.length; t++) {
    var wrap = document.createElement('div');
    wrap.className = 'table-scroll';
    tables[t].parentNode.insertBefore(wrap, tables[t]);
    wrap.appendChild(tables[t]);
  }

  /* ── Table Scroll Indicators ── */
  article.querySelectorAll('.table-scroll').forEach(function(tw) {
    function checkScroll() {
      tw.classList.toggle('ncert-table-scrolled', tw.scrollLeft + tw.clientWidth >= tw.scrollWidth - 4);
    }
    checkScroll();
    tw.addEventListener('scroll', checkScroll, { passive: true });
  });

  /* ── PART Dividers ── */
  article.querySelectorAll('h2').forEach(function(h2) {
    if (/^PART\s+\d/i.test(h2.textContent.trim())) {
      h2.classList.add('ncert-part-divider');
    }
  });

  /* ── Special Box Post-processor ──
     Detects h3 headings with box prefixes and wraps
     the heading + following content in styled box divs.
     Patterns:
       ### 💡 Explainer: Title   → .ncert-box--explainer
       ### 🔗 Beyond the Book: Title → .ncert-box--bridge
       ### 🎯 UPSC Connect: Title → .ncert-box--upsc
       ### 📌 Key Fact: Title     → .ncert-box--fact
  */
  var BOX_PATTERNS = [
    { re: /^(💡\s*Explainer|Explainer)[\s:]/i, cls: 'explainer' },
    { re: /^(🔗\s*Beyond the Book|Beyond the Book|Bridging Gap)[\s:]/i, cls: 'bridge' },
    { re: /^(🎯\s*UPSC Connect|UPSC Connect)[\s:]/i, cls: 'upsc' },
    { re: /^(📌\s*Key Fact|Key Fact)[\s:]/i, cls: 'fact' }
  ];

  var h3s = Array.from(article.querySelectorAll('h3'));
  h3s.forEach(function(h3) {
    var text = h3.textContent.trim();
    var matched = null;
    for (var i = 0; i < BOX_PATTERNS.length; i++) {
      if (BOX_PATTERNS[i].re.test(text)) { matched = BOX_PATTERNS[i]; break; }
    }
    if (!matched) return;

    /* Collect content nodes until next h2/h3/hr */
    var bodyNodes = [];
    var next = h3.nextElementSibling;
    while (next && next.tagName !== 'H2' && next.tagName !== 'H3' && next.tagName !== 'HR') {
      bodyNodes.push(next);
      next = next.nextElementSibling;
    }

    /* Build box */
    var box = document.createElement('div');
    box.className = 'ncert-box--' + matched.cls;

    var titleDiv = document.createElement('div');
    titleDiv.className = 'ncert-box__title';
    var cleanTitle = text.replace(/^(💡|🔗|🎯|📌)\s*/u, '').replace(/^(Explainer|Beyond the Book|Bridging Gap|UPSC Connect|Key Fact)\s*:\s*/iu, '');
    titleDiv.textContent = cleanTitle || text;

    var bodyDiv = document.createElement('div');
    bodyDiv.className = 'ncert-box__body';
    bodyNodes.forEach(function(n) { bodyDiv.appendChild(n); });

    box.appendChild(titleDiv);
    box.appendChild(bodyDiv);

    h3.parentNode.insertBefore(box, h3);
    h3.remove();
  });

  /* ── TOC Builder ── */
  var tocList = document.getElementById('toc-list');
  var tocMobileList = document.getElementById('toc-mobile-list');
  var tocMobileWrap = document.getElementById('toc-mobile');
  var tocMobileToggle = document.getElementById('toc-mobile-toggle');

  if (!tocList) return;

  var headings = article.querySelectorAll('h2, h3');
  if (headings.length < 2) {
    var tocCard = document.getElementById('toc-sidebar');
    if (tocCard) tocCard.hidden = true;
    return;
  }

  function truncToc(t, max) {
    max = max || 52;
    return t.length > max ? t.slice(0, max - 1).replace(/\s+\S*$/, '') + '\u2026' : t;
  }
  function toTitleCase(s) {
    return s.toLowerCase().replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  var tocHtml = '';
  headings.forEach(function(h, idx) {
    var id = h.id || ('ncert-h-' + idx);
    h.id = id;
    var isH3 = h.tagName === 'H3';
    var text = h.textContent.trim();
    var isPart = /^PART\s+\d/i.test(text);

    var liClass, aClass, displayText;
    if (isPart) {
      liClass = 'toc-item toc-item--part';
      aClass = 'toc-link toc-link--part';
      var m = text.match(/^PART\s+(\d+)[:\s\u2014\-]+(.+)/i);
      displayText = m
        ? 'Part ' + m[1] + '\u2002\u00b7\u2002' + truncToc(toTitleCase(m[2].trim()), 24)
        : truncToc(text, 28);
    } else if (!isH3) {
      liClass = 'toc-item toc-item--h2';
      aClass = 'toc-link';
      displayText = truncToc(text, 52);
    } else {
      liClass = 'toc-item toc-item--h3';
      aClass = 'toc-link';
      displayText = truncToc(text, 48);
    }

    tocHtml += '<li class="' + liClass + '"><a href="#' + id + '" class="' + aClass + '">' + displayText + '</a></li>';
  });
  tocList.innerHTML = tocHtml;
  if (tocMobileList) tocMobileList.innerHTML = tocHtml;

  if (tocMobileWrap) {
    tocMobileWrap.hidden = false;
    tocMobileToggle && tocMobileToggle.addEventListener('click', function() {
      var expanded = tocMobileToggle.getAttribute('aria-expanded') === 'true';
      tocMobileToggle.setAttribute('aria-expanded', String(!expanded));
      tocMobileList.hidden = expanded;
    });
  }

  /* ── TOC Scroll Spy ── */
  if ('IntersectionObserver' in window) {
    var activeTocLink = null;
    var spy = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var link = tocList.querySelector('a[href="#' + entry.target.id + '"]');
          if (link && link !== activeTocLink) {
            if (activeTocLink) activeTocLink.classList.remove('toc-active');
            link.classList.add('toc-active');
            activeTocLink = link;
          }
        }
      });
    }, { rootMargin: '-10% 0px -80% 0px', threshold: 0 });
    article.querySelectorAll('h2[id], h3[id]').forEach(function(h) { spy.observe(h); });
  }
})();
</script>
