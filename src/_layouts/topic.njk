---
layout: base.njk
---

{%- set subjectData = null -%}
{%- for s in subjects -%}
  {%- if s.slug == subject -%}{%- set subjectData = s -%}{%- endif -%}
{%- endfor -%}

<!-- Quiz mode top bar (hidden in article mode via CSS) -->
<div class="quiz-mode-bar">
  <a href="/quiz/" class="quiz-mode-bar__back">← Quiz Hub</a>
  <span class="quiz-mode-bar__title">🎯 Practice Mode</span>
  <a href="{{ page.url }}" class="quiz-mode-bar__hub">Exit to Article →</a>
</div>

<section class="page-header page-header--topic">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      <a href="/subjects/">Subjects</a><span class="breadcrumb__sep">/</span>
      {% if subjectData %}<a href="/subjects/{{ subject }}/">{{ subjectData.name }}</a><span class="breadcrumb__sep">/</span>{% endif %}
      {% if parent_topic_url %}<a href="{{ parent_topic_url }}">{{ parent_topic }}</a><span class="breadcrumb__sep">/</span>{% endif %}
      {{ title }}
    </nav>
    <div class="page-header__tags">
      {% if subjectData %}<span style="font-size:1.5rem;">{{ subjectData.icon }}</span>{% endif %}
      {% for paper in gs_papers %}
      <span class="gs-badge gs-badge--{{ paper }}">{{ paper | upper }}</span>
      {% endfor %}
    </div>
    {% if chapter %}<span style="font-size:var(--text-xs); font-weight:700; color:var(--color-accent); letter-spacing:0.06em; text-transform:uppercase;">Chapter {{ chapter | string | padStart(2, "0") }}</span>{% endif %}
    <h1 class="page-header__title">{{ title }}</h1>
    {% if description %}<p class="page-header__subtitle">{{ description }}</p>{% endif %}
    <div class="page-header__actions">
      <button id="btn-download-pdf-hero" class="page-header__action-btn" onclick="document.getElementById('btn-download-pdf') && document.getElementById('btn-download-pdf').click()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Save PDF
      </button>
      <button id="btn-bookmark-hero" class="page-header__action-btn page-header__action-btn--bookmark">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        Bookmark
      </button>
    </div>
  </div>
</section>

<!-- Sticky tab sub-nav: own band between header and content -->
<div class="topic-subnav">
  <div class="container">
    <nav class="topic-tabs" aria-label="Jump to section">
      {% if foundation %}
      <button class="topic-tab active" data-tab="foundation">🌱 Foundation</button>
      {% endif %}
      {% if prelims %}
      <button class="topic-tab" data-tab="prelims">🎯 Prelims</button>
      {% endif %}
      {% if mains %}
      <button class="topic-tab" data-tab="mains">✍️ Mains</button>
      {% endif %}
    </nav>
  </div>
</div>

<section style="padding:var(--space-6) 0 var(--space-12);">
  <div class="container">

    <div class="layout-with-sidebar">
      <!-- Single flowing article -->
      <div>
        <!-- Mobile TOC (collapsible, shown only on small screens) -->
        <div class="toc-mobile" id="toc-mobile" hidden>
          <button class="toc-mobile__toggle" id="toc-mobile-toggle" aria-expanded="false">
            <span>In This Article</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <ol class="toc-list toc-mobile__list" id="toc-mobile-list" hidden></ol>
        </div>
        <article class="article-body" data-pagefind-body>
          {{ content | safe }}
        </article>

        <!-- In-article ad unit (initialized by cookie consent script in base.njk) -->
        <div style="margin:var(--space-6) 0; text-align:center;">
          <ins class="adsbygoogle"
               style="display:block; text-align:center;"
               data-ad-layout="in-article"
               data-ad-format="fluid"
               data-ad-client="ca-pub-9707179008545368"
               data-ad-slot="4545617453"></ins>
        </div>

        {% if related_topics and related_topics.length %}
        <div class="related-topics">
          <h4 class="related-topics__heading">📌 Related Topics Across GS Papers</h4>
          <div class="related-topics__grid">
            {%- for rt in related_topics %}
            <a href="{{ rt.url }}" class="related-topics__link">
              <span class="related-topics__title">{{ rt.title }}</span>
              {% if rt.subject %}<span class="related-topics__subject">{{ rt.subject }}</span>{% endif %}
            </a>
            {%- endfor %}
          </div>
        </div>
        {% endif %}

        {% if parent_topic_url %}
        {# Prev / Next chapter navigation #}
        {%- set chapterSiblings = [] -%}
        {%- for item in collections.all -%}
          {%- if item.data.parent_topic_url == parent_topic_url -%}
            {%- set chapterSiblings = (chapterSiblings.push(item), chapterSiblings) -%}
          {%- endif -%}
        {%- endfor -%}
        {%- set chapterSiblings = chapterSiblings | sort(false, false, "data.sub_chapter") -%}
        {%- set prevCh = null -%}{%- set nextCh = null -%}{%- set foundSelf = false -%}
        {%- for ch in chapterSiblings -%}
          {%- if ch.url == page.url -%}{%- set foundSelf = true -%}
          {%- elif not foundSelf -%}{%- set prevCh = ch -%}
          {%- elif foundSelf and not nextCh -%}{%- set nextCh = ch -%}
          {%- endif -%}
        {%- endfor -%}

        <nav class="chapter-nav">
          {% if prevCh %}
          <a href="{{ prevCh.url }}" class="chapter-nav__link">
            <span class="chapter-nav__arrow">←</span>
            <div>
              <span class="chapter-nav__label">Previous Chapter</span>
              <span class="chapter-nav__title">{{ prevCh.data.title | truncate(60, true) }}</span>
            </div>
          </a>
          {% else %}
          <a href="{{ parent_topic_url }}" class="chapter-nav__link">
            <span class="chapter-nav__arrow">←</span>
            <div>
              <span class="chapter-nav__label">Back to</span>
              <span class="chapter-nav__title">{{ parent_topic }}</span>
            </div>
          </a>
          {% endif %}
          {% if nextCh %}
          <a href="{{ nextCh.url }}" class="chapter-nav__link chapter-nav__link--next">
            <div>
              <span class="chapter-nav__label">Next Chapter</span>
              <span class="chapter-nav__title">{{ nextCh.data.title | truncate(60, true) }}</span>
            </div>
            <span class="chapter-nav__arrow">→</span>
          </a>
          {% else %}
          <a href="{{ parent_topic_url }}" class="chapter-nav__link chapter-nav__link--next">
            <div>
              <span class="chapter-nav__label">Back to</span>
              <span class="chapter-nav__title">{{ parent_topic }}</span>
            </div>
            <span class="chapter-nav__arrow">→</span>
          </a>
          {% endif %}
        </nav>
        {% endif %}
      </div>

      <!-- Sidebar -->
      <aside class="topic-sidebar">

        <!-- ── TOP ZONE: scrolls with page ─────────────── -->
        <div class="topic-sidebar__top">

        <!-- Section tabs — desktop only (mobile uses subnav band) -->
        <nav class="sidebar-tabs" aria-label="Jump to section">
          {% if foundation %}
          <button class="topic-tab sidebar-tab active" data-tab="foundation">🌱 Foundation</button>
          {% endif %}
          {% if prelims %}
          <button class="topic-tab sidebar-tab" data-tab="prelims">🎯 Prelims</button>
          {% endif %}
          {% if mains %}
          <button class="topic-tab sidebar-tab" data-tab="mains">✍️ Mains</button>
          {% endif %}
        </nav>

        <!-- Author Profile — top of sidebar for trust/attribution -->
        <div class="ncert-author-card">
          <div class="ncert-author-card__header">
            <img class="ncert-author-card__photo" src="/img/bharat-choudhary.png" alt="Bharat Choudhary" loading="lazy">
            <div>
              <div class="ncert-author-card__name">Bharat Choudhary</div>
              <div class="ncert-author-card__role">UPSC Educator &amp; Content Creator</div>
            </div>
          </div>
          <div class="ncert-author-card__sites">
            <a href="https://bharatnotes.com" class="ncert-author-card__site" target="_blank" rel="noopener">
              <div class="ncert-author-card__site-badge ncert-author-card__site-badge--bn">B</div>
              <span class="ncert-author-card__site-name">BharatNotes</span>
              <span class="ncert-author-card__site-desc">GS Notes</span>
            </a>
            <a href="https://ujiyari.com" class="ncert-author-card__site" target="_blank" rel="noopener">
              <div class="ncert-author-card__site-badge ncert-author-card__site-badge--uj">U</div>
              <span class="ncert-author-card__site-name">Ujiyari</span>
              <span class="ncert-author-card__site-desc">Current Affairs</span>
            </a>
          </div>
        </div>

        </div><!-- /topic-sidebar__top -->

        <!-- ── STICKY ZONE: sticks while reading ──────── -->
        <div class="topic-sidebar__sticky">

        <!-- Table of Contents -->
        <nav class="toc-card card" id="toc-sidebar" aria-label="Table of contents" style="margin-bottom:var(--space-5);">
          <h4 class="toc-card__heading">In This Article</h4>
          <ol class="toc-list" id="toc-list"></ol>
        </nav>

        <!-- Download PDF -->
        <div class="card" style="margin-bottom:var(--space-3);">
          <button id="btn-download-pdf" class="btn btn--primary" style="width:100%;justify-content:center;gap:8px;min-height:48px;font-size:var(--text-sm);border-radius:10px;touch-action:manipulation;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download PDF
          </button>
          <p style="font-size:var(--text-xs); color:var(--color-text-muted); margin-top:var(--space-2); text-align:center;">Print-ready · ink-optimised · longer pages may take a moment</p>
        </div>

        <!-- Bookmark — separate card, secondary action -->
        <div class="card" style="margin-bottom:var(--space-5);">
          <button id="btn-bookmark-sidebar" class="btn btn--ghost" style="width:100%;justify-content:center;gap:8px;min-height:44px;font-size:var(--text-sm);border-radius:10px;touch-action:manipulation;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            Bookmark this topic
          </button>
        </div>

        <!-- Topic Info -->
        <div class="card" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--color-brand); font-size:var(--text-xs); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:var(--space-3);">Topic Info</h4>
          {% if syllabus_topic %}
          <div style="font-size:var(--text-xs); color:var(--color-text-muted); margin-bottom:var(--space-2);">
            <strong>Syllabus:</strong> {{ syllabus_topic }}
          </div>
          {% endif %}
          {% if gs_papers %}
          <div style="font-size:var(--text-xs); color:var(--color-text-muted); margin-bottom:var(--space-2);">
            <strong>GS Paper:</strong>
            {% for paper in gs_papers %}{{ paper | upper }}{% if not loop.last %}, {% endif %}{% endfor %}
          </div>
          {% endif %}
          <div style="font-size:var(--text-xs); color:var(--color-text-muted);">
            <strong>Depth:</strong>
            {% if foundation %}Foundation {% endif %}{% if prelims %}Prelims {% endif %}{% if mains %}Mains{% endif %}
          </div>
        </div>

        <!-- Quick Actions — topic-specific -->
        <div class="card" style="margin-bottom:var(--space-5);">
          <h4 style="color:var(--color-brand); font-size:var(--text-xs); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:var(--space-3);">Practice & Prepare</h4>
          {% if prelims %}
          <a href="/prelims/" class="btn btn--accent btn--sm" style="width:100%; justify-content:center; margin-bottom:var(--space-2);"><span role="img" aria-label="Target">🎯</span> Prelims Practice</a>
          {% endif %}
          {% if mains %}
          <a href="/mains/" class="btn btn--ghost btn--sm" style="width:100%; justify-content:center; margin-bottom:var(--space-2);"><span role="img" aria-label="Writing">✍️</span> Mains Practice</a>
          {% endif %}
          <a href="/pyq/" class="btn btn--ghost btn--sm" style="width:100%; justify-content:center; margin-bottom:var(--space-2);"><span role="img" aria-label="Paper">📝</span> PYQ Analysis</a>
        </div>

        <!-- More in this subject -->
        {% if subjectData %}
        {% set siblings = collections.allTopics | selectattr("data.subject", "equalto", subject) | sort(false, false, "data.chapter") %}
        {% if siblings.length > 1 %}
        <div class="card sidebar-more-in">
          <div class="sidebar-more-in__head">
            <span class="sidebar-more-in__icon">{{ subjectData.icon }}</span>
            <span class="sidebar-more-in__label">More in {{ subjectData.name }}</span>
          </div>
          <ul class="sidebar-more-in__list">
            {% for sibling in siblings | limit(7) %}
            {% if sibling.url != page.url %}
            <li class="sidebar-more-in__item">
              {% if sibling.data.chapter %}<span class="sidebar-more-in__ch">{{ sibling.data.chapter | string | padStart(2, "0") }}</span>{% endif %}
              <a href="{{ sibling.url }}" class="sidebar-more-in__link">{{ sibling.data.title }}</a>
            </li>
            {% endif %}
            {% endfor %}
          </ul>
          <a href="/subjects/{{ subject }}/" class="sidebar-more-in__all">View all chapters →</a>
        </div>
        {% endif %}
        {% endif %}

        <!-- Current Affairs from Ujiyari -->
        <div class="card sidebar-ujiyari">
          <h4 class="sidebar-ujiyari__heading">Current Affairs</h4>
          <a href="https://ujiyari.com/subjects/{{ subject }}/" class="btn btn--accent btn--sm sidebar-ujiyari__primary" target="_blank">{{ subjectData.name if subjectData else 'Subject' }} News →</a>
          <div class="sidebar-ujiyari__secondary">
            <a href="https://ujiyari.com/editorials/" class="sidebar-ujiyari__link" target="_blank">Editorials →</a>
            <a href="https://ujiyari.com/daily/" class="sidebar-ujiyari__link" target="_blank">Daily Updates →</a>
          </div>
        </div>

        <!-- Read on Phone — QR code for current page -->
        <div class="sidebar-qr-card" id="sidebar-qr-card">
          <div class="sidebar-qr-card__qr" id="sidebar-qr-img"></div>
          <div class="sidebar-qr-card__meta">
            <span class="sidebar-qr-card__label">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><polyline points="12 18 12 18"/></svg>
              Read on Phone
            </span>
            <p class="sidebar-qr-card__hint">Scan to open on any device</p>
            <span class="sidebar-qr-card__url">bharatnotes.com</span>
          </div>
        </div>

        </div><!-- /topic-sidebar__sticky -->
      </aside>
    </div>
  </div>
</section>

<script>
(function() {
  /* ── Quiz mode: activated when ?mode=quiz is in the URL ── */
  window.__quizMode = new URLSearchParams(window.location.search).get('mode') === 'quiz';
  if (window.__quizMode) {
    document.documentElement.classList.add('quiz-mode');
  }

  /* ── Sidebar QR: generate for current page ── */
  (function() {
    var el = document.getElementById('sidebar-qr-img');
    if (!el) return;
    var url = window.location.href;
    var qrSrc = 'https://api.qrserver.com/v1/create-qr-code/?size=110x110&format=png&margin=8&data=' + encodeURIComponent(url);
    var link = document.createElement('a');
    link.href = url;
    link.title = 'Open this article';
    var img = document.createElement('img');
    img.src = qrSrc;
    img.width = 110; img.height = 110;
    img.alt = 'QR code for this article';
    img.onerror = function() { document.getElementById('sidebar-qr-card').style.display = 'none'; };
    link.appendChild(img);
    el.appendChild(link);
  })();

  /* ── Sticky subnav: add shadow when stuck ── */
  var subnav = document.querySelector('.topic-subnav');
  if (subnav) {
    var sentinel = document.createElement('div');
    sentinel.style.cssText = 'height:1px;pointer-events:none;';
    subnav.parentNode.insertBefore(sentinel, subnav);
    var tabObs = new IntersectionObserver(function(entries) {
      subnav.classList.toggle('is-stuck', !entries[0].isIntersecting);
    }, { threshold: 1.0 });
    tabObs.observe(sentinel);
  }

  var article = document.querySelector('.article-body');
  if (!article) return;

  /* Wrap tables: outer clips to border-radius, inner scrolls horizontally */
  var tables = article.querySelectorAll('table');
  for (var t = 0; t < tables.length; t++) {
    var outer = document.createElement('div');
    outer.className = 'table-scroll';
    var inner = document.createElement('div');
    inner.className = 'table-scroll-inner';
    tables[t].parentNode.insertBefore(outer, tables[t]);
    outer.appendChild(inner);
    inner.appendChild(tables[t]);
  }

  var chevronSvg = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>';
  var checkSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
  var crossSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
  var qCount = 0;

  /* ── Helper: strip Q number + year from question text (shown in badge) ── */
  function cleanQText(html) {
    // Strip patterns like: **Q1. (2017)**, **Q. (CSE Prelims 2017)**, Q1., Q.
    return html
      .replace(/^(<strong>)?Q\d*[\.\)]\s*/i, '')
      .replace(/^\((?:CSE\s+)?(?:Prelims|Mains)?\s*\d{4}\)\s*(<\/strong>)?\s*/i, '')
      .replace(/^(<\/strong>)?\s*/, '');
  }

  /* ── Helper: strip inline answer options (a) 1 only (b) 2 only... from text ── */
  function stripInlineOptions(html) {
    // Remove patterns like: (a) 1 only (b) 2 only (c) Both 1 and 2 (d) Neither
    return html.replace(/\s*\(a\)\s+.*$/i, '');
  }

  /* ── Helper: parse inline (a)(b)(c)(d) options from text ── */
  function extractInlineOptions(text) {
    var match = text.match(/\(a\)\s+(.+?)\s+\(b\)\s+(.+?)\s+\(c\)\s+(.+?)\s+\(d\)\s+(.+?)(?:\s*$|\s*\*)/i);
    if (match) return [match[1].trim(), match[2].trim(), match[3].trim(), match[4].trim()];
    return null;
  }

  /* ── Helper: find correct option from answer text when options are explicit ── */
  function parseCorrectFromAnswer(answerText, options) {
    var t = answerText.trim();
    // Match patterns like "(b)", "(b) --", "Answer: (b)"
    var match = t.match(/^\(?([a-d])\)?/i) || t.match(/:\s*\(?([a-d])\)?/i);
    if (match) return match[1].toLowerCase().charCodeAt(0) - 97; // a=0, b=1, c=2, d=3
    return -1;
  }

  /* ── Helper: generate UPSC answer options based on statement count ── */
  function generateOptions(n) {
    if (n === 2) return ['1 only', '2 only', 'Both 1 and 2', 'Neither 1 nor 2'];
    if (n === 3) return ['1 and 2 only', '2 and 3 only', '1 and 3 only', '1, 2 and 3'];
    if (n === 4) return ['1, 2 and 3 only', '1 and 4 only', '2, 3 and 4 only', '1, 2, 3 and 4'];
    return null;
  }

  /* ── Helper: parse answer text to find correct option index ── */
  function parseCorrectAnswer(answerText, numStatements) {
    var t = answerText.toLowerCase();
    var correct = [];

    // Detect "neither" / "none"
    if (/neither|none\s+(is|are)\s+correct/.test(t)) { correct = []; }
    // Detect "both" (2 statements)
    else if (/both.*correct/.test(t) && numStatements === 2) { correct = [1, 2]; }
    // Detect "all" correct
    else if (/all.*correct|all\s+three|all\s+four/.test(t)) {
      for (var i = 1; i <= numStatements; i++) correct.push(i);
    }
    // Detect specific patterns: "Statements 1 and 3 are correct" or "1 and 3"
    else {
      var match = t.match(/statements?\s+([\d,\s]+(?:and\s+\d+)?)\s+(?:is|are)\s+correct/);
      if (match) { var nums = match[1].match(/\d+/g); if (nums) correct = nums.map(Number); }
      // Check individual: "Statement 1 is correct"
      if (correct.length === 0) {
        for (var i = 1; i <= numStatements; i++) {
          if (new RegExp('statement\\s+' + i + '\\s+(?:is\\s+)?correct').test(t)) correct.push(i);
        }
      }
      // Fallback: check for "X is correct" without "statement" prefix
      if (correct.length === 0) {
        var nums = t.match(/(\d+)\s+(?:and\s+(\d+)\s+)?(?:is|are)\s+correct/);
        if (nums) {
          correct.push(parseInt(nums[1]));
          if (nums[2]) correct.push(parseInt(nums[2]));
        }
      }
    }

    correct.sort();
    // Map to option index
    if (numStatements === 2) {
      if (correct.length === 0) return 3;
      if (correct.length === 1 && correct[0] === 1) return 0;
      if (correct.length === 1 && correct[0] === 2) return 1;
      if (correct.length === 2) return 2;
    }
    if (numStatements === 3) {
      var key = correct.join(',');
      if (key === '1,2') return 0;
      if (key === '2,3') return 1;
      if (key === '1,3') return 2;
      if (key === '1,2,3') return 3;
    }
    if (numStatements === 4) {
      var key = correct.join(',');
      if (key === '1,2,3') return 0;
      if (key === '1,4') return 1;
      if (key === '2,3,4') return 2;
      if (key === '1,2,3,4') return 3;
    }
    return -1; // can't determine
  }

  // ── Style "Important for UPSC" as a highlighted card section ──
  var headings = article.querySelectorAll('h2');
  headings.forEach(function(h2) {
    var text = h2.textContent.trim().toLowerCase();

    // Wrap "Important for UPSC" in a styled card
    if (/important\s+for\s+upsc|upsc\s+relevance|exam\s+strategy/i.test(text)) {
      var wrapper = document.createElement('div');
      wrapper.className = 'section-card section-card--upsc';
      h2.parentNode.insertBefore(wrapper, h2);
      wrapper.appendChild(h2);
      var next = wrapper.nextElementSibling;
      while (next && next.tagName !== 'H2' && next.tagName !== 'HR') {
        var move = next;
        next = next.nextElementSibling;
        wrapper.appendChild(move);
      }
      if (next && next.tagName === 'HR') next.remove();
    }

    // PYQ section: inject "Practice Quiz" button in article mode; full interactive in quiz mode
    if (/previous\s+year\s+questions|pyq/i.test(text)) {
      if (!window.__quizMode) {
        // Article mode: add a Practice Quiz CTA button after the heading
        var quizUrl = window.location.pathname + '?mode=quiz';
        var ctaEl = document.createElement('a');
        ctaEl.href = quizUrl;
        ctaEl.className = 'pyq-quiz-cta';
        ctaEl.innerHTML = '<span>🎯</span><span>Practice these questions interactively</span><span class="pyq-quiz-cta__arrow">→</span>';
        h2.parentNode.insertBefore(ctaEl, h2.nextSibling);
        return;
      }
    }
    if (window.__quizMode && /previous\s+year\s+questions|pyq/i.test(text)) {
      var wrapper = document.createElement('div');
      wrapper.className = 'section-card section-card--pyq';
      h2.parentNode.insertBefore(wrapper, h2);
      wrapper.appendChild(h2);

      var nodes = [];
      var next = wrapper.nextElementSibling;
      while (next && next.tagName !== 'H2') {
        nodes.push(next);
        next = next.nextElementSibling;
      }
      if (next && next.tagName === 'HR') next.remove();

      var currentSection = '';
      var cardsHtml = '';

      nodes.forEach(function(node) {
        node.remove();
        var tag = node.tagName;
        var content = node.innerHTML || '';
        var textContent = node.textContent || '';

        if (tag === 'H3') {
          var t = textContent.trim().toLowerCase();
          if (t.indexOf('prelims') !== -1) currentSection = 'prelims';
          else if (t.indexOf('mains') !== -1) currentSection = 'mains';
          cardsHtml += '<h3 class="pyq-section-heading">' + node.innerHTML + '</h3>';
          return;
        }

        if (/^\*?\*?Q\d*[\.\)]\s|^<strong>Q\d*[\.\)]\s/i.test(content.trim())) {
          qCount++;
          var isMains = currentSection === 'mains';
          var cardClass = isMains ? 'pyq-card pyq-card--mains' : 'pyq-card';
          var yearMatch = textContent.match(/\b(19|20)\d{2}\b/);
          var yearText = yearMatch ? yearMatch[0] : '';
          var typeLabel = isMains ? 'Mains' : 'Prelims';
          var inlineOpts = extractInlineOptions(textContent);
          var cleanContent = cleanQText(content);
          if (inlineOpts) cleanContent = stripInlineOptions(cleanContent);
          var inlineAnswerSplit = cleanContent.split(/<strong>Answer:?<\/strong>\s*:?\s*/i);
          var answerHtml = '';
          if (inlineAnswerSplit.length > 1) {
            answerHtml = inlineAnswerSplit.slice(1).join('');
            cleanContent = inlineAnswerSplit[0];
          }
          cardsHtml += '<div class="' + cardClass + '" data-q="' + qCount + '" data-type="' + (isMains ? 'mains' : 'prelims') + '" data-year="' + yearText + '"';
          if (inlineOpts) cardsHtml += ' data-options="' + encodeURIComponent(JSON.stringify(inlineOpts)) + '"';
          cardsHtml += '>';
          cardsHtml += '<div class="pyq-meta"><span class="pyq-q-number">' + qCount + '</span><span class="pyq-year-badge">' + typeLabel + (yearText ? ' \u00B7 ' + yearText : '') + '</span></div>';
          cardsHtml += '<div class="pyq-question-text">' + cleanContent + '</div>';
          if (answerHtml) {
            var answerId = 'pyq-ans-' + qCount;
            cardsHtml += '<button class="pyq-answer-toggle" aria-expanded="false" aria-controls="' + answerId + '">Reveal Answer ' + chevronSvg + '</button>';
            cardsHtml += '<div class="pyq-answer" id="' + answerId + '">' + answerHtml + '</div>';
          }
          cardsHtml += '</div>';
          return;
        }

        if (/^\*?\*?Answer|^<strong>Answer:?<\/strong>/i.test(content.trim())) {
          var answerId = 'pyq-ans-' + qCount;
          var lastDiv = cardsHtml.lastIndexOf('</div>');
          if (lastDiv !== -1) {
            var toggle = '<button class="pyq-answer-toggle" aria-expanded="false" aria-controls="' + answerId + '">Reveal Answer ' + chevronSvg + '</button>';
            toggle += '<div class="pyq-answer" id="' + answerId + '">' + content + '</div>';
            cardsHtml = cardsHtml.substring(0, lastDiv) + toggle + '</div>';
          }
          return;
        }

        if (textContent.trim() && qCount > 0) {
          var lastDiv = cardsHtml.lastIndexOf('</div>');
          if (lastDiv !== -1) {
            var answerSplit = content.split(/<strong>Answer:?<\/strong>\s*:?\s*/i);
            if (answerSplit.length > 1) {
              var qPart = answerSplit[0].trim();
              var aPart = '<strong>Answer</strong>: ' + answerSplit.slice(1).join('');
              var answerId = 'pyq-ans-' + qCount;
              var insert = '';
              if (qPart) insert += '<div class="pyq-question-text" style="margin-top:var(--space-1);">' + qPart + '</div>';
              insert += '<button class="pyq-answer-toggle" aria-expanded="false" aria-controls="' + answerId + '">Reveal Answer ' + chevronSvg + '</button>';
              insert += '<div class="pyq-answer" id="' + answerId + '">' + aPart + '</div>';
              cardsHtml = cardsHtml.substring(0, lastDiv) + insert + '</div>';
            } else {
              cardsHtml = cardsHtml.substring(0, lastDiv) + '<div class="pyq-question-text" style="margin-top:var(--space-1);">' + content + '</div></div>';
            }
          }
        }
      });

      cardsHtml = cardsHtml.replace(/<h3[^>]*>([^<]*)<\/h3>(?=\s*<h3|$)/g, '');
      var pyqInner = document.createElement('div');
      pyqInner.className = 'pyq-panel-inner';
      pyqInner.innerHTML = cardsHtml;
      wrapper.appendChild(pyqInner);

      if (qCount > 0) {
        var badge = document.getElementById('pyq-tab-count');
        if (badge) { badge.textContent = qCount; badge.hidden = false; }
      }

      /* ── Score tracking (localStorage) ── */
      var pageSlug = window.location.pathname;
      var pyqScoresKey = 'bharatnotes_pyq_scores';
      function loadScores() {
        try { return JSON.parse(localStorage.getItem(pyqScoresKey)) || {}; } catch(e) { return {}; }
      }
      function saveScore(qNum, type, selectedIdx, isCorrect) {
        var scores = loadScores();
        if (!scores[pageSlug]) scores[pageSlug] = { prelims: { total: 0, correct: 0, answers: {} }, mains: { attempted: [] }, lastAttempted: '' };
        var s = scores[pageSlug];
        if (type === 'prelims') {
          if (!s.prelims.answers[qNum]) {
            s.prelims.total++;
            if (isCorrect) s.prelims.correct++;
          }
          s.prelims.answers[qNum] = selectedIdx;
        } else {
          if (s.mains.attempted.indexOf(qNum) === -1) s.mains.attempted.push(qNum);
        }
        s.lastAttempted = new Date().toISOString();
        localStorage.setItem(pyqScoresKey, JSON.stringify(scores));
        document.dispatchEvent(new CustomEvent('pyq-score-updated'));
      }
      function removeScore(qNum, type) {
        var scores = loadScores();
        var s = scores[pageSlug];
        if (!s) return;
        if (type === 'prelims' && s.prelims.answers[qNum] !== undefined) {
          s.prelims.total--;
          // We don't know if it was correct — recalculate
          delete s.prelims.answers[qNum];
          s.prelims.correct = 0;
          // Recalc from remaining answers by re-checking cards
          pyqInner.querySelectorAll('.pyq-card[data-type="prelims"]').forEach(function(c) {
            var q = c.getAttribute('data-q');
            if (s.prelims.answers[q] !== undefined && c.querySelector('.pyq-option--correct.pyq-option--selected')) {
              s.prelims.correct++;
            }
          });
        } else if (type === 'mains') {
          var idx = s.mains.attempted.indexOf(qNum);
          if (idx !== -1) s.mains.attempted.splice(idx, 1);
        }
        localStorage.setItem(pyqScoresKey, JSON.stringify(scores));
        document.dispatchEvent(new CustomEvent('pyq-score-updated'));
      }
      function clearAllScores() {
        var scores = loadScores();
        delete scores[pageSlug];
        localStorage.setItem(pyqScoresKey, JSON.stringify(scores));
        document.dispatchEvent(new CustomEvent('pyq-score-updated'));
      }

      /* ── Progress bar ── */
      var totalCards = pyqInner.querySelectorAll('.pyq-card').length;
      var progressEl = document.createElement('div');
      progressEl.className = 'pyq-progress';
      progressEl.innerHTML = '<div class="pyq-progress__top"><div class="pyq-progress__text"><span class="pyq-progress__label">Progress</span><span class="pyq-progress__count" id="pyq-prog-count">0 / ' + totalCards + ' attempted</span></div><button class="pyq-reset-all" id="pyq-reset-all" title="Reset all answers">Reset All</button></div><div class="pyq-progress__bar"><div class="pyq-progress__fill pyq-progress__fill--correct" id="pyq-fill-correct"></div><div class="pyq-progress__fill pyq-progress__fill--wrong" id="pyq-fill-wrong"></div></div><div class="pyq-progress__score" id="pyq-prog-score" hidden></div>';
      wrapper.insertBefore(progressEl, pyqInner);

      function updateProgress() {
        var scores = loadScores();
        var s = scores[pageSlug] || { prelims: { total: 0, correct: 0, answers: {} }, mains: { attempted: [] } };
        var attempted = s.prelims.total + s.mains.attempted.length;
        var correct = s.prelims.correct;
        var wrong = s.prelims.total - correct;
        document.getElementById('pyq-prog-count').textContent = attempted + ' / ' + totalCards + ' attempted';
        var scoreEl = document.getElementById('pyq-prog-score');
        if (s.prelims.total > 0) {
          scoreEl.hidden = false;
          scoreEl.innerHTML = 'Prelims Score: <strong>' + correct + '/' + s.prelims.total + '</strong> correct';
        } else {
          scoreEl.hidden = true;
        }
        var pCorrect = totalCards ? (correct / totalCards * 100) : 0;
        var pWrong = totalCards ? (wrong / totalCards * 100) : 0;
        document.getElementById('pyq-fill-correct').style.width = pCorrect + '%';
        document.getElementById('pyq-fill-wrong').style.width = pWrong + '%';
      }
      document.addEventListener('pyq-score-updated', updateProgress);

      /* ── Reset All button ── */
      document.getElementById('pyq-reset-all').addEventListener('click', function() {
        clearAllScores();
        location.reload();
      });

      /* ── Filter bar ── */
      var years = {};
      pyqInner.querySelectorAll('.pyq-card').forEach(function(c) {
        var y = c.getAttribute('data-year');
        if (y) years[y] = true;
      });
      var yearOpts = '<option value="all">All Years</option>';
      Object.keys(years).sort().reverse().forEach(function(y) {
        yearOpts += '<option value="' + y + '">' + y + '</option>';
      });
      var filterBar = document.createElement('div');
      filterBar.className = 'pyq-filters';
      filterBar.innerHTML = '<button class="pyq-filter active" data-filter="all">All</button><button class="pyq-filter" data-filter="prelims">Prelims</button><button class="pyq-filter" data-filter="mains">Mains</button><span class="pyq-filter-sep"></span><select class="pyq-filter-year" id="pyq-filter-year">' + yearOpts + '</select><span class="pyq-filter-sep"></span><button class="pyq-filter" data-filter="unanswered">Unanswered</button>';
      wrapper.insertBefore(filterBar, pyqInner);

      var activeFilter = 'all';
      function applyPyqFilters() {
        var yearVal = document.getElementById('pyq-filter-year').value;
        var scores = loadScores();
        var s = scores[pageSlug] || { prelims: { total: 0, correct: 0, answers: {} }, mains: { attempted: [] } };
        pyqInner.querySelectorAll('.pyq-card').forEach(function(c) {
          var type = c.getAttribute('data-type');
          var year = c.getAttribute('data-year');
          var qNum = parseInt(c.getAttribute('data-q'));
          var matchType = activeFilter === 'all' || activeFilter === type;
          var matchYear = yearVal === 'all' || year === yearVal;
          var matchUnanswered = true;
          if (activeFilter === 'unanswered') {
            matchType = true;
            var isAnswered = (type === 'prelims' && s.prelims.answers[qNum] !== undefined) || (type === 'mains' && s.mains.attempted.indexOf(qNum) !== -1);
            matchUnanswered = !isAnswered;
          }
          c.hidden = !(matchType && matchYear && matchUnanswered);
        });
        // Hide empty section headings
        pyqInner.querySelectorAll('.pyq-section-heading').forEach(function(h3) {
          var next = h3.nextElementSibling;
          var hasVisible = false;
          while (next && !next.classList.contains('pyq-section-heading')) {
            if (next.classList.contains('pyq-card') && !next.hidden) hasVisible = true;
            next = next.nextElementSibling;
          }
          h3.hidden = !hasVisible;
        });
      }
      filterBar.querySelectorAll('.pyq-filter').forEach(function(btn) {
        btn.addEventListener('click', function() {
          filterBar.querySelectorAll('.pyq-filter').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          activeFilter = btn.getAttribute('data-filter');
          applyPyqFilters();
        });
      });
      document.getElementById('pyq-filter-year').addEventListener('change', applyPyqFilters);

      /* ── Mains directive hints ── */
      var directiveMap = {
        'discuss': 'Cover multiple dimensions \u2014 what, why, significance, challenges, way forward',
        'critically examine': 'Present both sides with evidence, give your reasoned conclusion',
        'critically analyse': 'Break down into components, evaluate strengths and weaknesses, conclude',
        'enumerate': 'List systematically with brief explanation of each point',
        'comment': 'Express a reasoned opinion supported by facts and examples',
        'evaluate': 'Assess the value or effectiveness with evidence from both sides',
        'elucidate': 'Explain clearly with examples to make the concept accessible',
        'examine': 'Investigate in detail, look at different angles and implications',
        'analyse': 'Break into components, study relationships, draw conclusions',
        'assess': 'Determine the significance, value, or extent of something',
        'justify': 'Provide reasons and evidence in support of a position',
        'compare': 'Identify similarities and differences between two or more things'
      };

      pyqInner.querySelectorAll('.pyq-card--mains').forEach(function(card) {
        var qText = card.querySelector('.pyq-question-text');
        if (!qText) return;
        var fullText = qText.textContent;
        var yearBadge = card.querySelector('.pyq-year-badge');
        var badgeText = yearBadge ? yearBadge.textContent : '';

        // Extract marks and derive word count
        var marksMatch = fullText.match(/(\d+(?:\.5)?)\s*marks/i) || badgeText.match(/(\d+(?:\.5)?)\s*marks/i);
        var marks = marksMatch ? parseFloat(marksMatch[1]) : 0;
        var wordCount = marks >= 15 ? 250 : marks >= 10 ? 150 : marks > 0 ? 150 : 0;
        // Extract GS Paper
        var paperMatch = fullText.match(/GS\s*Paper\s*(\d|I{1,3}V?)/i);
        var paper = paperMatch ? 'GS' + paperMatch[1] : '';
        // Extract directive
        var directive = '';
        var directiveHint = '';
        for (var d in directiveMap) {
          if (new RegExp('\\b' + d + '\\b', 'i').test(fullText)) {
            directive = d.charAt(0).toUpperCase() + d.slice(1);
            directiveHint = directiveMap[d];
            break;
          }
        }

        if (marks || directive) {
          var metaHtml = '<div class="pyq-mains-hints">';
          metaHtml += '<div class="pyq-mains-meta">';
          if (wordCount) metaHtml += '<span class="pyq-mains-badge">\u270D ~' + wordCount + ' words</span>';
          if (marks) metaHtml += '<span class="pyq-mains-badge">' + marks + ' marks</span>';
          if (paper) metaHtml += '<span class="pyq-mains-badge">' + paper + '</span>';
          if (directive) metaHtml += '<span class="pyq-mains-badge pyq-mains-badge--directive">' + directive + '</span>';
          metaHtml += '</div>';
          if (directiveHint) {
            metaHtml += '<button class="pyq-hint-toggle">\uD83D\uDCA1 Approach Hint ' + chevronSvg + '</button>';
            metaHtml += '<div class="pyq-hint-body" hidden><p><strong>Directive \u2014 ' + directive + ':</strong> ' + directiveHint + '</p><p><strong>Structure:</strong> Introduction (1\u20132 lines) \u2192 Body (multi-dimensional analysis) \u2192 Conclusion (way forward / your view)</p></div>';
          }
          metaHtml += '</div>';
          var hintsEl = document.createElement('div');
          hintsEl.innerHTML = metaHtml;
          var toggle = card.querySelector('.pyq-answer-toggle');
          if (toggle) card.insertBefore(hintsEl.firstChild, toggle);
          else card.appendChild(hintsEl.firstChild);
        }

        // Hint toggle handler
        var hintBtn = card.querySelector('.pyq-hint-toggle');
        if (hintBtn) {
          hintBtn.addEventListener('click', function() {
            var body = card.querySelector('.pyq-hint-body');
            if (body) {
              body.hidden = !body.hidden;
              hintBtn.classList.toggle('pyq-hint-toggle--open', !body.hidden);
            }
          });
        }
      });

      /* ── Post-process: add interactive quiz options to prelims cards ── */
      pyqInner.querySelectorAll('.pyq-card:not(.pyq-card--mains)').forEach(function(card) {
        var answerDiv = card.querySelector('.pyq-answer');
        var toggle = card.querySelector('.pyq-answer-toggle');
        if (!answerDiv) return;

        var answerText = answerDiv.textContent;
        var qNum = parseInt(card.getAttribute('data-q'));

        var explicitOpts = card.dataset.options ? JSON.parse(decodeURIComponent(card.dataset.options)) : null;
        var options, correctIdx;

        // Try to extract (a)/(b)/(c)/(d) options from question text divs
        if (!explicitOpts) {
          var qTexts = card.querySelectorAll('.pyq-question-text');
          var extractedOpts = [];
          var optNodes = [];
          qTexts.forEach(function(qt) {
            var txt = qt.textContent.trim();
            // Check for single-line inline: (a) ... (b) ... (c) ... (d) ...
            var inlineM = extractInlineOptions(txt);
            if (inlineM && extractedOpts.length === 0) {
              extractedOpts = inlineM;
              optNodes.push(qt);
              return;
            }
            // Check for one-option-per-line: (a) some text
            var m = txt.match(/^\(([a-d])\)\s*(.+)/i);
            if (m) { extractedOpts.push(m[2].trim()); optNodes.push(qt); }
          });
          if (extractedOpts.length === 4) {
            explicitOpts = extractedOpts;
            optNodes.forEach(function(n) { n.remove(); });
            card.setAttribute('data-options', encodeURIComponent(JSON.stringify(explicitOpts)));
          }
        }

        if (explicitOpts && explicitOpts.length === 4) {
          options = explicitOpts;
          correctIdx = parseCorrectFromAnswer(answerText, options);
          if (correctIdx === -1) {
            var statements = card.querySelectorAll('ol li');
            if (statements.length >= 2) correctIdx = parseCorrectAnswer(answerText, statements.length);
          }
        } else {
          var statements = card.querySelectorAll('ol li');
          if (statements.length < 2 || statements.length > 4) return;
          options = generateOptions(statements.length);
          if (!options) return;
          correctIdx = parseCorrectAnswer(answerText, statements.length);
        }

        var optionsEl = document.createElement('div');
        optionsEl.className = 'pyq-options';
        optionsEl.innerHTML = '<div class="pyq-options-label">Select your answer:</div>';
        var letters = ['a', 'b', 'c', 'd'];
        options.forEach(function(opt, i) {
          var btn = document.createElement('button');
          btn.className = 'pyq-option';
          btn.setAttribute('data-idx', i);
          btn.innerHTML = '<span class="pyq-option-label">' + letters[i] + '</span><span>' + opt + '</span>';
          optionsEl.appendChild(btn);
        });

        if (toggle) toggle.parentNode.insertBefore(optionsEl, toggle);

        var checkBtn = document.createElement('button');
        checkBtn.className = 'pyq-check-btn';
        checkBtn.disabled = true;
        checkBtn.textContent = 'Check Answer';
        if (toggle) {
          toggle.parentNode.insertBefore(checkBtn, toggle);
          toggle.hidden = true;
        }

        var selectedIdx = -1;
        var answered = false;

        function resetCard() {
          answered = false;
          selectedIdx = -1;
          optionsEl.querySelectorAll('.pyq-option').forEach(function(b) {
            b.classList.remove('pyq-option--selected', 'pyq-option--correct', 'pyq-option--wrong');
            b.disabled = false;
          });
          checkBtn.disabled = true;
          checkBtn.hidden = false;
          if (answerDiv) answerDiv.classList.remove('pyq-answer--open');
          if (toggle) toggle.hidden = true;
          var result = card.querySelector('.pyq-result');
          if (result) result.remove();
          var retry = card.querySelector('.pyq-retry-btn');
          if (retry) retry.remove();
        }

        function showResult(selIdx, skipSave) {
          answered = true;
          selectedIdx = selIdx;

          var resultEl = document.createElement('div');
          resultEl.className = 'pyq-result';
          var isCorrect = false;

          if (correctIdx >= 0) {
            optionsEl.querySelectorAll('.pyq-option').forEach(function(btn, i) {
              btn.disabled = true;
              if (i === correctIdx) btn.classList.add('pyq-option--correct');
              if (i === selIdx && i !== correctIdx) btn.classList.add('pyq-option--wrong');
              if (i === selIdx) btn.classList.add('pyq-option--selected');
            });
            if (selIdx === correctIdx) {
              isCorrect = true;
              resultEl.className += ' pyq-result--correct';
              resultEl.innerHTML = checkSvg + ' Correct!';
            } else {
              resultEl.className += ' pyq-result--wrong';
              resultEl.innerHTML = crossSvg + ' Incorrect \u2014 the correct answer is (' + letters[correctIdx] + ')';
            }
          } else {
            optionsEl.querySelectorAll('.pyq-option').forEach(function(btn) { btn.disabled = true; });
            resultEl.className += ' pyq-result--correct';
            resultEl.innerHTML = 'See explanation below';
            isCorrect = true;
          }

          checkBtn.parentNode.insertBefore(resultEl, checkBtn);
          checkBtn.hidden = true;
          if (answerDiv) answerDiv.classList.add('pyq-answer--open');
          if (toggle) toggle.hidden = true;

          // Try Again button
          var retryBtn = document.createElement('button');
          retryBtn.className = 'pyq-retry-btn';
          retryBtn.innerHTML = '\u21BB Try Again';
          resultEl.parentNode.insertBefore(retryBtn, resultEl.nextSibling);
          retryBtn.addEventListener('click', function() {
            resetCard();
            removeScore(qNum, 'prelims');
          });

          if (!skipSave) saveScore(qNum, 'prelims', selIdx, isCorrect);
        }

        optionsEl.querySelectorAll('.pyq-option').forEach(function(btn) {
          btn.addEventListener('click', function() {
            if (answered) return;
            optionsEl.querySelectorAll('.pyq-option').forEach(function(b) { b.classList.remove('pyq-option--selected'); });
            btn.classList.add('pyq-option--selected');
            selectedIdx = parseInt(btn.getAttribute('data-idx'));
            checkBtn.disabled = false;
          });
        });

        checkBtn.addEventListener('click', function() {
          if (answered || selectedIdx === -1) return;
          showResult(selectedIdx, false);
        });

        // Store refs for state restoration
        card._pyqShowResult = showResult;
        card._pyqCorrectIdx = correctIdx;
      });

      /* ── Mains answer-toggle with score tracking ── */
      pyqInner.querySelectorAll('.pyq-card--mains .pyq-answer-toggle').forEach(function(toggle) {
        var card = toggle.closest('.pyq-card');
        var qNum = parseInt(card.getAttribute('data-q'));
        var answerDiv = card.querySelector('.pyq-answer');
        toggle.addEventListener('click', function() {
          var expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', !expanded);
          if (answerDiv) {
            answerDiv.classList.toggle('pyq-answer--open', !expanded);
            if (!expanded) saveScore(qNum, 'mains', -1, false);
          }
        });
      });

      /* ── Mains Answer Writing (4d) ── */
      var DRAFTS_KEY = 'bn_mains_drafts_v1';
      function loadMainsDraft(qn) {
        try { var d = JSON.parse(localStorage.getItem(DRAFTS_KEY)) || {}; return (d[pageSlug] || {})[qn] || null; }
        catch(e) { return null; }
      }
      function saveMainsDraft(qn, text, submitted) {
        try {
          var d = JSON.parse(localStorage.getItem(DRAFTS_KEY)) || {};
          if (!d[pageSlug]) d[pageSlug] = {};
          d[pageSlug][qn] = { text: text, submitted: submitted, ts: Date.now() };
          localStorage.setItem(DRAFTS_KEY, JSON.stringify(d));
        } catch(e) {}
      }
      function fmtTime(s) { return Math.floor(s/60) + ':' + ('0' + (s%60)).slice(-2); }

      pyqInner.querySelectorAll('.pyq-card--mains').forEach(function(card) {
        var qn = parseInt(card.getAttribute('data-q')) || 0;
        var qText = card.querySelector('.pyq-question-text');
        if (!qText) return;
        var fullText = qText.textContent;
        var marksM = fullText.match(/(\d+(?:\.5)?)\s*marks/i);
        var marks = marksM ? parseFloat(marksM[1]) : 0;
        var timerSecs = marks >= 15 ? 900 : 600;
        var targetWords = marks >= 15 ? 250 : 150;

        var answerDiv = card.querySelector('.pyq-answer');
        var toggle = card.querySelector('.pyq-answer-toggle');
        if (!answerDiv && !toggle) return; // no model answer — skip

        /* Write button */
        var writeBtn = document.createElement('button');
        writeBtn.className = 'pyq-write-btn';
        writeBtn.innerHTML = '\u270D\uFE0F Practice Writing';

        /* Writing zone */
        var zone = document.createElement('div');
        zone.className = 'pyq-write-zone';
        var timerId = 'pwt-' + qn;
        zone.innerHTML =
          '<div class="pyq-write-header">' +
            '<div class="pyq-timer" id="' + timerId + '">' + fmtTime(timerSecs) + '</div>' +
            '<span class="pyq-write-target">~' + targetWords + ' words' + (marks ? ' \u00B7 ' + marks + ' marks' : '') + '</span>' +
            '<button class="pyq-write-close" title="Close" type="button">\u00D7</button>' +
          '</div>' +
          '<textarea class="pyq-write-textarea" placeholder="Write your structured answer here...\n\nIntroduction \u2192 Body (multi-dimensional) \u2192 Conclusion"></textarea>' +
          '<div class="pyq-write-footer">' +
            '<span class="pyq-write-wc">0 / ' + targetWords + ' words</span>' +
            '<button class="pyq-write-submit" type="button">Submit \u0026 See Model Answer</button>' +
          '</div>';

        var timeLeft = timerSecs;
        var timerInterval = null;
        var timerStarted = false;

        var textarea  = zone.querySelector('.pyq-write-textarea');
        var wcEl      = zone.querySelector('.pyq-write-wc');
        var submitBtn = zone.querySelector('.pyq-write-submit');
        var closeBtn  = zone.querySelector('.pyq-write-close');

        function startTimer() {
          if (timerStarted) return;
          timerStarted = true;
          timerInterval = setInterval(function() {
            timeLeft--;
            var te = document.getElementById(timerId);
            if (te) {
              if (timeLeft <= 0) {
                clearInterval(timerInterval);
                te.textContent = '\u23F1\uFE0F Time\'s up!';
                te.className = 'pyq-timer pyq-timer--up';
              } else {
                te.textContent = fmtTime(timeLeft);
                te.className = 'pyq-timer' + (timeLeft <= timerSecs * 0.2 ? ' pyq-timer--warn' : '');
              }
            }
          }, 1000);
        }
        function stopTimer() { if (timerInterval) { clearInterval(timerInterval); timerInterval = null; } }

        function countWords(str) { return str.trim().split(/\s+/).filter(function(w) { return w; }).length; }

        textarea.addEventListener('input', function() {
          startTimer();
          var w = countWords(textarea.value);
          wcEl.textContent = w + ' / ' + targetWords + ' words';
          wcEl.className = 'pyq-write-wc' + (w >= targetWords ? ' pyq-write-wc--ok' : '');
          saveMainsDraft(qn, textarea.value, false);
        });

        submitBtn.addEventListener('click', function() {
          stopTimer();
          saveMainsDraft(qn, textarea.value, true);
          saveScore(qn, 'mains', -1, false);
          // Reveal model answer
          if (answerDiv) answerDiv.classList.add('pyq-answer--open');
          if (toggle) { toggle.setAttribute('aria-expanded', 'true'); toggle.hidden = true; }
          // Lock zone
          zone.classList.add('pyq-write-zone--submitted');
          submitBtn.textContent = '\u2713 Submitted';
          submitBtn.disabled = true;
          textarea.readOnly = true;
          if (answerDiv) setTimeout(function() { answerDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 200);
        });

        closeBtn.addEventListener('click', function() {
          stopTimer();
          zone.classList.remove('pyq-write-zone--open');
          writeBtn.hidden = false;
        });

        /* Insert into card before toggle (toggle stays hidden — writing is the path) */
        if (toggle) {
          toggle.hidden = true;
          card.insertBefore(writeBtn, toggle);
          card.insertBefore(zone, toggle);
        } else {
          card.appendChild(writeBtn);
          card.appendChild(zone);
        }

        writeBtn.addEventListener('click', function() {
          zone.classList.add('pyq-write-zone--open');
          writeBtn.hidden = true;
          setTimeout(function() { textarea.focus(); }, 50);
        });

        /* Restore saved state */
        var saved = loadMainsDraft(qn);
        if (saved && saved.text) {
          textarea.value = saved.text;
          var ww = countWords(saved.text);
          wcEl.textContent = ww + ' / ' + targetWords + ' words';
          wcEl.className = 'pyq-write-wc' + (ww >= targetWords ? ' pyq-write-wc--ok' : '');
          if (saved.submitted) {
            zone.classList.add('pyq-write-zone--open', 'pyq-write-zone--submitted');
            writeBtn.hidden = true;
            submitBtn.textContent = '\u2713 Submitted';
            submitBtn.disabled = true;
            textarea.readOnly = true;
            if (answerDiv) answerDiv.classList.add('pyq-answer--open');
            if (toggle) toggle.hidden = true;
          } else {
            writeBtn.innerHTML = '\u270D\uFE0F Continue Writing (' + ww + ' words saved)';
          }
        }
      });

      /* ── Restore state from localStorage ── */
      var savedScores = loadScores();
      var savedPage = savedScores[pageSlug];
      if (savedPage) {
        // Restore prelims answers
        if (savedPage.prelims && savedPage.prelims.answers) {
          Object.keys(savedPage.prelims.answers).forEach(function(qNum) {
            var selIdx = savedPage.prelims.answers[qNum];
            var card = pyqInner.querySelector('.pyq-card[data-q="' + qNum + '"][data-type="prelims"]');
            if (card && card._pyqShowResult) {
              card._pyqShowResult(selIdx, true);
            }
          });
        }
        // Restore mains revealed
        if (savedPage.mains && savedPage.mains.attempted) {
          savedPage.mains.attempted.forEach(function(qNum) {
            var card = pyqInner.querySelector('.pyq-card[data-q="' + qNum + '"][data-type="mains"]');
            if (card) {
              var answerDiv = card.querySelector('.pyq-answer');
              var toggle = card.querySelector('.pyq-answer-toggle');
              if (answerDiv) answerDiv.classList.add('pyq-answer--open');
              if (toggle) toggle.setAttribute('aria-expanded', 'true');
            }
          });
        }
      }
      updateProgress();

      /* ── Mark as Revised ── */
      var revisedStoreKey = 'bn_pyq_revised_v1';
      function loadRevised() {
        try { return JSON.parse(localStorage.getItem(revisedStoreKey)) || {}; } catch(e) { return {}; }
      }
      function saveRevised(qNum, state) {
        var data = loadRevised();
        if (!data[pageSlug]) data[pageSlug] = [];
        var idx = data[pageSlug].indexOf(qNum);
        if (state && idx === -1) data[pageSlug].push(qNum);
        else if (!state && idx !== -1) data[pageSlug].splice(idx, 1);
        localStorage.setItem(revisedStoreKey, JSON.stringify(data));
      }
      function isRevisedQ(qNum) {
        var data = loadRevised();
        return data[pageSlug] && data[pageSlug].indexOf(qNum) !== -1;
      }

      var checkIconSvg = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

      pyqInner.querySelectorAll('.pyq-card').forEach(function(card) {
        var qNum = parseInt(card.getAttribute('data-q'));
        var revisedBtn = document.createElement('button');
        revisedBtn.className = 'pyq-revised-btn';

        function updateRevisedUI(rev) {
          if (rev) {
            revisedBtn.innerHTML = checkIconSvg + ' Marked as Revised';
            card.classList.add('pyq-card--revised');
          } else {
            revisedBtn.innerHTML = checkIconSvg + ' Mark as Revised';
            card.classList.remove('pyq-card--revised');
          }
        }

        updateRevisedUI(isRevisedQ(qNum));
        revisedBtn.addEventListener('click', function() {
          var nowRevised = !card.classList.contains('pyq-card--revised');
          saveRevised(qNum, nowRevised);
          updateRevisedUI(nowRevised);
        });
        card.appendChild(revisedBtn);
      });
    }

    // ── Vocabulary / Key Terms — rich expandable entries ──
    if (/^(?:key\s+)?vocabular(?:y|ies)$/i.test(text) || /^key\s+(?:terms?|concepts?)$/i.test(text)) {
      var isVocab = /vocabular/i.test(text);
      var variant = isVocab ? 'vocab' : 'terms';
      var wrapper = document.createElement('div');
      wrapper.className = 'section-card section-card--' + variant;
      h2.parentNode.insertBefore(wrapper, h2);
      wrapper.appendChild(h2);
      var next = wrapper.nextElementSibling;
      while (next && next.tagName !== 'H2' && next.tagName !== 'HR') {
        var move = next;
        next = next.nextElementSibling;
        wrapper.appendChild(move);
      }
      if (next && next.tagName === 'HR') next.remove();

      /* ── Parse H3-based entries ── */
      var fieldMap = {
        'pronunciation': 'pronunciation', 'pron': 'pronunciation',
        'definition': 'definition', 'def': 'definition',
        'explanation': 'explanation', 'detail': 'explanation', 'details': 'explanation',
        'origin': 'origin', 'etymology': 'origin', 'root': 'origin',
        'synonyms': 'synonyms', 'synonym': 'synonyms',
        'antonyms': 'antonyms', 'antonym': 'antonyms',
        'upsc': 'upsc', 'upsc context': 'upsc', 'exam relevance': 'upsc',
        'related': 'related'
      };
      var entries = [];
      var h3List = wrapper.querySelectorAll('h3');

      h3List.forEach(function(h3) {
        var entry = { term: h3.textContent.trim(), fields: {}, sourceEls: [h3] };
        var slugBase = entry.term.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        entry.slug = slugBase;
        // Collect UL(s) after this H3 until next H3 or end
        var sib = h3.nextElementSibling;
        while (sib && sib.tagName !== 'H3' && sib.tagName !== 'H2') {
          entry.sourceEls.push(sib);
          if (sib.tagName === 'UL') {
            sib.querySelectorAll('li').forEach(function(li) {
              var strong = li.querySelector('strong');
              if (!strong) return;
              var label = strong.textContent.replace(/[:：]\s*$/, '').trim().toLowerCase();
              var key = fieldMap[label];
              if (!key) return;
              // Get content after the strong tag
              var clone = li.cloneNode(true);
              var s = clone.querySelector('strong');
              if (s) {
                var nx = s.nextSibling;
                s.remove();
                if (nx && nx.nodeType === 3) nx.textContent = nx.textContent.replace(/^[:：]\s*/, '');
              }
              entry.fields[key] = clone.innerHTML.trim();
            });
          }
          sib = sib.nextElementSibling;
        }
        if (entry.fields.definition || Object.keys(entry.fields).length > 0) entries.push(entry);
      });

      /* ── Fallback: parse 2-column table if no H3s ── */
      if (entries.length === 0) {
        var table = wrapper.querySelector('table');
        if (table) {
          table.querySelectorAll('tbody tr').forEach(function(row) {
            var cells = row.querySelectorAll('td');
            if (cells.length < 2) return;
            var t = cells[0].textContent.trim();
            entries.push({
              term: t,
              slug: t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''),
              fields: { definition: cells[1].innerHTML.trim() },
              sourceEls: []
            });
          });
          if (entries.length > 0) {
            table.hidden = true;
            table.classList.add('vocab-src-hidden');
          }
        }
      }

      if (entries.length > 0) {
        // Hide source H3/UL elements
        entries.forEach(function(e) {
          e.sourceEls.forEach(function(el) { el.hidden = true; el.classList.add('vocab-src-hidden'); });
        });

        // Search box (3+ entries)
        if (entries.length >= 3) {
          var searchDiv = document.createElement('div');
          searchDiv.className = 'vocab-search';
          searchDiv.innerHTML = '<input type="text" class="vocab-search__input" placeholder="Search ' + entries.length + ' terms\u2026" aria-label="Filter terms">';
          wrapper.appendChild(searchDiv);
        }

        // Progress + bar (C)
        var progressDiv = document.createElement('div');
        progressDiv.className = 'vocab-progress';
        progressDiv.innerHTML = '<span>' + entries.length + ' terms</span><span class="vocab-progress__count"><span class="vocab-expanded-count">0</span> / ' + entries.length + ' explored</span>';
        wrapper.appendChild(progressDiv);
        var barWrap = document.createElement('div');
        barWrap.className = 'vocab-progress__bar-wrap';
        barWrap.innerHTML = '<div class="vocab-progress__bar-fill"></div>';
        wrapper.appendChild(barWrap);

        var entriesDiv = document.createElement('div');
        entriesDiv.className = 'vocab-entries';
        var expandedCount = 0;

        entries.forEach(function(entry) {
          var card = document.createElement('div');
          card.className = 'vocab-entry';
          card.setAttribute('data-term', entry.slug);
          card.id = 'term-' + entry.slug;

          var f = entry.fields;
          // Header
          var header = document.createElement('div');
          header.className = 'vocab-entry__header';
          header.setAttribute('tabindex', '0');
          header.setAttribute('role', 'button');
          header.setAttribute('aria-expanded', 'false');
          header.innerHTML =
            '<div class="vocab-entry__header-top">' +
              '<span class="vocab-entry__term">' + entry.term + '</span>' +
              '<svg class="vocab-entry__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>' +
            '</div>' +
            '<div class="vocab-entry__header-sub">' +
              (f.pronunciation ? '<span class="vocab-entry__pron">' + f.pronunciation + '</span>' : '') +
              '<span class="vocab-entry__brief">' + (f.definition || '') + '</span>' +
            '</div>';

          // Body
          var body = document.createElement('div');
          body.className = 'vocab-entry__body';
          body.hidden = true;
          var bodyHtml = '';

          var fieldOrder = [
            ['definition', 'Definition'],
            ['explanation', 'Explanation'],
            ['origin', 'Origin & Etymology'],
            ['synonyms', 'Synonyms'],
            ['antonyms', 'Antonyms'],
            ['upsc', 'UPSC Context']
          ];
          fieldOrder.forEach(function(pair) {
            if (f[pair[0]]) {
              bodyHtml += '<div class="vocab-entry__field"><div class="vocab-entry__label">' + pair[1] + '</div><div class="vocab-entry__value">' + f[pair[0]] + '</div></div>';
            }
          });

          // Related terms chips
          if (f.related) {
            var chips = f.related.match(/\[\[([^\]]+)\]\]/g);
            if (chips && chips.length > 0) {
              bodyHtml += '<div class="vocab-entry__related">';
              chips.forEach(function(chip) {
                var name = chip.replace(/^\[\[|\]\]$/g, '');
                var slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
                bodyHtml += '<span class="vocab-related-chip" data-term="' + slug + '" tabindex="0" role="button">' + name + '</span>';
              });
              bodyHtml += '</div>';
            }
          }

          // Link to individual term page
          var pathParts = window.location.pathname.replace(/^\/|\/$/g, '').split('/');
          var fileSlug = pathParts[pathParts.length - 1] || '';
          var termPageSlug = entry.slug + '--' + fileSlug;
          var termPageUrl = '/resources/key-terms/' + termPageSlug + '/';
          if (variant === 'terms') {
            bodyHtml += '<div style="padding:var(--space-3) 0 0;border-top:1px solid rgba(0,0,0,0.05);margin-top:var(--space-3);">';
            bodyHtml += '<a href="' + termPageUrl + '" style="font-size:var(--text-xs);color:var(--color-brand);font-weight:600;text-decoration:none;">View full page &rarr;</a>';
            bodyHtml += '</div>';
          }

          body.innerHTML = bodyHtml;
          card.appendChild(header);
          card.appendChild(body);

          // Toggle expand
          function toggleCard() {
            var isExpanded = !body.hidden;
            body.hidden = isExpanded;
            card.classList.toggle('vocab-entry--expanded', !isExpanded);
            header.setAttribute('aria-expanded', String(!isExpanded));
            if (!isExpanded) {
              card.classList.add('vocab-entry--explored'); // D: permanent explored dot
              if (!card.dataset.counted) {
                card.dataset.counted = 'true';
                expandedCount++;
                var cEl = wrapper.querySelector('.vocab-expanded-count');
                if (cEl) cEl.textContent = expandedCount;
                // C: update progress bar fill
                var barFill = wrapper.querySelector('.vocab-progress__bar-fill');
                if (barFill) barFill.style.width = Math.round((expandedCount / entries.length) * 100) + '%';
              }
            }
          }
          header.addEventListener('click', toggleCard);
          header.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleCard(); }
          });

          entriesDiv.appendChild(card);

          // Store parsed data on the DOM element for dialog use
          card._vocabData = entry;
        });

        wrapper.appendChild(entriesDiv);

        // Wire search
        var sInput = wrapper.querySelector('.vocab-search__input');
        if (sInput) {
          sInput.addEventListener('input', function() {
            var q = sInput.value.toLowerCase().trim();
            var cards = entriesDiv.querySelectorAll('.vocab-entry');
            var vis = 0;
            cards.forEach(function(c) {
              var match = !q || c.textContent.toLowerCase().indexOf(q) !== -1;
              c.hidden = !match;
              if (match) vis++;
            });
            var noRes = entriesDiv.querySelector('.vocab-no-results');
            if (vis === 0) {
              if (!noRes) {
                noRes = document.createElement('p');
                noRes.className = 'vocab-no-results';
                noRes.textContent = 'No matching terms found.';
                entriesDiv.appendChild(noRes);
              }
              noRes.hidden = false;
            } else if (noRes) { noRes.hidden = true; }
          });
        }
      }
    }

    // Wrap "Current Affairs Connect" in styled card
    if (/current\s+affairs/i.test(text)) {
      var wrapper = document.createElement('div');
      wrapper.className = 'section-card section-card--news';
      h2.parentNode.insertBefore(wrapper, h2);
      wrapper.appendChild(h2);
      var next = wrapper.nextElementSibling;
      while (next && next.tagName !== 'H2' && next.tagName !== 'HR') {
        var move = next;
        next = next.nextElementSibling;
        wrapper.appendChild(move);
      }
      if (next && next.tagName === 'HR') next.remove();
    }
  });

  // Wire up answer toggles (for mains cards + any non-enhanced prelims)
  document.querySelectorAll('.pyq-answer-toggle:not([hidden])').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var ans = document.getElementById(btn.getAttribute('aria-controls'));
      if (ans) ans.hidden = expanded;
      btn.innerHTML = (expanded ? 'Hide Answer' : 'Reveal Answer') + ' ' + chevronSvg;
    });
  });

  // ── Vocab: Interlink processor + Dialog ──
  (function() {
    // Create shared dialog (HTML <dialog> element — native modal)
    var dialog = document.createElement('dialog');
    dialog.className = 'vocab-dialog';
    dialog.innerHTML =
      '<div class="vocab-dialog__header">' +
        '<div class="vocab-dialog__info">' +
          '<div class="vocab-dialog__term"></div>' +
          '<div class="vocab-dialog__pron"></div>' +
        '</div>' +
        '<button class="vocab-dialog__close" aria-label="Close">' +
          '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
        '</button>' +
      '</div>' +
      '<div class="vocab-dialog__body"></div>' +
      '<div class="vocab-dialog__footer">' +
        '<button class="vocab-dialog__more">Know More &rarr;</button>' +
      '</div>';
    document.body.appendChild(dialog);

    dialog.querySelector('.vocab-dialog__close').addEventListener('click', function() { dialog.close(); });
    dialog.addEventListener('click', function(e) { if (e.target === dialog) dialog.close(); });

    function slugify(t) { return t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); }

    function openVocabDialog(termSlug, termName) {
      var entry = document.querySelector('.vocab-entry[data-term="' + termSlug + '"]');
      var data = entry && entry._vocabData ? entry._vocabData : null;

      dialog.querySelector('.vocab-dialog__term').textContent = termName || (data ? data.term : termSlug);
      dialog.querySelector('.vocab-dialog__pron').textContent = data && data.fields.pronunciation ? data.fields.pronunciation : '';
      dialog.querySelector('.vocab-dialog__body').innerHTML = data && data.fields.definition
        ? data.fields.definition
        : 'This term is covered in detail on this page.';

      var moreBtn = dialog.querySelector('.vocab-dialog__more');
      if (entry) {
        moreBtn.onclick = function() {
          dialog.close();
          entry.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Expand if collapsed
          var body = entry.querySelector('.vocab-entry__body');
          var header = entry.querySelector('.vocab-entry__header');
          if (body && body.hidden) {
            body.hidden = false;
            entry.classList.add('vocab-entry--expanded');
            if (header) header.setAttribute('aria-expanded', 'true');
          }
        };
        moreBtn.style.display = '';
      } else {
        moreBtn.style.display = 'none';
      }

      if (typeof dialog.showModal === 'function') dialog.showModal();
    }

    // Process [[Term]] interlinks in text nodes via TreeWalker
    var walker = document.createTreeWalker(
      article,
      NodeFilter.SHOW_TEXT,
      { acceptNode: function(node) {
        // Skip code, pre, script, style elements
        var parent = node.parentElement;
        if (!parent) return NodeFilter.FILTER_REJECT;
        var tag = parent.tagName;
        if (tag === 'CODE' || tag === 'PRE' || tag === 'SCRIPT' || tag === 'STYLE') return NodeFilter.FILTER_REJECT;
        return node.textContent.indexOf('[[') !== -1 ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
      }}
    );

    var textNodes = [];
    while (walker.nextNode()) textNodes.push(walker.currentNode);

    textNodes.forEach(function(textNode) {
      var parts = textNode.textContent.split(/(\[\[[^\]]+\]\])/g);
      if (parts.length <= 1) return;
      var frag = document.createDocumentFragment();
      parts.forEach(function(part) {
        var match = part.match(/^\[\[([^\]]+)\]\]$/);
        if (match) {
          var name = match[1].trim();
          var span = document.createElement('span');
          span.className = 'vocab-interlink';
          span.textContent = name;
          span.setAttribute('data-term', slugify(name));
          span.setAttribute('tabindex', '0');
          span.setAttribute('role', 'button');
          span.addEventListener('click', function() { openVocabDialog(slugify(name), name); });
          span.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openVocabDialog(slugify(name), name); }
          });
          frag.appendChild(span);
        } else {
          frag.appendChild(document.createTextNode(part));
        }
      });
      textNode.parentNode.replaceChild(frag, textNode);
    });

    // Wire related-chip clicks to open dialog
    document.querySelectorAll('.vocab-related-chip').forEach(function(chip) {
      var slug = chip.getAttribute('data-term');
      var name = chip.textContent.trim();
      chip.addEventListener('click', function() { openVocabDialog(slug, name); });
      chip.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openVocabDialog(slug, name); }
      });
    });

    // Auto-expand entry if URL hash matches #term-{slug}
    if (window.location.hash) {
      var target = document.getElementById(window.location.hash.slice(1));
      if (target && target.classList.contains('vocab-entry')) {
        var body = target.querySelector('.vocab-entry__body');
        var header = target.querySelector('.vocab-entry__header');
        if (body) {
          body.hidden = false;
          target.classList.add('vocab-entry--expanded');
          if (header) header.setAttribute('aria-expanded', 'true');
        }
        setTimeout(function() { target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 200);
      }
    }
  })();

  // ── Convert blockquotes with prefixes to annotation callouts ──
  // Markdown usage: > **Exam Tip:** Your text here
  // Supported: Info, Tip, Exam Tip, Warning, Why in News, Key Point, Note, Remember
  var calloutMap = {
    'info': 'info', 'note': 'info', 'key point': 'info', 'key points': 'info', 'historical note': 'info', 'important': 'info',
    'tip': 'tip', 'remember': 'tip', 'hint': 'tip',
    'exam tip': 'exam', 'exam strategy': 'exam', 'upsc tip': 'exam', 'prelims tip': 'exam', 'mains tip': 'exam', 'upsc relevance': 'exam', 'upsc note': 'exam',
    'warning': 'warning', 'caution': 'warning', 'common mistake': 'warning', 'exception': 'warning',
    'why in news': 'news', 'in news': 'news',
    'quote': 'quote',
    'definition': 'definition', 'key definition': 'definition',
    'example': 'example', 'illustration': 'example', 'analogy': 'example', 'case study': 'example',
    'comparison': 'comparison', 'key distinction': 'comparison', 'distinguish': 'comparison', 'compare': 'comparison', 'vs': 'comparison',
    'mnemonic': 'mnemonic', 'memory trick': 'mnemonic', 'trick to remember': 'mnemonic'
  };
  article.querySelectorAll('blockquote').forEach(function(bq) {
    var firstEl = bq.querySelector('p:first-child, strong:first-child');
    if (!firstEl) return;
    var text = (firstEl.tagName === 'STRONG' ? firstEl : bq.querySelector('p:first-child strong'));
    if (!text) return;
    var label = text.textContent.replace(/[:：]\s*$/, '').trim().toLowerCase();
    var variant = calloutMap[label];
    if (!variant) return;

    var callout = document.createElement('div');
    callout.className = 'callout callout--' + variant;
    var titleSpan = '<span class="callout-title">' + text.textContent.replace(/[:：]\s*$/, '') + '</span>';

    // Get the rest of content after the label
    var firstP = bq.querySelector('p:first-child');
    if (firstP) {
      var clone = firstP.cloneNode(true);
      var strong = clone.querySelector('strong:first-child');
      if (strong) {
        // Remove the label strong and any trailing colon/space
        var next = strong.nextSibling;
        strong.remove();
        if (next && next.nodeType === 3) {
          next.textContent = next.textContent.replace(/^[:：]\s*/, '');
        }
      }
      var remainingFirst = clone.innerHTML.trim();
      var restHtml = '';
      var sibling = firstP.nextElementSibling;
      while (sibling) {
        restHtml += sibling.outerHTML;
        sibling = sibling.nextElementSibling;
      }
      callout.innerHTML = titleSpan + (remainingFirst ? '<p>' + remainingFirst + '</p>' : '') + restHtml;
    }
    bq.parentNode.replaceChild(callout, bq);
  });

  // ── Build Table of Contents from h2 headings ──
  (function() {
    var tocSidebar = document.getElementById('toc-list');
    var tocMobileList = document.getElementById('toc-mobile-list');
    var tocMobile = document.getElementById('toc-mobile');
    var h2s = article.querySelectorAll('h2');
    if (h2s.length < 2) {
      // Not enough headings — hide TOC entirely
      var tocCard = document.getElementById('toc-sidebar');
      if (tocCard) tocCard.hidden = true;
      if (tocMobile) tocMobile.hidden = true;
    } else {
      var tocItems = [];
      h2s.forEach(function(h2, i) {
        // Ensure h2 has an id for anchor linking
        if (!h2.id) h2.id = 'section-' + i;
        var li = document.createElement('li');
        var a = document.createElement('a');
        a.href = '#' + h2.id;
        a.textContent = h2.textContent.trim();
        a.setAttribute('data-toc-target', h2.id);
        li.appendChild(a);
        tocSidebar.appendChild(li);
        // Clone for mobile
        tocMobileList.appendChild(li.cloneNode(true));
        tocItems.push({ id: h2.id, el: h2 });
      });
      if (tocMobile) tocMobile.hidden = false;

      // Smooth scroll on click
      [tocSidebar, tocMobileList].forEach(function(list) {
        list.addEventListener('click', function(e) {
          var link = e.target.closest('a[data-toc-target]');
          if (!link) return;
          e.preventDefault();
          var target = document.getElementById(link.getAttribute('data-toc-target'));
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Close mobile TOC after click
          var toggle = document.getElementById('toc-mobile-toggle');
          if (toggle && toggle.getAttribute('aria-expanded') === 'true') {
            toggle.setAttribute('aria-expanded', 'false');
            tocMobileList.hidden = true;
          }
        });
      });

      // Active section tracking via IntersectionObserver
      if ('IntersectionObserver' in window) {
        var setActive = function(id) {
          [tocSidebar, tocMobileList].forEach(function(list) {
            list.querySelectorAll('a').forEach(function(a) {
              a.classList.toggle('toc-active', a.getAttribute('data-toc-target') === id);
            });
          });
        };
        var currentId = tocItems[0].id;
        setActive(currentId);

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              currentId = entry.target.id;
              setActive(currentId);
            }
          });
        }, { rootMargin: '-10% 0px -80% 0px' });

        tocItems.forEach(function(item) { observer.observe(item.el); });
      }

      // Mobile TOC toggle
      var mobileToggle = document.getElementById('toc-mobile-toggle');
      if (mobileToggle) {
        mobileToggle.addEventListener('click', function() {
          var expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
          mobileToggle.setAttribute('aria-expanded', String(!expanded));
          tocMobileList.hidden = expanded;
        });
      }
    }
  })();

  // ── Tabs: scroll-to-section + auto-sync active tab on scroll ──
  var sectionMap = {
    foundation: article.querySelector('h2'),
    prelims:    article.querySelector('.section-card--upsc') || article.querySelectorAll('h2')[1] || null,
    mains:      article.querySelector('.section-card--mains') || article.querySelectorAll('h2')[2] || null,
    pyqs:       article.querySelector('.section-card--pyq')
  };

  function setActiveTab(key) {
    document.querySelectorAll('.topic-tab').forEach(function(t) {
      t.classList.toggle('active', t.dataset.tab === key);
    });
  }

  // Click: scroll to section
  document.querySelectorAll('.topic-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = sectionMap[tab.dataset.tab];
      if (target) {
        setActiveTab(tab.dataset.tab);
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Scroll-sync: update active tab as sections enter viewport
  if ('IntersectionObserver' in window) {
    var tabKeys = Object.keys(sectionMap).filter(function(k) { return sectionMap[k]; });
    var lastVisible = tabKeys[0];
    var sectionObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var key = tabKeys.find(function(k) { return sectionMap[k] === entry.target; });
          if (key) {
            lastVisible = key;
            setActiveTab(key);
          }
        }
      });
    }, { rootMargin: '-120px 0px -60% 0px', threshold: 0 });
    tabKeys.forEach(function(k) { if (sectionMap[k]) sectionObserver.observe(sectionMap[k]); });
  }

  // Sync bookmark sidebar button with hero bookmark state
  var bookmarkHero = document.getElementById('btn-bookmark-hero');
  var bookmarkSidebar = document.getElementById('btn-bookmark-sidebar');
  if (bookmarkHero && bookmarkSidebar) {
    bookmarkSidebar.addEventListener('click', function() { bookmarkHero.click(); });
    // Mirror bookmarked state
    var bookmarkObserver = new MutationObserver(function() {
      var isBookmarked = bookmarkHero.classList.contains('page-header__action-btn--bookmarked');
      bookmarkSidebar.textContent = '';
      bookmarkSidebar.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> ' + (isBookmarked ? 'Bookmarked ✓' : 'Bookmark this topic');
    });
    bookmarkObserver.observe(bookmarkHero, { attributes: true, attributeFilter: ['class'] });
  }

})();
</script>
