---
layout: base.njk
title: "Vocab Builder"
description: "Build your UPSC vocabulary — pronunciation, etymology, synonyms, antonyms, and exam context for every key term across all GS subjects."
---

<section class="page-header">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="breadcrumb__sep">/</span>
      <a href="/resources/">Resources</a><span class="breadcrumb__sep">/</span>
      Vocab Builder
    </nav>
    <p class="page-header__eyebrow">Resources</p>
    <h1 class="page-header__title">Vocabulary Builder</h1>
    <p class="page-header__subtitle">Master words that elevate your UPSC Essay, GS answer writing, and Interview performance.</p>
  </div>
</section>

<section class="vocab-hub" style="padding:var(--space-8) 0;">
  <div class="container">

    {# ── Stats bar ── #}
    <div class="vocab-hub__stats">
      <span class="vocab-hub__count"><strong>{{ vocabIndex.vocab | length }}</strong> Total Words</span>
      <span class="vocab-hub__sep">|</span>
      <span class="vocab-hub__learned" id="vh-learned">0 Learned</span>
      <span class="vocab-hub__sep">|</span>
      <span class="vocab-hub__remaining" id="vh-remaining">{{ vocabIndex.vocab | length }} Remaining</span>
    </div>

    {# ── Search + Filters ── #}
    <div class="vocab-hub__controls">
      <div class="vocab-hub__search-wrap">
        <input type="text" id="vh-search" class="vocab-hub__search" placeholder="Search vocabulary..." autocomplete="off">
        <span class="vocab-hub__search-count" id="vh-search-count"></span>
      </div>

      <div class="vocab-hub__filters">
        <button class="vocab-hub__filter active" data-subject="all">All Subjects</button>
        {% for s in subjects %}
        {%- set hasEntries = false -%}
        {%- for v in vocabIndex.vocab -%}{%- if v.subject == s.slug -%}{%- set hasEntries = true -%}{%- endif -%}{%- endfor -%}
        {%- if hasEntries %}
        <button class="vocab-hub__filter" data-subject="{{ s.slug }}">{{ s.icon }} {{ s.name }}</button>
        {%- endif -%}
        {% endfor %}
      </div>
    </div>

    {# ── Alphabet nav ── #}
    <nav class="vocab-hub__alpha" id="vh-alpha" aria-label="Jump to letter">
      {%- set letters = [] -%}
      {%- for v in vocabIndex.vocab -%}
        {%- set letter = v.term | upper | truncate(1, true, "") -%}
        {%- if letter not in letters -%}{%- set letters = (letters.push(letter), letters) -%}{%- endif -%}
      {%- endfor -%}
      {%- for ch in "ABCDEFGHIJKLMNOPQRSTUVWXYZ" -%}
        {%- if ch in letters -%}
        <a href="#vocab-letter-{{ ch }}" class="vocab-hub__alpha-btn active-letter">{{ ch }}</a>
        {%- else -%}
        <span class="vocab-hub__alpha-btn disabled">{{ ch }}</span>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    {# ── No results message ── #}
    <div class="vocab-hub__no-results" id="vh-no-results" hidden>
      <p>No matching vocabulary found. Try a different search or filter.</p>
    </div>

    {# ── Cards grouped by letter ── #}
    {%- set currentLetter = "" -%}
    {%- for v in vocabIndex.vocab -%}
      {%- set letter = v.term | upper | truncate(1, true, "") -%}
      {%- if letter != currentLetter -%}
        {%- if currentLetter != "" %}</div>{%- endif -%}
        {%- set currentLetter = letter -%}
    <div class="vocab-hub__letter-group" id="vocab-letter-{{ letter }}" data-letter="{{ letter }}">
      <h2 class="vocab-hub__letter-heading">{{ letter }}</h2>
      {%- endif %}

      {%- set subjectName = v.subject -%}
      {%- for s in subjects -%}{%- if s.slug == v.subject -%}{%- set subjectName = s.name -%}{%- endif -%}{%- endfor -%}

      <div class="vocab-hub__card" data-subject="{{ v.subject }}" data-term="{{ v.term | lower }}" data-def="{{ v.definition | lower }}">
        <div class="vocab-hub__card-header">
          <h3 class="vocab-hub__term">{{ v.term }}</h3>
          {% if v.pronunciation %}<span class="vocab-hub__pron">{{ v.pronunciation }}</span>{% endif %}
        </div>
        <p class="vocab-hub__def">{{ v.definition }}</p>
        {% if v.origin %}<p class="vocab-hub__origin"><strong>Origin:</strong> {{ v.origin | truncate(120, true) }}</p>{% endif %}
        <div class="vocab-hub__card-footer">
          <div class="vocab-hub__tags">
            {%- for gp in v.gs_papers %}<span class="gs-badge gs-badge--{{ gp }}">{{ gp | upper }}</span>{% endfor %}
            <a href="/subjects/{{ v.subject }}/" class="vocab-hub__subject-tag">{{ subjectName }}</a>
          </div>
          <div class="vocab-hub__actions">
            <a href="{{ v.topicUrl }}#term-{{ v.slug }}" class="vocab-hub__detail-link">Details &rarr;</a>
            <button class="vocab-hub__learn-btn" data-term-id="vocab-{{ v.slug }}" aria-label="Mark as learned">Revise</button>
          </div>
        </div>
      </div>

    {%- endfor -%}
    {%- if currentLetter != "" %}</div>{%- endif -%}

  </div>
</section>

<script>
(function() {
  var search = document.getElementById("vh-search");
  var countEl = document.getElementById("vh-search-count");
  var noResults = document.getElementById("vh-no-results");
  var cards = document.querySelectorAll(".vocab-hub__card");
  var groups = document.querySelectorAll(".vocab-hub__letter-group");
  var filters = document.querySelectorAll(".vocab-hub__filter");
  var activeSubject = "all";

  function applyFilters() {
    var q = search.value.toLowerCase().trim();
    var shown = 0;
    cards.forEach(function(c) {
      var matchSubject = activeSubject === "all" || c.dataset.subject === activeSubject;
      var matchSearch = !q || c.dataset.term.indexOf(q) !== -1 || c.dataset.def.indexOf(q) !== -1;
      var visible = matchSubject && matchSearch;
      c.style.display = visible ? "" : "none";
      if (visible) shown++;
    });
    // Hide empty letter groups
    groups.forEach(function(g) {
      var hasVisible = g.querySelector('.vocab-hub__card:not([style*="display: none"])');
      g.style.display = hasVisible ? "" : "none";
    });
    countEl.textContent = q ? shown + " found" : "";
    noResults.hidden = shown > 0;
  }

  search.addEventListener("input", applyFilters);

  filters.forEach(function(btn) {
    btn.addEventListener("click", function() {
      filters.forEach(function(b) { b.classList.remove("active"); });
      btn.classList.add("active");
      activeSubject = btn.dataset.subject;
      applyFilters();
    });
  });

  // Learn/Revise toggle
  var learnedSet = JSON.parse(localStorage.getItem("bn_vocab_learned") || "[]");
  var learnedEl = document.getElementById("vh-learned");
  var remainEl = document.getElementById("vh-remaining");
  var total = cards.length;

  function updateProgress() {
    learnedEl.textContent = learnedSet.length + " Learned";
    remainEl.textContent = (total - learnedSet.length) + " Remaining";
    localStorage.setItem("bn_vocab_learned", JSON.stringify(learnedSet));
  }

  document.querySelectorAll(".vocab-hub__learn-btn").forEach(function(btn) {
    var id = btn.dataset.termId;
    if (learnedSet.indexOf(id) !== -1) {
      btn.classList.add("learned");
      btn.textContent = "Learned ✓";
    }
    btn.addEventListener("click", function() {
      var idx = learnedSet.indexOf(id);
      if (idx === -1) {
        learnedSet.push(id);
        btn.classList.add("learned");
        btn.textContent = "Learned ✓";
      } else {
        learnedSet.splice(idx, 1);
        btn.classList.remove("learned");
        btn.textContent = "Revise";
      }
      updateProgress();
    });
  });
  updateProgress();
})();
</script>
