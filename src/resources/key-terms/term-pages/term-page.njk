---
pagination:
  data: vocabIndex.terms
  size: 1
  alias: term
permalink: "/resources/key-terms/{{ term.pageSlug }}/"
layout: base.njk
eleventyComputed:
  title: "{{ term.term }} — UPSC Key Term | BharatNotes"
  description: "{{ term.definition | truncate(155, true) }}"
---

{%- set subjectName = term.subject -%}
{%- set subjectIcon = "" -%}
{%- set subjectColor = "#0f4c3a" -%}
{%- for s in subjects -%}{%- if s.slug == term.subject -%}{%- set subjectName = s.name -%}{%- set subjectIcon = s.icon -%}{%- set subjectColor = s.color -%}{%- endif -%}{%- endfor -%}

<style>
.tp-bg{background:linear-gradient(180deg,rgba(15,76,58,0.03) 0%,var(--color-bg) 400px);min-height:100vh;padding:var(--space-8) 0}

.tp-header{margin-bottom:var(--space-6)}
.tp-breadcrumb{margin-bottom:var(--space-4)}
.tp-breadcrumb a{color:var(--color-text-muted);text-decoration:none;font-size:var(--text-xs)}
.tp-breadcrumb a:hover{color:var(--color-brand)}
.tp-breadcrumb span{color:var(--color-text-muted);margin:0 var(--space-1);font-size:var(--text-xs)}
.tp-meta{display:flex;align-items:center;flex-wrap:wrap;gap:var(--space-2);margin-bottom:var(--space-3)}
.tp-meta__tag{padding:4px 14px;border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600}
.tp-title{font-family:var(--font-heading);font-size:clamp(1.75rem,5vw,2.5rem);font-weight:800;color:var(--color-text);margin:0 0 var(--space-3);line-height:1.2;letter-spacing:-0.02em}
.tp-pron{font-family:monospace;font-size:var(--text-sm);color:var(--color-text-muted);background:rgba(0,0,0,0.05);padding:4px 14px;border-radius:var(--radius-full,999px);display:inline-block}

.tp-layout{display:grid;grid-template-columns:1fr 320px;gap:var(--space-8);align-items:start}

/* Main */
.tp-def{font-size:var(--text-base);line-height:1.85;color:var(--color-text);margin:0 0 var(--space-6);padding:var(--space-5) var(--space-6);background:#fff;border-left:4px solid var(--tp-color,var(--color-brand));border-radius:0 var(--radius-lg) var(--radius-lg) 0;box-shadow:0 1px 4px rgba(0,0,0,0.04)}

.tp-section{margin-bottom:var(--space-6)}
.tp-section__label{font-family:var(--font-body);font-size:var(--text-xs);font-weight:700;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.06em;margin:0 0 var(--space-3);display:flex;align-items:center;gap:var(--space-2)}
.tp-section__label::after{content:'';flex:1;height:1px;background:var(--color-border)}
.tp-section__content{font-size:var(--text-sm);line-height:1.85;color:var(--color-text-secondary)}

.tp-upsc{padding:var(--space-5) var(--space-6);background:linear-gradient(135deg,rgba(212,160,23,0.06) 0%,rgba(15,76,58,0.03) 100%);border:1px solid rgba(212,160,23,0.15);border-radius:var(--radius-lg);margin-bottom:var(--space-6);box-shadow:0 1px 4px rgba(212,160,23,0.06)}
.tp-upsc__label{font-size:var(--text-xs);font-weight:700;color:var(--color-accent-hover);text-transform:uppercase;letter-spacing:0.06em;margin:0 0 var(--space-3);display:flex;align-items:center;gap:var(--space-2)}
.tp-upsc__label::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--color-accent);flex-shrink:0}
.tp-upsc__content{font-size:var(--text-sm);line-height:1.85;color:var(--color-text-secondary)}

/* Sidebar */
.tp-sidebar{position:sticky;top:var(--space-6)}
.tp-sb{background:#fff;border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-5);margin-bottom:var(--space-4);box-shadow:0 1px 4px rgba(0,0,0,0.04)}
.tp-sb__title{font-size:var(--text-xs);font-weight:700;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;margin:0 0 var(--space-3);padding-bottom:var(--space-2);border-bottom:1px solid var(--color-border)}
.tp-sb__row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.04);font-size:var(--text-xs)}
.tp-sb__row:last-child{border-bottom:none}
.tp-sb__label{color:var(--color-text-muted)}
.tp-sb__value{color:var(--color-text);font-weight:600}

.tp-chapter-card{display:flex;align-items:center;gap:var(--space-3);padding:var(--space-4);background:#fff;border:1.5px solid var(--color-border);border-radius:var(--radius-lg);text-decoration:none;color:inherit;transition:all 0.2s;margin-bottom:var(--space-4);box-shadow:0 1px 4px rgba(0,0,0,0.04)}
.tp-chapter-card:hover{border-color:var(--tp-color,var(--color-brand));box-shadow:0 4px 16px rgba(0,0,0,0.08);transform:translateY(-2px)}
.tp-chapter-card__icon{width:44px;height:44px;border-radius:var(--radius-md);background:color-mix(in srgb,var(--tp-color) 10%,#fff);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.tp-chapter-card__info{flex:1}
.tp-chapter-card__label{font-size:0.6rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;margin:0 0 2px}
.tp-chapter-card__name{font-size:var(--text-xs);font-weight:600;color:var(--color-text);margin:0}
.tp-chapter-card__arrow{color:var(--tp-color,var(--color-brand));font-size:var(--text-lg);font-weight:300}

.tp-links{display:flex;flex-direction:column;gap:var(--space-2)}
.tp-link{display:flex;align-items:center;gap:var(--space-2);padding:10px var(--space-4);border:1.5px solid var(--color-border);border-radius:var(--radius-md);font-size:var(--text-xs);font-weight:600;text-decoration:none;color:var(--color-text);transition:all 0.15s;background:#fff}
.tp-link:hover{border-color:var(--color-brand);color:var(--color-brand);transform:translateY(-1px)}
.tp-link--primary{background:var(--color-brand);color:#fff;border-color:var(--color-brand)}
.tp-link--primary:hover{background:var(--color-brand-dark);color:#fff;transform:translateY(-1px)}
.tp-link__icon{font-size:0.9rem}

.tp-tools{background:#fff;border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-4);box-shadow:0 1px 4px rgba(0,0,0,0.04)}
.tp-tools__title{font-size:var(--text-xs);font-weight:700;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;margin:0 0 var(--space-3)}
.tp-tools__grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-2)}
.tp-tools__item{display:flex;align-items:center;gap:4px;padding:6px 8px;border-radius:var(--radius-sm);font-size:0.65rem;font-weight:600;color:var(--color-text-muted);text-decoration:none;transition:all 0.1s}
.tp-tools__item:hover{background:rgba(15,76,58,0.04);color:var(--color-brand)}

.tp-nav{display:flex;justify-content:space-between;padding-top:var(--space-5);border-top:1px solid var(--color-border);margin-top:var(--space-6)}
.tp-nav a{font-size:var(--text-sm);color:var(--color-brand);text-decoration:none;font-weight:600}
.tp-nav a:hover{text-decoration:underline}

/* Notes-style formatting */
.tp-notes{font-size:var(--text-sm);line-height:1.85;color:var(--color-text-secondary)}
.tp-notes ul{margin:var(--space-2) 0;padding-left:var(--space-5);list-style:none}
.tp-notes li{position:relative;padding:var(--space-1) 0;padding-left:var(--space-3)}
.tp-notes li::before{content:'';position:absolute;left:0;top:11px;width:6px;height:6px;border-radius:50%;background:var(--tp-color,var(--color-brand));opacity:0.5}
.tp-notes strong,.tp-notes b{color:var(--color-text);font-weight:600}
.tp-notes .tp-highlight{background:rgba(212,160,23,0.1);padding:1px 4px;border-radius:3px;font-weight:600;color:var(--color-text)}

.tp-upsc .tp-notes ul{padding-left:var(--space-4)}
.tp-upsc .tp-notes li::before{background:var(--color-accent)}

.tp-prelims-box,.tp-mains-box{padding:var(--space-3) var(--space-4);border-radius:var(--radius-md);margin:var(--space-3) 0;font-size:var(--text-sm);line-height:1.8}
.tp-prelims-box{background:rgba(15,76,58,0.04);border-left:3px solid var(--color-brand)}
.tp-prelims-box strong{color:var(--color-brand)}
.tp-mains-box{background:rgba(124,58,237,0.04);border-left:3px solid #7c3aed}
.tp-mains-box strong{color:#7c3aed}

@media(max-width:768px){.tp-layout{grid-template-columns:1fr}.tp-sidebar{position:static}.tp-tools__grid{grid-template-columns:1fr}}
</style>

<div class="tp-bg">
  <div class="container">
    <div style="--tp-color:{{ subjectColor }};">

      {# ── Header ── #}
      <div class="tp-header">
        <nav class="tp-breadcrumb">
          <a href="/">Home</a><span>/</span>
          <a href="/resources/key-terms/">Key Terms</a><span>/</span>
          <a href="/subjects/{{ term.subject }}/">{{ subjectName }}</a><span>/</span>
          {{ term.term }}
        </nav>
        <div class="tp-meta">
          {%- for gp in term.gs_papers %}<span class="gs-badge gs-badge--{{ gp }}">{{ gp | upper }}</span>{% endfor %}
          <span class="tp-meta__tag" style="background:color-mix(in srgb,{{ subjectColor }} 12%,transparent);color:{{ subjectColor }};">{{ subjectIcon }} {{ subjectName }}</span>
        </div>
        <h1 class="tp-title">{{ term.term }}</h1>
        {% if term.pronunciation %}<span class="tp-pron">{{ term.pronunciation }}</span>{% endif %}
      </div>

      {# ── Layout ── #}
      <div class="tp-layout">

        {# ── Main ── #}
        <div>

          <p class="tp-def">{{ term.definition }}</p>

          {% if term.origin %}
          <div class="tp-section">
            <h2 class="tp-section__label">Context & Background</h2>
            <div class="tp-notes" id="tp-context">{{ term.origin }}</div>
          </div>
          {% endif %}

          {% if term.upsc %}
          <div class="tp-upsc">
            <h2 class="tp-upsc__label">UPSC Relevance</h2>
            <div class="tp-notes" id="tp-upsc">{{ term.upsc }}</div>
          </div>
          {% endif %}

          {# ── Bottom Nav ── #}
          <div class="tp-nav">
            <a href="/resources/key-terms/">&larr; All Key Terms</a>
            <a href="/upsc-checklist/">Syllabus Checklist &rarr;</a>
          </div>

        </div>

        {# ── Sidebar ── #}
        <aside class="tp-sidebar">

          {# Quick Facts #}
          <div class="tp-sb">
            <h3 class="tp-sb__title">Quick Reference</h3>
            <div class="tp-sb__row"><span class="tp-sb__label">Subject</span><span class="tp-sb__value" style="color:{{ subjectColor }};">{{ subjectIcon }} {{ subjectName }}</span></div>
            <div class="tp-sb__row"><span class="tp-sb__label">GS Paper</span><span class="tp-sb__value">{%- for gp in term.gs_papers %}{{ gp | upper }}{% if not loop.last %}, {% endif %}{% endfor %}</span></div>
            <div class="tp-sb__row"><span class="tp-sb__label">Exam</span><span class="tp-sb__value">Prelims + Mains</span></div>
            <div class="tp-sb__row"><span class="tp-sb__label">Priority</span><span class="tp-sb__value" style="color:var(--color-accent-hover);">High-yield</span></div>
          </div>

          {# Source Chapter #}
          <a href="{{ term.topicUrl }}" class="tp-chapter-card">
            <div class="tp-chapter-card__icon">{{ subjectIcon }}</div>
            <div class="tp-chapter-card__info">
              <p class="tp-chapter-card__label">Source Chapter</p>
              <p class="tp-chapter-card__name">{{ term.topicTitle | truncate(45, true) }}</p>
            </div>
            <span class="tp-chapter-card__arrow">&rarr;</span>
          </a>

          {# Actions #}
          <div class="tp-links" style="margin-bottom:var(--space-4);">
            <a href="{{ term.topicUrl }}" class="tp-link tp-link--primary"><span class="tp-link__icon">📖</span> Read Full Chapter</a>
            <a href="/subjects/{{ term.subject }}/" class="tp-link"><span class="tp-link__icon">{{ subjectIcon }}</span> All {{ subjectName }}</a>
            <a href="/resources/key-terms/" class="tp-link"><span class="tp-link__icon">📋</span> Browse All Terms</a>
          </div>

          {# Study Tools #}
          <div class="tp-tools">
            <h3 class="tp-tools__title">Study Tools</h3>
            <div class="tp-tools__grid">
              <a href="/upsc-checklist/" class="tp-tools__item">📋 Checklist</a>
              <a href="/study-kit/" class="tp-tools__item">📦 Study Kit</a>
              <a href="/pyq/" class="tp-tools__item">📊 PYQ Analysis</a>
              <a href="/resources/vocab-builder/" class="tp-tools__item">📚 Vocab</a>
              <a href="/prelims/" class="tp-tools__item">📝 Prelims</a>
              <a href="/mains/" class="tp-tools__item">✍️ Mains</a>
            </div>
          </div>

        </aside>
      </div>

    </div>
  </div>
</div>

<script>
// Auto-format flat text into UPSC notes style
(function(){
  function formatNotes(el) {
    if (!el) return;
    var text = el.textContent.trim();
    if (!text) return;

    // Split on semicolons or periods followed by space+capital (sentence boundaries)
    var parts = text.split(/;\s*(?=[A-Z])|(?<=\.)\s+(?=[A-Z][a-z])/);
    if (parts.length <= 1) {
      // Single block — just highlight key patterns
      el.innerHTML = '<p>' + highlightText(text) + '</p>';
      return;
    }

    var html = '<ul>';
    parts.forEach(function(part) {
      part = part.trim().replace(/\.$/, '');
      if (!part) return;
      html += '<li>' + highlightText(part) + '</li>';
    });
    html += '</ul>';
    el.innerHTML = html;
  }

  function formatUPSC(el) {
    if (!el) return;
    var text = el.textContent.trim();
    if (!text) return;

    // Try to split into Prelims and Mains sections
    var prelimsMatch = text.match(/Prelims[:\s—–-]+([^;]*(?:;[^M]*)?)/i);
    var mainsMatch = text.match(/Mains[:\s—–-]+(.+)/i);

    if (prelimsMatch || mainsMatch) {
      var html = '';
      // GS Paper header
      var gsMatch = text.match(/^(GS\d[^—–-]*)[—–-]/i);
      if (gsMatch) {
        html += '<p style="font-weight:700;color:var(--color-text);margin:0 0 var(--space-3);font-size:var(--text-sm);">' + gsMatch[1].trim() + '</p>';
      }

      if (prelimsMatch) {
        var prelimsText = prelimsMatch[1].trim().replace(/[;.]$/, '');
        var prelimsParts = prelimsText.split(/,\s*/);
        html += '<div class="tp-prelims-box"><strong>Prelims Focus:</strong><ul>';
        prelimsParts.forEach(function(p) {
          p = p.trim();
          if (p) html += '<li>' + highlightText(p) + '</li>';
        });
        html += '</ul></div>';
      }

      if (mainsMatch) {
        var mainsText = mainsMatch[1].trim().replace(/\.$/, '');
        // Split mains on commas that are followed by meaningful content
        var mainsParts = mainsText.split(/,\s*(?=[a-z])/i);
        if (mainsParts.length <= 1) mainsParts = [mainsText];
        html += '<div class="tp-mains-box"><strong>Mains Focus:</strong><ul>';
        mainsParts.forEach(function(p) {
          p = p.trim();
          if (p) html += '<li>' + highlightText(p) + '</li>';
        });
        html += '</ul></div>';
      }

      el.innerHTML = html;
    } else {
      formatNotes(el);
    }
  }

  function highlightText(text) {
    // Highlight Article numbers, years, key terms in parentheses
    return text
      .replace(/\b(Article\s+\d+[\w()]*)/g, '<span class="tp-highlight">$1</span>')
      .replace(/\b(\d{4})\b/g, '<span class="tp-highlight">$1</span>')
      .replace(/\b(Part\s+[IVXLC]+\w*)/g, '<span class="tp-highlight">$1</span>')
      .replace(/\b(Section\s+\d+[\w()]*)/g, '<span class="tp-highlight">$1</span>');
  }

  formatNotes(document.getElementById('tp-context'));
  formatUPSC(document.getElementById('tp-upsc'));
})();
</script>
