---
layout: base.njk
title: "Key Terms & Concepts — UPSC GS Encyclopedia"
description: "Comprehensive UPSC key terms encyclopedia — 280+ concepts with definitions, context, exam relevance, and chapter links across all GS papers."
---

<style>
/* ── Key Terms Page — 4-size type scale ──
   Title:  --text-sm (13px)  — card titles, headings
   Body:   --text-xs (12px)  — definition, context, UPSC, brief, filters, links
   Meta:   0.7rem   (11.2px) — subject tags, pronunciation
   Micro:  0.65rem  (10.4px) — UPSC label, alpha nav
*/
.kt-hero{display:flex;align-items:center;gap:var(--space-5);padding:var(--space-5);background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);margin-bottom:var(--space-6)}
.kt-hero-ring{flex-shrink:0}
.kt-ring-bg{fill:none;stroke:var(--color-border);stroke-width:6}
.kt-ring-fill{fill:none;stroke:var(--color-brand);stroke-width:6;stroke-linecap:round;transform:rotate(-90deg);transform-origin:50% 50%;transition:stroke-dashoffset 0.6s ease-out}
.kt-ring-pct{fill:var(--color-text);font-size:1.125rem;font-weight:800}
.kt-ring-sub{fill:var(--color-text-muted);font-size:0.5625rem}
.kt-hero-info{flex:1}
.kt-hero-label{font-size:var(--text-sm);font-weight:700;color:var(--color-text);margin:0 0 2px}
.kt-hero-sub{font-size:var(--text-xs);color:var(--color-text-muted);margin:0}

.kt-filters{display:flex;flex-wrap:wrap;gap:var(--space-2);margin-bottom:var(--space-3)}
.kt-filter{padding:5px 12px;border:1.5px solid var(--color-border);border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600;background:var(--color-surface);color:var(--color-text);cursor:pointer;transition:all 0.15s}
.kt-filter:hover{border-color:var(--color-brand);color:var(--color-brand)}
.kt-filter.active{background:var(--color-brand);color:#fff;border-color:var(--color-brand)}
.kt-filter--gs{border-color:var(--gs-color,var(--color-border))}
.kt-filter--gs.active{background:var(--gs-color);border-color:var(--gs-color)}

.kt-controls{display:flex;flex-wrap:wrap;gap:var(--space-3);align-items:center;margin-bottom:var(--space-4);position:sticky;top:0;z-index:10;background:var(--color-bg);padding:var(--space-3) 0;border-bottom:1px solid var(--color-border)}
.kt-search{flex:1;min-width:180px;padding:8px 14px;border:1px solid var(--color-border);border-radius:var(--radius-md);font-size:var(--text-xs);background:var(--color-surface)}
.kt-search-count{font-size:var(--text-xs);color:var(--color-text-muted)}
.kt-bulk-btn{padding:5px 12px;border:1.5px solid var(--color-border);border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600;background:none;color:var(--color-text-muted);cursor:pointer;transition:all 0.15s}
.kt-bulk-btn:hover{border-color:var(--color-brand);color:var(--color-brand)}

.kt-letter{font-family:var(--font-heading);font-size:var(--text-2xl);font-weight:800;color:var(--color-text);margin:var(--space-6) 0 var(--space-4)}

.kt-card{background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);margin-bottom:var(--space-4);padding:var(--space-5);transition:box-shadow 0.15s;position:relative}
.kt-card:hover{box-shadow:var(--shadow-md)}
.kt-card__top{display:flex;align-items:flex-start;justify-content:space-between;gap:var(--space-3);margin-bottom:var(--space-3)}
.kt-card__title-wrap{flex:1}
.kt-card__title{font-family:var(--font-heading);font-size:var(--text-xl);font-weight:700;color:var(--color-text);margin:0;display:inline}
.kt-card__badges{display:inline-flex;gap:4px;margin-left:var(--space-2);vertical-align:middle}
.kt-card__actions{display:flex;flex-direction:column;gap:var(--space-2);flex-shrink:0;align-items:flex-end}
.kt-card__link{padding:5px 14px;border:1.5px solid var(--color-brand);border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600;color:var(--color-brand);text-decoration:none;transition:all 0.15s;white-space:nowrap}
.kt-card__link:hover{background:var(--color-brand);color:#fff}
.kt-card__btn{padding:5px 14px;border:1.5px solid var(--color-border);border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600;background:none;color:var(--color-text-muted);cursor:pointer;transition:all 0.15s;white-space:nowrap}
.kt-card__btn:hover{border-color:var(--color-brand);color:var(--color-brand)}
.kt-card__btn.learned{background:var(--color-brand);color:#fff;border-color:var(--color-brand)}
.kt-card__def{font-size:var(--text-sm);line-height:1.75;color:var(--color-text-secondary);margin:0 0 var(--space-3)}
.kt-card__tags{display:flex;flex-wrap:wrap;gap:var(--space-2)}
.kt-card__tag{padding:3px 12px;border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600}

.kt-alpha{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:var(--space-4)}
.kt-alpha-btn{width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:var(--radius-sm);font-size:0.65rem;font-weight:700;text-decoration:none;border:1px solid var(--color-border);color:var(--color-text);transition:all 0.1s}
.kt-alpha-btn:hover{border-color:var(--color-brand);color:var(--color-brand)}
.kt-alpha-btn.active-letter{background:var(--color-brand);color:#fff;border-color:var(--color-brand)}
.kt-alpha-btn.disabled{opacity:0.3;pointer-events:none}

.kt-no-results{text-align:center;padding:var(--space-8);color:var(--color-text-muted);font-size:var(--text-xs)}

@media(max-width:768px){.kt-hero{flex-direction:column;text-align:center}.kt-controls{flex-direction:column;align-items:stretch}}
@media(max-width:480px){.kt-card{padding:var(--space-4)}.kt-card__title{font-size:var(--text-lg)}.kt-card__top{flex-direction:column;gap:var(--space-2)}.kt-card__actions{flex-direction:row;align-items:flex-start}}
</style>

<section class="page-header">
  <div class="container">
    <nav class="breadcrumb"><a href="/">Home</a><span class="breadcrumb__sep">/</span><a href="/resources/">Resources</a><span class="breadcrumb__sep">/</span>Key Terms</nav>
    <p class="page-header__eyebrow">Concept Encyclopedia</p>
    <h1 class="page-header__title">Key Terms & Concepts</h1>
    <p class="page-header__subtitle">{{ vocabIndex.terms | length }}+ UPSC concepts — definitions, context, and exam relevance.</p>
  </div>
</section>

<section style="padding:var(--space-8) 0;">
  <div class="container">

    {# ── Progress Ring ── #}
    <div class="kt-hero">
      <div class="kt-hero-ring">
        <svg viewBox="0 0 90 90" width="80" height="80">
          <circle class="kt-ring-bg" cx="45" cy="45" r="38"/>
          <circle class="kt-ring-fill" id="kt-ring" cx="45" cy="45" r="38" stroke-dasharray="238.76" stroke-dashoffset="238.76"/>
          <text class="kt-ring-pct" id="kt-ring-pct" x="45" y="42" dominant-baseline="central" text-anchor="middle">0%</text>
          <text class="kt-ring-sub" id="kt-ring-sub" x="45" y="55" dominant-baseline="central" text-anchor="middle">0 / {{ vocabIndex.terms | length }}</text>
        </svg>
      </div>
      <div class="kt-hero-info">
        <p class="kt-hero-label" id="kt-label">{{ vocabIndex.terms | length }} concepts to master</p>
        <p class="kt-hero-sub">Mark terms as understood. Progress saved in your browser.</p>
      </div>
    </div>

    {# ── GS Paper Filters ── #}
    <div class="kt-filters" id="kt-gs-filters">
      <button class="kt-filter active" data-gs="all">All Papers</button>
      <button class="kt-filter kt-filter--gs" data-gs="gs1" style="--gs-color:#9f1239;">GS1</button>
      <button class="kt-filter kt-filter--gs" data-gs="gs2" style="--gs-color:#7c3aed;">GS2</button>
      <button class="kt-filter kt-filter--gs" data-gs="gs3" style="--gs-color:#0369a1;">GS3</button>
      <button class="kt-filter kt-filter--gs" data-gs="gs4" style="--gs-color:#854d0e;">GS4</button>
    </div>

    {# ── Subject Filters ── #}
    <div class="kt-filters" id="kt-subj-filters">
      <button class="kt-filter active" data-subject="all">All Subjects</button>
      {% for s in subjects %}
      {%- set hasEntries = false -%}
      {%- for t in vocabIndex.terms -%}{%- if t.subject == s.slug -%}{%- set hasEntries = true -%}{%- endif -%}{%- endfor -%}
      {%- if hasEntries %}
      <button class="kt-filter" data-subject="{{ s.slug }}">{{ s.icon }} {{ s.name }}</button>
      {%- endif -%}
      {% endfor %}
    </div>

    {# ── Search + Bulk Actions ── #}
    <div class="kt-controls">
      <input type="search" id="kt-search" class="kt-search" placeholder="Search terms, definitions, concepts..." autocomplete="off">
      <span class="kt-search-count" id="kt-count"></span>
    </div>

    {# ── Alphabet Nav with # for numbers ── #}
    <nav class="kt-alpha" id="kt-alpha">
      {%- set letters = [] -%}
      {%- set hasNumbers = false -%}
      {%- for t in vocabIndex.terms -%}
        {%- set first = (t.term | upper)[0] -%}
        {%- if "0123456789" in first -%}{%- set hasNumbers = true -%}
        {%- elif first not in letters -%}{%- set letters = (letters.push(first), letters) -%}{%- endif -%}
      {%- endfor -%}
      {%- if hasNumbers -%}<a href="#kt-NUM" class="kt-alpha-btn active-letter">#</a>{%- endif -%}
      {%- for ch in "ABCDEFGHIJKLMNOPQRSTUVWXYZ" -%}
        {%- if ch in letters -%}
        <a href="#kt-{{ ch }}" class="kt-alpha-btn active-letter">{{ ch }}</a>
        {%- else -%}
        <span class="kt-alpha-btn disabled">{{ ch }}</span>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    {# ── No results ── #}
    <div class="kt-no-results" id="kt-no-results" hidden>No matching terms found.</div>

    {# ── Cards grouped by letter ── #}
    {%- set currentLetter = "" -%}
    {%- for t in vocabIndex.terms -%}
      {%- set first = (t.term | upper)[0] -%}
      {%- if "0123456789" in first -%}{%- set letter = "NUM" -%}
      {%- else -%}{%- set letter = first -%}{%- endif -%}

      {%- if letter != currentLetter -%}
        {%- if currentLetter != "" %}</div>{%- endif -%}
        {%- set currentLetter = letter -%}
    <div class="kt-letter-group" id="kt-{{ letter }}" data-letter="{{ letter }}">
      <h2 class="kt-letter{% if letter == 'NUM' %} kt-letter--num{% endif %}">{% if letter == "NUM" %}#{% else %}{{ letter }}{% endif %}</h2>
      {%- endif %}

      {%- set subjectName = t.subject -%}
      {%- set subjectIcon = "" -%}
      {%- for s in subjects -%}{%- if s.slug == t.subject -%}{%- set subjectName = s.name -%}{%- set subjectIcon = s.icon -%}{%- endif -%}{%- endfor -%}

      <div class="kt-card" data-subject="{{ t.subject }}" data-gs="{{ t.gs_papers | join(',') }}" data-term="{{ t.term | lower }}" data-def="{{ t.definition | lower }}" data-ctx="{{ t.origin | lower }}">
        <div class="kt-card__top">
          <div class="kt-card__title-wrap">
            <h3 class="kt-card__title">{{ t.term }}</h3>
            <div class="kt-card__badges">
              {%- for gp in t.gs_papers %}<span class="gs-badge gs-badge--{{ gp }}">{{ gp | upper }}</span>{% endfor %}
            </div>
          </div>
          <div class="kt-card__actions">
            <a href="/resources/key-terms/{{ t.pageSlug }}/" class="kt-card__link">Definition &rarr;</a>
            <button class="kt-card__btn" data-tid="terms-{{ t.slug }}">Revise</button>
          </div>
        </div>
        <p class="kt-card__def">{{ t.definition | truncate(180, true) }}</p>
        <div class="kt-card__tags">
          <span class="kt-card__tag" style="background:color-mix(in srgb, {{ subjectColor }} 12%, transparent);color:{{ subjectColor }};">{{ subjectName }}</span>
        </div>
      </div>

    {%- endfor -%}
    {%- if currentLetter != "" %}</div>{%- endif -%}

  </div>
</section>

<script>
(function(){
  var search = document.getElementById('kt-search');
  var countEl = document.getElementById('kt-count');
  var noResults = document.getElementById('kt-no-results');
  var cards = document.querySelectorAll('.kt-card');
  var groups = document.querySelectorAll('.kt-letter-group');
  var activeSubject = 'all';
  var activeGS = 'all';
  var total = cards.length;
  var CIRC = 2 * Math.PI * 38;

  // ── GS Paper filters (radio-style: one active at a time) ──
  document.getElementById('kt-gs-filters').addEventListener('click', function(e){
    var btn = e.target.closest('.kt-filter');
    if(!btn || !btn.dataset.gs) return;
    document.querySelectorAll('#kt-gs-filters .kt-filter').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    activeGS = btn.dataset.gs;
    applyFilters();
  });

  // ── Subject filters ──
  document.getElementById('kt-subj-filters').addEventListener('click', function(e){
    var btn = e.target.closest('.kt-filter');
    if(!btn || !btn.dataset.subject) return;
    document.querySelectorAll('#kt-subj-filters .kt-filter').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    activeSubject = btn.dataset.subject;
    applyFilters();
  });

  function applyFilters(){
    var q = (search.value||'').toLowerCase().trim();
    var shown = 0;
    cards.forEach(function(c){
      var matchSubj = activeSubject === 'all' || c.dataset.subject === activeSubject;
      var matchGS = activeGS === 'all' || c.dataset.gs.indexOf(activeGS) !== -1;
      var matchSearch = !q || c.dataset.term.indexOf(q) !== -1 || c.dataset.def.indexOf(q) !== -1 || c.dataset.ctx.indexOf(q) !== -1;
      var vis = matchSubj && matchGS && matchSearch;
      c.style.display = vis ? '' : 'none';
      if(vis) shown++;
    });
    groups.forEach(function(g){
      g.style.display = g.querySelector('.kt-card:not([style*="display: none"])') ? '' : 'none';
    });
    countEl.textContent = q ? shown + ' found' : shown < total ? shown + ' shown' : '';
    noResults.hidden = shown > 0;
  }

  search.addEventListener('input', applyFilters);

  // ── Learn toggle ──
  var learned = JSON.parse(localStorage.getItem('bn_terms_learned')||'[]');

  function updateProgress(){
    var pct = total ? Math.round(learned.length/total*100) : 0;
    document.getElementById('kt-ring').setAttribute('stroke-dashoffset', CIRC-(pct/100)*CIRC);
    document.getElementById('kt-ring-pct').textContent = pct+'%';
    document.getElementById('kt-ring-sub').textContent = learned.length+' / '+total;
    document.getElementById('kt-label').textContent = learned.length > 0 ? learned.length+' of '+total+' understood' : total+' concepts to master';
    localStorage.setItem('bn_terms_learned', JSON.stringify(learned));
  }

  document.querySelectorAll('.kt-card__btn').forEach(function(btn){
    var id = btn.dataset.tid;
    if(learned.indexOf(id)!==-1){btn.classList.add('learned');btn.textContent='Understood \u2713';}
    btn.addEventListener('click',function(){
      var idx = learned.indexOf(id);
      if(idx===-1){learned.push(id);btn.classList.add('learned');btn.textContent='Understood \u2713';}
      else{learned.splice(idx,1);btn.classList.remove('learned');btn.textContent='Mark understood';}
      updateProgress();
    });
  });
  updateProgress();
})();
</script>
