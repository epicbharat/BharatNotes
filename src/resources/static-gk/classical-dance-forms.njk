    {# ══ SNA OVERVIEW ══ #}
    <div class="gk-section">
      <h2 class="gk-section-title">🎭 Sangeet Natak Akademi — Overview</h2>

      <div class="gk-scroll">
        <table class="gk-table">
          <thead>
            <tr><th>Parameter</th><th>Detail</th></tr>
          </thead>
          <tbody>
            <tr><td>Established</td><td>31 May 1952 (set up); inaugurated by President Rajendra Prasad on <strong>28 January 1953</strong></td></tr>
            <tr><td>Under</td><td>Ministry of Culture, Government of India (autonomous body)</td></tr>
            <tr><td>Classical dances recognised</td><td><strong>8</strong> — Bharatanatyam, Kathak, Odissi, Kuchipudi, Kathakali, Mohiniyattam, Manipuri, Sattriya</td></tr>
            <tr><td>Foundational text</td><td><em>Natya Shastra</em> — attributed to sage Bharata Muni; composed ~200 BCE–200 CE; ~6,000 verses; covers drama, dance, music, rasa theory</td></tr>
            <tr><td>"Mother of classical dances"</td><td><strong>Bharatanatyam</strong></td></tr>
            <tr><td>Newest classical dance</td><td><strong>Sattriya</strong> — granted classical status November <strong>2000</strong></td></tr>
          </tbody>
        </table>
      </div>
