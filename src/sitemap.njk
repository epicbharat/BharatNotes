---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  {# ── GS Topic Pages ── #}
  {%- for page in collections.allTopics %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ page.date | isoDate }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {%- endfor %}

  {# ── NCERT Chapter Pages ── #}
  {%- for page in collections.all %}
  {%- if page.data.layout == "ncert-chapter.njk" and not page.data.robotsMeta %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ page.date | isoDate }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {%- endif %}
  {%- endfor %}

  {# ── NCERT Index Pages (book + class hub) ── #}
  {%- for page in collections.all %}
  {%- if page.data.layout == "ncert-index.njk" %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ page.date | isoDate }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {%- endif %}
  {%- endfor %}

  {# ── Subject Listing Pages ── #}
  {%- for s in subjects %}
  <url>
    <loc>{{ site.url }}/subjects/{{ s.slug }}/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {%- endfor %}

  {# ── Static hub & utility pages ── #}
  <url><loc>{{ site.url }}/subjects/</loc><changefreq>weekly</changefreq><priority>0.9</priority></url>
  <url><loc>{{ site.url }}/ncert/</loc><changefreq>weekly</changefreq><priority>0.9</priority></url>
  <url><loc>{{ site.url }}/prelims/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/mains/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/pyq/</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/gs1/</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/gs2/</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/gs3/</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/gs4/</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/essay/</loc><changefreq>monthly</changefreq><priority>0.6</priority></url>
  <url><loc>{{ site.url }}/interview/</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/start-here/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/about/</loc><changefreq>monthly</changefreq><priority>0.5</priority></url>
  <url><loc>{{ site.url }}/privacy/</loc><changefreq>yearly</changefreq><priority>0.3</priority></url>
  <url><loc>{{ site.url }}/disclaimer/</loc><changefreq>yearly</changefreq><priority>0.3</priority></url>
</urlset>
