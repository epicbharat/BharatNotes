<script>
(function(){
  // Accordion toggle
  document.getElementById('pr-subjects').addEventListener('click', function(e){
    var head = e.target.closest('.pr-subj__head');
    if(!head) return;
    var id = head.dataset.toggle;
    var body = document.getElementById(id);
    var arrow = head.querySelector('.pr-subj__arrow');
    if(body){body.classList.toggle('open');}
    if(arrow){arrow.classList.toggle('open');}
  });
  // Auto-expand first subject
  var first = document.querySelector('.pr-subj__body');
  var firstArrow = document.querySelector('.pr-subj__arrow');
  if(first){first.classList.add('open');if(firstArrow)firstArrow.classList.add('open');}

  // Checklist progress ring
  try{
    var state=JSON.parse(localStorage.getItem('bharatnotes_upsc_checklist')||'{}');
    var keys=Object.keys(state);
    var done=0,total=224;
    keys.forEach(function(k){if(k.indexOf('prelims-gs/')===0)done++;});
    var pct=total?Math.round(done/total*100):0;
    var circ=2*Math.PI*34;
    document.getElementById('pr-ring').setAttribute('stroke-dashoffset',circ-(pct/100)*circ);
    document.getElementById('pr-ring-pct').textContent=pct+'%';
    document.getElementById('pr-ring-sub').textContent=done+'/'+total;
    if(done>0)document.getElementById('pr-label').textContent=done+' of '+total+' Prelims topics covered';
  }catch(e){}
})();
</script>
