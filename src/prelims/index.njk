.pr-stat--accent .pr-stat__num{color:var(--color-accent-hover)}
.pr-stat--danger .pr-stat__num{color:var(--color-error,#dc2626)}
.pr-note{display:flex;align-items:flex-start;gap:var(--space-3);padding:var(--space-4) var(--space-5);background:rgba(15,76,58,0.04);border:1px solid var(--color-border);border-left:4px solid var(--color-brand);border-radius:var(--radius-md);font-size:var(--text-sm);line-height:1.6;margin-bottom:var(--space-6)}
.pr-progress{display:flex;align-items:center;gap:var(--space-4);padding:var(--space-4) var(--space-5);background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-md);margin-bottom:var(--space-6)}
.pr-progress__ring{flex-shrink:0}
.pr-ring-bg{fill:none;stroke:var(--color-border);stroke-width:6}
.pr-ring-fill{fill:none;stroke:var(--color-brand);stroke-width:6;stroke-linecap:round;transform:rotate(-90deg);transform-origin:50% 50%;transition:stroke-dashoffset 0.6s ease-out}
.pr-ring-pct{fill:var(--color-text);font-size:16px;font-weight:800}
.pr-ring-sub{fill:var(--color-text-muted);font-size:8px}
.pr-progress__info{flex:1}
.pr-progress__label{font-size:var(--text-sm);font-weight:700;color:var(--color-text);margin:0 0 2px}
.pr-progress__sub{font-size:var(--text-xs);color:var(--color-text-muted);margin:0}
.pr-progress__link{font-size:var(--text-xs);color:var(--color-brand);font-weight:600;text-decoration:none}
.pr-progress__link:hover{text-decoration:underline}
.pr-subj{background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:var(--space-4);transition:box-shadow 0.2s}
.pr-subj:hover{box-shadow:var(--shadow-sm)}
.pr-subj__head{display:flex;align-items:center;gap:var(--space-3);padding:var(--space-3) var(--space-4);border-left:4px solid var(--pr-color,var(--color-brand));cursor:pointer;user-select:none}
.pr-subj__icon{font-size:1.2rem;flex-shrink:0}
.pr-subj__info{flex:1;min-width:0}
.pr-subj__title{font-size:var(--text-sm);font-weight:600;color:var(--color-text);margin:0}
.pr-subj__meta{font-size:0.6rem;color:var(--color-text-muted)}
.pr-subj__pct{font-size:var(--text-xs);font-weight:700;color:var(--pr-color);min-width:32px;text-align:right}
.pr-subj__arrow{color:var(--color-text-muted);transition:transform 0.2s;flex-shrink:0}
.pr-subj__arrow.open{transform:rotate(180deg)}
.pr-subj__body{display:none;padding:0 var(--space-4) var(--space-3) calc(var(--space-4) + 4px);border-top:1px solid var(--color-border-light,rgba(0,0,0,0.06))}
.pr-subj__body.open{display:block}
.pr-subj__links{display:flex;flex-wrap:wrap;gap:var(--space-2);padding-top:var(--space-3)}
.pr-subj__link{display:inline-flex;align-items:center;gap:4px;padding:5px 12px;border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600;text-decoration:none;border:1.5px solid var(--pr-color,var(--color-brand));color:var(--pr-color,var(--color-brand));background:transparent;transition:all 0.15s}
.pr-subj__link:hover{background:var(--pr-color,var(--color-brand));color:#fff}
.pr-subj__link-count{font-size:0.55rem;opacity:0.7}
.pr-csat{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:var(--space-4);margin-bottom:var(--space-6)}
.pr-csat-card{padding:var(--space-4);background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-md);border-top:3px solid #6366f1}
.pr-csat-card h4{font-size:var(--text-sm);font-weight:700;color:#6366f1;margin:0 0 var(--space-2)}
.pr-csat-card p{font-size:var(--text-xs);color:var(--color-text-muted);line-height:1.5;margin:0}
.pr-strategy{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-4);margin-bottom:var(--space-6)}
.pr-tip{display:flex;gap:var(--space-3);padding:var(--space-4);background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-md)}
.pr-tip__icon{font-size:1.2rem;flex-shrink:0;margin-top:2px}
.pr-tip__title{font-size:var(--text-sm);font-weight:700;color:var(--color-text);margin:0 0 4px}
.pr-tip__desc{font-size:var(--text-xs);color:var(--color-text-muted);line-height:1.5;margin:0}
.pr-tip__desc a{color:var(--color-brand);font-weight:600}
.pr-tools{display:flex;flex-wrap:wrap;gap:var(--space-3);margin-bottom:var(--space-6)}
.pr-tool{display:inline-flex;align-items:center;gap:var(--space-2);padding:8px 16px;border:1.5px solid var(--color-border);border-radius:var(--radius-full,999px);font-size:var(--text-xs);font-weight:600;text-decoration:none;color:var(--color-text);transition:all 0.15s}
.pr-tool:hover{border-color:var(--color-brand);color:var(--color-brand);transform:translateY(-1px)}
.pr-tool--accent{border-color:var(--color-accent);color:var(--color-accent-hover)}
.pr-tool--accent:hover{background:var(--color-accent);color:#fff}
@media(max-width:480px){.pr-stats{grid-template-columns:repeat(2,1fr)}.pr-csat{grid-template-columns:1fr}.pr-strategy{grid-template-columns:1fr}.pr-progress{flex-direction:column;text-align:center}}
</style>

