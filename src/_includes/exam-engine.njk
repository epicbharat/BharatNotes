<style>
/* ══ Exam Engine — ee- namespace ═══════════════════════════════════
   Reads: window.EXAM_DATA, window.EXAM_CONFIG
   Modes: all-subjects | single-subject | chapter
══════════════════════════════════════════════════════════════════ */

/* ── Setup hero ─────────────────────────────────────────────── */
.ee-hero{
  background:linear-gradient(135deg,#0a1f18 0%,#0f2e24 60%,#1a3d2f 100%);
  padding:var(--space-12) 0 var(--space-10);
  position:relative;overflow:hidden;
}
.ee-hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 70% 50%,rgba(212,160,23,.08) 0%,transparent 60%);
  pointer-events:none;
}
.ee-hero .breadcrumb a,.ee-hero .breadcrumb{color:rgba(255,255,255,.45);}
.ee-hero .breadcrumb__sep{color:rgba(255,255,255,.25);}
.ee-hero__inner{position:relative;z-index:1;}
.ee-hero__kicker{
  display:inline-flex;align-items:center;gap:7px;
  font-size:0.65rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;
  color:#d4a017;border:1px solid rgba(212,160,23,.35);
  background:rgba(212,160,23,.1);border-radius:100px;
  padding:4px 12px;margin-bottom:var(--space-4);
}
.ee-hero h1{
  font-family:var(--font-serif);font-size:clamp(1.8rem,4vw,2.8rem);
  color:#fff;margin:0 0 var(--space-3);line-height:1.2;
}
.ee-hero h1 em{color:#d4a017;font-style:italic;}
.ee-hero p{color:rgba(255,255,255,.6);font-size:var(--text-sm);margin:0;max-width:560px;}
.ee-hero__meta{
  display:flex;gap:var(--space-6);margin-top:var(--space-5);
  flex-wrap:wrap;
}
.ee-hero__meta-item{
  display:flex;align-items:center;gap:6px;
  font-size:var(--text-xs);color:rgba(255,255,255,.55);
}
.ee-hero__meta-item svg{color:rgba(255,255,255,.35);}
.ee-hero__links{
  display:flex;gap:10px;flex-wrap:wrap;margin-top:var(--space-5);
}
.ee-hero__link{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.13);
  border-radius:10px;padding:9px 14px;
  font-size:var(--text-xs);font-weight:600;color:rgba(255,255,255,.85);
  text-decoration:none;cursor:pointer;transition:background .18s,border-color .18s;
  flex-shrink:0;
}
.ee-hero__link:hover{ background:rgba(255,255,255,.14);border-color:rgba(255,255,255,.25);color:#fff; }
.ee-hero__link svg{ flex-shrink:0;color:rgba(255,255,255,.5); }
.ee-hero__link-badge{
  font-size:0.6rem;font-weight:800;letter-spacing:.04em;text-transform:uppercase;
  padding:2px 7px;border-radius:100px;
}
.ee-hero__link-badge--official{ background:rgba(20,185,130,.22);color:#6ee7b7;border:1px solid rgba(52,211,153,.3); }
.ee-hero__link-badge--soon{ background:rgba(255,255,255,.1);color:rgba(255,255,255,.45);border:1px solid rgba(255,255,255,.15); }
.ee-hero__link--disabled{ opacity:.6;pointer-events:none; }

/* ── Setup body ─────────────────────────────────────────────── */
.ee-setup-body{background:var(--color-bg,#f5f5f0);padding:var(--space-8) 0 var(--space-16);}
.ee-setup-card{
  background:#fff;
  border:1px solid #e5e7eb;
  border-radius:16px;
  padding:var(--space-5) var(--space-6);
  margin-bottom:var(--space-4);
  box-shadow:0 1px 3px rgba(0,0,0,.04),0 1px 8px rgba(0,0,0,.03);
}
.ee-section-label{
  font-size:0.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;
  color:var(--color-text-muted);margin:0 0 var(--space-4);
  display:flex;align-items:center;gap:10px;
}
.ee-section-label::after{content:'';flex:1;height:1px;background:#f0f0ec;}

/* ── Size cards ── */
.ee-size-row{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-3);margin:0;}
.ee-size-card{
  border:2px solid #e5e7eb;border-radius:12px;
  padding:var(--space-5) var(--space-3);cursor:pointer;transition:all .18s;
  background:#fafafa;text-align:center;user-select:none;position:relative;overflow:hidden;
}
.ee-size-card:hover{
  border-color:var(--color-brand);background:#fff;
  box-shadow:0 4px 20px rgba(15,76,58,.1);transform:translateY(-1px);
}
/* Selected: solid brand fill + white text */
.ee-size-card.selected{
  border-color:var(--color-brand);background:var(--color-brand);
  box-shadow:0 4px 20px rgba(15,76,58,.25);
}
.ee-size-card.selected .ee-size-card__num{color:#fff;}
.ee-size-card.selected .ee-size-card__label{color:rgba(255,255,255,.7);}
.ee-size-card.selected .ee-size-card__sub{background:rgba(255,255,255,.15);color:rgba(255,255,255,.85);}
/* Checkmark badge on selected */
.ee-size-card.selected::after{
  content:'✓';
  position:absolute;top:8px;right:10px;
  font-size:10px;font-weight:900;color:rgba(255,255,255,.7);
}
.ee-size-card__num{display:block;font-size:2.4rem;font-weight:900;color:var(--color-brand);line-height:1;transition:color .18s;}
.ee-size-card__label{display:block;font-size:var(--text-xs);color:var(--color-text-muted);margin-top:3px;transition:color .18s;}
.ee-size-card__sub{
  display:inline-flex;align-items:center;gap:4px;
  font-size:0.6rem;font-weight:600;color:var(--color-text-muted);margin-top:var(--space-2);
  background:#f0f0ec;padding:2px 8px;border-radius:100px;transition:all .18s;
}

/* ── Subject grid ── */
.ee-subj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(172px,1fr));gap:var(--space-2);}
.ee-subj-check{
  display:flex;align-items:center;gap:var(--space-2);
  padding:10px 12px;
  border:1.5px solid #e5e7eb;border-radius:10px;
  cursor:pointer;font-size:var(--text-xs);font-weight:600;
  transition:all .12s;user-select:none;
  background:#fafafa;border-left-width:3px;
}
.ee-subj-check input{width:14px;height:14px;cursor:pointer;accent-color:var(--color-brand);flex-shrink:0;}
.ee-subj-check:hover{background:#fff;box-shadow:0 2px 8px rgba(0,0,0,.07);}
.ee-subj-check.checked{background:#fff;}
.ee-subj-check__name{flex:1;line-height:1.3;}
.ee-subj-check__count{
  font-size:0.58rem;font-weight:700;color:var(--color-text-muted);
  background:#f0f0ec;padding:2px 6px;border-radius:100px;flex-shrink:0;min-width:22px;text-align:center;
}

/* ── Name input ── */
.ee-name-input-wrap{display:flex;flex-direction:column;gap:6px;}
.ee-name-input-wrap input{
  width:100%;padding:11px 14px;
  border:1.5px solid #e5e7eb;border-radius:10px;
  font-size:var(--text-sm);font-family:inherit;
  outline:none;transition:border-color .12s,box-shadow .12s;
  background:#fafafa;color:var(--color-text);
  box-sizing:border-box;
}
.ee-name-input-wrap input:focus{border-color:var(--color-brand);background:#fff;box-shadow:0 0 0 3px rgba(15,76,58,.08);}
.ee-name-hint{font-size:0.62rem;color:var(--color-text-muted);}

/* ── Current Affairs card ── */
.ee-ca-header{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:8px;margin-bottom:var(--space-4);
}
.ee-ca-powered{
  display:inline-flex;align-items:center;gap:6px;
  font-size:0.62rem;font-weight:700;color:var(--color-text-muted);
  text-decoration:none;
}
.ee-ca-powered svg{ flex-shrink:0; }
.ee-ca-powered:hover{ color:var(--color-brand); }
.ee-ca-count-row{ display:flex;gap:8px;flex-wrap:wrap;margin-bottom:0; }
.ee-ca-chip{
  border:1.5px solid #e5e7eb;border-radius:8px;
  background:#fafafa;color:var(--color-text-muted);
  font-size:var(--text-xs);font-weight:700;
  padding:7px 14px;cursor:pointer;transition:all .15s;
}
.ee-ca-chip:hover{ border-color:var(--color-brand);color:var(--color-brand); }
.ee-ca-chip.active{
  background:var(--color-brand);border-color:var(--color-brand);color:#fff;
}
.ee-ca-months-wrap{
  margin-top:var(--space-4);
  border-top:1px solid #f0f0ec;
  padding-top:var(--space-3);
}
.ee-ca-status{
  font-size:var(--text-xs);color:var(--color-text-muted);
  display:flex;align-items:center;gap:7px;
}
.ee-ca-status--error{ color:#dc2626; }
.ee-ca-months{ display:flex;flex-direction:column;gap:6px;margin-top:var(--space-3); }
.ee-ca-month{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;
  border:1.5px solid #e5e7eb;border-radius:10px;
  cursor:pointer;transition:border-color .15s;
  font-size:var(--text-xs);font-weight:600;
}
.ee-ca-month:hover{ border-color:var(--color-brand); }
.ee-ca-month input[type=checkbox]{ accent-color:var(--color-brand);width:15px;height:15px;flex-shrink:0;cursor:pointer; }
.ee-ca-month__label{ flex:1; }
.ee-ca-month__count{
  font-size:0.6rem;font-weight:700;padding:2px 8px;border-radius:100px;
  background:#f0f7f4;color:var(--color-brand);white-space:nowrap;
}
/* Loading spinner (reuse for CA) */
.ee-ca-spinner{
  width:13px;height:13px;border:2px solid #e5e7eb;border-top-color:var(--color-brand);
  border-radius:50%;animation:ee-spin .7s linear infinite;flex-shrink:0;
}
@keyframes ee-spin{ to{ transform:rotate(360deg); } }
/* Toast */
.ee-toast{
  position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);
  background:#1c1917;color:#fff;font-size:var(--text-xs);font-weight:600;
  padding:10px 18px;border-radius:100px;
  box-shadow:0 4px 20px rgba(0,0,0,.25);
  opacity:0;pointer-events:none;transition:opacity .25s,transform .25s;
  z-index:9999;white-space:nowrap;
}
.ee-toast.show{ opacity:1;transform:translateX(-50%) translateY(0); }

/* ── Launch row (preview + button) ── */
.ee-launch-card{
  background:#fff;border:1px solid #e5e7eb;border-radius:16px;
  padding:var(--space-5) var(--space-6);margin-bottom:var(--space-4);
  box-shadow:0 1px 3px rgba(0,0,0,.04);
  display:flex;align-items:center;justify-content:space-between;
  gap:var(--space-4);flex-wrap:wrap;
}
.ee-preview{
  flex:1;min-width:0;
  display:flex;align-items:center;flex-wrap:wrap;gap:var(--space-3);
}
.ee-preview-text{font-size:var(--text-sm);color:var(--color-text);font-weight:600;}
.ee-preview-text strong{color:var(--color-brand);}
.ee-preview-pills{display:flex;gap:var(--space-2);flex-wrap:wrap;}
.ee-preview-pill{
  font-size:0.62rem;font-weight:700;padding:3px 9px;border-radius:100px;
  background:rgba(15,76,58,.08);color:var(--color-brand);white-space:nowrap;
}

/* Start button */
.ee-start-btn{
  flex-shrink:0;
  display:inline-flex;align-items:center;gap:var(--space-2);
  padding:13px 28px;background:var(--color-brand);color:#fff;
  border:none;border-radius:10px;
  font-size:var(--text-sm);font-weight:800;cursor:pointer;
  transition:all .15s;letter-spacing:.01em;
  box-shadow:0 3px 14px rgba(15,76,58,.3);white-space:nowrap;
}
.ee-start-btn:hover{background:var(--color-brand-dark);transform:translateY(-1px);box-shadow:0 6px 20px rgba(15,76,58,.38);}
.ee-start-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}

/* ── Exam Header ────────────────────────────────────────────── */
.ee-hd{
  position:sticky;top:60px;z-index:200;
  background:#0f2e24;color:#fff;
  display:flex;align-items:center;height:54px;
  padding:0 var(--space-4);gap:10px;
  box-shadow:0 2px 16px rgba(0,0,0,.3);
  flex-shrink:0;
}
.ee-exit{
  background:none;border:1px solid rgba(255,255,255,.25);color:rgba(255,255,255,.8);
  cursor:pointer;font-size:var(--text-xs);font-weight:700;
  padding:4px 10px;border-radius:4px;
  display:flex;align-items:center;gap:4px;white-space:nowrap;flex-shrink:0;
  transition:all .12s;
}
.ee-exit:hover{background:rgba(255,255,255,.12);color:#fff;}
.ee-vdiv{width:1px;height:22px;background:rgba(255,255,255,.18);flex-shrink:0;}
.ee-subj-wrap{display:flex;align-items:center;gap:6px;overflow:hidden;}
.ee-subj-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;border:1.5px solid rgba(255,255,255,.4);}
.ee-subj-name{font-size:var(--text-xs);font-weight:600;color:rgba(255,255,255,.85);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:150px;}
.ee-qnum{font-size:var(--text-sm);font-weight:800;color:#fff;white-space:nowrap;flex-shrink:0;}
.ee-hd-spacer{flex:1;}
.ee-timer{
  font-family:monospace;font-size:1rem;font-weight:900;color:#fff;
  min-width:68px;text-align:center;flex-shrink:0;
  background:rgba(0,0,0,.25);padding:4px 10px;border-radius:6px;letter-spacing:.04em;
}
.ee-timer.warn{color:#fca5a5;animation:eeTimerPulse 1s infinite;}
@keyframes eeTimerPulse{0%,100%{opacity:1;}50%{opacity:.45;}}
.ee-pal-btn{
  display:flex;align-items:center;gap:5px;
  background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);
  color:#fff;cursor:pointer;border-radius:6px;
  font-size:var(--text-xs);font-weight:700;padding:5px 10px;flex-shrink:0;
  transition:background .12s;
}
.ee-pal-btn:hover{background:rgba(255,255,255,.22);}
.ee-submit-hd{
  background:#d4a017;color:#1a0a00;
  border:none;border-radius:6px;
  font-size:var(--text-xs);font-weight:800;padding:6px 14px;
  cursor:pointer;white-space:nowrap;flex-shrink:0;
  transition:opacity .12s;
}
.ee-submit-hd:hover{opacity:.85;}

/* ── Progress bar ───────────────────────────────────────────── */
.ee-prog{height:3px;background:rgba(15,46,36,.15);position:sticky;top:114px;z-index:199;}
.ee-prog-fill{height:100%;background:#d4a017;transition:width .4s;}

/* ── Exam body ──────────────────────────────────────────────── */
.ee-body{
  display:flex;gap:var(--space-5);
  padding:var(--space-6) var(--space-5) 90px;
  max-width:1240px;margin:0 auto;
  align-items:flex-start;
  min-height:calc(100vh - 54px - 3px - 58px);
}
.ee-main{flex:1;min-width:0;max-width:780px;}

/* ── Single question card ───────────────────────────────────── */
.ee-q-card{
  background:#fff;
  border:1px solid #e5e7eb;
  border-radius:16px;
  padding:var(--space-6) var(--space-8);
  box-shadow:0 2px 12px rgba(0,0,0,.05);
}
.ee-q-meta{
  display:flex;align-items:center;flex-wrap:wrap;gap:var(--space-2);
  margin-bottom:var(--space-5);padding-bottom:var(--space-4);
  border-bottom:1px solid #f0f0ec;
}
.ee-q-badge{font-size:0.62rem;font-weight:800;padding:3px 10px;border-radius:100px;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap;}
.ee-q-badge--num{background:#0f2e24;color:#fff;}
.ee-q-badge--year{background:#f5f5f0;color:#6b7280;border:1px solid #e5e7eb;}
.ee-q-badge--subj{color:#fff;font-size:0.6rem;}
.ee-q-badge--topic{background:transparent;color:#9ca3af;font-size:var(--text-xs);font-weight:500;padding:0;text-transform:none;letter-spacing:0;}

/* Question text — Crimson Pro for exam-paper feel */
.ee-q-stem{
  font-family:var(--font-serif);font-size:1.22rem;line-height:1.85;
  color:#1c1917;margin-bottom:var(--space-4);
}
.ee-q-stmts{
  margin:0 0 var(--space-4);
  padding:var(--space-3) var(--space-4);
  background:#f9faf8;border-radius:10px;border:1px solid #e8ede9;
  list-style:none;counter-reset:stmt;
}
.ee-q-stmts li{
  font-family:var(--font-serif);font-size:1.15rem;line-height:1.75;color:#292524;
  padding:5px 0;display:flex;gap:10px;align-items:baseline;
  counter-increment:stmt;
}
.ee-q-stmts li::before{
  content:counter(stmt)'.';font-family:var(--font-body);
  font-weight:700;color:#0f4c3a;flex-shrink:0;min-width:20px;font-size:0.82rem;
}
.ee-q-tail{
  font-family:var(--font-serif);font-size:1.15rem;color:#1c1917;
  margin:0 0 var(--space-4);font-weight:600;
}
.ee-q-ar{
  font-family:var(--font-serif);font-size:1.15rem;line-height:1.8;
  margin-bottom:var(--space-3);
  padding:var(--space-3) var(--space-4);
  background:#f9faf8;border-radius:10px;
  border-left:3px solid #0f4c3a;color:#292524;
}
.ee-q-ar strong{color:#0c0a09;font-family:var(--font-body);font-size:0.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;}
.ee-q-ar-note{font-size:var(--text-sm);color:#9ca3af;margin:var(--space-2) 0 var(--space-4);}

/* Options */
.ee-opts{display:flex;flex-direction:column;gap:10px;}
.ee-opt{
  display:flex;align-items:center;gap:var(--space-3);
  padding:14px 18px;
  border:1.5px solid #e8e8e4;border-radius:10px;
  cursor:pointer;transition:all .15s;
  user-select:none;background:#fff;
}
.ee-opt input{display:none;}
.ee-opt__letter{
  font-weight:800;color:#adb5bd;flex-shrink:0;
  width:32px;height:32px;border-radius:8px;
  background:#f4f4f0;border:1.5px solid #e5e7eb;
  display:flex;align-items:center;justify-content:center;
  font-size:0.75rem;transition:all .15s;
}
.ee-opt__text{flex:1;color:#292524;font-family:var(--font-serif);font-size:1.12rem;line-height:1.4;}
.ee-opt:hover{border-color:#b8d4c8;background:#fafffe;box-shadow:0 2px 8px rgba(15,76,58,.06);}
.ee-opt:hover .ee-opt__letter{border-color:#b8d4c8;color:#2d7a5f;background:#eef7f3;}
.ee-opt.selected{border-color:#3d9970;border-width:2px;background:#f0faf5;box-shadow:0 2px 12px rgba(15,76,58,.1);}
.ee-opt.selected .ee-opt__letter{background:#2d7a5f;border-color:#2d7a5f;color:#fff;}
.ee-opt.selected .ee-opt__text{color:#0f2e24;font-weight:600;}

/* ── Exam Footer (fixed) ────────────────────────────────────── */
.ee-footer{
  position:fixed;bottom:0;left:0;right:0;z-index:200;
  background:#fff;
  border-top:1px solid #e5e7eb;
  box-shadow:0 -4px 20px rgba(0,0,0,.07);
  display:flex;align-items:center;justify-content:center;
  padding:10px 24px;gap:0;
  min-height:58px;
}
.ee-footer__sep{
  width:1px;height:26px;background:#e5e7eb;
  margin:0 var(--space-3);flex-shrink:0;
}
.ee-footer__center{
  display:flex;align-items:center;gap:var(--space-2);
}
.ee-btn{
  border:none;border-radius:10px;
  font-size:var(--text-xs);font-weight:700;cursor:pointer;
  padding:10px 16px;transition:all .12s;white-space:nowrap;
  display:inline-flex;align-items:center;gap:6px;
}
.ee-btn--prev{background:#f5f5f0;color:#6b7280;border:1.5px solid #e5e7eb;}
.ee-btn--prev:hover{background:#e9e9e4;color:#374151;}
.ee-btn--clear{background:#fff;color:#6b7280;border:1.5px solid #e5e7eb;}
.ee-btn--clear:hover{background:#f9f9f9;border-color:#9ca3af;color:#374151;}
.ee-btn--mark{background:#f5f3ff;color:#7c3aed;border:1.5px solid #ddd6fe;}
.ee-btn--mark:hover{background:#ede9fe;border-color:#c4b5fd;}
.ee-btn--save{background:var(--color-brand);color:#fff;padding:10px 22px;box-shadow:0 2px 10px rgba(15,76,58,.25);}
.ee-btn--save:hover{background:var(--color-brand-dark);box-shadow:0 4px 14px rgba(15,76,58,.35);}
.ee-footer__right{display:flex;gap:var(--space-2);align-items:center;}

/* ── Sidebar palette (desktop) ──────────────────────────────── */
.ee-sidebar{
  width:340px;flex-shrink:0;
  position:sticky;top:132px;
  align-self:flex-start;
  background:var(--color-surface);
  border:1px solid var(--color-border);
  border-radius:var(--radius-lg);
  overflow:hidden;
  max-height:calc(100vh - 155px);
  display:flex;flex-direction:column;
  box-shadow:var(--shadow-sm);
  overflow:hidden;
}
.ee-sidebar__head{
  padding:10px var(--space-4);
  background:#0f2e24;
  color:rgba(255,255,255,.9);
  font-size:var(--text-xs);font-weight:700;
  text-transform:uppercase;letter-spacing:.06em;
  flex-shrink:0;
}
.ee-sidebar__body{overflow-y:auto;padding:var(--space-3) var(--space-4);flex:1;min-height:0;}
.ee-sidebar__stats{
  padding:var(--space-3) var(--space-4);
  border-top:1px solid #e5e7eb;
  background:#f9f9f6;
  display:flex;gap:var(--space-1);
  flex-shrink:0;
}
.ee-stat-mini{text-align:center;flex:1;padding:var(--space-2) 0;}
.ee-stat-mini__n{display:block;font-size:var(--text-base);font-weight:900;line-height:1.2;}
.ee-stat-mini__l{display:block;font-size:0.55rem;color:#9ca3af;margin-top:3px;text-transform:uppercase;letter-spacing:.04em;font-weight:700;}

/* Legend */
.ee-legend{margin-bottom:var(--space-3);}
.ee-legend-item{display:flex;align-items:center;gap:7px;font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:5px;}
.ee-legend-chip{
  width:22px;height:22px;border-radius:4px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:9px;font-weight:800;
}

/* Palette grid */
.ee-palette{display:grid;grid-template-columns:repeat(8,1fr);gap:4px;margin-bottom:var(--space-3);}
.ee-pal-q{
  width:100%;aspect-ratio:1;border:1.5px solid transparent;
  border-radius:5px;font-size:var(--text-xs);font-weight:700;
  cursor:pointer;transition:all .1s;position:relative;
}
.ee-pal-q--not-visited{background:#e9eaeb;color:#9ca3af;border-color:#e9eaeb;}
.ee-pal-q--not-answered{background:#fee2e2;color:#dc2626;border-color:#fca5a5;}
.ee-pal-q--answered{background:#dcfce7;color:#15803d;border-color:#86efac;}
.ee-pal-q--marked{background:#ede9fe;color:#7c3aed;border-color:#c4b5fd;}
.ee-pal-q--answered-marked{background:#7c3aed;color:#fff;border-color:#7c3aed;}
.ee-pal-q--answered-marked::after{
  content:'';position:absolute;top:2px;right:2px;
  width:5px;height:5px;border-radius:50%;background:#4ade80;
  border:1px solid rgba(255,255,255,.5);
}
.ee-pal-q--active{outline:2.5px solid #0f2e24;outline-offset:2px;z-index:1;position:relative;}
.ee-pal-q:hover{filter:brightness(.92);transform:scale(1.08);z-index:1;}

/* ── Mobile drawer ──────────────────────────────────────────── */
.ee-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:300;
  opacity:0;pointer-events:none;transition:opacity .22s;
}
.ee-overlay.open{opacity:1;pointer-events:all;}
.ee-drawer{
  position:fixed;right:0;top:0;bottom:0;width:272px;z-index:301;
  background:var(--color-surface);
  box-shadow:-6px 0 24px rgba(0,0,0,.18);
  display:flex;flex-direction:column;
  transform:translateX(100%);transition:transform .24s cubic-bezier(.4,0,.2,1);
  overflow:hidden;
}
.ee-drawer.open{transform:translateX(0);}
.ee-drawer__head{
  display:flex;align-items:center;justify-content:space-between;
  padding:12px var(--space-4);
  background:#0f2e24;color:#fff;
  font-size:var(--text-sm);font-weight:700;flex-shrink:0;
}
.ee-drawer__close{background:none;border:none;color:rgba(255,255,255,.7);font-size:1.1rem;cursor:pointer;padding:2px 6px;line-height:1;transition:color .1s;}
.ee-drawer__close:hover{color:#fff;}
.ee-drawer__body{overflow-y:auto;padding:var(--space-4);flex:1;}
.ee-drawer__foot{
  padding:var(--space-3) var(--space-4);border-top:1px solid var(--color-border);
  background:var(--color-bg-alt,#f5f5f0);flex-shrink:0;
}
.ee-drawer__stats{
  display:flex;gap:var(--space-2);margin-bottom:var(--space-3);
  padding-bottom:var(--space-3);border-bottom:1px solid var(--color-border);
}

/* ── Results view ───────────────────────────────────────────── */
.ee-results-body{background:var(--color-bg,#f7f7f4);padding:var(--space-8) 0 var(--space-16);}
.ee-results-wrap{max-width:820px;margin:0 auto;}

/* Score hero */
.ee-score-card{
  background:linear-gradient(135deg,#07201a 0%,#0f2e24 50%,#1a4a35 100%);
  color:#fff;border-radius:var(--radius-xl);
  padding:var(--space-8) var(--space-8) var(--space-6);
  margin-bottom:var(--space-5);
  position:relative;overflow:hidden;
  box-shadow:0 8px 32px rgba(15,46,36,.3);
}
.ee-score-card::before{
  content:'';position:absolute;
  right:-60px;top:-60px;
  width:220px;height:220px;border-radius:50%;
  background:radial-gradient(circle,rgba(212,160,23,.15) 0%,transparent 70%);
}
.ee-score-card__top{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4);}
.ee-score-card__left{}
.ee-score-card__label{font-size:var(--text-xs);opacity:.55;text-transform:uppercase;letter-spacing:.08em;margin-bottom:var(--space-1);}
.ee-score-card__marks{font-size:clamp(3rem,8vw,5rem);font-weight:900;line-height:1;color:#fff;}
.ee-score-card__total{font-size:var(--text-base);opacity:.55;margin-top:2px;}
.ee-score-card__band{
  display:inline-flex;align-items:center;gap:6px;
  font-size:var(--text-xs);font-weight:800;letter-spacing:.06em;text-transform:uppercase;
  padding:5px 14px;border-radius:100px;align-self:flex-start;
}
.ee-score-card__band--excellent{background:rgba(74,222,128,.2);color:#4ade80;border:1px solid rgba(74,222,128,.35);}
.ee-score-card__band--good{background:rgba(250,204,21,.2);color:#fbbf24;border:1px solid rgba(250,204,21,.35);}
.ee-score-card__band--average{background:rgba(251,146,60,.2);color:#fb923c;border:1px solid rgba(251,146,60,.35);}
.ee-score-card__band--poor{background:rgba(248,113,113,.2);color:#f87171;border:1px solid rgba(248,113,113,.35);}
.ee-score-card__divider{border:none;border-top:1px solid rgba(255,255,255,.1);margin:var(--space-4) 0 var(--space-3);}
.ee-score-card__note{font-size:var(--text-xs);opacity:.45;}

/* Stats row */
.ee-stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-3);margin-bottom:var(--space-5);}
.ee-stat{
  background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-lg);padding:var(--space-4) var(--space-3);text-align:center;
  box-shadow:0 1px 3px rgba(0,0,0,.04);position:relative;overflow:hidden;
}
.ee-stat::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
}
.ee-stat--correct::before{background:#16a34a;}
.ee-stat--wrong::before{background:#dc2626;}
.ee-stat--skip::before{background:#9ca3af;}
.ee-stat--acc::before{background:var(--color-brand);}
.ee-stat__icon{font-size:1.3rem;display:block;margin-bottom:var(--space-1);}
.ee-stat__num{display:block;font-size:var(--text-2xl);font-weight:900;line-height:1;}
.ee-stat__num--correct{color:#16a34a;}
.ee-stat__num--wrong{color:#dc2626;}
.ee-stat__num--skip{color:#9ca3af;}
.ee-stat__num--acc{color:var(--color-brand);}
.ee-stat__label{display:block;font-size:0.62rem;color:var(--color-text-muted);margin-top:4px;text-transform:uppercase;letter-spacing:.04em;font-weight:700;}

/* Breakdown */
.ee-breakdown{
  background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-xl);overflow:hidden;margin-bottom:var(--space-5);
  box-shadow:0 1px 4px rgba(0,0,0,.05);
}
.ee-breakdown__head{
  padding:var(--space-4) var(--space-5);
  background:var(--color-brand-dark);color:#fff;
  font-size:var(--text-xs);font-weight:800;
  text-transform:uppercase;letter-spacing:.07em;
  display:flex;align-items:center;justify-content:space-between;
}
.ee-breakdown table{width:100%;border-collapse:collapse;font-size:var(--text-sm);}
.ee-breakdown td,.ee-breakdown th{padding:var(--space-3) var(--space-5);border-bottom:1px solid rgba(0,0,0,.04);}
.ee-breakdown th{font-size:var(--text-xs);font-weight:700;color:var(--color-text-muted);text-align:left;background:var(--color-bg,#f7f7f4);}
.ee-breakdown td:not(:first-child){text-align:center;}
.ee-breakdown tr:last-child td{border-bottom:none;}
.ee-breakdown tr:hover td{background:rgba(15,76,58,.02);}

/* Review section */
.ee-review-toggle{
  width:100%;padding:var(--space-4) var(--space-5);
  background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-lg);font-size:var(--text-sm);font-weight:700;
  cursor:pointer;text-align:left;margin-bottom:var(--space-4);
  display:flex;align-items:center;gap:var(--space-3);
  box-shadow:0 1px 3px rgba(0,0,0,.04);transition:border-color .12s;
}
.ee-review-toggle:hover{border-color:var(--color-brand);}
.ee-review-list{display:flex;flex-direction:column;gap:var(--space-4);margin-bottom:var(--space-6);}
.ee-review-q{
  background:var(--color-surface);border:1px solid var(--color-border);
  border-left:4px solid #dc2626;border-radius:var(--radius-md);
  padding:var(--space-4) var(--space-5);
  box-shadow:0 1px 3px rgba(0,0,0,.04);
}
.ee-review-q__meta{font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-2);}
.ee-review-q__stem{font-size:var(--text-sm);line-height:1.7;margin-bottom:var(--space-3);}
.ee-review-q__opts{display:flex;flex-direction:column;gap:6px;margin-bottom:var(--space-3);}
.ee-review-q__opt{font-size:var(--text-xs);padding:var(--space-2) var(--space-3);border-radius:var(--radius-sm);}
.ee-review-q__opt--correct{background:rgba(22,163,74,.12);color:#15803d;font-weight:700;border-left:3px solid #16a34a;}
.ee-review-q__opt--wrong{background:rgba(220,38,38,.08);color:#dc2626;border-left:3px solid #dc2626;}
.ee-review-q__opt--neutral{color:var(--color-text-muted);padding-left:calc(var(--space-3) + 3px);}
.ee-review-q__exp{
  font-size:var(--text-xs);line-height:1.75;
  color:var(--color-text-secondary);
  background:rgba(15,76,58,.04);border:1px solid rgba(15,76,58,.1);
  padding:var(--space-3) var(--space-4);border-radius:var(--radius-sm);
}
.ee-review-q__exp strong{color:var(--color-brand);}

/* Certificate */
.ee-cert-wrap{
  background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-xl);overflow:hidden;
  margin-bottom:var(--space-5);box-shadow:0 2px 12px rgba(0,0,0,.06);
}
.ee-cert-header{
  padding:var(--space-3) var(--space-5);
  background:var(--color-brand-dark);color:#fff;
  font-size:var(--text-xs);font-weight:800;
  text-transform:uppercase;letter-spacing:.07em;
  display:flex;align-items:center;gap:var(--space-2);
}
.ee-cert-body{padding:var(--space-4) var(--space-5);}
.ee-cert-actions{display:flex;gap:var(--space-3);margin-top:var(--space-3);flex-wrap:wrap;}
.ee-cert-btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:9px 18px;border:none;border-radius:var(--radius-md);
  font-size:var(--text-xs);font-weight:700;cursor:pointer;transition:all .12s;
}
.ee-cert-btn--dl{background:var(--color-brand);color:#fff;box-shadow:0 2px 8px rgba(15,76,58,.25);}
.ee-cert-btn--dl:hover{background:var(--color-brand-dark);transform:translateY(-1px);}
.ee-cert-btn--share{background:#fff;color:var(--color-text);border:1.5px solid var(--color-border);}
.ee-cert-btn--share:hover{border-color:var(--color-brand);color:var(--color-brand);}

/* Action buttons */
.ee-results-actions{display:flex;flex-wrap:wrap;gap:var(--space-3);margin-bottom:var(--space-5);}
.ee-tryagain{
  display:inline-flex;align-items:center;gap:var(--space-2);
  padding:12px 28px;background:var(--color-brand);color:#fff;
  border:none;border-radius:var(--radius-md);
  font-size:var(--text-sm);font-weight:700;cursor:pointer;
  box-shadow:0 3px 12px rgba(15,76,58,.3);transition:all .15s;
}
.ee-tryagain:hover{background:var(--color-brand-dark);transform:translateY(-1px);}

/* ── Responsive ─────────────────────────────────────────────── */
@media(max-width:900px){
  .ee-sidebar{display:none;}
  .ee-body{padding:var(--space-4) var(--space-3) 85px;}
}
@media(max-width:640px){
  .ee-size-row{grid-template-columns:repeat(3,1fr);gap:var(--space-2);}
  .ee-size-card{padding:var(--space-4) var(--space-2);}
  .ee-size-card__num{font-size:1.8rem;}
  .ee-size-card__sub{display:none;}
  .ee-stats-grid{grid-template-columns:repeat(2,1fr);}
  .ee-hd{height:50px;padding:0 var(--space-3);gap:7px;}
  .ee-prog{top:110px;}
  .ee-q-card{padding:var(--space-4);}
  .ee-subj-name{display:none;}
  .ee-btn{padding:8px 10px;}
  .ee-btn--mark .ee-lbl-full{display:none;}
  .ee-footer{flex-wrap:wrap;padding:8px 12px;gap:6px;justify-content:center;}
  .ee-footer__sep{display:none;}
  .ee-footer__center{gap:6px;}
  .ee-setup-card,.ee-launch-card{padding:var(--space-4) var(--space-4);}
  .ee-hero{padding:var(--space-8) 0 var(--space-6);}
  .ee-score-card{padding:var(--space-6);}
  .ee-score-card__top{flex-direction:column;}
  .ee-launch-card{flex-direction:column;align-items:stretch;}
  .ee-start-btn{width:100%;justify-content:center;padding:14px;}
  .ee-subj-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr));}
}

/* ── Fullscreen exam mode ───────────────────────────────── */
body.ee-exam-active .site-header{ display:none !important; }
body.ee-exam-active .ee-hd{ top:0; }
body.ee-exam-active .ee-prog{ top:54px; }

/* In fullscreen, make the header exit button slightly more prominent */
body.ee-exam-active .ee-exit{ border-color:rgba(255,255,255,.4);color:#fff; }

/* ══ SETTINGS ═══════════════════════════════════════════════════ */
.ee-settings-wrap{ position:relative;flex-shrink:0; }
.ee-settings-btn{
  display:flex;align-items:center;justify-content:center;
  width:32px;height:32px;
  background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);
  color:#fff;cursor:pointer;border-radius:6px;
  transition:background .12s;flex-shrink:0;
}
.ee-settings-btn:hover{ background:rgba(255,255,255,.22); }
.ee-settings-btn.open{ background:rgba(255,255,255,.28); }

.ee-settings-pop{
  position:absolute;top:calc(100% + 10px);right:0;
  width:228px;
  background:#fff;border:1px solid #e5e7eb;
  border-radius:14px;padding:16px;
  box-shadow:0 8px 32px rgba(0,0,0,.14),0 2px 8px rgba(0,0,0,.08);
  z-index:600;
  display:none;
}
.ee-settings-pop.open{ display:block; }
.ee-settings-section{ margin-bottom:14px; }
.ee-settings-section:last-child{ margin-bottom:0; }
.ee-settings-lbl{
  font-size:0.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em;
  color:#9ca3af;margin-bottom:7px;
}
.ee-settings-chips{ display:flex;gap:5px; }
.ee-sc{
  flex:1;padding:7px 6px;border-radius:8px;
  border:1.5px solid #e5e7eb;background:#f9f9f6;
  font-size:var(--text-xs);font-weight:700;
  cursor:pointer;text-align:center;
  transition:all .12s;color:#6b7280;
  font-family:var(--font-body);
}
.ee-sc:hover{ border-color:#0f4c3a;color:#0f4c3a;background:#f0faf5; }
.ee-sc.active{ background:#0f4c3a;border-color:#0f4c3a;color:#fff; }

/* ── Font-size presets ───────────────────────────────────────── */
#ee-test.ee-font-sm .ee-q-stem   { font-size:1.0rem; }
#ee-test.ee-font-sm .ee-q-stmts li{ font-size:0.94rem; }
#ee-test.ee-font-sm .ee-q-tail  { font-size:0.94rem; }
#ee-test.ee-font-sm .ee-q-ar    { font-size:0.94rem; }
#ee-test.ee-font-sm .ee-opt__text{ font-size:0.92rem; }
#ee-test.ee-font-lg .ee-q-stem   { font-size:1.42rem; }
#ee-test.ee-font-lg .ee-q-stmts li{ font-size:1.32rem; }
#ee-test.ee-font-lg .ee-q-tail  { font-size:1.32rem; }
#ee-test.ee-font-lg .ee-q-ar    { font-size:1.32rem; }
#ee-test.ee-font-lg .ee-opt__text{ font-size:1.28rem; }

/* ── Bottom palette strip ────────────────────────────────────── */
.ee-pal-btm-strip{
  position:fixed;bottom:58px;left:0;right:0;
  background:#fff;border-top:1px solid #e5e7eb;
  box-shadow:0 -4px 16px rgba(0,0,0,.08);
  padding:6px 20px;z-index:190;
  display:none;
}
.ee-pal-btm-strip .ee-palette{
  /* 2 rows of 50 — compact, all 100 visible, ~72px total height */
  grid-template-columns:repeat(50,1fr);gap:3px;margin-bottom:0;
  max-width:1200px;margin:0 auto;
}
.ee-pal-btm-strip .ee-pal-q{ font-size:0.55rem;border-radius:3px; }
#ee-test.ee-pal-bottom .ee-pal-btm-strip{ display:block; }
#ee-test.ee-pal-bottom .ee-sidebar{ display:none !important; }
#ee-test.ee-pal-bottom .ee-body{ padding-bottom:110px; }
#ee-test.ee-pal-off .ee-sidebar{ display:none !important; }

/* ══ DARK MODE ══════════════════════════════════════════════════ */
#ee-test.ee-dark,
#ee-test.ee-dark .ee-body{ background:#111a16; }
#ee-test.ee-dark .ee-q-card{ background:#1a2820;border-color:#283d30;box-shadow:0 2px 12px rgba(0,0,0,.35); }
#ee-test.ee-dark .ee-q-meta{ border-bottom-color:#283d30; }
#ee-test.ee-dark .ee-q-stem,
#ee-test.ee-dark .ee-q-tail{ color:#e2d9ce; }
#ee-test.ee-dark .ee-q-stmts{ background:#162219;border-color:#283d30; }
#ee-test.ee-dark .ee-q-stmts li{ color:#d4cab8; }
#ee-test.ee-dark .ee-q-ar{ background:#162219;border-left-color:#4ade80;color:#d4cab8; }
#ee-test.ee-dark .ee-opt{ background:#162219;border-color:#283d30; }
#ee-test.ee-dark .ee-opt__text{ color:#d4cab8; }
#ee-test.ee-dark .ee-opt__letter{ background:#111a16;border-color:#283d30;color:#6b7280; }
#ee-test.ee-dark .ee-opt:hover{ background:#1c2e22;border-color:#4ade80; }
#ee-test.ee-dark .ee-opt:hover .ee-opt__letter{ border-color:#4ade80;color:#4ade80;background:#162219; }
#ee-test.ee-dark .ee-opt.selected{ background:#1a3a28;border-color:#4ade80; }
#ee-test.ee-dark .ee-opt.selected .ee-opt__letter{ background:#2d7a5f;border-color:#2d7a5f;color:#fff; }
#ee-test.ee-dark .ee-opt.selected .ee-opt__text{ color:#c8f0d8; }
#ee-test.ee-dark .ee-pal-btm-strip{ background:#1a2820;border-top-color:#283d30; }
#ee-test.ee-dark .ee-settings-pop{ background:#1a2820;border-color:#283d30; }
#ee-test.ee-dark .ee-settings-lbl{ color:#6b7280; }
#ee-test.ee-dark .ee-sc{ background:#162219;border-color:#283d30;color:#9ca3af; }
#ee-test.ee-dark .ee-sc:hover{ border-color:#4ade80;color:#4ade80;background:#1a2820; }
#ee-test.ee-dark .ee-sc.active{ background:#2d7a5f;border-color:#2d7a5f;color:#fff; }
/* footer + sidebar dark (controlled via JS class) */
#ee-footer.ee-dark{ background:#1a2820;border-top-color:#283d30; }
#ee-footer.ee-dark .ee-btn--prev{ background:#162219;color:#9ca3af;border-color:#283d30; }
#ee-footer.ee-dark .ee-btn--prev:hover{ background:#1c2e22;color:#e2d9ce; }
#ee-footer.ee-dark .ee-btn--clear{ background:#162219;color:#9ca3af;border-color:#283d30; }
#ee-footer.ee-dark .ee-btn--clear:hover{ background:#1c2e22;color:#e2d9ce;border-color:#4ade80; }
#ee-footer.ee-dark .ee-footer__sep{ background:#283d30; }

/* ══ HELP BUTTON ════════════════════════════════════════════════ */
.ee-help-btn{
  display:flex;align-items:center;justify-content:center;
  width:32px;height:32px;
  background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);
  color:#fff;cursor:pointer;border-radius:50%;
  font-size:0.85rem;font-weight:900;flex-shrink:0;
  transition:background .12s;font-family:var(--font-body);
  line-height:1;
}
.ee-help-btn:hover{ background:rgba(255,255,255,.25); }
.ee-help-wrap{ position:relative;flex-shrink:0; }

/* Help popover */
.ee-help-pop{
  position:absolute;top:calc(100% + 10px);right:0;
  width:300px;
  background:#fff;border:1px solid #e5e7eb;
  border-radius:14px;
  box-shadow:0 8px 32px rgba(0,0,0,.14),0 2px 8px rgba(0,0,0,.08);
  z-index:600;display:none;overflow:hidden;
}
.ee-help-pop.open{ display:block; }
.ee-help-pop__head{
  background:#0f2e24;color:#fff;
  padding:12px 16px;
  font-size:var(--text-xs);font-weight:800;
  text-transform:uppercase;letter-spacing:.07em;
  display:flex;align-items:center;gap:8px;
}
.ee-help-pop__body{ padding:14px 16px;display:flex;flex-direction:column;gap:14px; }
.ee-help-section-lbl{
