/* ══ Results ═══════════════════════════════════════════════════ */
function showResults() {
  var correct = 0, wrong = 0, skip = 0;
  var bySubject = {};

  testQuestions.forEach(function(q, idx) {
    var subj = q._subject;
    if (!bySubject[subj]) bySubject[subj] = { correct:0, wrong:0, skip:0 };
    var chosen = userAnswers.hasOwnProperty(idx) ? userAnswers[idx] : null;
    if (chosen === null) {
      skip++;
      bySubject[subj].skip++;
    } else if (chosen === q.correct) {
      correct++;
      bySubject[subj].correct++;
    } else {
      wrong++;
      bySubject[subj].wrong++;
    }
  });

  var net = correct * 2 - wrong * (2/3);
  var max = testQuestions.length * 2;
  var acc = (correct + wrong) > 0 ? Math.round(correct / (correct + wrong) * 100) : 0;

  document.getElementById('ee-res-net').textContent     = net.toFixed(2);
  document.getElementById('ee-res-max').textContent     = max;
  document.getElementById('ee-res-correct').textContent = correct;
  document.getElementById('ee-res-wrong').textContent   = wrong;
  document.getElementById('ee-res-skip').textContent    = skip;
  document.getElementById('ee-res-acc').textContent     = acc + '%';

  /* Performance band */
  var pct = max > 0 ? (net / max * 100) : 0;
  var bandKey, bandCls, bandTxt;
  if (pct >= 65)      { bandKey = 'excellent'; bandCls = 'ee-score-card__band--excellent'; bandTxt = '★ Excellent'; }
  else if (pct >= 50) { bandKey = 'good';      bandCls = 'ee-score-card__band--good';      bandTxt = '▲ Good'; }
  else if (pct >= 35) { bandKey = 'average';   bandCls = 'ee-score-card__band--average';   bandTxt = '◆ Average'; }
  else                { bandKey = 'poor';       bandCls = 'ee-score-card__band--poor';      bandTxt = '▼ Needs Work'; }

  var bandEl = document.getElementById('ee-res-band');
  if (bandEl) { bandEl.className = 'ee-score-card__band ' + bandCls; bandEl.textContent = bandTxt; }

  /* Personalised greeting + quote */
  var bd = BAND_DATA[bandKey];
  var displayName = candidateName || 'Aspirant';
  var greetingEl = document.getElementById('ee-greeting');
  if (greetingEl && bd) {
    document.getElementById('ee-greeting-text').textContent = bd.greeting.replace('{name}', displayName);
    var rndQuote = bd.quotes[Math.floor(Math.random() * bd.quotes.length)];
    document.getElementById('ee-quote-text').textContent = '\u201c' + rndQuote + '\u201d';
    greetingEl.style.display = '';
  }

  /* Build certificate after a short delay (results DOM must be visible) */
  setTimeout(function(){ buildCertificate(displayName, net, max, bandTxt, testQuestions.length); }, 120);

  var bHTML = '';
  Object.keys(bySubject).forEach(function(slug) {
    var d = bySubject[slug];
    var m = SUBJ_META[slug] || { name: slug, color: '#666' };
    var attempted   = d.correct + d.wrong;
    var subjectNet  = d.correct * 2 - d.wrong * (2/3);
    bHTML += '<tr>';
    bHTML += '<td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:'+m.color+';margin-right:6px;vertical-align:middle;"></span>'+esc(m.name)+'</td>';
    bHTML += '<td>'+attempted+'</td>';
    bHTML += '<td style="color:#16a34a;font-weight:600;">'+d.correct+'</td>';
    bHTML += '<td style="color:#dc2626;font-weight:600;">'+d.wrong+'</td>';
    bHTML += '<td style="font-weight:700;color:'+(subjectNet>=0?'var(--color-brand)':'#dc2626')+';">'+subjectNet.toFixed(1)+'</td>';
    bHTML += '</tr>';
  });
  document.getElementById('ee-res-breakdown-body').innerHTML = bHTML;
  document.getElementById('ee-wrong-count').textContent = wrong;

  /* Wrong answer review */
  var wrongItems = [];
  testQuestions.forEach(function(q, idx) {
    var chosen = userAnswers.hasOwnProperty(idx) ? userAnswers[idx] : null;
    if (chosen !== null && chosen !== q.correct) wrongItems.push({ q:q, chosen:chosen, num:idx+1 });
  });

  if (!reviewListenerAdded) {
    reviewListenerAdded = true;
    document.getElementById('ee-review-toggle').addEventListener('click', function() {
      var list   = document.getElementById('ee-review-list');
      var hidden = list.style.display === 'none';
      list.style.display = hidden ? '' : 'none';
      if (hidden && list.innerHTML === '') renderReview(wrongItems);
    });
  }

  exitFullscreen();
  document.getElementById('ee-test').style.display    = 'none';
  document.getElementById('ee-footer').style.display  = 'none';
  document.getElementById('ee-results').style.display = '';
  window.scrollTo(0, 0);
}

function renderReview(items) {
  var list = document.getElementById('ee-review-list');
  if (items.length === 0) {
    list.innerHTML = '<p style="color:var(--color-text-muted);font-size:var(--text-sm);">No wrong answers to review — great job!</p>';
    return;
  }
  var html = '';
  items.forEach(function(item) {
    var q = item.q; var chosen = item.chosen;
    var opts = getOpts(q);
    html += '<div class="ee-review-q">';
    html += '<div class="ee-review-q__meta">Q'+item.num+' · '+esc(q.topic||q._subject)+(q.year?' · '+q.year:'')+'</div>';

    if (q.qtype === 'assertion') {
      html += '<p class="ee-review-q__stem"><strong>A:</strong> '+esc(q.assertion)+'<br><strong>R:</strong> '+esc(q.reason)+'</p>';
    } else if (q.qtype === 'statement') {
      html += '<p class="ee-review-q__stem">'+esc(q.stem)+'</p>';
      if (q.statements && q.statements.length) {
        html += '<ol style="font-size:var(--text-xs);padding-left:var(--space-5);margin:var(--space-2) 0;">';
        q.statements.forEach(function(s, si){ html += '<li data-n="'+(si+1)+'">'+esc(s)+'</li>'; });
        html += '</ol>';
      }
      if (q.tail) html += '<p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:4px;">'+esc(q.tail)+'</p>';
    } else {
      html += '<p class="ee-review-q__stem">'+esc(q.stem)+'</p>';
    }

    html += '<div class="ee-review-q__opts">';
    opts.forEach(function(opt, oi) {
      var cls = 'ee-review-q__opt ee-review-q__opt--neutral';
      var suffix = '';
      if (oi === q.correct)  { cls = 'ee-review-q__opt ee-review-q__opt--correct'; suffix = ' ✓ Correct'; }
      else if (oi === chosen) { cls = 'ee-review-q__opt ee-review-q__opt--wrong';   suffix = ' ✗ Your answer'; }
      html += '<div class="'+cls+'"><strong>'+LETTERS[oi]+'.</strong> '+esc(opt)+suffix+'</div>';
    });
    html += '</div>';
    if (q.explanation) {
      html += '<div class="ee-review-q__exp"><strong>Explanation:</strong> '+esc(q.explanation)+'</div>';
    }
    html += '</div>';
  });
  list.innerHTML = html;
}

/* ══ Certificate ═══════════════════════════════════════════════ */
function buildCertificate(name, net, max, bandLabel, qCount) {
  var canvas = document.getElementById('ee-cert-canvas');
  if (!canvas) return;

  /* Canvas is 1200×630 (OG-image ratio — also perfect for sharing) */
  var W = 1200, H = 630;
  canvas.width  = W;
  canvas.height = H;
  var ctx = canvas.getContext('2d');

  /* ── Background ── */
  var bg = ctx.createLinearGradient(0, 0, W, H);
  bg.addColorStop(0,   '#07201a');
  bg.addColorStop(0.5, '#0f2e24');
  bg.addColorStop(1,   '#1a4a35');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  /* Subtle radial glow (top-right) */
  var glow = ctx.createRadialGradient(W * 0.85, H * 0.15, 0, W * 0.85, H * 0.15, 380);
  glow.addColorStop(0,   'rgba(212,160,23,0.18)');
  glow.addColorStop(1,   'rgba(212,160,23,0)');
  ctx.fillStyle = glow;
  ctx.fillRect(0, 0, W, H);

  /* ── Gold border frame ── */
  var pad = 28;
  ctx.strokeStyle = 'rgba(212,160,23,0.5)';
  ctx.lineWidth   = 2;
  roundRect(ctx, pad, pad, W - pad*2, H - pad*2, 16);
  ctx.stroke();

  /* Inner thinner frame */
  ctx.strokeStyle = 'rgba(212,160,23,0.2)';
  ctx.lineWidth   = 1;
  roundRect(ctx, pad + 10, pad + 10, W - (pad+10)*2, H - (pad+10)*2, 10);
  ctx.stroke();

  /* ── "Certificate of Achievement" label ── */
  ctx.fillStyle = '#d4a017';
  ctx.font = 'bold 13px "Georgia", serif';
  ctx.letterSpacing = '4px';
  ctx.textAlign = 'center';
  ctx.fillText('CERTIFICATE OF ACHIEVEMENT', W/2, 105);
  ctx.letterSpacing = '0px';

  /* ── Divider line ── */
  ctx.strokeStyle = 'rgba(212,160,23,0.35)';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(W/2 - 200, 118); ctx.lineTo(W/2 + 200, 118); ctx.stroke();

  /* ── "This certifies that" ── */
  ctx.fillStyle = 'rgba(255,255,255,0.45)';
  ctx.font = 'italic 17px "Georgia", serif';
  ctx.fillText('This certifies that', W/2, 155);

  /* ── Candidate name ── */
  var nameFontSize = name.length > 25 ? 46 : name.length > 18 ? 54 : 62;
  ctx.fillStyle = '#ffffff';
  ctx.font = 'bold ' + nameFontSize + 'px "Georgia", serif';
  ctx.fillText(name, W/2, 230);

  /* ── Name underline ── */
  var nameWidth = ctx.measureText(name).width;
  ctx.strokeStyle = '#d4a017';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(W/2 - nameWidth/2, 240);
  ctx.lineTo(W/2 + nameWidth/2, 240);
  ctx.stroke();

  /* ── "has completed" text ── */
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.font = 'italic 17px "Georgia", serif';
  ctx.fillText('has successfully completed a ' + qCount + '-question UPSC Prelims Mock Test', W/2, 278);

  /* ── Score box ── */
  var bx = W/2 - 180, by = 308, bw = 360, bh = 90;
  ctx.fillStyle = 'rgba(212,160,23,0.12)';
  roundRect(ctx, bx, by, bw, bh, 10);
  ctx.fill();
  ctx.strokeStyle = 'rgba(212,160,23,0.4)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  ctx.fillStyle = '#d4a017';
  ctx.font = 'bold 13px Arial, sans-serif';
  ctx.fillText('NET SCORE', W/2, 333);

  ctx.fillStyle = '#ffffff';
  ctx.font = 'bold 36px "Georgia", serif';
  ctx.fillText(parseFloat(net).toFixed(1) + ' / ' + max, W/2, 375);

  /* ── Band label ── */
  ctx.fillStyle = '#d4a017';
  ctx.font = 'bold 15px Arial, sans-serif';
  ctx.fillText(bandLabel.replace(/[★▲◆▼]\s?/, '').toUpperCase(), W/2, 420);

  /* ── Bottom divider ── */
  ctx.strokeStyle = 'rgba(212,160,23,0.25)';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(80, 450); ctx.lineTo(W - 80, 450); ctx.stroke();

  /* ── Date (left) ── */
  var dateStr = new Date().toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' });
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.font = '13px Arial, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText(dateStr, 80, 480);

  /* ── BharatNotes branding (right) ── */
  ctx.textAlign = 'right';
  ctx.fillStyle = 'rgba(255,255,255,0.7)';
  ctx.font = 'bold 15px "Georgia", serif';
  ctx.fillText('BharatNotes.com', W - 80, 476);
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.font = '12px Arial, sans-serif';
  ctx.fillText('Free UPSC Study Portal', W - 80, 493);

  /* ── Watermark logo text (bottom center) ── */
  ctx.textAlign = 'center';
  ctx.fillStyle = 'rgba(255,255,255,0.08)';
  ctx.font = 'bold 72px "Georgia", serif';
  ctx.fillText('BN', W/2, H - 30);

  /* ── Footer URL ── */
  ctx.fillStyle = 'rgba(212,160,23,0.5)';
  ctx.font = '12px Arial, sans-serif';
  ctx.fillText('bharatnotes.com/prelims-practice/', W/2, H - 44);
}

/* Helper: rounded rect path */
function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

/* ── Certificate download ── */
document.getElementById('ee-cert-download').addEventListener('click', function() {
  var canvas = document.getElementById('ee-cert-canvas');
  if (!canvas) return;
  var a = document.createElement('a');
  a.download = 'BharatNotes-Certificate-' + (candidateName || 'Aspirant').replace(/\s+/g,'-') + '.png';
  a.href = canvas.toDataURL('image/png');
  a.click();
});

/* ── Certificate share ── */
document.getElementById('ee-cert-share').addEventListener('click', function() {
  var canvas = document.getElementById('ee-cert-canvas');
  if (!canvas) return;
  var shareBtn = this;

  function fallback() {
    /* Copy link to clipboard */
    try {
      navigator.clipboard.writeText('https://bharatnotes.com/prelims-practice/');
      shareBtn.textContent = '✓ Link copied!';
      setTimeout(function(){ shareBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Share'; }, 2500);
    } catch(e) {}
  }

  if (navigator.share && navigator.canShare) {
    canvas.toBlob(function(blob) {
      var file = new File([blob], 'BharatNotes-Certificate.png', { type: 'image/png' });
      if (navigator.canShare({ files: [file] })) {
        navigator.share({
          title: 'My UPSC Mock Test Certificate — BharatNotes',
          text: 'I just scored ' + document.getElementById('ee-res-net').textContent + ' on a UPSC Prelims mock test at BharatNotes.com!',
          files: [file]
        }).catch(function(){});
      } else {
        fallback();
      }
    }, 'image/png');
  } else {
    fallback();
  }
});

