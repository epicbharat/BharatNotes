/* ══ Timer ═════════════════════════════════════════════════════ */
function startTimer(mins) {
  timerSecsLeft = mins * 60;
  var timerEl = document.getElementById('ee-timer');
  function tick() {
    timerSecsLeft--;
    var m = Math.floor(timerSecsLeft / 60);
    var s = timerSecsLeft % 60;
    timerEl.textContent = (m<10?'0':'')+m+':'+(s<10?'0':'')+s;
    if (timerSecsLeft <= 300) timerEl.classList.add('warn');
    if (timerSecsLeft <= 0) { clearInterval(timerInterval); timerEl.textContent='00:00'; submitTest(true); }
  }
  var m0 = Math.floor(timerSecsLeft / 60);
  timerEl.textContent = (m0<10?'0':'')+m0+':00';
  timerInterval = setInterval(tick, 1000);
}

