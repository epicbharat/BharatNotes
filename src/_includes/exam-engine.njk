function showToast(msg) {
  var t = document.getElementById('ee-toast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 3500);
}

function startTest(caQuestions) {
  /* Capture & persist name */
  candidateName = (nameInput.value || '').trim() || 'Aspirant';
  try { localStorage.setItem('bn_exam_name', candidateName === 'Aspirant' ? '' : candidateName); } catch(e){}

  buildTest(caQuestions || []);
