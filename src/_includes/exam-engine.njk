  <button class="ee-btn ee-btn--save" id="ee-save-btn">
    Save &amp; Next
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>

<!-- Toast -->
<div class="ee-toast" id="ee-toast"></div>

<!-- ═══ INSTRUCTION MODAL ════════════════════════════════════════ -->
<div class="ee-instr-overlay" id="ee-instr-overlay" style="display:none;">
  <div class="ee-instr-modal" role="dialog" aria-modal="true" aria-labelledby="ee-instr-title">
    <div class="ee-instr-head">
