/* Fetch CA questions then start — entry point for all start paths */
function launchTest() {
  if (caCount === 0 || caSelectedMonths.length === 0) {
    startTest([]);
    return;
  }
  /* Show loading on start btn */
  var btn = document.getElementById('ee-start-btn');
  btn.disabled = true;
  btn.innerHTML = '<div class="ee-ca-spinner" style="border-top-color:#fff;margin-right:8px;"></div>Fetching current affairs…';

  var urls = caManifest
    .filter(function(m){ return caSelectedMonths.indexOf(m.month) > -1; })
    .map(function(m){ return m.url.startsWith('http') ? m.url : 'https://ujiyari.com' + m.url; });

  Promise.all(urls.map(function(url){ return fetch(url).then(function(r){ return r.json(); }); }))
    .then(function(arrays) {
      var all = [].concat.apply([], arrays);
      all = all.map(function(q){ return Object.assign({}, q, { _subject: 'current-affairs' }); });
      all = shuffle(all).slice(0, caCount);
      startTest(all);
    })
    .catch(function() {
      showToast('⚠ Could not fetch current affairs — starting without them.');
      startTest([]);
    })
    .finally(function() {
      var b = document.getElementById('ee-start-btn');
      if (b) {
        b.disabled = false;
        b.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>Start Test';
      }
    });
}

