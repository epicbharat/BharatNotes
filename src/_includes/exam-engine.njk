        <div class="ee-instr-head__stat" id="ee-instr-q-count"><strong>—</strong> Questions</div>
        <div class="ee-instr-head__stat" id="ee-instr-time"><strong>—</strong> Minutes</div>
        <div class="ee-instr-head__stat"><strong>+2 / −⅔</strong> Marking</div>
      </div>
    </div>
    <div class="ee-instr-body">

      <!-- Scoring -->
      <div>
        <div class="ee-instr-section-title">Marking Scheme</div>
        <div class="ee-instr-score-grid">
          <div class="ee-instr-score-card ee-instr-score-card--correct">
            <span class="ee-instr-score-card__val">+2</span>
            <span class="ee-instr-score-card__lbl">Correct</span>
          </div>
          <div class="ee-instr-score-card ee-instr-score-card--wrong">
            <span class="ee-instr-score-card__val">−⅔</span>
            <span class="ee-instr-score-card__lbl">Wrong</span>
          </div>
          <div class="ee-instr-score-card ee-instr-score-card--skip">
            <span class="ee-instr-score-card__val">0</span>
            <span class="ee-instr-score-card__lbl">Skipped</span>
          </div>
        </div>
      </div>

      <!-- Status chips legend -->
      <div>
        <div class="ee-instr-section-title">Question Status Indicators</div>
        <div class="ee-instr-status-grid">
          <div class="ee-instr-status-row">
            <span class="ee-legend-chip" style="background:#e9eaeb;color:#9ca3af;flex-shrink:0;">—</span>
            <span><strong>Not visited</strong> — you haven't opened this question yet</span>
          </div>
          <div class="ee-instr-status-row">
            <span class="ee-legend-chip" style="background:#fee2e2;color:#dc2626;flex-shrink:0;">—</span>
            <span><strong>Not answered</strong> — visited but no option selected</span>
          </div>
          <div class="ee-instr-status-row">
            <span class="ee-legend-chip" style="background:#dcfce7;color:#15803d;flex-shrink:0;">✓</span>
            <span><strong>Answered</strong> — option selected and saved</span>
          </div>
          <div class="ee-instr-status-row">
            <span class="ee-legend-chip" style="background:#ede9fe;color:#7c3aed;flex-shrink:0;">★</span>
            <span><strong>Marked for review</strong> — flagged to revisit</span>
          </div>
          <div class="ee-instr-status-row">
            <span class="ee-legend-chip" style="background:#7c3aed;color:#fff;flex-shrink:0;">✓</span>
            <span><strong>Answered &amp; marked</strong> — saved but flagged for review</span>
          </div>
        </div>
      </div>

      <!-- Buttons -->
      <div>
        <div class="ee-instr-section-title">Buttons</div>
        <div class="ee-instr-btn-grid">
          <div class="ee-instr-btn-row">
            <span class="ee-instr-btn-name">Save &amp; Next</span>
            <span class="ee-instr-btn-desc">Saves your answer and moves to the next question</span>
          </div>
          <div class="ee-instr-btn-row">
            <span class="ee-instr-btn-name">Mark for Review</span>
            <span class="ee-instr-btn-desc">Flags the question — your answer (if any) is still saved</span>
          </div>
          <div class="ee-instr-btn-row">
            <span class="ee-instr-btn-name">Clear</span>
            <span class="ee-instr-btn-desc">Deselects your current option for this question</span>
          </div>
        </div>
      </div>

      <!-- Keyboard shortcuts -->
      <div>
        <div class="ee-instr-section-title">Keyboard Shortcuts</div>
        <div class="ee-instr-kbd-row">
          <span class="ee-instr-kbd">1</span><span class="ee-instr-kbd">2</span><span class="ee-instr-kbd">3</span><span class="ee-instr-kbd">4</span>
          <span style="font-size:var(--text-xs);color:#6b7280;">Select option A / B / C / D</span>
        </div>
        <div class="ee-instr-kbd-row" style="margin-top:6px;">
          <span class="ee-instr-kbd">→</span> <span style="font-size:var(--text-xs);color:#6b7280;margin-right:14px;">Save &amp; Next</span>
          <span class="ee-instr-kbd">←</span> <span style="font-size:var(--text-xs);color:#6b7280;margin-right:14px;">Previous</span>
          <span class="ee-instr-kbd">M</span> <span style="font-size:var(--text-xs);color:#6b7280;margin-right:14px;">Mark / Unmark</span>
          <span class="ee-instr-kbd">C</span> <span style="font-size:var(--text-xs);color:#6b7280;">Clear</span>
        </div>
      </div>

    </div>
    <div class="ee-instr-foot">
      <label class="ee-instr-skip">
        <input type="checkbox" id="ee-instr-skip-cb">
        Don't show this again
      </label>
      <button class="ee-instr-begin" id="ee-instr-begin-btn">
        Begin Exam
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- ═══ RESULTS VIEW ═════════════════════════════════════════════ -->
<div id="ee-results" style="display:none;">
  <div class="ee-results-body">
    <div class="container">
      <div class="ee-results-wrap">

        <!-- Personalised greeting -->
        <div id="ee-greeting" style="margin-bottom:var(--space-5);display:none;">
          <div style="font-family:var(--font-serif);font-size:clamp(1.3rem,3vw,1.8rem);color:var(--color-brand-dark);font-weight:700;margin-bottom:var(--space-2);" id="ee-greeting-text"></div>
          <div style="font-size:var(--text-sm);color:var(--color-text-muted);font-style:italic;line-height:1.6;border-left:3px solid var(--color-accent,#d4a017);padding-left:var(--space-3);" id="ee-quote-text"></div>
        </div>

        <!-- Score hero card -->
        <div class="ee-score-card">
          <div class="ee-score-card__top">
            <div class="ee-score-card__left">
              <div class="ee-score-card__label">Net Score</div>
              <div class="ee-score-card__marks" id="ee-res-net">—</div>
              <div class="ee-score-card__total">out of <span id="ee-res-max">200</span> marks</div>
            </div>
            <span class="ee-score-card__band" id="ee-res-band">—</span>
          </div>
          <hr class="ee-score-card__divider">
          <div class="ee-score-card__note">Correct +2 &nbsp;·&nbsp; Wrong −⅔ &nbsp;·&nbsp; Unanswered 0</div>
        </div>

        <!-- Stats grid -->
        <div class="ee-stats-grid">
          <div class="ee-stat ee-stat--correct">
            <span class="ee-stat__icon">✓</span>
            <span class="ee-stat__num ee-stat__num--correct" id="ee-res-correct">0</span>
            <span class="ee-stat__label">Correct</span>
          </div>
          <div class="ee-stat ee-stat--wrong">
            <span class="ee-stat__icon">✗</span>
            <span class="ee-stat__num ee-stat__num--wrong" id="ee-res-wrong">0</span>
            <span class="ee-stat__label">Wrong</span>
          </div>
          <div class="ee-stat ee-stat--skip">
            <span class="ee-stat__icon">–</span>
            <span class="ee-stat__num ee-stat__num--skip" id="ee-res-skip">0</span>
            <span class="ee-stat__label">Skipped</span>
          </div>
          <div class="ee-stat ee-stat--acc">
            <span class="ee-stat__icon">◎</span>
            <span class="ee-stat__num ee-stat__num--acc" id="ee-res-acc">—</span>
            <span class="ee-stat__label">Accuracy</span>
          </div>
        </div>

        <!-- Subject breakdown -->
        <div class="ee-breakdown">
          <div class="ee-breakdown__head">
            Subject-wise Breakdown
          </div>
          <table>
            <thead><tr><th>Subject</th><th>Attempted</th><th>Correct</th><th>Wrong</th><th>Net Marks</th></tr></thead>
            <tbody id="ee-res-breakdown-body"></tbody>
          </table>
        </div>

        <!-- Certificate -->
        <div class="ee-cert-wrap" id="ee-cert-wrap">
          <div class="ee-cert-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
            Your Certificate
          </div>
          <div class="ee-cert-body">
            <canvas id="ee-cert-canvas" style="width:100%;border-radius:var(--radius-md);display:block;"></canvas>
            <div class="ee-cert-actions">
              <button class="ee-cert-btn ee-cert-btn--dl" id="ee-cert-download">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download PNG
              </button>
              <button class="ee-cert-btn ee-cert-btn--share" id="ee-cert-share">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                Share
              </button>
            </div>
          </div>
        </div>

        <!-- Actions + review -->
        <div class="ee-results-actions">
          <button class="ee-tryagain" id="ee-tryagain-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
            Try Another Test
          </button>
          <button class="ee-review-toggle" id="ee-review-toggle">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Review Wrong Answers (<span id="ee-wrong-count">0</span>)
          </button>
        </div>

        <div id="ee-review-list" class="ee-review-list" style="display:none;"></div>

      </div>
    </div>
  </div>
</div>

<script>
(function(){
'use strict';

/* ══ Read globals ══════════════════════════════════════════════ */
var DATA   = window.EXAM_DATA   || {};
var CONFIG = window.EXAM_CONFIG || {};

var mode           = CONFIG.mode         || 'all-subjects';
var cfgTitle       = CONFIG.title        || 'Mock Test';
var cfgSubtitle    = CONFIG.subtitle     || '';
var cfgSizes       = CONFIG.sizes        || [{ n:100, mins:120, label:'Full Mock' }, { n:50, mins:60, label:'Half Mock' }, { n:25, mins:30, label:'Quick Test' }];
var cfgDefaultSize = CONFIG.defaultSize  || 0;
var cfgAutoStart   = CONFIG.autoStart    || false;
var cfgShowSubj    = (mode === 'all-subjects') ? (CONFIG.showSubjectPicker !== false) : false;
var cfgSubject     = CONFIG.subject      || null;
var cfgBreadcrumb  = CONFIG.breadcrumb   || [];

/* ══ Subject metadata ══════════════════════════════════════════ */
var SUBJ_META = {
  'polity':                  { name:'Polity & Constitution',    color:'#7c3aed' },
  'economy':                 { name:'Indian Economy',           color:'#0369a1' },
  'geography':               { name:'Geography',                color:'#b45309' },
  'history-culture':         { name:'History & Culture',        color:'#9f1239' },
  'environment':             { name:'Environment & Ecology',    color:'#047857' },
  'general-science':         { name:'General Science',          color:'#0d9488' },
  'science-tech':            { name:'Science & Technology',     color:'#4338ca' },
  'international-relations': { name:'International Relations',  color:'#0e7490' },
  'society':                 { name:'Indian Society',           color:'#be123c' },
  'security':                { name:'Internal Security',        color:'#1e3a5f' },
  'disaster-management':     { name:'Disaster Management',      color:'#dc2626' },
  'current-affairs':         { name:'Current Affairs',          color:'#d97706' }
};

/* ══ Constants ═════════════════════════════════════════════════ */
var AR_OPTIONS = [
  'Both A and R are true and R is the correct explanation of A',
  'Both A and R are true but R is NOT the correct explanation of A',
  'A is true but R is false',
  'A is false but R is true'
];
var LETTERS = ['A','B','C','D'];

/* ══ State ═════════════════════════════════════════════════════ */
var selectedSize     = cfgSizes[cfgDefaultSize] ? cfgSizes[cfgDefaultSize].n    : 100;
var selectedMins     = cfgSizes[cfgDefaultSize] ? cfgSizes[cfgDefaultSize].mins : 120;
var selectedSubjects = [];
var testQuestions    = [];
var caCount          = 0;          // 0 = off
var caSelectedMonths = [];         // ['2026-03', '2026-02', ...]
var caManifest       = [];         // [{month, label, count, url}, ...]
var CA_MANIFEST_URL  = 'https://ujiyari.com/api/ca-manifest.json';
var userAnswers      = {};
var questionStatus   = [];
var currentQ         = 0;
var timerInterval    = null;
var timerSecsLeft    = 0;
var reviewListenerAdded = false;
var candidateName = '';

/* ══ Quotes per band ════════════════════════════════════════════ */
var BAND_DATA = {
  excellent: {
    greeting: 'Brilliant performance, {name}!',
    quotes: [
      'Excellence is not a destination but a continuous journey that never ends. — Brian Tracy',
      'The secret of success is to do the common things uncommonly well. — John D. Rockefeller',
      'Success is the sum of small efforts, repeated day in and day out. — Robert Collier',
      'Talent wins games, but teamwork and intelligence win championships. — Michael Jordan',
      'The harder you work for something, the greater you\'ll feel when you achieve it.'
    ]
  },
  good: {
    greeting: 'Good work, {name}. Keep pushing!',
    quotes: [
      'Success is not final, failure is not fatal: it is the courage to continue that counts. — Churchill',
      'The only way to do great work is to love what you do. — Steve Jobs',
      'It does not matter how slowly you go as long as you do not stop. — Confucius',
      'Every expert was once a beginner. Every pro was once an amateur.',
      'Push yourself, because no one else is going to do it for you.'
    ]
  },
  average: {
    greeting: 'Good effort, {name}. There\'s more in you!',
    quotes: [
      'The secret of getting ahead is getting started. — Mark Twain',
      'Failure is the condiment that gives success its flavour. — Truman Capote',
      'A river cuts through rock not because of its power but because of its persistence.',
      'Don\'t watch the clock; do what it does. Keep going. — Sam Levenson',
      'Start where you are. Use what you have. Do what you can. — Arthur Ashe'
    ]
  },
  poor: {
    greeting: 'Every master was once a beginner, {name}.',
    quotes: [
      'Our greatest glory is not in never falling, but in rising every time we fall. — Confucius',
      'The oak sleeps in the acorn; the bird waits in the egg. — James Allen',
      'It always seems impossible until it\'s done. — Nelson Mandela',
      'Mistakes are the portals of discovery. — James Joyce',
      'Fall seven times, stand up eight. — Japanese proverb'
    ]
  }
};

/* ══ Utilities ═════════════════════════════════════════════════ */
function shuffle(arr) {
  var a = arr.slice();
  for (var i = a.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var t = a[i]; a[i] = a[j]; a[j] = t;
  }
  return a;
}
function getOpts(q) { return q.qtype === 'assertion' ? AR_OPTIONS : (q.options || []); }
function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function getPool() {
  if (mode === 'all-subjects') {
    var pool = [];
    selectedSubjects.forEach(function(s){ (DATA[s] || []).forEach(function(q){ pool.push(Object.assign({}, q, { _subject: s })); }); });
    return pool;
  } else {
    /* single-subject or chapter — DATA is a flat array */
    var slug = cfgSubject || 'general';
    return (Array.isArray(DATA) ? DATA : []).map(function(q){ return Object.assign({}, q, { _subject: q._subject || slug }); });
  }
}

/* ══ Build Setup UI ════════════════════════════════════════════ */

/* Breadcrumb */
var bcEl = document.getElementById('ee-breadcrumb');
if (cfgBreadcrumb.length) {
  var bcHTML = '';
  cfgBreadcrumb.forEach(function(item, i) {
    if (i > 0) bcHTML += '<span class="breadcrumb__sep">/</span>';
    if (item.url) {
      bcHTML += '<a href="'+esc(item.url)+'">'+esc(item.label)+'</a>';
    } else {
      bcHTML += esc(item.label);
    }
  });
  bcEl.innerHTML = bcHTML;
}

/* Title / subtitle */
document.getElementById('ee-title').textContent    = cfgTitle;
document.getElementById('ee-subtitle').textContent = cfgSubtitle;

/* Size cards */
var sizeRow = document.getElementById('ee-size-row');
cfgSizes.forEach(function(s, i) {
  var card = document.createElement('div');
  card.className = 'ee-size-card' + (i === cfgDefaultSize ? ' selected' : '');
  card.dataset.size = s.n;
  card.dataset.mins = s.mins;
  card.innerHTML =
    '<span class="ee-size-card__num">'+s.n+'</span>' +
    '<span class="ee-size-card__label">Questions</span>' +
    '<span class="ee-size-card__sub">'+s.mins+' min · '+esc(s.label)+'</span>';
  sizeRow.appendChild(card);
});

sizeRow.addEventListener('click', function(e) {
  var card = e.target.closest('.ee-size-card');
  if (!card) return;
  document.querySelectorAll('.ee-size-card').forEach(function(c){ c.classList.remove('selected'); });
  card.classList.add('selected');
  selectedSize = parseInt(card.dataset.size);
  selectedMins = parseInt(card.dataset.mins);
  updatePreview();
});

/* Subject picker */
var subjSection = document.getElementById('ee-subj-section');
var selectAllBtn = document.getElementById('ee-select-all');
if (!cfgShowSubj) {
  subjSection.style.display = 'none';
  selectAllBtn.style.display = 'none';
}

if (cfgShowSubj) {
  var subjGrid = document.getElementById('ee-subj-grid');
  Object.keys(SUBJ_META).forEach(function(slug) {
    var m = SUBJ_META[slug];
    var count = (DATA[slug] || []).length;
    if (count === 0) return; /* skip subjects with no data */
    var label = document.createElement('label');
    label.className = 'ee-subj-check checked';
    label.style.borderColor = m.color;
    label.innerHTML =
      '<input type="checkbox" checked data-slug="'+slug+'">' +
      '<span class="ee-subj-check__name">'+esc(m.name)+'</span>' +
      '<span class="ee-subj-check__count">'+count+'</span>';
    subjGrid.appendChild(label);
    selectedSubjects.push(slug);
  });

  selectAllBtn.addEventListener('click', function() {
    var all = document.querySelectorAll('#ee-subj-grid input[type=checkbox]');
    var anyUnchecked = Array.from(all).some(function(cb){ return !cb.checked; });
    all.forEach(function(cb) {
      cb.checked = anyUnchecked;
      cb.closest('label').classList.toggle('checked', anyUnchecked);
      cb.closest('label').style.borderColor = anyUnchecked ? SUBJ_META[cb.dataset.slug].color : 'var(--color-border)';
    });
    updatePreview();
  });

  document.getElementById('ee-subj-grid').addEventListener('change', function(e) {
    var cb = e.target;
    cb.closest('label').classList.toggle('checked', cb.checked);
    cb.closest('label').style.borderColor = cb.checked ? SUBJ_META[cb.dataset.slug].color : 'var(--color-border)';
    updatePreview();
  });
}

function getCheckedSubjects() {
  if (!cfgShowSubj) return cfgSubject ? [cfgSubject] : [];
  return Array.from(document.querySelectorAll('#ee-subj-grid input:checked')).map(function(cb){ return cb.dataset.slug; });
}

function updatePreview() {
  selectedSubjects = getCheckedSubjects();
  var pool = getPool();
  var avail = Math.min(pool.length, selectedSize);
  var preview  = document.getElementById('ee-preview');
  var startBtn = document.getElementById('ee-start-btn');
  if (!cfgShowSubj) {
    /* single-subject / chapter: no subject selection step */
    if (pool.length === 0) {
      preview.innerHTML = 'No questions available.';
      startBtn.disabled = true;
    } else {
      preview.innerHTML = '<span class="ee-preview-text"><strong>'+avail+'</strong> questions</span><div class="ee-preview-pills"><span class="ee-preview-pill">'+selectedMins+' min</span><span class="ee-preview-pill">+2 correct</span><span class="ee-preview-pill">−⅔ wrong</span></div>';
      startBtn.disabled = false;
    }
  } else {
    if (selectedSubjects.length === 0) {
      preview.innerHTML = '<span class="ee-preview-text" style="color:var(--color-text-muted);">Select at least one subject to continue.</span>';
      startBtn.disabled = true;
    } else {
      preview.innerHTML = '<span class="ee-preview-text"><strong>'+avail+'</strong> questions · <strong>'+selectedSubjects.length+'</strong> subject'+(selectedSubjects.length>1?'s':'')+'</span><div class="ee-preview-pills"><span class="ee-preview-pill">'+selectedMins+' min</span><span class="ee-preview-pill">+2 correct</span><span class="ee-preview-pill">−⅔ wrong</span></div>';
      startBtn.disabled = false;
    }
  }
}
updatePreview();

/* ══ Build Test ════════════════════════════════════════════════ */
function buildTest(caQuestions) {
  caQuestions = caQuestions || [];
  var coreSize = Math.max(0, selectedSize - caQuestions.length);
  var pool = shuffle(getPool()).slice(0, coreSize);
  testQuestions = shuffle(pool.concat(caQuestions));
  userAnswers   = {};
  questionStatus = testQuestions.map(function(){ return 'not-visited'; });
  currentQ = 0;
}

/* ══ Render single question ════════════════════════════════════ */
function renderSingleQuestion(q, idx) {
  var opts = getOpts(q);
  var m = SUBJ_META[q._subject] || { name: q._subject, color: '#666' };
  var html = '<div class="ee-q-card">';

  html += '<div class="ee-q-meta">';
  if (q.year) html += '<span class="ee-q-badge ee-q-badge--year">'+q.year+'</span>';
  html += '<span class="ee-q-badge ee-q-badge--subj" style="background:'+m.color+';">'+esc(m.name)+'</span>';
  if (q.topic) html += '<span class="ee-q-badge ee-q-badge--topic">'+esc(q.topic)+(q.subtopic?' — '+esc(q.subtopic):'')+'</span>';
  html += '</div>';

  if (q.qtype === 'assertion') {
    html += '<div class="ee-q-ar"><strong>Assertion (A):</strong> '+esc(q.assertion)+'</div>';
    html += '<div class="ee-q-ar"><strong>Reason (R):</strong> '+esc(q.reason)+'</div>';
    html += '<p class="ee-q-ar-note">In the context of the above, which one of the following is correct?</p>';
  } else if (q.qtype === 'statement') {
    html += '<p class="ee-q-stem">'+esc(q.stem)+'</p>';
    if (q.statements && q.statements.length) {
      html += '<ol class="ee-q-stmts">';
      q.statements.forEach(function(s, si){ html += '<li data-n="'+(si+1)+'">'+esc(s)+'</li>'; });
      html += '</ol>';
    }
    if (q.tail) html += '<p class="ee-q-tail">'+esc(q.tail)+'</p>';
  } else {
    html += '<p class="ee-q-stem">'+esc(q.stem)+'</p>';
  }

  var chosen = userAnswers.hasOwnProperty(idx) ? userAnswers[idx] : null;
  html += '<div class="ee-opts">';
  opts.forEach(function(opt, oi) {
    var sel = (chosen === oi);
    html += '<label class="ee-opt'+(sel?' selected':'')+'" data-oi="'+oi+'">';
    html += '<input type="radio" name="ee-q" value="'+oi+'"'+(sel?' checked':'')+'>';
    html += '<span class="ee-opt__letter">'+LETTERS[oi]+'</span>';
    html += '<span class="ee-opt__text">'+esc(opt)+'</span>';
    html += '</label>';
  });
  html += '</div></div>';
  return html;
}

/* ══ Show question ═════════════════════════════════════════════ */
function showQuestion(idx) {
  if (idx < 0) idx = testQuestions.length - 1;
  if (idx >= testQuestions.length) idx = 0;
  currentQ = idx;

  if (questionStatus[idx] === 'not-visited') questionStatus[idx] = 'not-answered';

  var q = testQuestions[idx];
  var m = SUBJ_META[q._subject] || { name: q._subject, color: '#999' };
  var dot    = document.getElementById('ee-subj-dot');
  var nameEl = document.getElementById('ee-subj-name');
  var qnum   = document.getElementById('ee-qnum');
  if (dot)    dot.style.background = m.color;
  if (nameEl) nameEl.textContent   = m.name;
  if (qnum)   qnum.textContent     = 'Q '+(idx+1)+' / '+testQuestions.length;

  var display = document.getElementById('ee-q-display');
  display.innerHTML = renderSingleQuestion(q, idx);

  display.querySelectorAll('.ee-opt').forEach(function(opt) {
    opt.addEventListener('click', function(e) {
      e.preventDefault();
      selectOption(parseInt(opt.dataset.oi));
    });
  });

  renderPalette();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* ══ Select option ═════════════════════════════════════════════ */
function selectOption(oi) {
  userAnswers[currentQ] = oi;
  if (questionStatus[currentQ] === 'marked') {
    questionStatus[currentQ] = 'answered-marked';
  } else if (questionStatus[currentQ] !== 'answered-marked') {
    questionStatus[currentQ] = 'answered';
  }
  document.querySelectorAll('.ee-opt').forEach(function(opt, i) {
    var sel = (i === oi);
    opt.classList.toggle('selected', sel);
    var radio = opt.querySelector('input');
    if (radio) radio.checked = sel;
  });
  renderPalette();
}

/* ══ Navigation ════════════════════════════════════════════════ */
document.getElementById('ee-save-btn').addEventListener('click', function() {
  if (questionStatus[currentQ] === 'not-visited') questionStatus[currentQ] = 'not-answered';
  showQuestion(currentQ + 1);
});

document.getElementById('ee-mark-btn').addEventListener('click', function() {
  if (questionStatus[currentQ] === 'answered') {
    questionStatus[currentQ] = 'answered-marked';
  } else if (questionStatus[currentQ] !== 'answered-marked') {
    questionStatus[currentQ] = 'marked';
  }
  renderPalette();
  showQuestion(currentQ + 1);
});

document.getElementById('ee-prev-btn').addEventListener('click', function() {
  showQuestion(currentQ - 1);
});

document.getElementById('ee-clear-btn').addEventListener('click', function() {
  delete userAnswers[currentQ];
  if (questionStatus[currentQ] === 'answered-marked') {
    questionStatus[currentQ] = 'marked';
  } else if (questionStatus[currentQ] !== 'marked') {
    questionStatus[currentQ] = 'not-answered';
  }
  document.querySelectorAll('.ee-opt').forEach(function(opt) {
    opt.classList.remove('selected');
    var r = opt.querySelector('input');
    if (r) r.checked = false;
  });
  renderPalette();
});

/* ══ Palette ═══════════════════════════════════════════════════ */
function renderPalette() {
  var html = '';
  testQuestions.forEach(function(q, idx) {
    var status = questionStatus[idx] || 'not-visited';
    var cls = 'ee-pal-q ee-pal-q--' + status + (idx === currentQ ? ' ee-pal-q--active' : '');
    html += '<button class="'+cls+'" data-qi="'+idx+'">'+(idx+1)+'</button>';
  });

  ['ee-palette', 'ee-palette-mob', 'ee-palette-btm'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.innerHTML = html;
  });

  var answered = questionStatus.filter(function(s){ return s==='answered'||s==='answered-marked'; }).length;
  var palCount = document.getElementById('ee-pal-count');
  if (palCount) palCount.textContent = answered + '/' + testQuestions.length;

  var pct  = testQuestions.length ? (answered / testQuestions.length * 100) : 0;
  var fill = document.getElementById('ee-prog-fill');
  if (fill) fill.style.width = pct + '%';

  updateSidebarStats();
}

function updateSidebarStats() {
  var counts = { 'not-visited':0,'not-answered':0,'answered':0,'marked':0,'answered-marked':0 };
  questionStatus.forEach(function(s){ if(counts.hasOwnProperty(s)) counts[s]++; });
  var totalAnswered = counts.answered + counts['answered-marked'];
  var totalMarked   = counts.marked   + counts['answered-marked'];

  var statsHTML =
    '<div class="ee-stat-mini"><span class="ee-stat-mini__n" style="color:#15803d;">'+totalAnswered+'</span><span class="ee-stat-mini__l">Answered</span></div>' +
    '<div class="ee-stat-mini"><span class="ee-stat-mini__n" style="color:#dc2626;">'+counts['not-answered']+'</span><span class="ee-stat-mini__l">Not Ans.</span></div>' +
    '<div class="ee-stat-mini"><span class="ee-stat-mini__n" style="color:#7c3aed;">'+totalMarked+'</span><span class="ee-stat-mini__l">Marked</span></div>' +
    '<div class="ee-stat-mini"><span class="ee-stat-mini__n" style="color:#9ca3af;">'+counts['not-visited']+'</span><span class="ee-stat-mini__l">Not Seen</span></div>';

  var statsEl = document.getElementById('ee-sidebar-stats');
  if (statsEl) statsEl.innerHTML = statsHTML;
  var drawerStats = document.getElementById('ee-drawer-stats');
  if (drawerStats) drawerStats.innerHTML = statsHTML;
}

