/* Fetch manifest */
(function fetchCAManifest() {
  fetch(CA_MANIFEST_URL)
    .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function(data) {
      caManifest = data;
      var status = document.getElementById('ee-ca-status');
      if (status) status.style.display = 'none';
      renderCAMonths(data);
    })
    .catch(function() {
      var status = document.getElementById('ee-ca-status');
      if (status) {
        status.innerHTML = 'Could not load months — check back later.';
        status.className = 'ee-ca-status ee-ca-status--error';
      }
    });
})();

function renderCAMonths(manifest) {
  var container = document.getElementById('ee-ca-months');
  if (!container) return;
  container.innerHTML = '';
  manifest.forEach(function(m, i) {
    var checked = (i === 0); // default: latest month pre-selected
    if (checked && caSelectedMonths.indexOf(m.month) === -1) {
      caSelectedMonths.push(m.month);
    }
    var row = document.createElement('label');
    row.className = 'ee-ca-month';
    row.innerHTML =
      '<input type="checkbox" value="' + esc(m.month) + '"' + (checked ? ' checked' : '') + '>' +
      '<span class="ee-ca-month__label">' + esc(m.label) + '</span>' +
      '<span class="ee-ca-month__count">' + m.count + ' questions</span>';
    row.querySelector('input').addEventListener('change', function(e) {
      if (e.target.checked) {
        if (caSelectedMonths.indexOf(m.month) === -1) caSelectedMonths.push(m.month);
      } else {
        caSelectedMonths = caSelectedMonths.filter(function(x) { return x !== m.month; });
      }
      updatePreview();
    });
    container.appendChild(row);
  });
}

