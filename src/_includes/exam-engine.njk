/* ══ Fullscreen helpers ════════════════════════════════════ */
function enterFullscreen() {
  var el = document.documentElement;
  var req = el.requestFullscreen || el.webkitRequestFullscreen || el.mozRequestFullScreen || el.msRequestFullscreen;
  if (req) req.call(el).catch(function(){});
  document.body.classList.add('ee-exam-active');
}
function exitFullscreen() {
  document.body.classList.remove('ee-exam-active');
  var exit = document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen || document.msExitFullscreen;
  if (exit && (document.fullscreenElement || document.webkitFullscreenElement)) exit.call(document).catch(function(){});
}
/* If user presses Esc and browser exits fullscreen natively, keep exam-active class in sync */
document.addEventListener('fullscreenchange', function() {
  if (!document.fullscreenElement) {
    document.body.classList.remove('ee-exam-active');
  }
});
document.addEventListener('webkitfullscreenchange', function() {
  if (!document.webkitFullscreenElement) {
    document.body.classList.remove('ee-exam-active');
  }
});


