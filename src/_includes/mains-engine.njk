    <!-- Sidebar palette -->
    <aside class="me-sidebar">
      <div class="me-sidebar__head">Questions</div>
      <div class="me-sidebar__body">
        <div class="me-palette" id="me-palette"></div>
        <div class="me-legend">
          <div class="me-legend-item"><span class="me-legend-chip" style="background:#f5f5f0;color:#9ca3af;border-color:#e5e7eb;">—</span> Not attempted</div>
          <div class="me-legend-item"><span class="me-legend-chip" style="background:#dcfce7;color:#15803d;border-color:#86efac;">✓</span> Written</div>
          <div class="me-legend-item"><span class="me-legend-chip" style="background:#ede9fe;color:#7c3aed;border-color:#c4b5fd;">★</span> Marked</div>
          <div class="me-legend-item"><span class="me-legend-chip" style="background:#fee2e2;color:#dc2626;border-color:#fca5a5;">—</span> Skipped</div>
