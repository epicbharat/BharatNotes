}
.me-results-hero__score{font-size:clamp(3rem,8vw,5rem);font-weight:900;color:#fb923c;line-height:1;}
.me-results-hero__max{font-size:var(--text-sm);color:rgba(255,255,255,.5);margin-top:4px;}
.me-results-hero__label{font-size:var(--text-xs);font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.4);margin-bottom:var(--space-3);}
.me-q-result-card{
  background:#fff;border:1px solid #e5e7eb;border-radius:14px;
  margin-bottom:var(--space-3);overflow:hidden;
}
.me-q-result-hd{
  display:flex;align-items:center;gap:10px;
  padding:14px 18px;cursor:pointer;
}
.me-q-result-num{font-size:var(--text-xs);font-weight:900;color:var(--color-text-muted);flex-shrink:0;}
.me-q-result-text{flex:1;font-size:var(--text-xs);color:var(--color-brand);font-weight:600;line-height:1.4;}
