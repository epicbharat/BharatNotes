      <div class="me-sidebar__stats">
        <div class="me-stat-row"><span>Written</span><span class="me-stat-val" id="me-stat-written">0</span></div>
        <div class="me-stat-row"><span>Remaining</span><span class="me-stat-val" id="me-stat-remaining">20</span></div>
        <div class="me-stat-row"><span>Time left</span><span class="me-stat-val" id="me-stat-time">3:00:00</span></div>
      </div>
    </aside>
  </div>
</div>

<!-- Footer nav -->
<div id="me-footer">
  <div class="me-footer">
    <button class="me-btn me-btn--prev" id="me-prev-btn">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
