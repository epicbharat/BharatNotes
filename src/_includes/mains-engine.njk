.me-score-card{background:#f8f8f6;border-radius:10px;padding:12px 14px;}
.me-score-card__label{font-size:0.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:var(--color-text-muted);margin-bottom:6px;}
.me-score-card__bar-wrap{background:#e5e7eb;border-radius:100px;height:6px;margin-bottom:6px;}
