}
.me-model__lbl{font-size:var(--text-xs);font-weight:800;color:#15803d;text-transform:uppercase;letter-spacing:.06em;}
.me-model__toggle{font-size:var(--text-xs);color:#15803d;font-weight:700;}
.me-model__body{padding:20px;display:none;}
.me-model__body.open{display:block;}
.me-model__text{
  font-family:var(--font-serif);font-size:1.05rem;line-height:1.85;color:#1c1917;
