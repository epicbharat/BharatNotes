</div>

<!-- ═══ RESULTS VIEW ══════════════════════════════════════════ -->
<div id="me-results">
  <div class="container">
    <div class="me-results-wrap">
      <div class="me-results-hero">
        <div class="me-results-hero__label">Your Score</div>
        <div class="me-results-hero__score" id="me-results-score">—</div>
        <div class="me-results-hero__max" id="me-results-max">out of —</div>
      </div>
      <div id="me-results-list"></div>
      <div style="margin-top:var(--space-6);text-align:center;">
        <button onclick="location.reload()" style="background:#ea580c;color:#fff;border:none;border-radius:10px;padding:12px 28px;font-size:var(--text-sm);font-weight:800;cursor:pointer;">
          Try Again
        </button>
      </div>
    </div>
  </div>
</div>

<script>
/* ══ Config & Data ════════════════════════════════════════ */
var CONFIG   = window.MAINS_CONFIG || {};
var DATA     = window.MAINS_DATA   || [];
var EVAL_URL = CONFIG.evalUrl || '';

var selectedPaper = CONFIG.paper || 'gs1';
var selectedMode  = 'full';
var candidateName = 'Aspirant';

var testQuestions  = [];
var userAnswers    = {};   /* idx -> string */
var qStatus        = [];   /* 'not-attempted'|'attempted'|'marked'|'skipped' */
var evalResults    = {};   /* idx -> evaluation JSON */
var currentQ       = 0;
var timerInterval  = null;
var timerSecs      = 0;
var voiceRecog     = null;
var isRecording    = false;

var PAPER_META = {
  gs1: { name:'GS Paper I',   sub:'History · Society · Geography',     mins:180, full:20, half:10 },
  gs2: { name:'GS Paper II',  sub:'Governance · Polity · IR',          mins:180, full:20, half:10 },
  gs3: { name:'GS Paper III', sub:'Economy · Environment · Technology', mins:180, full:20, half:10 },
  gs4: { name:'GS Paper IV',  sub:'Ethics · Integrity · Aptitude',     mins:180, full:20, half:10 }
};

/* ── Restore name ─────────────────────────────────────── */
try { var _n = localStorage.getItem('bn_exam_name'); if (_n) document.getElementById('me-name-input').value = _n; } catch(e){}

/* ── Paper chips ──────────────────────────────────────── */
document.querySelectorAll('.me-paper-chip').forEach(function(chip) {
  chip.addEventListener('click', function() {
    document.querySelectorAll('.me-paper-chip').forEach(function(c){ c.classList.remove('active'); });
    chip.classList.add('active');
    selectedPaper = chip.dataset.paper;
    updatePreview();
  });
});

/* ── Mode chips ───────────────────────────────────────── */
document.querySelectorAll('.me-mode-chip').forEach(function(chip) {
  chip.addEventListener('click', function() {
    document.querySelectorAll('.me-mode-chip').forEach(function(c){ c.classList.remove('active'); });
    chip.classList.add('active');
    selectedMode = chip.dataset.mode;
    updatePreview();
  });
});

function updatePreview() {
  var pm = PAPER_META[selectedPaper] || PAPER_META.gs1;
  var n  = selectedMode === 'full' ? pm.full : (selectedMode === 'half' ? pm.half : '—');
  var t  = selectedMode === 'full' ? pm.mins : (selectedMode === 'half' ? 90 : '—');
  document.getElementById('me-preview').innerHTML =
    '<strong>' + pm.name + '</strong> · ' + selectedMode.charAt(0).toUpperCase() + selectedMode.slice(1) +
    ' · ' + n + ' questions · ' + t + ' min';
}
updatePreview();

/* ── Build question pool ──────────────────────────────── */
function shuffle(arr) {
  var a = arr.slice();
  for (var i = a.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var t = a[i]; a[i] = a[j]; a[j] = t;
  }
  return a;
}

function buildTest() {
  var pool = DATA.filter(function(q){ return q.paper === selectedPaper; });
  if (pool.length === 0) pool = DATA; /* fallback: all questions */
  pool = shuffle(pool);
  var pm = PAPER_META[selectedPaper];
  var n  = selectedMode === 'full' ? pm.full : (selectedMode === 'half' ? pm.half : pool.length);
  testQuestions = pool.slice(0, Math.min(n, pool.length));
  userAnswers   = {};
  evalResults   = {};
  qStatus       = testQuestions.map(function(){ return 'not-attempted'; });
  currentQ      = 0;
}

/* ── Start test ───────────────────────────────────────── */
document.getElementById('me-start-btn').addEventListener('click', startTest);

function startTest() {
  candidateName = (document.getElementById('me-name-input').value || '').trim() || 'Aspirant';
  try { localStorage.setItem('bn_exam_name', candidateName); } catch(e){}

  buildTest();
  if (testQuestions.length === 0) { alert('No questions available for this paper.'); return; }

  var pm   = PAPER_META[selectedPaper];
  var mins = selectedMode === 'full' ? pm.mins : (selectedMode === 'half' ? 90 : pm.mins);
  timerSecs = mins * 60;

  document.getElementById('me-setup').style.display    = 'none';
  document.getElementById('me-test').style.display     = 'block';
  document.getElementById('me-footer').style.display   = 'block';
  document.getElementById('me-hd-title').textContent   = pm.name + ' — ' + selectedMode.charAt(0).toUpperCase() + selectedMode.slice(1) + ' Mock';

  startTimer();
  showQuestion(0);
  window.scrollTo(0, 0);
  document.body.classList.add('me-exam-active');
}

/* ── Timer ────────────────────────────────────────────── */
function startTimer() {
  updateTimerDisplay();
  timerInterval = setInterval(function() {
    timerSecs--;
    updateTimerDisplay();
    if (timerSecs <= 0) { clearInterval(timerInterval); submitTest(true); }
  }, 1000);
}
function updateTimerDisplay() {
  var h = Math.floor(timerSecs / 3600);
  var m = Math.floor((timerSecs % 3600) / 60);
  var s = timerSecs % 60;
  var str = h + ':' + (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
  var el = document.getElementById('me-timer');
  if (el) { el.textContent = str; el.classList.toggle('warning', timerSecs < 600); }
  var st = document.getElementById('me-stat-time');
  if (st) st.textContent = str;
}

/* ── Show question ────────────────────────────────────── */
function showQuestion(idx) {
  if (idx < 0 || idx >= testQuestions.length) return;
  currentQ = idx;

  /* Save current textarea content before switching */
  var prev = document.getElementById('me-answer-ta');
  /* (already saved via blur/input event) */

  var q   = testQuestions[idx];
  var ans = userAnswers[idx] || '';

  /* Build HTML */
  var html = '';

  /* Question card */
  html += '<div class="me-q-card">';
  html += '<div class="me-q-meta">';
  html += '<span class="me-q-badge me-q-badge--paper">' + (PAPER_META[q.paper] || {name:q.paper}).name + '</span>';
  html += '<span class="me-q-badge me-q-badge--marks">' + q.marks + ' marks</span>';
  if (q.year) html += '<span class="me-q-badge me-q-badge--year">' + q.year + '</span>';
  if (q.topic) html += '<span class="me-q-badge me-q-badge--topic">' + escH(q.topic) + '</span>';
  html += '</div>';
  html += '<p class="me-q-text">' + escH(q.question) + '</p>';
  html += '<div class="me-q-hint"><strong>Suggested:</strong> ~' + (q.words || Math.round(q.marks * 13)) + ' words &nbsp;|&nbsp; Structure: Introduction → Analysis → Way Forward → Conclusion</div>';
  html += '</div>';

  /* Answer card */
  html += '<div class="me-answer-card">';
  html += '<div class="me-answer-hd">';
  html += '<span class="me-answer-lbl">Your Answer</span>';
  html += '<div class="me-answer-tools">';
  html += '<span class="me-word-count" id="me-wc">0 / ' + (q.words || Math.round(q.marks * 13)) + ' words</span>';
  html += '<button class="me-voice-btn" id="me-voice-btn" title="Voice typing"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg> Voice</button>';
  html += '</div></div>';
  html += '<textarea class="me-answer-textarea" id="me-answer-ta" placeholder="Write your answer here… (voice typing supported)">' + escH(ans) + '</textarea>';
  html += '</div>';

  /* Eval panel (if already evaluated) */
  if (evalResults[idx]) {
    html += renderEvalPanel(evalResults[idx], q.marks);
  } else if (qStatus[idx] === 'attempted' || qStatus[idx] === 'skipped') {
    html += '<div class="me-eval" id="me-eval-wrap"><div class="me-eval__hd"><span class="me-eval__lbl">AI Evaluation</span></div><div class="me-eval__body"><div class="me-eval__loading"><div class="me-eval__spinner"></div>Evaluating with Gemini…</div></div></div>';
    html += renderModelPanel(q, false);
    requestEval(idx, q, ans);
  }

  document.getElementById('me-main').innerHTML = html;

  /* Wire textarea */
  var ta = document.getElementById('me-answer-ta');
  var wl = q.words || Math.round(q.marks * 13);
  ta.addEventListener('input', function() {
    userAnswers[idx] = ta.value;
    updateWordCount(ta.value, wl);
  });
  updateWordCount(ans, wl);

  /* Wire voice button */
  wireVoice(idx, wl);

  /* Update nav */
  updateNav(idx);
  renderPalette();
}

function updateWordCount(text, limit) {
  var wc  = document.getElementById('me-wc');
  if (!wc) return;
  var cnt = text.trim() ? text.trim().split(/\s+/).length : 0;
  wc.textContent = cnt + ' / ' + limit + ' words';
  wc.className = 'me-word-count' + (cnt > limit * 1.15 ? ' over' : (cnt >= limit * 0.85 ? ' good' : ''));
}

function escH(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* Lightweight markdown renderer for model answer text.
   Handles: **bold**, headings (line starting with **X**:), bullet lists (- item), numbered lists (1. item) */
function renderMd(s) {
  if (!s) return '';
  var lines = String(s).split('\n');
  var html  = '';
  var inList = false, listType = '';

  lines.forEach(function(raw) {
    var line = raw;

    /* Close open list if line isn't a list item */
    var isBullet   = /^\s*[-•]\s+/.test(line);
    var isNumbered = /^\s*\d+\.\s+/.test(line);

    if (inList && !isBullet && !isNumbered) {
      html += listType === 'ul' ? '</ul>' : '</ol>';
      inList = false; listType = '';
    }

    /* Section heading: line is entirely **Text**: or **Text** */
    if (/^\s*\*\*[^*]+\*\*[:\s]*$/.test(line.trim())) {
      var heading = line.trim().replace(/\*\*/g, '').replace(/:$/, '');
      html += '<p class="me-md-heading">' + escH(heading) + '</p>';
      return;
    }

    /* Bullet list */
    if (isBullet) {
      if (!inList) { html += '<ul class="me-md-list">'; inList = true; listType = 'ul'; }
      var content = line.replace(/^\s*[-•]\s+/, '');
      html += '<li>' + inlineMd(content) + '</li>';
      return;
    }

    /* Numbered list */
    if (isNumbered) {
      if (!inList || listType !== 'ol') {
        if (inList) html += '</ul>';
        html += '<ol class="me-md-list">'; inList = true; listType = 'ol';
      }
      var ncontent = line.replace(/^\s*\d+\.\s+/, '');
      html += '<li>' + inlineMd(ncontent) + '</li>';
      return;
    }

    /* Empty line */
    if (!line.trim()) { html += '<br>'; return; }

    /* Normal paragraph line */
    html += '<p class="me-md-p">' + inlineMd(line) + '</p>';
  });

  if (inList) html += listType === 'ul' ? '</ul>' : '</ol>';
  return html;
}

function inlineMd(s) {
  return escH(s)
    /* **bold** */
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    /* *italic* */
    .replace(/\*([^*]+)\*/g, '<em>$1</em>')
    /* `code` */
    .replace(/`([^`]+)`/g, '<code>$1</code>');
}

/* ── Voice typing ─────────────────────────────────────── */
function wireVoice(idx, wl) {
  var btn = document.getElementById('me-voice-btn');
  if (!btn) return;
  var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) { btn.style.display = 'none'; return; }

  btn.addEventListener('click', function() {
    if (isRecording) {
      voiceRecog && voiceRecog.stop();
      return;
    }
    voiceRecog = new SpeechRecognition();
    voiceRecog.continuous     = true;
    voiceRecog.interimResults = true;
    voiceRecog.lang           = 'en-IN';

    var ta   = document.getElementById('me-answer-ta');
    var base = ta.value;

    voiceRecog.onresult = function(e) {
      var interim = '', final = '';
      for (var i = e.resultIndex; i < e.results.length; i++) {
        if (e.results[i].isFinal) final += e.results[i][0].transcript;
        else interim += e.results[i][0].transcript;
      }
      if (final) { base += (base ? ' ' : '') + final.trim(); }
      ta.value = base + (interim ? ' ' + interim : '');
      userAnswers[idx] = ta.value;
      updateWordCount(ta.value, wl);
    };
    voiceRecog.onend = function() {
      isRecording = false;
      btn.classList.remove('recording');
      btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg> Voice';
    };
    voiceRecog.start();
    isRecording = true;
    btn.classList.add('recording');
    btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="6" width="12" height="12"/></svg> Stop';
  });
}

/* ── Save answer ──────────────────────────────────────── */
function saveAnswer(idx) {
  var ta = document.getElementById('me-answer-ta');
  if (ta) userAnswers[idx] = ta.value;
  var hasText = (userAnswers[idx] || '').trim().length > 0;
  if (qStatus[idx] !== 'marked') {
    qStatus[idx] = hasText ? 'attempted' : 'skipped';
  }
  renderPalette();
}

/* ── Navigation ───────────────────────────────────────── */
document.getElementById('me-save-btn').addEventListener('click', function() {
  saveAnswer(currentQ);
  if (currentQ + 1 < testQuestions.length) showQuestion(currentQ + 1);
});
document.getElementById('me-prev-btn').addEventListener('click', function() {
  saveAnswer(currentQ);
  if (currentQ > 0) showQuestion(currentQ - 1);
});
document.getElementById('me-mark-btn').addEventListener('click', function() {
  saveAnswer(currentQ);
  qStatus[currentQ] = 'marked';
  renderPalette();
  if (currentQ + 1 < testQuestions.length) showQuestion(currentQ + 1);
});

function updateNav(idx) {
  document.getElementById('me-hd-qnum').textContent = 'Q ' + (idx + 1) + ' / ' + testQuestions.length;
  document.getElementById('me-prog-fill').style.width = ((idx + 1) / testQuestions.length * 100) + '%';
  var written  = qStatus.filter(function(s){ return s === 'attempted'; }).length;
  var remain   = testQuestions.length - qStatus.filter(function(s){ return s !== 'not-attempted'; }).length;
  document.getElementById('me-stat-written').textContent   = written;
  document.getElementById('me-stat-remaining').textContent = remain;
}

/* ── Palette ──────────────────────────────────────────── */
function renderPalette() {
  var html = '';
  testQuestions.forEach(function(q, i) {
    var s   = qStatus[i] || 'not-attempted';
    var cls = 'me-pal-q me-pal-q--' + s + (i === currentQ ? ' me-pal-q--active' : '');
    html += '<button class="' + cls + '" data-qi="' + i + '">' + (i + 1) + '</button>';
  });
  var el = document.getElementById('me-palette');
  if (el) {
    el.innerHTML = html;
    el.querySelectorAll('.me-pal-q').forEach(function(btn) {
      btn.addEventListener('click', function() {
        saveAnswer(currentQ);
        showQuestion(parseInt(btn.dataset.qi, 10));
      });
    });
  }
}

/* ── AI Evaluation ────────────────────────────────────── */
function requestEval(idx, q, answer) {
  if (!EVAL_URL) {
    showEvalError(idx, 'Evaluation URL not configured.');
    return;
  }
  if (!answer || !answer.trim()) {
    showEvalError(idx, 'No answer written — nothing to evaluate.');
    return;
  }
  fetch(EVAL_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      question: q.question,
      answer:   answer,
      marks:    q.marks,
      words:    q.words || Math.round(q.marks * 13),
      paper:    q.paper,
      model_key_points: (q.model_answer && q.model_answer.key_points) || []
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.error) throw new Error(data.error);
    evalResults[idx] = data;
    /* If still on same question, re-render eval panel */
    if (currentQ === idx) {
      var wrap = document.getElementById('me-eval-wrap');
      if (wrap) wrap.outerHTML = renderEvalPanel(data, q.marks);
    }
  })
  .catch(function(err) {
    showEvalError(idx, 'Could not evaluate: ' + err.message);
  });
}

function showEvalError(idx, msg) {
  if (currentQ === idx) {
    var wrap = document.getElementById('me-eval-wrap');
    if (wrap) wrap.querySelector('.me-eval__body').innerHTML = '<div class="me-eval__error">⚠ ' + escH(msg) + '</div>';
  }
}

function renderEvalPanel(ev, maxMarks) {
  var pct = Math.round((ev.total / maxMarks) * 100);
  var barColor = pct >= 70 ? '#16a34a' : (pct >= 50 ? '#ea580c' : '#dc2626');
  var html = '<div class="me-eval">';
  html += '<div class="me-eval__hd">';
  html += '<span class="me-eval__lbl">AI Evaluation</span>';
  html += '<span class="me-eval__score-badge">' + ev.total + ' / ' + maxMarks + '</span>';
  html += '</div><div class="me-eval__body">';

  /* Score breakdown grid */
  html += '<div class="me-score-grid">';
  var dims = [
    { key:'content',   label:'Content & Accuracy' },
    { key:'analysis',  label:'Analytical Depth' },
    { key:'structure', label:'Structure' },
    { key:'words',     label:'Word Discipline' }
  ];
  dims.forEach(function(d) {
    var b = ev.breakdown && ev.breakdown[d.key];
    if (!b) return;
    var p = Math.round((b.score / b.max) * 100);
    html += '<div class="me-score-card">';
    html += '<div class="me-score-card__label">' + d.label + '</div>';
    html += '<div class="me-score-card__bar-wrap"><div class="me-score-card__bar" style="width:' + p + '%;background:' + (p >= 70 ? '#16a34a' : (p >= 50 ? '#ea580c' : '#dc2626')) + ';"></div></div>';
    html += '<div class="me-score-card__nums"><span class="me-score-card__val">' + b.score + '</span><span class="me-score-card__max">/ ' + b.max + '</span></div>';
    if (b.comment) html += '<div class="me-score-card__comment">' + escH(b.comment) + '</div>';
    html += '</div>';
  });
  html += '</div>';

  /* Strengths */
  if (ev.strengths && ev.strengths.length) {
    html += '<div class="me-eval__section-title">Strengths</div><ul class="me-eval__list me-eval__list--strengths">';
    ev.strengths.forEach(function(s){ html += '<li>' + escH(s) + '</li>'; });
    html += '</ul>';
  }
  /* Missing */
  if (ev.missing && ev.missing.length) {
    html += '<div class="me-eval__section-title">Key Points Missed</div><ul class="me-eval__list me-eval__list--missing">';
    ev.missing.forEach(function(s){ html += '<li>' + escH(s) + '</li>'; });
    html += '</ul>';
  }
  /* Examiner note */
  if (ev.examiner_note) {
    html += '<div class="me-eval__note">' + escH(ev.examiner_note) + '</div>';
  }

  html += '</div></div>';
  return html;
}

function renderModelPanel(q, open) {
  if (!q.model_answer) return '';
  var ma = q.model_answer;
  var html = '<div class="me-model">';
  html += '<div class="me-model__hd" onclick="this.nextElementSibling.classList.toggle(\'open\');this.querySelector(\'.me-model__toggle\').textContent=this.nextElementSibling.classList.contains(\'open\')?\'Hide ▲\':\'Show ▼\'">';
  html += '<span class="me-model__lbl">Model Answer</span>';
  html += '<span class="me-model__toggle">' + (open ? 'Hide ▲' : 'Show ▼') + '</span>';
  html += '</div>';
  html += '<div class="me-model__body' + (open ? ' open' : '') + '">';
  html += '<div class="me-model__text">' + renderMd(ma.text || '') + '</div>';
  if (ma.keywords && ma.keywords.length) {
    html += '<div class="me-model__kw"><div class="me-model__kw-label">Key Terms</div><div class="me-model__kw-chips">';
    ma.keywords.forEach(function(k){ html += '<span class="me-model__kw-chip">' + escH(k) + '</span>'; });
    html += '</div></div>';
  }
  html += '</div></div>';
  return html;
}

/* ── Submit ───────────────────────────────────────────── */
document.getElementById('me-submit-btn').addEventListener('click', function(){ submitTest(false); });
document.getElementById('me-back-btn').addEventListener('click', function() {
  if (!confirm('Exit test? Progress will be lost.')) return;
  clearInterval(timerInterval);
  if (voiceRecog) voiceRecog.stop();
  document.getElementById('me-test').style.display   = 'none';
  document.getElementById('me-footer').style.display = 'none';
  document.getElementById('me-setup').style.display  = 'block';
  document.body.classList.remove('me-exam-active');
  window.scrollTo(0, 0);
});

function submitTest(auto) {
  if (!auto && !confirm('Submit paper? Unanswered questions will show as skipped.')) return;
  saveAnswer(currentQ);
  clearInterval(timerInterval);
  if (voiceRecog) voiceRecog.stop();
  document.body.classList.remove('me-exam-active');
  showResults();
}

/* ── Results ──────────────────────────────────────────── */
function showResults() {
  document.getElementById('me-test').style.display   = 'none';
  document.getElementById('me-footer').style.display = 'none';
  document.getElementById('me-results').style.display = '';

  /* Calculate score from evalResults */
  var total = 0, maxTotal = 0;
  testQuestions.forEach(function(q, i){ maxTotal += q.marks; if (evalResults[i]) total += evalResults[i].total || 0; });

  document.getElementById('me-results-score').textContent = evalResults && Object.keys(evalResults).length ? total : '—';
  document.getElementById('me-results-max').textContent   = 'out of ' + maxTotal;

  /* Question result cards */
  var html = '';
  testQuestions.forEach(function(q, i) {
    var ev  = evalResults[i];
    var ans = userAnswers[i] || '';
    html += '<div class="me-q-result-card">';
    html += '<div class="me-q-result-hd" onclick="var b=this.nextElementSibling;b.classList.toggle(\'open\')">';
    html += '<span class="me-q-result-num">Q' + (i + 1) + '</span>';
    html += '<span class="me-q-result-text">' + escH(q.question.slice(0, 100)) + (q.question.length > 100 ? '…' : '') + '</span>';
    html += '<span class="me-q-result-score">' + (ev ? ev.total + '/' + q.marks : (ans ? '—' : 'Skip')) + '</span>';
    html += '</div>';
    html += '<div class="me-q-result-body">';
    if (ans) {
      html += '<div style="font-family:var(--font-serif);font-size:0.95rem;line-height:1.75;color:#44403c;background:#faf9f7;border-radius:10px;padding:14px 16px;margin-bottom:var(--space-3);white-space:pre-wrap;">' + escH(ans) + '</div>';
    } else {
      html += '<div style="font-size:var(--text-xs);color:#dc2626;margin-bottom:var(--space-3);">Not attempted</div>';
    }
    if (ev) html += renderEvalPanel(ev, q.marks);
    html += renderModelPanel(q, false);
    html += '</div></div>';
  });
  document.getElementById('me-results-list').innerHTML = html;
  window.scrollTo(0, 0);
}

/* ── Keyboard shortcuts ───────────────────────────────── */
document.addEventListener('keydown', function(e) {
  if (document.getElementById('me-test').style.display === 'none') return;
  var tag = e.target.tagName;
  if (tag === 'TEXTAREA') return; /* don't intercept while writing */
  if (e.key === 'ArrowRight') { document.getElementById('me-save-btn').click(); e.preventDefault(); }
  if (e.key === 'ArrowLeft')  { document.getElementById('me-prev-btn').click(); e.preventDefault(); }
  if (e.key === 'm' || e.key === 'M') { document.getElementById('me-mark-btn').click(); e.preventDefault(); }
});
</script>
