</style>

<!-- ═══ SETUP VIEW ═══════════════════════════════════════════ -->
<div id="me-setup">
  <!-- Hero -->
  <div class="me-hero">
    <div class="container">
      <div class="me-hero__inner">
        <div class="me-hero__kicker">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          Mains Answer Writing
        </div>
        <h1 id="me-title">UPSC Mains <em>Mock Test</em></h1>
        <p id="me-subtitle">Write answers, get AI evaluation &amp; compare with expert model answers</p>
        <div class="me-hero__meta">
          <span class="me-hero__meta-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Timed — 3 hours per paper
          </span>
          <span class="me-hero__meta-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            AI evaluation via Gemini
          </span>
          <span class="me-hero__meta-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>
            Voice typing supported
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Setup cards -->
  <div class="me-setup-body">
    <div class="container" style="max-width:800px;padding-top:var(--space-8);">

      <!-- Paper -->
      <div class="me-card">
        <div class="me-section-label">Select Paper</div>
        <div class="me-paper-row" id="me-paper-row">
          <div class="me-paper-chip active" data-paper="gs1">
            <span class="me-paper-chip__name">GS Paper I</span>
            <span class="me-paper-chip__sub">History · Society · Geography</span>
          </div>
          <div class="me-paper-chip" data-paper="gs2">
            <span class="me-paper-chip__name">GS Paper II</span>
            <span class="me-paper-chip__sub">Governance · Polity · IR</span>
          </div>
          <div class="me-paper-chip" data-paper="gs3">
            <span class="me-paper-chip__name">GS Paper III</span>
            <span class="me-paper-chip__sub">Economy · Environment · Tech</span>
          </div>
          <div class="me-paper-chip" data-paper="gs4">
            <span class="me-paper-chip__name">GS Paper IV</span>
            <span class="me-paper-chip__sub">Ethics · Integrity · Aptitude</span>
          </div>
        </div>
      </div>

      <!-- Mode -->
      <div class="me-card">
        <div class="me-section-label">Mode</div>
        <div class="me-mode-row">
          <button class="me-mode-chip active" data-mode="full">Full Paper (20 Qs · 3 hrs)</button>
          <button class="me-mode-chip" data-mode="half">Half Paper (10 Qs · 90 min)</button>
          <button class="me-mode-chip" data-mode="topic">Topic-wise Practice</button>
        </div>
      </div>

      <!-- Name -->
      <div class="me-card">
        <div class="me-section-label">Your Name</div>
        <div class="me-name-wrap">
          <input type="text" id="me-name-input" placeholder="Enter your name…" maxlength="50">
        </div>
      </div>

      <!-- Launch -->
      <div class="me-launch">
        <div class="me-preview" id="me-preview">
          <strong>GS Paper I</strong> · Full Paper · 20 questions · 180 min
        </div>
        <button class="me-start-btn" id="me-start-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Begin Writing
        </button>
      </div>

    </div>
  </div>
</div>

<!-- ═══ TEST VIEW ════════════════════════════════════════════ -->
<div id="me-test">
  <!-- Header -->
  <div class="me-hd">
    <button class="me-hd-back" id="me-back-btn">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      Exit
    </button>
    <span class="me-hd-title" id="me-hd-title">GS Paper I — Full Mock</span>
    <span class="me-hd-qnum" id="me-hd-qnum">Q 1 / 20</span>
    <span style="flex:1;"></span>
    <span class="me-hd-timer" id="me-timer">3:00:00</span>
    <button class="me-submit-hd" id="me-submit-btn">Submit Paper</button>
  </div>

  <!-- Progress -->
  <div class="me-prog"><div class="me-prog-fill" id="me-prog-fill" style="width:0%"></div></div>

  <!-- Body -->
