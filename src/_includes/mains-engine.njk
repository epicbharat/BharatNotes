  font-size:var(--text-xs);font-weight:800;padding:7px 14px;cursor:pointer;transition:background .15s;
}
.me-submit-hd:hover{background:#c2410c;}

/* Progress bar */
.me-prog{height:3px;background:rgba(255,255,255,.1);position:sticky;top:54px;z-index:299;}
