.me-paper-chip.active .me-paper-chip__name{color:#fff;}
.me-paper-chip.active .me-paper-chip__sub{color:rgba(255,255,255,.75);}
.me-paper-chip__name{display:block;font-size:var(--text-sm);font-weight:800;color:var(--color-brand);transition:color .18s;}
.me-paper-chip__sub{display:block;font-size:0.62rem;color:var(--color-text-muted);margin-top:3px;transition:color .18s;}

/* Mode chips */
.me-mode-row{display:flex;gap:8px;flex-wrap:wrap;}
.me-mode-chip{
  border:1.5px solid #e5e7eb;border-radius:8px;background:#fafafa;
  font-size:var(--text-xs);font-weight:700;color:var(--color-text-muted);
  padding:8px 16px;cursor:pointer;transition:all .15s;
}
.me-mode-chip:hover{border-color:#ea580c;color:#ea580c;}
.me-mode-chip.active{background:#ea580c;border-color:#ea580c;color:#fff;}

/* Name input */
.me-name-wrap input{
  width:100%;box-sizing:border-box;
  border:1.5px solid var(--color-border);border-radius:10px;
  padding:11px 14px;font-size:var(--text-sm);
  font-family:var(--font-body);background:#fafafa;color:var(--color-text);
}
.me-name-wrap input:focus{border-color:#ea580c;background:#fff;box-shadow:0 0 0 3px rgba(234,88,12,.08);outline:none;}

/* Launch */
.me-launch{
  background:#fff;border:1px solid #e5e7eb;border-radius:16px;
  padding:var(--space-5) var(--space-6);
