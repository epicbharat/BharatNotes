.me-eval__section-title{font-size:var(--text-xs);font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:var(--color-text-muted);margin:var(--space-4) 0 var(--space-2);}
.me-eval__list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:5px;}
.me-eval__list li{display:flex;align-items:flex-start;gap:8px;font-size:var(--text-xs);line-height:1.55;color:#374151;}
.me-eval__list--strengths li::before{content:'✓';color:#16a34a;font-weight:900;flex-shrink:0;margin-top:1px;}
.me-eval__list--missing  li::before{content:'✗';color:#dc2626;font-weight:900;flex-shrink:0;margin-top:1px;}
.me-eval__note{
  margin-top:var(--space-4);padding:12px 14px;
  background:#fff7ed;border-radius:10px;border-left:3px solid #ea580c;
  font-size:var(--text-xs);color:#7c2d12;line-height:1.6;font-style:italic;
