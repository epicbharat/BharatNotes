}
.me-hd-back:hover{background:rgba(255,255,255,.2);}
.me-hd-title{font-size:var(--text-xs);font-weight:800;color:rgba(255,255,255,.6);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.me-hd-qnum{font-size:var(--text-xs);font-weight:700;color:rgba(255,255,255,.5);white-space:nowrap;}
.me-hd-timer{
