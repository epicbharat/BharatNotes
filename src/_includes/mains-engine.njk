.me-hero__meta{display:flex;gap:var(--space-6);margin-top:var(--space-5);flex-wrap:wrap;}
.me-hero__meta-item{display:flex;align-items:center;gap:6px;font-size:var(--text-xs);color:rgba(255,255,255,.5);}

/* ── Setup body ───────────────────────────────────────────── */
.me-setup-body{background:var(--color-bg);padding:var(--space-8) 0 var(--space-16);}
.me-card{
  background:#fff;border:1px solid #e5e7eb;border-radius:16px;
  padding:var(--space-5) var(--space-6);margin-bottom:var(--space-4);
  box-shadow:0 1px 3px rgba(0,0,0,.04);
}
.me-section-label{
  font-size:0.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;
  color:var(--color-text-muted);margin:0 0 var(--space-4);
