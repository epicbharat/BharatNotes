}
.me-start-btn:hover{background:#c2410c;transform:translateY(-1px);}
.me-start-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}

/* ── Test header ──────────────────────────────────────────── */
#me-test{display:none;}
.me-hd{
